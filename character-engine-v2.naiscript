// ============================================================================
// SECTION 3 — SCRIPT-LEVEL STATE VARIABLES
// All mutable module-level state. Declared here so the full state surface is
// visible in one place. Never rely on implicit global declaration.
// ============================================================================

// ── Engine State ──────────────────────────────────────────────────────────────
// ae_lock: probability engine mutex — prevents double-rolling on a single player input.
var ae_lock = false;
var ae_genInFlight = false;  // [v0.9.36] an editor.generate() is active (cleared in onGenerationEnd)

// ── Editor Yoink generation (budget-free) ────────────────────────────────────
// [vNEXT] The World-Build Wizard's chats and field generators must not draw on the
// script generation budget. Instead of api.v1.generate(), we hijack the normal
// editor generation path (the "yoink" method, per Yoink Editor Gen / Brainstorming
// Partner): set _yoinkState.active, swap our prompt in via onContextBuilt, capture
// + swallow the output via onResponse, and resolve the promise in onGenerationEnd.
// While active, the engine's normal context/response/end logic early-returns so a
// yoink gen never injects world-state, ticks the story counter, or fires triggers.
interface AEYoinkState {
    active: boolean;
    messages: any[];
    responseText: string;
    resolve: ((value: string) => void) | null;
    reject: ((reason: any) => void) | null;
    // [v1.22.1 YOINK-WATCHDOG] NAI's own per-generation id (present on onContextBuilt /
    // onResponse / onGenerationEnd params). Captured when a yoink's context is built;
    // checked by onResponse/onGenerationEnd before touching _aeYoink state, so a late
    // event from a generation the watchdog already gave up on (see executeYoinkGeneration)
    // cannot resolve, or corrupt the buffer of, a newer call that has since taken the slot.
    continuityId: string | null;
}
var _aeYoink: AEYoinkState = { active: false, messages: [], responseText: '', resolve: null, reject: null, continuityId: null };

// ── [v1.2.0 WIZMODE] Hard wizard mode switch ─────────────────────────────────
// [WIZMODE] The per-call _aeYoink.active bracket only isolates a SINGLE generation.
// This is a session-level switch, set true for as long as the wizard tab/modal is
// open (bridge sends AE_WIZ_MODE on tab enter/exit). While on:
//   - onGenerationRequested blocks any user/story-initiated generation outright.
//   - onResponse swallows ALL output unconditionally (not just continuityId matches),
//     so a stalled/abandoned yoink can never leak into the document.
//   - generationParameters are snapshotted and max_tokens is pinned for wizard replies,
//     restored on exit.
//   - The wizard's assembled context (buildWizardContext) is frozen per chat on first
//     use and reused for the rest of the session, so only the transcript grows per
//     turn — fewer context substitutions, whatever caching benefit that permits.
// A zombie continuityId set is the backstop: if the 90s yoink watchdog force-recovers
// a stuck generation, its id is remembered so any of its late output/end-event is still
// caught even after mode has since exited (bounded, does not block exit indefinitely).
var _aeWizardMode = false;
var _wizModeParamSnapshot: any = null;
var _wizModeExitPending = false;
var _wizFrozenCtx: { [chatId: string]: string } = {};
var _wizZombieIds: { [continuityId: string]: boolean } = {};
var AE_WIZARD_MAX_TOKENS = 300; // pinned output cap for wizard replies while mode is on

async function broadcastWizModeState(): Promise<void> {
    try { await broadcastToTM(EVT_WIZ_MODE_STATE, { active: _aeWizardMode, draining: _wizModeExitPending }); }
    catch (e) { api.v1.log('[AE:wizard] broadcastWizModeState failed:', e); }
}

async function aeSetWizardMode(on: boolean): Promise<void> {
    if (on) {
        if (_aeWizardMode) return;
        // [v2.4.0 WIZLIVE] The two wizard modes are mutually exclusive: classic mode
        // swallows ALL output unconditionally, which would eat live-chat replies.
        if (_aeLiveWiz.active) { api.v1.ui.toast('An in-story wizard chat is open \u2014 end it before opening the classic wizard.', { type: 'warning', autoClose: 4000 }); return; }
        if (_aeCharChat.active) { api.v1.ui.toast('A character chat is open in the story \u2014 end it before opening the classic wizard.', { type: 'warning', autoClose: 4000 }); return; }
        _aeWizardMode = true;
        _wizModeExitPending = false;
        await api.v1.tempStorage.set(STORAGE_WIZ_MODE, 'true').catch(function() {});
        try {
            _wizModeParamSnapshot = await api.v1.generationParameters.get();
            await api.v1.generationParameters.update({ max_tokens: AE_WIZARD_MAX_TOKENS });
        } catch (e) { api.v1.log('[AE:wizard] mode-enter param pin failed, continuing without pin:', e); _wizModeParamSnapshot = null; }
        api.v1.ui.toast('Wizard mode ON \u2014 story generation paused', { type: 'info', autoClose: 3000 });
        await broadcastWizModeState();
        return;
    }
    // Exiting. If a yoink is genuinely still in flight, defer the actual restore until
    // it resolves (onGenerationEnd) or the watchdog gives up on it (both bounded by
    // AE_YOINK_TIMEOUT_MS) — never leave the document unswallowed mid-generation.
    if (_aeYoink.active) {
        _wizModeExitPending = true;
        api.v1.log('[AE:wizard] mode-exit requested while a yoink is in flight \u2014 draining before restore.');
        await broadcastWizModeState();
        return;
    }
    await aeCompleteWizardModeExit();
}

async function aeCompleteWizardModeExit(): Promise<void> {
    _aeWizardMode = false;
    _wizModeExitPending = false;
    _wizFrozenCtx = {};
    await api.v1.tempStorage.remove(STORAGE_WIZ_MODE).catch(function() {});
    if (_wizModeParamSnapshot) {
        try {
            let r: any = { model: _wizModeParamSnapshot.model };
            if (_wizModeParamSnapshot.max_tokens !== undefined) r.max_tokens = _wizModeParamSnapshot.max_tokens;
            if (_wizModeParamSnapshot.temperature !== undefined) r.temperature = _wizModeParamSnapshot.temperature;
            if (_wizModeParamSnapshot.top_p !== undefined) r.top_p = _wizModeParamSnapshot.top_p;
            if (_wizModeParamSnapshot.top_k !== undefined) r.top_k = _wizModeParamSnapshot.top_k;
            if (_wizModeParamSnapshot.frequency_penalty !== undefined) r.frequency_penalty = _wizModeParamSnapshot.frequency_penalty;
            if (_wizModeParamSnapshot.presence_penalty !== undefined) r.presence_penalty = _wizModeParamSnapshot.presence_penalty;
            if (_wizModeParamSnapshot.min_p !== undefined) r.min_p = _wizModeParamSnapshot.min_p;
            await api.v1.generationParameters.update(r);
        } catch (e) { api.v1.error('[AE:wizard] failed to restore generation params after wizard mode exit:', e); }
        _wizModeParamSnapshot = null;
    }
    api.v1.ui.toast('Wizard mode OFF \u2014 story generation resumed', { type: 'success', autoClose: 3000 });
    await broadcastWizModeState();
}
// ── [v1.2.0 WIZMODE] end ──────────────────────────────────────────────────────

// ── [v2.4.0 WIZLIVE] In-document wizard chat ──────────────────────────────────
// The chat lives IN the story document instead of a hidden yoink conversation:
//   - startLiveWizardChat appends a boundary marker + an editable protocol
//     paragraph (both source:'instruction' — NAI's native instruct blocks) and
//     an opening greeting; the user then talks in { } instruct blocks and
//     presses NAI's own Send. Replies are ordinary generations landing in the
//     document — nothing is swallowed, no onResponse capture, no watchdog.
//   - CACHING CONTRACT: the story prefix (system prompt, memory, lorebook,
//     early story text) is NEVER touched while the chat is live. The only
//     context differences on a chat turn are the Author's Note being
//     deactivated (tail of context) and the chat paragraphs growing at the
//     document tail. Ending the chat removes those paragraphs, so story
//     generation resumes with a byte-identical top of context. Committing to
//     Memory is the single deliberate exception — that is the feature.
//   - endLiveWizardChat collects the transcript (instruction-source paragraphs
//     = user turns, everything else = wizard turns), archives it as a normal
//     WizardChat record unless discarding, optionally commits raw or distilled
//     notes to Memory, then removes every paragraph from the marker down.
//   - Batch generators are untouched — they still run through
//     executeYoinkGeneration. Classic WIZMODE and WIZLIVE are mutually
//     exclusive (guards in aeSetWizardMode and startLiveWizardChat).
interface LiveWizState {
    active: boolean;
    markerId: number | null;        // sectionId of the boundary marker paragraph
    setupIds: number[];             // sectionIds of engine-authored setup paragraphs (excluded from the transcript)
    topicId: string;                // wizard topic supplying the persona; '' = generic live persona
    paramSnapshot: any;             // generationParameters snapshot restored on end (persisted so a reload can still restore)
    startedAt: number;
    sourceEntryId: string | null;   // [v2.5.0] CE-Chats lorebook entry this chat resumes/overwrites; null = a fresh chat (Save creates a new entry)
    contextEntryIds: string[];      // [v2.5.0] CE-Chats entries switched forceActivation:true for THIS session; switched back off on end
    title: string;                  // [v2.6.0] user-facing chat name — defaults to the topic label at start/resume, renameable live; NEVER carries a timestamp
}
var _aeLiveWiz: LiveWizState = { active: false, markerId: null, setupIds: [], topicId: '', paramSnapshot: null, startedAt: 0, sourceEntryId: null, contextEntryIds: [], title: '' };

const AE_WIZLIVE_RULE_MARKER  = 'ae-wizlive-marker';
const AE_WIZLIVE_RULE_USER    = 'ae-wizlive-user';   // [v2.5.0] Director (instruction) turns — cool blue
const AE_WIZLIVE_RULE_WIZ     = 'ae-wizlive-wiz';    // [v2.5.0] Wizard replies + setup paragraphs — violet
const AE_WIZLIVE_MARKER_TEXT  = '\u2501\u2501 WIZARD CHAT \u2501\u2501 The story above is reference material. Everything below this line is an out-of-story planning chat and will be removed when the chat ends.';

// [v2.5.0 CE-CHATS] Live wizard chats persist to the lorebook instead of a bespoke
// Memory sentinel. A dedicated category holds one entry per saved chat; entries carry
// NO keys, so they never activate by keyword — they only enter context when their
// forceActivation ("Always On") flag is switched true, and go dormant again when
// switched false. That is how a chat (or a batch generator) "chooses" a saved chat as
// context: turn it on for the session, off when done. Resuming pulls the entry text
// back into the story to be continued, then Save overwrites the same entry.
var WIZLIVE_CAT_NAME  = 'CE Chats';
var _aeWizChatCatId: string | null = null;   // module cache of the category id (also mirrored to storyStorage)

async function saveLiveWizState(): Promise<void> {
    try { await api.v1.storyStorage.set(STORAGE_WIZLIVE, JSON.stringify(_aeLiveWiz)); }
    catch (e) { api.v1.error('[AE:wizlive] state save failed:', e); }
}

async function broadcastWizLiveState(): Promise<void> {
    try { await broadcastToTM(EVT_WIZLIVE_STATE, { active: _aeLiveWiz.active, topicId: _aeLiveWiz.topicId, startedAt: _aeLiveWiz.startedAt }); }
    catch (e) { api.v1.log('[AE:wizlive] state broadcast failed:', e); }
}

// ── CE-Chats lorebook store ─────────────────────────────────────────────────
// Find (or create) the "CE Chats" lorebook category. Cached in module scope and
// mirrored to storyStorage so we usually skip the categories() scan.
async function ensureWizChatCategory(): Promise<string> {
    if (_aeWizChatCatId) return _aeWizChatCatId;
    try {
        let cached = (await api.v1.storyStorage.getOrDefault(STORAGE_WIZLIVE_CAT, '')) as string;
        if (cached) {
            let c = await api.v1.lorebook.category(cached);
            if (c) { _aeWizChatCatId = cached; return cached; }
        }
    } catch (_e0) {}
    try {
        let cats = await api.v1.lorebook.categories();
        let found = (cats || []).filter(function(c: any) { return (c.name || '') === WIZLIVE_CAT_NAME; })[0];
        if (found) {
            _aeWizChatCatId = found.id;
            try { await api.v1.storyStorage.set(STORAGE_WIZLIVE_CAT, found.id); } catch (_e1) {}
            return found.id;
        }
    } catch (_e2) {}
    let newId = await api.v1.lorebook.createCategory({ id: api.v1.uuid(), name: WIZLIVE_CAT_NAME, enabled: true });
    _aeWizChatCatId = newId;
    try { await api.v1.storyStorage.set(STORAGE_WIZLIVE_CAT, newId); } catch (_e3) {}
    return newId;
}

// All CE-Chats entries (each is one saved wizard chat), newest lorebook order.
async function listWizChatEntries(): Promise<any[]> {
    try { let cat = await ensureWizChatCategory(); return (await api.v1.lorebook.entries(cat)) || []; }
    catch (e) { api.v1.error('[AE:wizlive] listWizChatEntries:', e); return []; }
}

// Serialize a transcript into a round-trippable, human-readable block. The header
// line carries the title and (optionally) the source topic so a resume restores the
// right persona. Turns are "Director:"/"Wizard:" prefixed — the same shape the chat
// already reads naturally as context when switched Always-On.
// [v2.6.0] The timestamp is stamped into this HEADER line only (a [saved:...] tag) —
// title/displayName (the lorebook entry's actual NAME) never carries a date, per design.
function serializeChatTranscript(title: string, msgs: WizardChatMessage[], topicId: string): string {
    let head = '=== ' + (title || 'Wizard Chat') + (topicId ? ' [topic:' + topicId + ']' : '') + ' [saved:' + new Date().toLocaleString() + ']' + ' ===';
    let parts: string[] = [head, ''];
    for (let i = 0; i < msgs.length; i++) {
        let m = msgs[i];
        parts.push((m.role === 'user' ? 'Director: ' : 'Wizard: ') + m.content);
        parts.push('');
    }
    return parts.join('\n').replace(/\s+$/, '');
}

// Inverse of serializeChatTranscript. String-parsed (no bracket-bearing regex) so the
// engine brace-balance check stays meaningful. Lines before the first role header are
// ignored; a role line starts a turn, and following lines accrue to it until the next
// role header — so multi-line wizard replies survive the round trip.
function parseChatTranscript(text: string): { title: string; topicId: string; msgs: WizardChatMessage[] } {
    let title = ''; let topicId = '';
    let lines = String(text || '').split('\n');
    let msgs: WizardChatMessage[] = [];
    let cur: WizardChatMessage | null = null;
    for (let i = 0; i < lines.length; i++) {
        let line = lines[i];
        let t = line.trim();
        if (t.length >= 6 && t.indexOf('===') === 0 && t.lastIndexOf('===') === t.length - 3) {
            let inner = t.substring(3, t.length - 3).trim();
            let tp = inner.indexOf('[topic:');
            if (tp >= 0) {
                let close = inner.indexOf(']', tp);
                if (close > tp) {
                    topicId = inner.substring(tp + 7, close).trim();
                    inner = (inner.substring(0, tp) + inner.substring(close + 1)).trim();
                }
            }
            // [v2.6.0] Strip the [saved:...] stamp too — it is metadata, never part of the title.
            let sp = inner.indexOf('[saved:');
            if (sp >= 0) {
                let sclose = inner.indexOf(']', sp);
                if (sclose > sp) inner = (inner.substring(0, sp) + inner.substring(sclose + 1)).trim();
            }
            title = inner;
            continue;
        }
        let role: 'user' | 'assistant' | null = null;
        let rest = '';
        if (line.indexOf('Director:') === 0) { role = 'user'; rest = line.substring(9); }
        else if (line.indexOf('Wizard:') === 0) { role = 'assistant'; rest = line.substring(7); }
        if (role) {
            if (cur) msgs.push(cur);
            if (rest.charAt(0) === ' ') rest = rest.substring(1);
            cur = { role: role, content: rest };
        } else if (cur) {
            cur.content += '\n' + line;
        }
    }
    if (cur) msgs.push(cur);
    let outM: WizardChatMessage[] = [];
    for (let k = 0; k < msgs.length; k++) {
        let c = msgs[k].content.replace(/^\s+/, '').replace(/\s+$/, '');
        if (c.length > 0) outM.push({ role: msgs[k].role, content: c });
    }
    return { title: title, topicId: topicId, msgs: outM };
}

// Create-or-overwrite a CE-Chats entry. sourceEntryId (when it still exists) is
// overwritten in place; otherwise a fresh keyless, forceActivation:false entry is made.
async function upsertChatEntry(sourceEntryId: string | null, title: string, msgs: WizardChatMessage[], topicId: string): Promise<string> {
    let cat = await ensureWizChatCategory();
    let text = serializeChatTranscript(title, msgs, topicId);
    if (sourceEntryId) {
        let existing: any = null;
        try { existing = await api.v1.lorebook.entry(sourceEntryId); } catch (_e) {}
        if (existing) {
            await api.v1.lorebook.updateEntry(sourceEntryId, { text: text, displayName: title, category: cat });
            return sourceEntryId;
        }
    }
    let id = api.v1.uuid();
    let newId = await api.v1.lorebook.createEntry({ id: id, category: cat, displayName: title, text: text, keys: [], enabled: true, forceActivation: false, hidden: false });
    return newId || id;
}

// Flip forceActivation ("Always On") for a set of entries. Turning entries on is a
// deliberate top-of-context change (like the old Memory commit was); it happens once
// at chat start and reverts once at chat end, so all turns WITHIN a chat stay
// byte-identical and the prefix cache survives the session.
async function setContextEntriesActivation(ids: string[], on: boolean): Promise<void> {
    for (let i = 0; i < ids.length; i++) {
        try { await api.v1.lorebook.updateEntry(ids[i], { forceActivation: on }); }
        catch (e) { api.v1.error('[AE:wizlive] context toggle failed:', e); }
    }
}

// ── Decorations: split Director (blue) vs Wizard (violet) ───────────────────
// Registered once with empty user/wiz scopes; refreshLiveWizDecorations recomputes
// the two id sets from the live document (called on start, restore, and each turn end).
async function _wizliveRegisterDecorations(markerId: number): Promise<void> {
    await api.v1.editor.decorations.registerRules([
        { id: AE_WIZLIVE_RULE_MARKER, type: 'node', match: '^', style: { backgroundColor: 'rgba(147, 112, 219, 0.22)', borderTop: '2px solid rgba(147, 112, 219, 0.85)', borderBottom: '1px solid rgba(147, 112, 219, 0.4)' }, scope: { sectionIds: [markerId] } },
        { id: AE_WIZLIVE_RULE_USER,   type: 'node', match: '^', style: { backgroundColor: 'rgba(74, 158, 217, 0.10)', borderLeft: '3px solid rgba(74, 158, 217, 0.60)' }, scope: { sectionIds: [] } },
        { id: AE_WIZLIVE_RULE_WIZ,    type: 'node', match: '^', style: { backgroundColor: 'rgba(147, 112, 219, 0.07)', borderLeft: '3px solid rgba(147, 112, 219, 0.45)' }, scope: { sectionIds: [] } }
    ]);
}

async function refreshLiveWizDecorations(): Promise<void> {
    if (!_aeLiveWiz.active || _aeLiveWiz.markerId === null) return;
    let all: any[] = [];
    try { all = await api.v1.document.scan(); } catch (_eScan) { return; }
    let userIds: number[] = [];
    let wizIds: number[] = [];
    let seen = false;
    for (let idx = 0; idx < all.length; idx++) {
        let row = all[idx];
        if (row.sectionId === _aeLiveWiz.markerId) { seen = true; continue; }
        if (!seen) continue;
        // Engine-authored setup (protocol/greeting) reads as the wizard side.
        if (_aeLiveWiz.setupIds.indexOf(row.sectionId) >= 0) { wizIds.push(row.sectionId); continue; }
        let isUser = row.section.source === 'instruction';
        if (!isUser) {
            let org = row.section.origin || [];
            if (org.length > 0) {
                let allTyped = true;
                let anyUser = false;
                for (let o of org) {
                    if (o.data === 'user') anyUser = true;
                    if (o.data !== 'user' && o.data !== 'edit') { allTyped = false; break; }
                }
                isUser = allTyped && anyUser;
            }
        }
        if (isUser) userIds.push(row.sectionId); else wizIds.push(row.sectionId);
    }
    try {
        await api.v1.editor.decorations.updateRules([
            { id: AE_WIZLIVE_RULE_USER, scope: { sectionIds: userIds } },
            { id: AE_WIZLIVE_RULE_WIZ,  scope: { sectionIds: wizIds } }
        ]);
    } catch (e) { api.v1.log('[AE:wizlive] decoration refresh failed (cosmetic only):', e); }
}

// Build the persona + protocol paragraphs shared by start and resume.
function _wizliveProtocolText(cfg: GlobalConfig, topicId: string): string {
    let topic = topicId ? getWizardTopic(cfg, topicId) : null;
    let persona = topic ? topic.instructions : 'You are a warm, collaborative worldbuilding assistant helping the user develop their story. Write in pure prose \u2014 no markdown, bolding, headers, or lists. Offer one or two concrete suggestions that push the idea forward and ask exactly ONE focused question per turn. Typically respond in 2-5 sentences.';
    let protoParts: string[] = [];
    protoParts.push('WIZARD CHAT MODE. ' + persona);
    protoParts.push('The user speaks in instruction blocks like this one. Reply to their newest instruction in plain conversational prose \u2014 do NOT continue the story itself. The story text above the chat marker is reference material you may draw on.');
    if (cfg.projectName || cfg.projectGenre || cfg.projectConcept) {
        let pj: string[] = [];
        if (cfg.projectName) pj.push('Project: ' + cfg.projectName);
        if (cfg.projectGenre) pj.push('Genre: ' + cfg.projectGenre);
        if (cfg.projectConcept) pj.push('Concept: ' + cfg.projectConcept);
        protoParts.push(pj.join('. ') + '.');
    }
    return protoParts.join(' ');
}

async function startLiveWizardChat(topicId: string, ctxEntryIds?: string[]): Promise<void> {
    if (_aeLiveWiz.active) { api.v1.ui.toast('A wizard chat is already open in the story.', { type: 'warning', autoClose: 3000 }); return; }
    if (_aeWizardMode) { api.v1.ui.toast('Close the classic wizard first \u2014 the two modes are exclusive.', { type: 'warning', autoClose: 4000 }); return; }
    if (_aeCharChat.active) { api.v1.ui.toast('A character chat is open in the story \u2014 end it first.', { type: 'warning', autoClose: 4000 }); return; }
    if (_aeYoink.active) { api.v1.ui.toast('A background generation is running \u2014 try again in a moment.', { type: 'warning', autoClose: 3000 }); return; }

    let cfg = await loadConfig();
    let topic = topicId ? getWizardTopic(cfg, topicId) : null;
    let protoText = _wizliveProtocolText(cfg, topicId);
    let greeting = (topic && (topic as any).seedMessage && String((topic as any).seedMessage).trim())
        ? String((topic as any).seedMessage).trim()
        // [FEATURE v2.29.0 WIZLIVE-BRACE-WRAP, per user] No longer tells the user to type
        // a curly brace themselves — _wizliveNormalizeDocument wraps a Director turn in
        // braces automatically after every reply, the same "you don't have to do it
        // yourself" wording change CharChat's own greeting got in v2.26.0/v2.27.0.
        : 'I\u2019m listening \u2014 write your message in a new paragraph, then press Send.';

    let before = await api.v1.document.sectionIds();
    await api.v1.document.appendParagraphs([
        { text: AE_WIZLIVE_MARKER_TEXT, source: 'instruction' },
        { text: protoText, source: 'instruction' },
        { text: greeting }
    ]);
    let after = await api.v1.document.sectionIds();
    let added = after.slice(before.length);
    if (added.length === 0) { api.v1.ui.toast('Could not start the chat \u2014 document append failed.', { type: 'error', autoClose: 4000 }); return; }
    let markerId = added[0];

    let snap: any = null;
    try {
        snap = await api.v1.generationParameters.get();
        await api.v1.generationParameters.update({ max_tokens: AE_WIZARD_MAX_TOKENS });
    } catch (eP) { api.v1.log('[AE:wizlive] param pin failed, continuing without pin:', eP); snap = null; }

    let ctx = Array.isArray(ctxEntryIds) ? ctxEntryIds.slice() : [];
    let startTitle = (topic && topic.label) ? topic.label : 'General Worldbuilding';
    _aeLiveWiz = { active: true, markerId: markerId, setupIds: added.slice(1), topicId: topicId || '', paramSnapshot: snap, startedAt: Date.now(), sourceEntryId: null, contextEntryIds: ctx, title: startTitle };
    await saveLiveWizState();

    if (ctx.length > 0) {
        try { await setContextEntriesActivation(ctx, true); }
        catch (eCtx) { api.v1.error('[AE:wizlive] context activation failed:', eCtx); }
    }

    try { await _wizliveRegisterDecorations(markerId); await refreshLiveWizDecorations(); }
    catch (eD) { api.v1.log('[AE:wizlive] decoration registration failed (cosmetic only):', eD); }

    api.v1.ui.toast('Wizard chat open \u2014 talk in { } instruct blocks below the marker, then press Send.', { type: 'info', autoClose: 6000 });
    await broadcastWizLiveState();
}

// Pull a saved chat back into the story and go live on it. The entry it came from is
// held as sourceEntryId so Save & Close overwrites that same entry.
async function resumeLiveWizardChatFromEntry(entryId: string): Promise<void> {
    if (_aeLiveWiz.active) { api.v1.ui.toast('A wizard chat is already open in the story.', { type: 'warning', autoClose: 3000 }); return; }
    if (_aeWizardMode) { api.v1.ui.toast('Close the classic wizard first \u2014 the two modes are exclusive.', { type: 'warning', autoClose: 4000 }); return; }
    if (_aeCharChat.active) { api.v1.ui.toast('A character chat is open in the story \u2014 end it first.', { type: 'warning', autoClose: 4000 }); return; }
    if (_aeYoink.active) { api.v1.ui.toast('A background generation is running \u2014 try again in a moment.', { type: 'warning', autoClose: 3000 }); return; }

    let entry: any = null;
    try { entry = await api.v1.lorebook.entry(entryId); } catch (_e) {}
    if (!entry || !entry.text) { api.v1.ui.toast('Could not load that saved chat.', { type: 'error', autoClose: 4000 }); return; }
    let parsed = parseChatTranscript(entry.text);
    if (parsed.msgs.length === 0) { api.v1.ui.toast('That saved chat is empty.', { type: 'warning', autoClose: 3000 }); return; }

    let cfg = await loadConfig();
    let protoText = _wizliveProtocolText(cfg, parsed.topicId);

    // marker + protocol, then one paragraph per turn (user turns rebuilt as { } instruct blocks).
    let paras: any[] = [
        { text: AE_WIZLIVE_MARKER_TEXT, source: 'instruction' },
        { text: protoText, source: 'instruction' }
    ];
    for (let i = 0; i < parsed.msgs.length; i++) {
        let m = parsed.msgs[i];
        if (m.role === 'user') {
            paras.push({ text: '{ ' + m.content.replace(/\n+/g, ' ').trim() + ' }', source: 'instruction' });
        } else {
            let chunks = m.content.split('\n');
            for (let j = 0; j < chunks.length; j++) {
                let c = chunks[j].replace(/^\s+/, '').replace(/\s+$/, '');
                if (c.length > 0) paras.push({ text: c });
            }
        }
    }

    let before = await api.v1.document.sectionIds();
    await api.v1.document.appendParagraphs(paras);
    let after = await api.v1.document.sectionIds();
    let added = after.slice(before.length);
    if (added.length < 2) { api.v1.ui.toast('Could not insert the chat \u2014 document append failed.', { type: 'error', autoClose: 4000 }); return; }
    let markerId = added[0];
    let protocolId = added[1];

    let snap: any = null;
    try {
        snap = await api.v1.generationParameters.get();
        await api.v1.generationParameters.update({ max_tokens: AE_WIZARD_MAX_TOKENS });
    } catch (eP) { api.v1.log('[AE:wizlive] param pin failed, continuing without pin:', eP); snap = null; }

    let resumeTitle = (parsed.title || '').trim() || ((getWizardTopic(cfg, parsed.topicId) || {} as any).label) || 'General Worldbuilding';
    _aeLiveWiz = { active: true, markerId: markerId, setupIds: [protocolId], topicId: parsed.topicId || '', paramSnapshot: snap, startedAt: Date.now(), sourceEntryId: entryId, contextEntryIds: [], title: resumeTitle };
    await saveLiveWizState();

    try { await _wizliveRegisterDecorations(markerId); await refreshLiveWizDecorations(); }
    catch (eD) { api.v1.log('[AE:wizlive] decoration registration failed (cosmetic only):', eD); }

    api.v1.ui.toast('Chat resumed in the story \u2014 continue below the marker. Save & Close overwrites this saved chat.', { type: 'info', autoClose: 6000 });
    await broadcastWizLiveState();
}

function _wizliveStripBraces(t: string): string {
    let s = (t || '').trim();
    if (s.length >= 2 && s.charAt(0) === '{' && s.charAt(s.length - 1) === '}') s = s.substring(1, s.length - 1).trim();
    return s;
}

// [v2.29.0] Factored out of collectLiveWizTranscript's own inline copy, per user's
// new brace-auto-wrap request needing the exact same classification — same
// "one shared function, not drifting duplicates" call already made for CharChat's
// _charchatRowIsPov (grep it for the precedent). Role is NEVER inferred from text:
// instruction-source paragraphs are Director turns (NAI's { } instruct blocks); a
// paragraph whose origin metadata is entirely user/edit-typed is also a Director
// turn (they didn't use braces this time).
function _wizliveRowIsUser(section: any): boolean {
    if (section.source === 'instruction') return true;
    let wlOrg = section.origin || [];
    if (wlOrg.length === 0) return false;
    let wlAllTyped = true;
    let wlAnyUser = false;
    for (let wlO of wlOrg) {
        if (wlO.data === 'user') wlAnyUser = true;
        if (wlO.data !== 'user' && wlO.data !== 'edit') { wlAllTyped = false; break; }
    }
    return wlAllTyped && wlAnyUser;
}

// [FEATURE v2.29.0 WIZLIVE-BRACE-WRAP, per user: "just like character chats"] Rewrites
// every Director (user) turn in the live document to "{Director: body}" so the user
// never has to type braces themselves — CharChat's exact selling point, ported here.
// WRITE-PASS ONLY, called from onGenerationEnd, same timing rule CharChat's own
// _charchatNormalizeDocument follows and for the same reason: mutating the document
// mid-context-build would race the generation currently building against it.
// DELIBERATE DIFFERENCE FROM CHARCHAT, not an oversight: CharChat ALSO has a read-only
// twin (_charchatCanonicalChatText) that overrides storyText.content so the model's
// view is canonical on the SAME turn it's typed. WIZLIVE does not get one — WIZLIVE's
// onBeforeContextBuild deliberately leaves the story prefix (and the live document
// text within it) completely untouched, to protect prefix caching across the chat
// (see that hook's own WIZLIVE comment). Adding a same-turn override here would mean
// reversing THAT design decision too, which nothing in this request asked for. Net
// effect: a Director turn is typed raw, reaches the model raw for THAT one reply, and
// is rewritten with braces immediately after — visible correctly from that point on,
// and correctly formatted for every SUBSEQUENT generation's raw-document read. One
// turn of lag on the very first message of a session, same trade CharChat itself
// would have if its read-only twin were ever removed.
// NOT PORTED, flagged rather than guessed at: CharChat's v2.25.0 CHARCHAT-MERGE fix
// (_charchatSplitMergedSections) for NAI gluing a completion directly onto the same
// paragraph the user just typed into, with no trailing paragraph break. The same NAI
// editor mechanism underlies both chat modes, so the same bug is plausible here too —
// untested, not addressed this pass. Watch for a Director turn that looks like it
// swallowed the start of a Wizard reply, the exact symptom that bug produced there.
// ASSUMPTION, stated rather than silently made: the literal label is "Director" (no
// per-user customizable name exists for WIZLIVE, unlike CharChat's povName) — matches
// the fixed "Director:"/"Wizard:" prefixes serializeChatTranscript already uses for
// the SAVED transcript, so this is consistent with an existing convention, not a new
// one invented for this patch.
async function _wizliveNormalizeDocument(): Promise<void> {
    if (!_aeLiveWiz.active || _aeLiveWiz.markerId === null) return;
    let wlAll: any[] = [];
    try { wlAll = await api.v1.document.scan(); }
    catch (eWs) { api.v1.error('[AE:wizlive] turn scan failed:', eWs); return; }
    let wlSeen = false;
    let wlUpdates: { sectionId: number; section: any }[] = [];
    for (let wlR of wlAll) {
        if (wlR.sectionId === _aeLiveWiz.markerId) { wlSeen = true; continue; }
        if (!wlSeen) continue;
        if (_aeLiveWiz.setupIds.indexOf(wlR.sectionId) >= 0) continue;
        if (!_wizliveRowIsUser(wlR.section)) continue;   // only Director turns get wrapped; Wizard replies pass through untouched
        let wlTxt = (wlR.section.text || '');
        if (!wlTxt.trim()) continue;
        let wlBody = _wizliveStripBraces(wlTxt);
        if (!wlBody) continue;
        let wlCanon = '{Director: ' + wlBody + '}';
        if (wlCanon !== wlR.section.text) wlUpdates.push({ sectionId: wlR.sectionId, section: { text: wlCanon } });
    }
    if (wlUpdates.length > 0) {
        try { await api.v1.document.updateParagraphs(wlUpdates); }
        catch (eWu) { api.v1.log('[AE:wizlive] brace-wrap rewrite failed (cosmetic only):', eWu); }
    }
}

// Walk the document from the marker down and rebuild the conversation. Role mapping:
// instruction-source paragraphs are user turns (NAI's { } instruct blocks); anything
// whose origin metadata is entirely user/edit-typed is also treated as a user turn
// (they forgot the braces); everything else is the wizard. Consecutive wizard
// paragraphs merge into one turn. Engine-authored setup paragraphs are excluded.
async function collectLiveWizTranscript(): Promise<{ msgs: WizardChatMessage[]; ids: number[] }> {
    let out: WizardChatMessage[] = [];
    let ids: number[] = [];
    if (_aeLiveWiz.markerId === null) return { msgs: out, ids: ids };
    let all = await api.v1.document.scan();
    let seen = false;
    for (let row of all) {
        if (row.sectionId === _aeLiveWiz.markerId) { seen = true; ids.push(row.sectionId); continue; }
        if (!seen) continue;
        ids.push(row.sectionId);
        if (_aeLiveWiz.setupIds.indexOf(row.sectionId) >= 0) continue;
        let txt = (row.section.text || '').trim();
        if (!txt) continue;
        let isUser = _wizliveRowIsUser(row.section);
        if (isUser) {
            out.push({ role: 'user', content: _wizliveStripBraces(txt) });
        } else if (out.length > 0 && out[out.length - 1].role === 'assistant') {
            out[out.length - 1].content += '\n' + txt;
        } else {
            out.push({ role: 'assistant', content: txt });
        }
    }
    return { msgs: out, ids: ids };
}

// Run one distillation pass over the live transcript and RETURN the text without
// committing anything. The modal shows it as an editable preview the user can then
// save to the lorebook (or ignore). Replaces the old auto-commit "summarize" action.
async function previewSummarizeLiveChat(): Promise<string> {
    let collected = await collectLiveWizTranscript();
    if (collected.msgs.length === 0) return '';
    let sTranscript = collected.msgs.map(function(m) { return (m.role === 'user' ? 'USER: ' : 'WIZARD: ') + m.content; }).join('\n');
    let sOut = await executeYoinkGeneration([
        { role: 'system', content: 'Distill the following worldbuilding chat into dense, declarative canon statements suitable for a lorebook entry. Keep only established facts and decisions \u2014 drop questions, hedges, and conversational filler. Write in pure prose or short single-line statements. No markdown, no headers, no bullet lists. Be concise.' },
        { role: 'user', content: sTranscript }
    ], { tag: 'liveWizSummarize' });
    return (sOut || '').trim();
}

async function endLiveWizardChat(action: string): Promise<void> {
    if (!_aeLiveWiz.active) { api.v1.ui.toast('No wizard chat is open.', { type: 'warning', autoClose: 2500 }); return; }
    let act = (action === 'discard') ? 'discard' : 'save';

    let collected = await collectLiveWizTranscript();
    let msgs = collected.msgs;

    // Save FIRST, destroy LAST — a save failure returns early leaving the chat intact
    // in the document, so nothing is ever lost to a half-completed end.
    if (act === 'save' && msgs.length > 0) {
        try {
            let title = (_aeLiveWiz.title || '').trim() || 'Wizard Chat';
            await upsertChatEntry(_aeLiveWiz.sourceEntryId, title, msgs, _aeLiveWiz.topicId);
            api.v1.ui.toast('Chat saved to the CE Chats lorebook.', { type: 'success', autoClose: 3000 });
        } catch (eS) {
            api.v1.error('[AE:wizlive] lorebook save failed:', eS);
            api.v1.ui.toast('Save failed \u2014 the chat is still in your document, nothing was removed.', { type: 'error', autoClose: 5000 });
            return;
        }
    }

    // Switch this session's context entries back off so story mode returns to its exact
    // pre-chat prefix (preserving the story-generation cache).
    if (_aeLiveWiz.contextEntryIds && _aeLiveWiz.contextEntryIds.length > 0) {
        try { await setContextEntriesActivation(_aeLiveWiz.contextEntryIds, false); }
        catch (eCtx) { api.v1.error('[AE:wizlive] context deactivation failed:', eCtx); }
    }

    // Remove the chat region, marker included, in one call.
    try {
        if (collected.ids.length > 0) await api.v1.document.removeParagraphs(collected.ids);
    } catch (eR) { api.v1.error('[AE:wizlive] paragraph removal failed \u2014 clean up manually from the marker down:', eR); }

    try { api.v1.editor.decorations.removeRules([AE_WIZLIVE_RULE_MARKER, AE_WIZLIVE_RULE_USER, AE_WIZLIVE_RULE_WIZ]); } catch (_eDr) {}

    // Restore pinned generation params (same field-by-field shape as the WIZMODE restore).
    if (_aeLiveWiz.paramSnapshot) {
        try {
            let ps: any = _aeLiveWiz.paramSnapshot;
            let r: any = { model: ps.model };
            if (ps.max_tokens !== undefined) r.max_tokens = ps.max_tokens;
            if (ps.temperature !== undefined) r.temperature = ps.temperature;
            if (ps.top_p !== undefined) r.top_p = ps.top_p;
            if (ps.top_k !== undefined) r.top_k = ps.top_k;
            if (ps.frequency_penalty !== undefined) r.frequency_penalty = ps.frequency_penalty;
            if (ps.presence_penalty !== undefined) r.presence_penalty = ps.presence_penalty;
            if (ps.min_p !== undefined) r.min_p = ps.min_p;
            await api.v1.generationParameters.update(r);
        } catch (eRe) { api.v1.error('[AE:wizlive] param restore failed:', eRe); }
    }

    _aeLiveWiz = { active: false, markerId: null, setupIds: [], topicId: '', paramSnapshot: null, startedAt: 0, sourceEntryId: null, contextEntryIds: [], title: '' };
    try { await api.v1.storyStorage.remove(STORAGE_WIZLIVE); } catch (_eRm) {}
    api.v1.ui.toast('Wizard chat closed \u2014 story mode restored.', { type: 'success', autoClose: 3000 });
    await broadcastWizLiveState();
}

// Startup rehydration: a chat left open in this story (script reload, tab close)
// comes back live IF its marker paragraph still exists; otherwise the stale state
// is cleared and any pinned params restored from the persisted snapshot. Context
// entries stay Always-On across a reload (lorebook state is story-scoped and
// persistent) and are only switched off when the chat is finally ended.
async function restoreLiveWizOnStartup(): Promise<void> {
    let raw = '';
    try { raw = (await api.v1.storyStorage.getOrDefault(STORAGE_WIZLIVE, '')) as string; } catch (_e0) {}
    if (!raw) return;
    let st: any = null;
    try { st = JSON.parse(raw); } catch (_e1) { st = null; }
    if (!st || !st.active || typeof st.markerId !== 'number') {
        try { await api.v1.storyStorage.remove(STORAGE_WIZLIVE); } catch (_e2) {}
        return;
    }
    let ids: number[] = [];
    try { ids = await api.v1.document.sectionIds(); } catch (_e3) {}
    if (ids.indexOf(st.markerId) < 0) {
        if (st.paramSnapshot) {
            try {
                let rp: any = { model: st.paramSnapshot.model };
                if (st.paramSnapshot.max_tokens !== undefined) rp.max_tokens = st.paramSnapshot.max_tokens;
                await api.v1.generationParameters.update(rp);
            } catch (_e4) {}
        }
        // Stale marker: make sure any leftover Always-On context entries are switched off.
        if (Array.isArray(st.contextEntryIds) && st.contextEntryIds.length > 0) {
            try { await setContextEntriesActivation(st.contextEntryIds, false); } catch (_e4b) {}
        }
        try { await api.v1.storyStorage.remove(STORAGE_WIZLIVE); } catch (_e5) {}
        api.v1.log('[AE:wizlive] stale chat state cleared (marker no longer in document).');
        return;
    }
    _aeLiveWiz = {
        active: true,
        markerId: st.markerId,
        setupIds: Array.isArray(st.setupIds) ? st.setupIds : [],
        topicId: st.topicId || '',
        paramSnapshot: st.paramSnapshot || null,
        startedAt: st.startedAt || Date.now(),
        sourceEntryId: (typeof st.sourceEntryId === 'string') ? st.sourceEntryId : null,
        contextEntryIds: Array.isArray(st.contextEntryIds) ? st.contextEntryIds : [],
        title: (typeof st.title === 'string' && st.title) ? st.title : 'Wizard Chat'
    };
    try { await _wizliveRegisterDecorations(st.markerId); await refreshLiveWizDecorations(); }
    catch (eD) { api.v1.log('[AE:wizlive] decoration restore failed (cosmetic only):', eD); }
    api.v1.ui.toast('Wizard chat still open in this story \u2014 continue below the marker or end it from the World-Build Wizard.', { type: 'info', autoClose: 6000 });
    await broadcastWizLiveState();
}
// ── [v2.4.0 WIZLIVE] end ──────────────────────────────────────────────────────

// ============================================================================
// [v2.21.0 CHARCHAT] IN-STORY CHARACTER CHAT (P1 — engine core)
// ----------------------------------------------------------------------------
// A texting-style conversation with ONE character, held in the document tail,
// driven by NAI's own Send/generate path. Modeled on WIZLIVE (marker paragraph +
// instruct-block turns + param pin + strip-on-end) but with one decisive
// difference: WIZLIVE deliberately leaves the top of context untouched to
// preserve the story prefix cache, whereas CHARCHAT OWNS THE WHOLE PROMPT.
//
// While a chat is active, runCharChatContextOverride() replaces, per generation:
//   systemPrompt  chat framing + "you are X" + X's folded lorebook identity +
//                 X's dynamic block + X's persona register.  (top of context)
//   lorebook      EVERY character-linked entry deactivated — both participants'
//                 (already folded into the system prompt above, so leaving them
//                 on would duplicate) and everyone else's (the persona-bleed
//                 guard: only the two chat participants are scene-present, so
//                 the NPC web between them surfaces naturally). NON-character
//                 entries (locations, factions, world lore) are left alone.
//   authorsNote   REPURPOSED as the contact's ephemeral/emotional state. Not
//                 suppressed — the AN is a near-bottom injection slot and this is
//                 exactly the sort of recency-weighted content it is for. Note it
//                 lands at the user's configured depth (~3 paragraphs from the
//                 end), i.e. INSIDE recent chat history, not after it; that is why
//                 the next-message instruction uses storyText instead.
//   storyText     "[ NARRATIVE CONTEXT ]" header prepended; the next-message
//                 instruction APPENDED (true bottom, invisible in the document).
//
// COST: overriding the system prompt changes the top of context, so the story
// prefix cache is invalidated on entering and again on exiting. That cost is
// PER-SESSION, not per-turn — mid-chat the sys prompt/memory/lorebook are
// constant and only the tail grows, so the cache behaves normally from turn 2.
// Reasoned from how prefix caching works generally, NOT from an NAI-specific
// citation — if latency/cost looks wrong in testing, look here first.
//
// NO CONTEXT POISONING: story generation cannot run while a chat is open, so any
// generation firing while _aeCharChat.active IS a chat turn, which is what makes
// applying the override unconditionally safe. That guarantee rests on the
// mutual-exclusion guards (in startCharChat / startLiveWizardChat /
// resumeLiveWizardChatFromEntry / aeSetWizardMode) plus the fact that ending a
// chat strips every chat paragraph, returning the document byte-identical.
// The override is applied on the dryRun pass too, so NAI's context viewer shows
// the real chat context — that is the debugging window for this whole subsystem.
//
// NOT IN P1 (do not assume these exist): persona-register editor/generator (P3),
// Save/Summarize to a "CE Character Chats" lorebook category + its cached-id
// storage key (P4 — deliberately NOT declared here, a key with no reader is the
// dead code this project keeps cutting), activation modes (P4), decoration bubble
// polish (P5), bridge HUD panel (P6). endCharChat therefore ships DISCARD ONLY.
// ============================================================================
interface CharChatState {
    active: boolean;
    markerId: number | null;        // sectionId of the boundary marker paragraph
    setupIds: number[];             // engine-authored setup paragraphs (excluded from the transcript)
    contactId: string;              // the character being texted \u2014 the model speaks AS this one
    contactName: string;            // denormalized so context assembly needs no character load on the hot path
    povId: string;                  // [v2.29.0, REVERSES the old LOCKED DECISION] whose phone this is, AND now the second half of the saved-thread partition key (see charChatEntryId) — no longer label-only. '' = unset ("No POV" bucket, back-compat with pre-v2.29.0 threads).
    povName: string;
    paramSnapshot: any;             // generationParameters snapshot restored on end (persisted so a reload can still restore)
    startedAt: number;
    lastEmotion: string;            // [v2.21.0] last parsed Emotion: tag \u2014 diagnostic/bridge only; the tag itself stays in the document
}
var _aeCharChat: CharChatState = { active: false, markerId: null, setupIds: [], contactId: '', contactName: '', povId: '', povName: '', paramSnapshot: null, startedAt: 0, lastEmotion: '' };

const AE_CHARCHAT_RULE_MARKER = 'ae-charchat-marker';
const AE_CHARCHAT_RULE_POV    = 'ae-charchat-pov';      // POV (instruction) turns \u2014 warm amber
const AE_CHARCHAT_RULE_CONTACT= 'ae-charchat-contact';  // the character's replies \u2014 cool teal
const AE_CHARCHAT_MAX_TOKENS  = 120;                    // SMS-length DEFAULT pin — [v2.24.0] now only the fallback for a contact whose persona verbosity is 'auto'. See charChatMaxTokensFor().
// [v2.27.0] AE_CHARCHAT_THINK_TOKENS removed — CHARCHAT-THINK is gone (see the
// CE-INDEX v2.27.0 entry); its replacement, generateEphemeral(), is a fully separate
// call with its own budget and shares nothing with the reply's own max_tokens pin.
const AE_CHARCHAT_SUMMARY_MAX_TOKENS = 300;             // [v2.23.0] Matches AE_WIZARD_MAX_TOKENS's precedent for "a short prose passage" — used only transiently during previewSummarizeCharChat, never left pinned.
const AE_CHARCHAT_MARKER_TEXT = '\u2501\u2501 CHARACTER CHAT \u2501\u2501 The story above is reference material. Everything below this line is a text-message conversation and will be removed when the chat ends.';

// [v2.21.0 CHARCHAT] Global fallback texting rubric, used when a character has no
// chatPersona of their own (or has one that is disabled/empty). Adapted from the Chat
// Simulator's proven persona rubric. P3 adds the per-character editor + generator that
// can override this.
const CHARCHAT_DEFAULT_RUBRIC = [
    'Translate this character\u2019s personality into a realistic text-messaging style based on their age, traits, habits and tech familiarity. For example:',
    '* Digital native / casual: relaxed grammar, lowercase, slang.',
    '* Professional / adult: standard punctuation, clear syntax, concise phrasing.',
    '* Senior / tech-unsavvy: overly formal grammar, or excessive punctuation ("...").',
    'Never repeat the same emoticon consecutively. Avoid cliches. Only rarely include narrative prose or actions (e.g. *sighs*). Messages must be under 32 words \u2014 keep replies SMS-length.'
].join('\n');

async function saveCharChatState(): Promise<void> {
    try { await api.v1.storyStorage.set(STORAGE_CHARCHAT, JSON.stringify(_aeCharChat)); }
    catch (e) { api.v1.error('[AE:charchat] state save failed:', e); }
}

async function broadcastCharChatState(): Promise<void> {
    try {
        await broadcastToTM(EVT_CHARCHAT_STATE, {
            active: _aeCharChat.active, contactId: _aeCharChat.contactId, contactName: _aeCharChat.contactName,
            povId: _aeCharChat.povId, povName: _aeCharChat.povName, startedAt: _aeCharChat.startedAt
        });
    } catch (e) { api.v1.log('[AE:charchat] state broadcast failed (no bridge handler until P6):', e); }
}

// ── Decorations: POV (amber) vs contact (teal) ──────────────────────────
// Same shape as _wizliveRegisterDecorations: registered once with empty scopes, then
// refreshed from the live document on start, restore, and each turn end. Bubble polish
// is P5 — this is only enough to see the chat region and who said what.
async function _charchatRegisterDecorations(markerId: number): Promise<void> {
    await api.v1.editor.decorations.registerRules([
        { id: AE_CHARCHAT_RULE_MARKER,  type: 'node', match: '^', style: { backgroundColor: 'rgba(232, 160, 74, 0.22)', borderTop: '2px solid rgba(232, 160, 74, 0.85)', borderBottom: '1px solid rgba(232, 160, 74, 0.4)' }, scope: { sectionIds: [markerId] } },
        { id: AE_CHARCHAT_RULE_POV,     type: 'node', match: '^', style: { backgroundColor: 'rgba(232, 160, 74, 0.10)', borderLeft: '3px solid rgba(232, 160, 74, 0.60)' }, scope: { sectionIds: [] } },
        { id: AE_CHARCHAT_RULE_CONTACT, type: 'node', match: '^', style: { backgroundColor: 'rgba(64, 176, 166, 0.09)', borderLeft: '3px solid rgba(64, 176, 166, 0.55)' }, scope: { sectionIds: [] } }
    ]);
}

async function refreshCharChatDecorations(): Promise<void> {
    if (!_aeCharChat.active || _aeCharChat.markerId === null) return;
    let ccAll: any[] = [];
    try { ccAll = await api.v1.document.scan(); } catch (_eccScan) { return; }
    let povIds: number[] = [];
    let contactIds: number[] = [];
    let ccSeen = false;
    for (let ccIdx = 0; ccIdx < ccAll.length; ccIdx++) {
        let ccRow = ccAll[ccIdx];
        if (ccRow.sectionId === _aeCharChat.markerId) { ccSeen = true; continue; }
        if (!ccSeen) continue;
        if (_aeCharChat.setupIds.indexOf(ccRow.sectionId) >= 0) { contactIds.push(ccRow.sectionId); continue; }
        // [v2.24.0] was an inline copy of the source/origin classifier — now shared with
        // the transcript walk and the normaliser, which is the only way all three can be
        // guaranteed to agree about who said what.
        if (_charchatRowIsPov(ccRow.section)) povIds.push(ccRow.sectionId); else contactIds.push(ccRow.sectionId);
    }
    try {
        await api.v1.editor.decorations.updateRules([
            { id: AE_CHARCHAT_RULE_POV,     scope: { sectionIds: povIds } },
            { id: AE_CHARCHAT_RULE_CONTACT, scope: { sectionIds: contactIds } }
        ]);
    } catch (eccD) { api.v1.log('[AE:charchat] decoration refresh failed (cosmetic only):', eccD); }
}

// ── Context assembly ────────────────────────────────────────────

// ── [v2.24.0 CHARCHAT-PERSONA] Structured texting persona ───────────────
// Three closed axes plus a free-text escape hatch, per user: STRUCTURED OPTIONS,
// NOT GENERATED. The reason is placement, not taste — the compiled persona rides the
// next-message instruction (buildCharChatInstruction), a terse block at the TRUE
// bottom of context. A generated paragraph would drown that block and be re-paid on
// every single turn; three enum lookups cost one sentence.
// 'auto' on every axis is the deliberate default and means "say nothing, let
// CHARCHAT_DEFAULT_RUBRIC in the system prompt do its job" — that rubric already tells
// the model to derive a texting style from the character's own age/traits/tech
// familiarity, which is the right behaviour until an author disagrees with it. So an
// empty compiled clause is a CORRECT output, not an unconfigured one.
// Each option's `clause` is what actually reaches the model: short, imperative, and
// written to be concatenated rather than read in isolation.
interface CharChatOpt { id: string; label: string; clause: string; }

const CHARCHAT_STYLE_OPTS: CharChatOpt[] = [
    { id: 'auto',     label: 'Auto (from their profile)', clause: '' },
    { id: 'casual',   label: 'Digital native / casual',   clause: 'relaxed grammar, lowercase, slang and abbreviations' },
    { id: 'standard', label: 'Standard / adult',          clause: 'standard punctuation, clear syntax, concise phrasing' },
    { id: 'formal',   label: 'Formal / tech-unsavvy',     clause: 'overly formal grammar, full sentences, heavy ellipses' },
    { id: 'clipped',  label: 'Clipped / guarded',         clause: 'short and flat, minimal punctuation, gives little away' },
    { id: 'warm',     label: 'Warm / effusive',           clause: 'affectionate, generous with words, leans into feeling' },
    { id: 'florid',   label: 'Florid / theatrical',       clause: 'ornate word choice, dramatic phrasing, deliberate flourish' }
];

// `tokens` is the whole reason verbosity is not just another clause: telling the model
// "be brief" while handing it a 240-token cap is two instructions that disagree, and
// the cap always wins. This axis sets BOTH. tokens:0 means "use AE_CHARCHAT_MAX_TOKENS".
interface CharChatVerbOpt extends CharChatOpt { tokens: number; }
const CHARCHAT_VERBOSITY_OPTS: CharChatVerbOpt[] = [
    { id: 'auto',   label: 'Auto (SMS length)',        clause: '',                                        tokens: 0   },
    { id: 'terse',  label: 'Terse (a few words)',      clause: 'a few words, under 10 words',             tokens: 60  },
    { id: 'short',  label: 'Short (one sentence)',     clause: 'one sentence, under 20 words',            tokens: 90  },
    { id: 'normal', label: 'Normal (SMS length)',      clause: 'SMS length, under 32 words',              tokens: 120 },
    { id: 'chatty', label: 'Chatty (two or three)',    clause: 'two or three sentences, under 50 words',  tokens: 170 },
    { id: 'long',   label: 'Long (a short paragraph)', clause: 'up to a short paragraph, under 80 words', tokens: 240 }
];

const CHARCHAT_EMOJI_OPTS: CharChatOpt[] = [
    { id: 'auto',  label: 'Auto (from their profile)', clause: '' },
    { id: 'none',  label: 'Never',                     clause: 'never use emoji or kaomoji' },
    { id: 'rare',  label: 'Rare',                      clause: 'emoji only rarely, and never the same one twice in a row' },
    { id: 'some',  label: 'Some',                      clause: 'occasional emoji, never the same one twice in a row' },
    { id: 'heavy', label: 'Heavy',                     clause: 'expressive emoji and kaomoji throughout, but never repeat one consecutively' }
];

function _charchatOpt(opts: CharChatOpt[], id: string): CharChatOpt {
    let ccWant = id || 'auto';
    for (let ccI = 0; ccI < opts.length; ccI++) { if (opts[ccI].id === ccWant) return opts[ccI]; }
    return opts[0];
}

// The compiled persona as ONE line for the instruction block. Empty when the persona is
// absent, disabled, or fully 'auto' — see the 'auto' note above; that is the intended
// resting state.
function buildCharChatPersonaClause(char: CharacterRecord): string {
    let cp = char.chatPersona;
    if (!cp || cp.enabled === false) return '';
    let ccBits: string[] = [];
    let ccSt = _charchatOpt(CHARCHAT_STYLE_OPTS, cp.style || 'auto').clause;
    if (ccSt) ccBits.push('Style: ' + ccSt + '.');
    let ccVb = _charchatOpt(CHARCHAT_VERBOSITY_OPTS, cp.verbosity || 'auto').clause;
    if (ccVb) ccBits.push('Length: ' + ccVb + '.');
    let ccEm = _charchatOpt(CHARCHAT_EMOJI_OPTS, cp.emoji || 'auto').clause;
    if (ccEm) ccBits.push('Emoji: ' + ccEm + '.');
    if (cp.notes && cp.notes.trim()) ccBits.push(cp.notes.trim().replace(/\s+/g, ' '));
    // [LEGACY v2.21.0] the old freeform shape, folded in as trailing notes so a
    // character authored before v2.24.0 does not silently lose their register.
    let ccLeg: string[] = [];
    if (cp.register && cp.register.trim()) ccLeg.push(cp.register.trim());
    if (cp.voice && cp.voice.trim())       ccLeg.push(cp.voice.trim());
    if (cp.content && cp.content.trim())   ccLeg.push(cp.content.trim());
    if (ccLeg.length > 0) ccBits.push(ccLeg.join(' ').replace(/\s+/g, ' '));
    return ccBits.join(' ');
}

// The output cap for THIS contact. Verbosity owns it entirely (see
// CHARCHAT_VERBOSITY_OPTS's `tokens` note). [v2.27.0] No longer tops up for
// "thinking" — CHARCHAT-THINK's inline reasoning line shared this budget with the
// reply itself; its replacement, generateEphemeral(), is a fully separate call with
// its own budget, so there is nothing left for this function to add for it.
function charChatMaxTokensFor(char: CharacterRecord | null, cfg: GlobalConfig | null): number {
    let ccBase = AE_CHARCHAT_MAX_TOKENS;
    let ccCp = char ? char.chatPersona : null;
    if (ccCp && ccCp.enabled !== false) {
        let ccV = _charchatOpt(CHARCHAT_VERBOSITY_OPTS, ccCp.verbosity || 'auto') as CharChatVerbOpt;
        if (ccV && ccV.tokens > 0) ccBase = ccV.tokens;
    }
    return ccBase;
}

// THE steering surface. Everything the model needs to be this character, in one
// contiguous top-of-context block: framing, then "you are the following character",
// then that character's identity (their real lorebook text, folded in — which is why
// the entry itself is deactivated), their dynamic layer, and their texting register.
// Adjacency is guaranteed here in a way lorebook insertion order could never promise.
async function buildCharChatSystemPrompt(contact: CharacterRecord, cfg: GlobalConfig): Promise<string> {
    let ccOut: string[] = [];
    ccOut.push('SMARTPHONE MESSAGING APP. You are writing one side of a live text-message conversation.');
    ccOut.push('Below the narrative context you will find a chat transcript. Write ONLY the next single message, as the character defined below. Do not narrate the story, do not write the other person\u2019s messages, and do not continue the prose above the chat marker \u2014 that story text is reference material for what these two know and where they stand, nothing more.');
    // [v2.24.0 CHARCHAT-PERSONA] The GLOBAL rubric lives here and only here. The
    // character's OWN persona (style/verbosity/emoji) no longer rides the system
    // prompt — it compiles to one line on the next-message instruction instead, per
    // user, where it is most present. Two useful side effects of the split: the
    // system prompt stays identical across every contact in a story (one less thing
    // invalidating the prefix cache when switching chats), and a persona edit takes
    // effect on the very next turn rather than needing a chat restart.
    ccOut.push(CHARCHAT_DEFAULT_RUBRIC);
    ccOut.push('You are the following character:');

    let ccIdentity = '';
    try { ccIdentity = (await buildLorebookContent(contact)).trim(); }
    catch (eccI) { api.v1.error('[AE:charchat] identity build failed:', eccI); }
    if (ccIdentity) ccOut.push(ccIdentity);
    else ccOut.push(contact.name + (contact.briefDescription ? ('\n' + contact.briefDescription) : ''));

    let ccDyn = '';
    try { ccDyn = (await buildCharDynamicBlock(contact, cfg)).trim(); }
    catch (eccD2) { api.v1.error('[AE:charchat] dynamic block failed:', eccD2); }
    if (ccDyn) ccOut.push(ccDyn);

    return ccOut.join('\n\n');
}

// The next-message instruction. Appended to the END of storyText.content, which puts it
// at true bottom of context and keeps it invisible in the document.
// [OPEN — test this first] Whether appending to storyText.content disturbs where the
// model continues from is the single biggest unknown in this design. If it misbehaves,
// the fallback is to carry this in the Author's Note and accept AN's fixed depth.
// [v2.24.0] This block grew from one line into the chat's whole steering tail, in
// deliberate priority order — task, then register, then state, then output protocol.
// Everything that used to be scattered (persona in the system prompt, ephemeral in the
// Author's Note) now lands here, because "most present" is a position, not a volume:
// the bottom of context is the only place we control precisely.
function buildCharChatInstruction(contact: CharacterRecord, povName: string, cfg: GlobalConfig | null): string {
    let ccName = _aeCharChat.contactName || contact.name;
    let ccAddr = povName ? (', addressed to ' + povName) : '';
    let ccOut: string[] = [];

    // [v2.22.0/v2.24.0] The name header is never requested and never trusted — it is
    // applied programmatically (charChatCleanReply on the way in, then
    // _charchatNormalizeDocument as a standing pass). Saying so explicitly is cheap and
    // stops the model spending its 120 tokens re-deriving a header we throw away.
    ccOut.push('[ Instruction: Write the next single message from ' + ccName + ccAddr + '. '
             + 'If the previous message also belongs to ' + ccName + ' \u2014 complement it rather than repeating it. '
             + 'Write ONLY the message body: the name header is applied automatically, so never write one yourself. ]');

    let ccPersona = buildCharChatPersonaClause(contact);
    if (ccPersona) ccOut.push('[ ' + ccName + '\u2019s texting style: ' + ccPersona + ' ]');

    // [v2.24.0, per user] The ephemeral line used to ride the Author's Note. The AN
    // lands at the user's configured depth INSIDE recent history and the hook exposes no
    // depth control, so a "right now" line was always some arbitrary distance from the
    // point of generation. Here it sits at the true bottom — most present, which is
    // exactly what a right-now line wants to be. The AN is deactivated during chat as a
    // result; see runCharChatContextOverride.
    let ccEph = (contact.ephemeral && contact.ephemeral.compressedLine) ? String(contact.ephemeral.compressedLine).trim() : '';
    if (ccEph) ccOut.push('[ ' + ccName + ' right now: ' + ccEph + ' ]');

    // [v2.27.0] CHARCHAT-THINK's inline "[Thinking: ...]" request is GONE — the model
    // no longer generates or reasons through a private line as part of this same
    // completion. Freshness now comes from the ccEph block above instead: when
    // GlobalConfig.charChatFreshThoughts is on, onGenerationEnd's CHARCHAT branch
    // calls generateEphemeral() for this contact right after each reply completes
    // ([v2.29.0] moved from onBeforeContextBuild — see that hook's CHARCHAT branch
    // for why), so ccEph is never more than one turn stale by the time the FOLLOWING
    // reply is built. See the CE-INDEX v2.27.0/v2.29.0 entries.
    // [v2.25.0, per user] Ask for one of the 24 canonical words directly rather than an
    // unconstrained "<single word>" — resolveEmotion() still normalises whatever comes
    // back (a synonym, a near-miss), so this is encouragement, not enforcement. Reuses
    // ALL_EMOTIONS_LIST rather than a second hand-typed copy of the 24-word list.
    ccOut.push('[ End your message with a new line: Emotion: <one word from this list \u2014 ' + ALL_EMOTIONS_LIST + '> ]');
    return ccOut.join('\n');
}

// ── [v2.24.0 CHARCHAT-TURNS] Canonical turn formatting ──────────────────
// THE replacement for the v2.22.0 POV scaffold, per user: instead of appending a
// half-written "{user: " into the document in ADVANCE and depending on the user to
// finish it (including a closing brace they were never obliged to type), the user
// writes whatever they like and we rewrite it into canonical shape AFTERWARDS.
//   "{Hi, Sara}"  ->  "{user: Hi, Sara}"
//   "Hi, Sara"    ->  "{user: Hi, Sara}"
//   "{Hi, Sara"   ->  "{user: Hi, Sara}"     (unclosed brace closed for them)
//   "Hi, Paul"    ->  "Sara:\nHi, Paul"        (contact side)
// A header the MODEL wrote itself is stripped and re-applied rather than trusted, so a
// WRONG one (the contact's name on the POV's line, or vice versa) can never survive.
// As the format stabilises in the transcript the model will tend to produce the right
// one unprompted, per user — and this pass costs nothing on the turns where it does.
// This SUPERSEDES the v2.23.0 dangling-scaffold context strip, which fixed the same
// root cause (an unclosed "{user: " reaching the model, whose most natural
// continuation is to finish user's line rather than reply as the contact) by deleting
// the scaffold from context. That was a patch on a self-inflicted wound; there is no
// scaffold now, and every POV turn is re-emitted WITH its closing brace whether the
// user typed one or not, so a dangling "{" cannot reach the model from any source.

const CHARCHAT_EMOTION_PREFIX = '  Emotion: ';   // [v2.24.0, per user] two leading spaces. The one authored string in this subsystem whose exact whitespace is load-bearing — user's emotion-image widget matches on it.

// One shared regex builder rather than three drifting copies (the v2.23.0 file had the
// emotion pattern written out in three places, and _charchatBareBody's copy silently
// stopped matching the moment the prefix gained leading spaces).
function _charchatEmotionRx(): RegExp { return /[\n\r\s]*Emotion:[ \t]*([^\n\r]+?)[ \t]*$/i; }

// Role classification, in ONE place. Previously duplicated verbatim in
// refreshCharChatDecorations and collectCharChatTranscript. Role is NEVER inferred from
// text — same guarantee WIZLIVE gives, and the reason the whole POV-optional design
// works at all.
function _charchatRowIsPov(section: any): boolean {
    if (section.source === 'instruction') return true;
    let ccOrg = section.origin || [];
    if (ccOrg.length === 0) return false;
    let ccAllTyped = true;
    let ccAnyUser = false;
    for (let ccO of ccOrg) {
        if (ccO.data === 'user') ccAnyUser = true;
        if (ccO.data !== 'user' && ccO.data !== 'edit') { ccAllTyped = false; break; }
    }
    return ccAllTyped && ccAnyUser;
}

// [BUGFIX v2.25.0 CHARCHAT-MERGE] Detect a section whose origin metadata crosses from
// user-typed (user/edit) to AI-generated (ai/prompt) data. This is the signature of NAI's
// native Send continuing a completion DIRECTLY INTO the same paragraph the user just
// typed into, because the cursor had no trailing paragraph break — rather than starting a
// fresh section for the reply. _charchatRowIsPov trusts a 'instruction' source for the
// WHOLE section regardless of what got appended to it afterward, so a merged section like
// this was being canonicalised as one giant POV turn: the user's own text PLUS the start
// of the contact's reply, wrapped together in POV braces. That is the confirmed source of
// both the "double brace" and "contact's header bleeding into the POV body" reports.
// Returns the character offset into section.text where the AI-authored portion begins,
// or -1 if the origin is homogeneous (nothing to split). Sorted defensively; origin spans
// are not documented as guaranteed-ordered.
function _charchatMergeSplitIdx(section: any): number {
    let ccOrg = (section && section.origin) || [];
    if (ccOrg.length < 2) return -1;
    let ccSorted = ccOrg.slice().sort(function(a: any, b: any) { return a.position - b.position; });
    let ccSawUser = false;
    for (let ccO of ccSorted) {
        if (ccO.data === 'user' || ccO.data === 'edit') { ccSawUser = true; continue; }
        if (ccSawUser && (ccO.data === 'ai' || ccO.data === 'prompt')) return ccO.position;
    }
    return -1;
}

// Strip a leading "Name:" header — whoever wrote it. Every name we know about is tried,
// so a header the model got WRONG is removed too rather than kept and doubled up.
function _charchatStripHeader(body: string, names: string[]): string {
    let ccT = (body || '').replace(/^\s+/, '');
    for (let ccPass = 0; ccPass < 2; ccPass++) {   // 2 passes: "Sara:\nSara: hi" happens
        let ccHit = false;
        for (let ccI = 0; ccI < names.length; ccI++) {
            if (!names[ccI]) continue;
            // [\s*] not [\r?\n?] after the colon, and the difference is a REAL bug found
            // by test, not a style choice: _charchatScanTurns joins a grouped turn with
            // '\n', so a reply NAI split as ["Sara:", "", "Hi, Paul"] arrives here as
            // "Sara:\n\nHi, Paul". Consuming at most ONE newline left the blank line in
            // place — which is precisely the "the character response adds a second
            // [newline]" report this pass is meant to fix.
            let ccRx = new RegExp('^\\*{0,2}' + _charchatEscapeRx(names[ccI]) + '\\*{0,2}[ \\t]*[:\uff1a]\\s*', 'i');
            if (ccRx.test(ccT)) { ccT = ccT.replace(ccRx, ''); ccHit = true; break; }
        }
        if (!ccHit) break;
    }
    return ccT;
}

// Unwrap our own brace wrapper, tolerating BOTH the unclosed case and the never-opened
// case — per user, the user was never obliged to type either one.
function _charchatUnwrapPov(text: string): string {
    let ccS = (text || '').trim();
    if (ccS.charAt(0) === '{') ccS = ccS.substring(1);
    if (ccS.length > 0 && ccS.charAt(ccS.length - 1) === '}') ccS = ccS.substring(0, ccS.length - 1);
    return ccS.trim();
}

// CANONICAL POV TURN. '' means "there is no turn here" (an empty brace block, a stray
// blank paragraph) — callers drop it rather than emitting an empty one.
// [BUGFIX v2.27.0 CHARCHAT-BRACE-REVERT, per user] REVERTS v2.26.0 CHARCHAT-BRACE.
// v2.26.0 theorised NAI's own editor draws the visible bracket and stopped this
// function from ALSO wrapping the text in literal '{'/'}'. User's direct test
// falsifies that: a typed "{Hi!}" still came back doubled as "{{POVname: Hi!}}", and
// a bare "Hi!" came back as bodyless "{POVname}" — not a render-only bracket at all.
// Removing our own wrap also broke turn recognition outright: with no literal brace,
// a POV paragraph had nothing marking it as a fresh instruction turn, so it read as a
// continuation (a bare newline) of the previous contact turn instead of a new one.
// Output is "{Name: body}" again, matching every version before v2.26.0.
// _charchatUnwrapPov still tolerantly STRIPS a leading/trailing brace the user or
// model wrote — that part was never the bug and stays. NOTE: the real double-brace
// root cause was already fixed in v2.25.0 (_charchatSplitMergedSections, physical
// section splitting) — this revert does not touch or undo that fix.
function _charchatCanonPov(text: string, povName: string, contactName: string): string {
    let ccBody = _charchatStripHeader(_charchatUnwrapPov(text), [povName, contactName]).replace(/\s+$/, '');
    if (!ccBody) return '';
    return '{' + (povName ? (povName + ': ' + ccBody) : ccBody) + '}';
}

// CANONICAL CONTACT TURN. The Emotion tag is split off first and re-attached last, so
// the header strip can never mistake it for body and a body strip can never eat it.
function _charchatCanonContact(text: string, contactName: string, povName: string): string {
    let ccT = (text || '');
    let ccEmotion = '';
    let ccCut = ccT.match(_charchatEmotionRx());
    if (ccCut && ccCut[1] && ccCut.index !== undefined) {
        let ccE = ccCut[1].trim();
        // [v2.25.0, per user] Canonicalise to the 24-state list rather than keeping
        // whatever synonym the model wrote — resolveEmotion() is the same normaliser the
        // image-generation pipeline already uses (EMOTION_MAP), so "annoyed" becomes
        // "irritated" etc. instead of silently missing user's emotion-image widget, which
        // keys off one of the 24 canonical words.
        if (ccE.length > 0 && ccE.length <= 40) { ccEmotion = resolveEmotion(ccE); ccT = ccT.substring(0, ccCut.index); }
    }
    let ccBody = _charchatStripHeader(ccT, [contactName, povName]).replace(/\s+$/, '');
    if (!ccBody && !ccEmotion) return '';
    // [v2.25.0, per user] Header and body share a line now ("Sara: message") \u2014 a
    // real text message doesn't put the sender's name on its own line. Emotion keeps its
    // own line below (unchanged, per user): CHARCHAT_EMOTION_PREFIX's leading newline is
    // still what user's emotion-image widget scans for.
    let ccOut = (contactName || 'They') + ': ' + (ccBody || '\u2026');
    if (ccEmotion) ccOut += '\n' + CHARCHAT_EMOTION_PREFIX + ccEmotion;
    return ccOut;
}

// A logical turn = a run of CONSECUTIVE same-role paragraphs. Grouping before
// normalising is not an optimisation, it is correctness: NAI splits a returned reply
// into sections however it likes, and normalising each section in isolation would stamp
// a "Sara:" header onto every line of a three-paragraph reply. Grouping also silently
// absorbs the stray blank paragraph a trailing newline leaves behind — the "the reply
// adds a second newline" report.
async function _charchatScanTurns(): Promise<{ turns: { isPov: boolean; ids: number[]; texts: string[] }[]; ids: number[] }> {
    let ccTurns: { isPov: boolean; ids: number[]; texts: string[] }[] = [];
    let ccAllIds: number[] = [];
    if (_aeCharChat.markerId === null) return { turns: ccTurns, ids: ccAllIds };
    let ccAll: any[] = [];
    try { ccAll = await api.v1.document.scan(); }
    catch (eTs) { api.v1.error('[AE:charchat] turn scan failed:', eTs); return { turns: ccTurns, ids: ccAllIds }; }
    let ccSeen = false;
    for (let ccR of ccAll) {
        if (ccR.sectionId === _aeCharChat.markerId) { ccSeen = true; ccAllIds.push(ccR.sectionId); continue; }
        if (!ccSeen) continue;
        ccAllIds.push(ccR.sectionId);
        if (_aeCharChat.setupIds.indexOf(ccR.sectionId) >= 0) continue;

        // [BUGFIX v2.25.0 CHARCHAT-MERGE] READ-ONLY safety net. The real fix physically
        // splits a merged section in _charchatSplitMergedSections (write-pass only, since
        // this function must never mutate the document \u2014 it also runs on dryRun). If
        // that split hasn't run yet (or failed), don't let a merged section inherit ONE
        // role from a stale 'instruction' source: cut it at the same origin boundary and
        // feed the two halves to their correct turns instead. NOTE: if this ever fires
        // during the WRITE pass (i.e. the physical split above failed), both halves still
        // carry the SAME sectionId into two different turns, and _charchatNormalizeDocument
        // schedules one updateParagraphs write per turn against that id \u2014 the second
        // write wins, so the OTHER half's text is silently lost for this cycle. Accepted:
        // strictly better than the pre-v2.25.0 behaviour (which corrupted BOTH halves
        // every time), and the physical split succeeding is the common case this guards.
        let ccFullText = ccR.section.text || '';
        let ccSplitIdx = _charchatMergeSplitIdx(ccR.section);
        if (ccSplitIdx > 0 && ccSplitIdx < ccFullText.length) {
            let ccHead = ccFullText.substring(0, ccSplitIdx);
            let ccTail = ccFullText.substring(ccSplitIdx);
            let ccLastH = (ccTurns.length > 0) ? ccTurns[ccTurns.length - 1] : null;
            if (ccLastH && ccLastH.isPov) { ccLastH.ids.push(ccR.sectionId); ccLastH.texts.push(ccHead); }
            else ccTurns.push({ isPov: true, ids: [ccR.sectionId], texts: [ccHead] });
            ccTurns.push({ isPov: false, ids: [ccR.sectionId], texts: [ccTail] });
            continue;
        }

        let ccIsPov = _charchatRowIsPov(ccR.section);
        let ccLast = (ccTurns.length > 0) ? ccTurns[ccTurns.length - 1] : null;
        if (ccLast && ccLast.isPov === ccIsPov) { ccLast.ids.push(ccR.sectionId); ccLast.texts.push(ccR.section.text || ''); }
        else ccTurns.push({ isPov: ccIsPov, ids: [ccR.sectionId], texts: [ccR.section.text || ''] });
    }
    return { turns: ccTurns, ids: ccAllIds };
}

// [BUGFIX v2.25.0 CHARCHAT-MERGE] WRITE-PASS ONLY (called from _charchatNormalizeDocument,
// onGenerationEnd \u2014 never from the read-only side, which must not mutate the document).
// Physically splits any section _charchatMergeSplitIdx flags into two real paragraphs: the
// user-typed head keeps the original sectionId and source (still a legitimate, just
// shorter, POV paragraph), and the AI-authored tail becomes a fresh paragraph via
// insertParagraphAfter with no source override \u2014 api.v1.document.append()'s own contract
// says script-written text gets 'script' origin, which _charchatRowIsPov correctly reads
// as NOT a POV turn (script data isn't 'user'/'edit'), same as any other contact reply.
// Runs BEFORE _charchatScanTurns in the write pass so grouping/canonicalisation never has
// to see a merged section at all \u2014 the in-memory fallback in _charchatScanTurns above is
// strictly a safety net for if this fails.
async function _charchatSplitMergedSections(): Promise<void> {
    if (_aeCharChat.markerId === null) return;
    let ccAll: any[] = [];
    try { ccAll = await api.v1.document.scan(); }
    catch (eSc) { api.v1.error('[AE:charchat] merge-split scan failed:', eSc); return; }
    let ccSeen = false;
    for (let ccR of ccAll) {
        if (ccR.sectionId === _aeCharChat.markerId) { ccSeen = true; continue; }
        if (!ccSeen) continue;
        if (_aeCharChat.setupIds.indexOf(ccR.sectionId) >= 0) continue;
        let ccFull = ccR.section.text || '';
        let ccIdx = _charchatMergeSplitIdx(ccR.section);
        if (ccIdx <= 0 || ccIdx >= ccFull.length) continue;
        let ccHead = ccFull.substring(0, ccIdx);
        let ccTail = ccFull.substring(ccIdx);
        try {
            await api.v1.document.insertParagraphAfter(ccR.sectionId, { text: ccTail });
            await api.v1.document.updateParagraph(ccR.sectionId, { text: ccHead });
        } catch (eSp) { api.v1.error('[AE:charchat] merge-split failed for section ' + ccR.sectionId + ':', eSp); }
    }
}

function _charchatCanonTurn(turn: { isPov: boolean; ids: number[]; texts: string[] }, povName: string, contactName: string): string {
    let ccJoined = turn.texts.join('\n');
    return turn.isPov ? _charchatCanonPov(ccJoined, povName, contactName)
                      : _charchatCanonContact(ccJoined, contactName, povName);
}

// WRITE PASS — onGenerationEnd ONLY, per user's "maybe we handle it after generation?".
// Deliberately NOT called from onBeforeContextBuild: mutating the document mid-context-
// build would race the very generation it is building for, and that hook also fires on
// dryRun, so a costing pass would rewrite the user's paragraphs. The read-only twin
// (_charchatCanonicalChatText) keeps the MODEL's view canonical every turn; this keeps
// the DOCUMENT's view canonical one beat later, which is all the document needs.
async function _charchatNormalizeDocument(): Promise<void> {
    if (!_aeCharChat.active || _aeCharChat.markerId === null) return;
    // [BUGFIX v2.25.0 CHARCHAT-MERGE] Fix any section NAI glued a completion onto BEFORE
    // grouping turns \u2014 see _charchatSplitMergedSections. Failure here is non-fatal
    // (logged, falls through to _charchatScanTurns's own in-memory fallback).
    try { await _charchatSplitMergedSections(); }
    catch (eSpAll) { api.v1.log('[AE:charchat] merge-split pass failed (continuing with unsplit sections):', eSpAll); }
    let ccScan = await _charchatScanTurns();
    let ccUpdates: { sectionId: number; section: any }[] = [];
    let ccRemove: number[] = [];
    for (let ccT of ccScan.turns) {
        let ccCanon = _charchatCanonTurn(ccT, _aeCharChat.povName, _aeCharChat.contactName);
        if (!ccCanon) { for (let ccX of ccT.ids) ccRemove.push(ccX); continue; }
        let ccLines = ccCanon.split('\n');
        // Fit the canonical lines back onto the sections this turn already occupies:
        // rewrite in place where they line up, fold any overflow onto the last written
        // section, drop sections the canonical form no longer needs. This deliberately
        // does NOT force one-paragraph-per-turn — NAI owns how a returned reply is split
        // into sections and fighting that is a losing game; we only fix the text.
        let ccKeep = Math.min(ccLines.length, ccT.ids.length);
        for (let ccI = 0; ccI < ccKeep; ccI++) {
            let ccText = (ccI === ccKeep - 1 && ccLines.length > ccKeep) ? ccLines.slice(ccI).join('\n') : ccLines[ccI];
            if (ccText !== ccT.texts[ccI]) ccUpdates.push({ sectionId: ccT.ids[ccI], section: { text: ccText } });
        }
        for (let ccJ = ccKeep; ccJ < ccT.ids.length; ccJ++) ccRemove.push(ccT.ids[ccJ]);
    }
    if (ccUpdates.length > 0) {
        try { await api.v1.document.updateParagraphs(ccUpdates); }
        catch (eNu) { api.v1.log('[AE:charchat] turn normalisation rewrite failed (cosmetic only):', eNu); }
    }
    if (ccRemove.length > 0) {
        try { await api.v1.document.removeParagraphs(ccRemove); }
        catch (eNr) { api.v1.log('[AE:charchat] turn normalisation cleanup failed (cosmetic only):', eNr); }
    }
}

// READ-ONLY twin of _charchatNormalizeDocument, for context assembly. This is what makes
// the model's view canonical on the SAME turn the user types it — the write pass only
// runs after a generation, so without this the newest turn would reach the model raw
// (unclosed brace, no header, or a header on the wrong side), which is precisely the
// class of bug v2.23.0 chased.
async function _charchatCanonicalChatText(): Promise<string> {
    let ccScan = await _charchatScanTurns();
    let ccOut: string[] = [];
    for (let ccT of ccScan.turns) {
        let ccC = _charchatCanonTurn(ccT, _aeCharChat.povName, _aeCharChat.contactName);
        if (ccC) ccOut.push(ccC);
    }
    return ccOut.join('\n\n');
}

// The whole steering thesis, in one function. Called from onBeforeContextBuild while a
// chat is active — including on dryRun, so the context viewer shows the real thing.
async function runCharChatContextOverride(params: any): Promise<any> {
    let ccResult: any = {};
    try {
        let ccCfg = await loadConfig();
        let ccContact = await loadCharacter(_aeCharChat.contactId);
        if (!ccContact) {
            api.v1.error('[AE:charchat] contact ' + _aeCharChat.contactId + ' could not be loaded \u2014 leaving context untouched this turn.');
            return undefined;
        }

        // [v2.29.0 CHARCHAT-FRESH-THOUGHTS-TIMING, per user's gen log] The pre-reply
        // ephemeral refresh that lived HERE in v2.27.0/v2.28.0 is GONE, moved to the
        // CHARCHAT branch of onGenerationEnd. ROOT CAUSE, confirmed directly by the
        // error text in the user's gen log ("A generation is already in progress"),
        // not the v2.28.0 re-entrancy theory: onBeforeContextBuild fires WHILE this
        // turn's own reply generation is already in progress (NAI's own internal
        // state, separate from this file's ae_genInFlight), so ANY nested
        // api.v1.generate() call made from in here is rejected outright — every
        // single time, hence "static," not merely stale. v2.28.0's _diagProbeActive
        // guard was still correct and necessary (it stopped the recursion the nested
        // call's re-entrant hook-firing would otherwise have caused) — it just wasn't
        // sufficient, because the very first nested call already failed before
        // recursion was ever the active problem. See onGenerationEnd for where this
        // now lives and why that timing is safe.

        // 1. TOP OF CONTEXT — we own it.
        ccResult.systemPrompt = { active: true, content: await buildCharChatSystemPrompt(ccContact, ccCfg) };

        // 2. LOREBOOK — deactivate every character-linked entry. Participants' entries
        //    are already folded into the system prompt (duplication guard); everyone
        //    else's is the persona-bleed guard. Enumerated from the character index,
        //    NOT from params.lorebookEntries: that parameter carries current state for
        //    entries the framework already knows about this build, which is not a
        //    guaranteed enumeration of every entry. Non-character lorebook entries are
        //    deliberately untouched — world lore is still true during a text message.
        let ccSuppress: any[] = [];
        try {
            let ccIdx = await loadIndex();
            for (let ccMeta of ccIdx.filter(Boolean)) {
                let ccChar = await loadCharacter(ccMeta.id);
                if (ccChar && ccChar.lorebookEntryId) ccSuppress.push([ccChar.lorebookEntryId, { active: false }]);
            }
        } catch (eccL) { api.v1.error('[AE:charchat] lorebook suppression failed \u2014 persona bleed possible this turn:', eccL); }
        if (ccSuppress.length > 0) ccResult.lorebookEntries = ccSuppress;

        // 3. AUTHOR'S NOTE — DEACTIVATED. [v2.24.0, per user] It used to carry the
        //    contact's ephemeral line. That line now rides the next-message instruction
        //    at the true bottom of context instead (see buildCharChatInstruction): the
        //    AN lands at the user's configured depth INSIDE recent history and the hook
        //    exposes no depth control, so it could never be made "most present", which
        //    is the entire job of a right-now line. Deactivating rather than leaving it
        //    alone is deliberate — the story's own AN is about the STORY, and a text
        //    message is not a story turn (same reasoning as WIZLIVE's AN deactivation).

        // 4. STORY TEXT — narrative header at the top, the CANONICAL chat region in the
        // middle, next-message instruction at the true bottom.
        // [v2.24.0 CHARCHAT-TURNS, supersedes the v2.23.0 dangling-scaffold strip] The
        // chat region is rebuilt from the document rather than passed through: every POV
        // turn re-emitted with its closing brace, every reply with a correct header, no
        // blank paragraphs. That makes v2.23.0's targeted "strip an untouched scaffold"
        // hack unnecessary — it existed only because we ourselves put an unclosed
        // "{user: " in the document, and nothing does that anymore.
        // GUARD, and the reason this is safe: only rebuild when the marker actually
        // SURVIVES in params.storyText.content. That content is already trimmed to the
        // context budget; the document scan is not. If the marker is still present then
        // the whole chat region is present (it is the tail), so a rebuild is length-
        // neutral. If it has been trimmed away, the chat has outgrown the budget and
        // storyText is left exactly as NAI trimmed it.
        // Also deliberate: the setup/greeting paragraph is dropped on rebuild. It is
        // instructions to the USER ("start a paragraph with a curly brace"), which the
        // model has no business reading and previously did, every single turn.
        let ccStory = (params && params.storyText && params.storyText.content) ? params.storyText.content : '';
        let ccMarkIdx = ccStory.indexOf(AE_CHARCHAT_MARKER_TEXT);
        if (ccMarkIdx >= 0) {
            let ccCanonChat = '';
            try { ccCanonChat = await _charchatCanonicalChatText(); }
            catch (eCc) { api.v1.error('[AE:charchat] canonical chat rebuild failed \u2014 passing the raw region through:', eCc); ccCanonChat = ''; ccMarkIdx = -1; }
            if (ccMarkIdx >= 0) {
                ccStory = ccStory.substring(0, ccMarkIdx) + AE_CHARCHAT_MARKER_TEXT
                        + (ccCanonChat ? ('\n\n' + ccCanonChat) : '');
            }
        }
        ccStory = ccStory.replace(/\s+$/, '');
        let ccBody = '[ NARRATIVE CONTEXT ]\n' + ccStory;
        ccBody += '\n\n' + buildCharChatInstruction(ccContact, _aeCharChat.povName, ccCfg);
        ccResult.storyText = { active: true, content: ccBody };

    } catch (eccAll) {
        api.v1.error('[AE:charchat] context override failed \u2014 falling back to untouched context:', eccAll);
        return undefined;
    }
    return ccResult;
}

// ── Post-hoc reply cleanup ────────────────────────────────────────
// Native generation exposes no per-turn stop sequences (generationParameters.get()
// has no `stop` field — that is the api.v1.generate path only), so instruct/paragraph
// turn alternation plus this regex net is the whole anti-impersonation defence.
// Adapted from the Chat Simulator's truncation pass.
function _charchatEscapeRx(str: string): string {
    return (str || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

// [DELIBERATE DEVIATION from the handoff — flagged, reverse if wrong] The handoff says
// the Emotion tag is "parsed + stripped". We parse it but DO NOT strip it. Stripping is
// what the Chat Simulator does because it renders its own bubbles and the raw text never
// reaches the document. Here the reply IS the document, and the entire stated reason for
// keeping the emotion sidecar is that user's separate emotion-image widget script reads
// `Emotion: <word>` off document text with zero changes. Strip it and that script has
// nothing left to read — the two requirements are mutually exclusive as written, and the
// synergy is the one worth keeping. Parsed value is mirrored to _aeCharChat.lastEmotion
// for diagnostics/bridge use; the tag stays in the text.
function charChatParseEmotion(raw: string): string {
    let ccM = (raw || '').match(_charchatEmotionRx());
    if (ccM && ccM[1]) {
        let ccE = ccM[1].trim();
        // [v2.25.0, per user] Canonicalise to the 24-state list via the same
        // resolveEmotion() the image pipeline already uses (EMOTION_MAP) — a synonym the
        // model writes instead (e.g. "annoyed") would otherwise reach the document
        // verbatim and silently miss user's emotion-image widget, which keys off one of
        // the 24 canonical words. resolveEmotion never returns '' (unrecognised words
        // fall back to 'neutral'), so the <=40 length guard below still governs whether
        // an emotion was found at all; normalisation only applies to guard-passing matches.
        if (ccE.length > 0 && ccE.length <= 40) return resolveEmotion(ccE);   // <=40 guard against false positives
    }
    return '';
}

// [v2.27.0] _charchatThoughtRx / charChatParseThought DELETED — CHARCHAT-THINK's
// inline "[Thinking: ...]" line is gone, so there is nothing left to strip or parse
// here (zero remaining callers verified before removal). Thoughts now come from
// generateEphemeral() instead — a real, persisted record (char.ephemeral /
// ephemeralHistory), not a line scraped out of the reply text. See the CE-INDEX
// v2.27.0 entry.

function charChatCleanReply(raw: string, contactName: string, povName: string): string {
    let ccT = (raw || '');
    if (!ccT.trim()) return ccT;

    // Split the Emotion tag off, clean the message body only, then re-attach it. Doing
    // it this way means an impersonation truncation can never eat the tag, and the tag
    // can never be mistaken for message content by the name-prefix strip.
    let ccEmotion = charChatParseEmotion(ccT);
    if (ccEmotion) {
        let ccCut = ccT.match(_charchatEmotionRx());
        if (ccCut && ccCut.index !== undefined) ccT = ccT.substring(0, ccCut.index);
    }

    // Drop a self-prefix the model added on its own — defensive only, since the
    // instruction now explicitly tells it not to write one. We prepend our OWN canonical
    // header below regardless, so a model-written one would otherwise double up.
    // [v2.24.0] Shared with the document normaliser (_charchatStripHeader) rather than
    // a second private copy of the same regex, and it now tries the POV's name too:
    // a header on the WRONG side ("user:" opening Sara's reply) was previously kept and
    // then had "Sara:" stamped on top of it.
    ccT = _charchatStripHeader(ccT, [contactName, povName]);

    // Truncate the moment the model starts speaking for the POV, or trails off with
    // their bare name (both are the model taking over the user's side of the chat).
    if (povName) {
        let ccRxList = [
            new RegExp('(?:^|\\n)\\s*\\*?\\*?' + _charchatEscapeRx(povName) + '\\*?\\*?\\s*[:\uff1a]', 'i'),
            new RegExp('(?:^|\\n)\\s*\\*?\\*?' + _charchatEscapeRx(povName) + '\\*?\\*?\\s*$', 'i')
        ];
        for (let ccRx of ccRxList) {
            let ccMt = ccT.match(ccRx);
            if (ccMt && ccMt.index !== undefined && ccMt.index > 0) ccT = ccT.substring(0, ccMt.index);
        }
    }

    ccT = ccT.replace(/\s+$/, '').replace(/^\s+/, '');

    // [v2.22.0] The name header is OURS, not the model's — same "bolted on around
    // generation" treatment Emotion already got, in the opposite direction: Emotion IS
    // requested from the model and kept; the header is NEVER requested and ALWAYS
    // applied here, so it is canonical regardless of what the model did or didn't write.
    // [v2.24.0] This is now the FIRST of two applications, not the only one:
    // _charchatNormalizeDocument re-canonicalises the same turn after generation. Both
    // exist because they cover different failure modes — this one owns the text on the
    // way in, that one owns anything the user or NAI did to it afterwards.
    let ccBody = ccT || '\u2026';   // an empty body after cleanup still gets a header + placeholder rather than vanishing silently
    // [v2.25.0, per user] Header and body share a line ("Sara: message"), matching
    // _charchatCanonContact's new format exactly — this and that function must stay in
    // sync (they cover the same shape at two different times, see the comment above).
    let ccOut = (contactName || 'They') + ': ' + ccBody;
    if (ccEmotion) ccOut += '\n' + CHARCHAT_EMOTION_PREFIX + ccEmotion;
    return ccOut;
}

// ── Session lifecycle ──────────────────────────────────────────

async function startCharChat(contactId: string, povId: string): Promise<void> {
    if (_aeCharChat.active) { api.v1.ui.toast('A character chat is already open in the story.', { type: 'warning', autoClose: 3000 }); return; }
    if (_aeLiveWiz.active)  { api.v1.ui.toast('A wizard chat is open in the story \u2014 end it before starting a character chat.', { type: 'warning', autoClose: 4000 }); return; }
    if (_aeWizardMode)      { api.v1.ui.toast('Close the classic wizard first \u2014 the modes are exclusive.', { type: 'warning', autoClose: 4000 }); return; }
    if (_aeYoink.active)    { api.v1.ui.toast('A background generation is running \u2014 try again in a moment.', { type: 'warning', autoClose: 3000 }); return; }

    let ccContact = await loadCharacter(contactId);
    if (!ccContact) { api.v1.ui.toast('Could not load that character.', { type: 'error', autoClose: 4000 }); return; }
    let ccCfgStart = await loadConfig();
    let ccPov: CharacterRecord | null = null;
    if (povId) { ccPov = await loadCharacter(povId); }

    // [LOCKED DECISION] POV is a LABEL ONLY. It names who the contact is texting so the
    // instruction can address them; it grants no scene presence and injects no profile.
    let ccPovName = ccPov ? ccPov.name : '';

    // [v2.24.0] Both paths get the same instructions now: there is no scaffold to
    // "finish" anymore (see the removal note at _charchatAppendPovScaffold's old site),
    // so every user starts a turn the same way. [v2.27.0 CHARCHAT-BRACE-REVERT, per
    // user] _charchatCanonPov wraps in literal braces again (see its own comment for
    // why), but the WORDING here is deliberately KEPT from v2.26.0, not reverted with
    // the code: the user never had to type a brace even before v2.26.0
    // (_charchatCanonPov re-wraps regardless of source — "Hi, Sara" and "{Hi, Sara}"
    // both come out the same), so telling them to type one was never accurate. This
    // greeting just no longer credits NAI with doing the wrapping, since that specific
    // claim is what testing disproved.
    let ccGreet = 'You are now texting ' + ccContact.name
        + '. Write your message in a new paragraph, then press Send.'
        + (ccPovName ? (' Your name is added for you automatically; just write what you want to say.') : '');

    let ccBefore = await api.v1.document.sectionIds();
    await api.v1.document.appendParagraphs([
        { text: AE_CHARCHAT_MARKER_TEXT, source: 'instruction' },
        { text: ccGreet, source: 'instruction' }
    ]);
    let ccAfter = await api.v1.document.sectionIds();
    let ccAdded = ccAfter.slice(ccBefore.length);
    if (ccAdded.length === 0) { api.v1.ui.toast('Could not start the chat \u2014 document append failed.', { type: 'error', autoClose: 4000 }); return; }
    let ccMarkerId = ccAdded[0];

    // Pin output short. Same snapshot->update->restore shape as WIZLIVE.
    // [v2.24.0] The cap is now this CONTACT's, not a global constant — verbosity is a
    // persona axis and it sets the token budget as well as the wording, because
    // instructing "be brief" under a 240-token cap is two instructions that disagree.
    let ccSnap: any = null;
    try {
        ccSnap = await api.v1.generationParameters.get();
        await api.v1.generationParameters.update({ max_tokens: charChatMaxTokensFor(ccContact, ccCfgStart) });
    } catch (eccP) { api.v1.log('[AE:charchat] param pin failed, continuing without pin:', eccP); ccSnap = null; }

    _aeCharChat = {
        active: true, markerId: ccMarkerId, setupIds: ccAdded.slice(1),
        contactId: contactId, contactName: ccContact.name,
        povId: ccPov ? povId : '', povName: ccPovName,
        paramSnapshot: ccSnap, startedAt: Date.now(), lastEmotion: ''
    };
    await saveCharChatState();

    try { await _charchatRegisterDecorations(ccMarkerId); await refreshCharChatDecorations(); }
    catch (eccDr) { api.v1.log('[AE:charchat] decoration registration failed (cosmetic only):', eccDr); }

    api.v1.ui.toast('Texting ' + ccContact.name + ' \u2014 write in { } blocks below the marker, then press Send.', { type: 'info', autoClose: 6000 });
    await broadcastCharChatState();
}

// Walk the LIVE document from the marker down (mirrors collectLiveWizTranscript).
// [v2.22.0] Now returns ids AND msgs from one document.scan() — used to be ids-only
// (P1 had nowhere to save a transcript to). Role comes from row.section.source, exactly
// like WIZLIVE — NEVER from name-prefix text, so this works identically whether or not
// a POV was set. Consecutive non-POV paragraphs merge into one turn (a reply split
// across several document sections — header, body, Emotion line — becomes one logical
// turn again, regardless of whether NAI kept onResponse's returned text as one section
// or split it along the embedded newlines; both cases produce the same result here).
async function collectCharChatTranscript(): Promise<{ ids: number[]; msgs: WizardChatMessage[] }> {
    let ccScan = await _charchatScanTurns();
    let ccMsgs: WizardChatMessage[] = [];
    for (let ccT of ccScan.turns) {
        // Canonicalise on the way out too, not just on the way in: a saved thread should
        // round-trip in the same shape the live document is kept in, and a turn the user
        // edited by hand between generations has never been through the write pass.
        let ccC = _charchatCanonTurn(ccT, _aeCharChat.povName, _aeCharChat.contactName);
        if (!ccC) continue;   // empty turn — a blank paragraph, or a brace block never typed into
        ccMsgs.push({ role: ccT.isPov ? 'user' : 'assistant', content: ccT.isPov ? _charchatStripBraces(ccC) : ccC });
    }
    return { ids: ccScan.ids, msgs: ccMsgs };
}

function _charchatStripBraces(t: string): string {
    let s = (t || '').trim();
    if (s.length >= 2 && s.charAt(0) === '{' && s.charAt(s.length - 1) === '}') s = s.substring(1, s.length - 1).trim();
    return s;
}

// ── Saved threads (one per character PAIR) ──────────────────────────────
// [v2.29.0, REVERSES the v2.22.0 LOCKED DECISION below, per user] Was: one lorebook
// entry per CONTACT, full stop — POV was "label only" and starting a second
// conversation with someone you'd already texted just found/overwrote the same
// entry. Per user: "each character pair can have one chat between them" — POV is
// now a real partition key. charChatEntryId takes povId as a second argument;
// entries stay backward compatible with every thread saved before this pass with
// ZERO migration needed (see charChatEntryId's own comment for how).
// [v2.22.0 CHARCHAT-SAVE, HISTORICAL — no longer true, kept for context] One
// lorebook entry per CONTACT, not per session — matching how a phone actually
// works. The entry id was DETERMINISTIC (charChatEntryId), so there was no
// per-session sourceEntryId to track the way WIZLIVE needs one: Save always
// overwrote the one thread for that contact, and Clear deleted it outright.
var CHARCHAT_CAT_NAME = 'CE Character Chats';
var _aeCharChatCatId: string | null = null;

async function ensureCharChatCategory(): Promise<string> {
    if (_aeCharChatCatId) return _aeCharChatCatId;
    try {
        let cached = (await api.v1.storyStorage.getOrDefault(STORAGE_CHARCHAT_CAT, '')) as string;
        if (cached) {
            let c = await api.v1.lorebook.category(cached);
            if (c) { _aeCharChatCatId = cached; return cached; }
        }
    } catch (_e0) {}
    try {
        let cats = await api.v1.lorebook.categories();
        let found = (cats || []).filter(function(c: any) { return (c.name || '') === CHARCHAT_CAT_NAME; })[0];
        if (found) {
            _aeCharChatCatId = found.id;
            try { await api.v1.storyStorage.set(STORAGE_CHARCHAT_CAT, found.id); } catch (_e1) {}
            return found.id;
        }
    } catch (_e2) {}
    let newId = await api.v1.lorebook.createCategory({ id: api.v1.uuid(), name: CHARCHAT_CAT_NAME, enabled: true });
    _aeCharChatCatId = newId;
    try { await api.v1.storyStorage.set(STORAGE_CHARCHAT_CAT, newId); } catch (_e3) {}
    return newId;
}

// [v2.29.0] Now a function of BOTH ids. povId='' reuses the EXACT pre-v2.29.0 id
// shape ('ae_charchat_<contactId>', no suffix) — every thread saved before this
// pass is automatically and correctly the "no POV" bucket under the new scheme,
// with no rekey/migration pass needed. A real povId appends '_pov_<povId>'; UUIDs
// never contain the literal substring '_pov_', so this splits unambiguously (see
// _charchatParseEntryId, the inverse).
function charChatEntryId(contactId: string, povId: string): string {
    return 'ae_charchat_' + contactId + (povId ? ('_pov_' + povId) : '');
}

// Inverse of charChatEntryId. Returns null for anything outside our own prefix
// (defensive — the category is hidden:true but nothing stops something else from
// living in it).
function _charchatParseEntryId(eId: string): { contactId: string; povId: string } | null {
    let prefix = 'ae_charchat_';
    if (!eId || eId.indexOf(prefix) !== 0) return null;
    let rest = eId.substring(prefix.length);
    if (!rest) return null;
    let povIdx = rest.indexOf('_pov_');
    if (povIdx === -1) return { contactId: rest, povId: '' };
    return { contactId: rest.substring(0, povIdx), povId: rest.substring(povIdx + 5) };
}

// [FEATURE v2.26.0 CHARCHAT-SUMMARY-SAVE, per user] Save an edited summary preview to
// the character's own Journal, not a lorebook entry — SUPERSEDES the v2.25.0 design
// (saveCharChatSummaryToLorebook / the "CE Character Chats" lorebook category), which
// is REMOVED. Reuses charJournalAddBubble as-is: same storage, same broadcast
// (AE_CHAR_JOURNAL_STATE), same surface user already reviews bubbles from — no new
// lorebook category, no new id scheme, no new UI to build. A summary becomes one more
// journal bubble for the contact, exactly like any other journal entry.
async function saveCharChatSummaryToJournal(summaryText: string): Promise<boolean> {
    let ccBody = (summaryText || '').trim();
    if (!ccBody || !_aeCharChat.contactId) return false;
    await charJournalAddBubble(_aeCharChat.contactId, ccBody);
    return true;
}

// [FEATURE v2.25.0/v2.26.0 CHARCHAT-SUMMARY-SAVE] Replaces the old toast+log stub
// (previously flagged in the CE-INDEX as "a real review modal is P6 territory") with an
// actual editable-preview modal, mirroring buildLiveChatTab's _wizModalPreview pattern: a
// multilineTextInput bound to the pending text, Save (writes via
// saveCharChatSummaryToJournal and closes) or Discard (drops the text and closes). The
// live chat itself is untouched either way \u2014 Summarize was always a preview action
// that keeps the chat open, and still is.
var _charchatSummaryPreview: string = '';   // '' = no summary modal pending

async function _charchatShowSummaryModal(): Promise<void> {
    let handle: any = null;
    async function render(): Promise<void> {
        let parts: UIPart[] = [
            { type: 'text', text: 'A narrative-prose recap of the conversation so far. Edit as needed, then save it to ' + (_aeCharChat.contactName || 'their') + '\u2019s Journal \u2014 or discard it. The live chat stays open either way.', style: { fontSize: '12px', opacity: '0.8', marginBottom: '10px' } },
            { type: 'multilineTextInput', initialValue: _charchatSummaryPreview, onChange: function(v: string) { _charchatSummaryPreview = v; }, style: { minHeight: '140px' } },
            { type: 'row', style: { gap: '8px', marginTop: '10px' }, content: [
                { type: 'button', text: 'Save to Journal', style: { flex: '1 1 0', backgroundColor: 'rgba(126,200,160,0.18)', border: '1px solid rgba(126,200,160,0.4)' }, disabledWhileCallbackRunning: true, callback: async function() {
                    try {
                        let saved = await saveCharChatSummaryToJournal(_charchatSummaryPreview);
                        if (!saved) { api.v1.ui.toast('Nothing to save.', { type: 'warning', autoClose: 3000 }); return; }
                        api.v1.ui.toast('Summary saved to ' + (_aeCharChat.contactName || 'their') + '\u2019s Journal.', { type: 'success', autoClose: 3000 });
                        _charchatSummaryPreview = '';
                        try { if (handle && !handle.isClosed()) await handle.close(); } catch (_eCl) {}
                    } catch (eSv) { api.v1.error('[AE:charchat] summary save:', eSv); api.v1.ui.toast('Could not save the summary.', { type: 'error', autoClose: 4000 }); }
                } } as UIPart,
                { type: 'button', text: 'Discard', style: { flex: '1 1 0' }, callback: async function() {
                    _charchatSummaryPreview = '';
                    try { if (handle && !handle.isClosed()) await handle.close(); } catch (_eCl2) {}
                } } as UIPart
            ] }
        ];
        try { if (handle && !handle.isClosed()) { await handle.update({ content: parts }); return; } } catch (_eUp) {}
        handle = await openEngineModal({ id: 'ae-charchat-summary', title: 'Summary \u2014 Texting ' + _aeCharChat.contactName, size: 'medium', content: parts });
    }
    await render();
}

// Sigil-delimited, NOT name-prefix-delimited — deliberately, so role reconstruction
// never depends on whether a POV was set. @POV/@CONTACT never appear in the live
// document; they exist only in the persisted lorebook text. Turn content is stored
// EXACTLY as it appeared live (including the contact's own "Name:" header and the
// trailing Emotion line) so a resumed thread is a lossless round trip.
// [BUGFIX v2.23.0, per user] Header simplified — plain names, no ids, no timestamp.
// contactId is NEVER stored in text at all: it's recovered from the entry's own
// deterministic id (charChatEntryId) wherever it's needed, so there is nothing to keep
// in sync here. povName is the only thing this header needs to carry for a resume —
// POV was always "label only" (see P1), so a name string is the whole of what a resume
// needs; there is no CharacterRecord field of theirs anything here ever reads.
function serializeCharChatTranscript(contactName: string, povName: string, msgs: WizardChatMessage[]): string {
    let head = '=== Texting ' + contactName + (povName ? (' (as ' + povName + ')') : '') + ' ===';
    let parts: string[] = [head, ''];
    for (let i = 0; i < msgs.length; i++) {
        parts.push(msgs[i].role === 'user' ? '@POV' : '@CONTACT');
        parts.push(msgs[i].content);
        parts.push('');
    }
    return parts.join('\n').replace(/\s+$/, '');
}

// Cheap, header-only read — no sigil walk needed. contactId is deliberately NOT parsed
// here: callers already know it (it's the deterministic entry id minus the prefix), so
// there's nothing to recover from text.
function parseCharChatEntryHeader(text: string): { povName: string } {
    let first = String(text || '').split('\n')[0] || '';
    let m = first.match(/\(as (.+?)\)/);
    return { povName: m ? m[1].trim() : '' };
}

// Inverse of serializeCharChatTranscript. Sigil lines are the ONLY thing that starts a
// new turn; everything else (including blank lines) accrues to whichever turn is
// currently open, so a multi-line contact reply (name header + body + Emotion line)
// survives the round trip as one turn — same guarantee parseChatTranscript gives WIZLIVE,
// just keyed on an unambiguous sigil instead of a fixed Director:/Wizard: prefix.
function parseCharChatTranscript(text: string): { msgs: WizardChatMessage[] } {
    let lines = String(text || '').split('\n');
    let msgs: WizardChatMessage[] = [];
    let cur: WizardChatMessage | null = null;
    for (let i = 0; i < lines.length; i++) {
        let t = lines[i].trim();
        if (t === '@POV' || t === '@CONTACT') {
            if (cur) msgs.push(cur);
            cur = { role: (t === '@POV' ? 'user' : 'assistant'), content: '' };
            continue;
        }
        if (!cur) continue; // header line / pre-first-sigil spacer
        cur.content += (cur.content ? '\n' : '') + lines[i];
    }
    if (cur) msgs.push(cur);
    let out: WizardChatMessage[] = [];
    for (let k = 0; k < msgs.length; k++) {
        let c = msgs[k].content.replace(/^\s+/, '').replace(/\s+$/, '');
        if (c.length > 0) out.push({ role: msgs[k].role, content: c });
    }
    return { msgs: out };
}

function countCharChatTurns(text: string): number {
    let m = String(text || '').match(/^@(?:POV|CONTACT)\s*$/gm);
    return m ? m.length : 0;
}

// ONE bulk lorebook.entries(cat) call, same shape as WIZLIVE's listWizChatEntries —
// never N individual entry() lookups for a roster-sized picker.
// [v2.29.0] Returns one record per (contactId, povId) PAIR now, not per contact —
// see the CE-INDEX v2.29.0 entry. contactId/povId both come straight off the
// entry's own deterministic id (_charchatParseEntryId), same "nothing to parse out
// of the header, nothing to drift out of sync" guarantee the old per-contact
// version had.
async function listCharChatThreads(): Promise<{ contactId: string; povId: string; entryId: string; turnCount: number }[]> {
    let out: { contactId: string; povId: string; entryId: string; turnCount: number }[] = [];
    try {
        let cat = await ensureCharChatCategory();
        let entries = await api.v1.lorebook.entries(cat);
        for (let e of (entries || [])) {
            let parsed = _charchatParseEntryId(e.id || '');
            if (!parsed || !parsed.contactId) continue;
            out.push({ contactId: parsed.contactId, povId: parsed.povId, entryId: e.id, turnCount: countCharChatTurns(e.text || '') });
        }
    } catch (eList) { api.v1.error('[AE:charchat] listCharChatThreads:', eList); }
    return out;
}

// Scoped view for one POV, built from a single listCharChatThreads() call — no
// extra lorebook round trip per POV selection. contactId -> {entryId, turnCount}.
function _charchatThreadsForPov(all: { contactId: string; povId: string; entryId: string; turnCount: number }[], povId: string): Map<string, { entryId: string; turnCount: number }> {
    let m = new Map<string, { entryId: string; turnCount: number }>();
    for (let t of all) { if (t.povId === povId) m.set(t.contactId, { entryId: t.entryId, turnCount: t.turnCount }); }
    return m;
}

// Strip a self-header/Emotion line back OFF a turn's content for the distiller — the
// live document formatting is exactly what we do NOT want the summary prompt to see.
function _charchatBareBody(content: string, ownName: string): string {
    let c = _charchatStripHeader(content, [ownName]);
    // [BUGFIX v2.24.0] This used to be /\n?Emotion:.../ — a private copy of the emotion
    // pattern that assumed the tag was preceded by at most one newline and no spaces.
    // CHARCHAT_EMOTION_PREFIX now carries two leading spaces (per user), which that
    // copy would have silently stopped matching, leaking "Emotion: wistful" into every
    // summarizer prompt. Shared builder now, so the prefix can change again safely.
    c = c.replace(_charchatEmotionRx(), '');
    return c.trim();
}

// [REMOVED v2.24.0, per user] _charchatAppendPovScaffold is GONE, along with its three
// call sites (startCharChat, resumeCharChatFromEntry, and the onGenerationEnd CHARCHAT
// branch). Flagged loudly rather than deleted quietly because it was load-bearing for
// two versions and its absence is the point of this pass.
// It appended a pre-filled "{user: " opener the user was meant to finish. Three
// separate reported bugs were all it:
//   - it assumed the user would type the closing "}" — they were never obliged to, and
//     an unclosed "{user: " reaching context is a dangling instruction block whose most
//     natural continuation is to finish BRUCE's line, not reply as the contact (the
//     "needs two clicks / wrong speaker" report; v2.23.0 patched the symptom by stripping
//     it back out of context, which is what a self-inflicted wound looks like);
//   - it appended unconditionally after every reply, so a user who typed their message
//     into a NEW paragraph instead of the scaffold accumulated a second POV header;
//   - it fought the user's own newlines rather than absorbing them.
// The replacement is the canonical turn engine above: write whatever you like, we make it
// canonical afterwards. That is strictly more general — it also fixes headers the MODEL
// invents, which no amount of scaffolding could reach.

// Create-or-overwrite THE thread for this (contact, pov) PAIR — deterministic id,
// no lookup needed to know where to write. [v2.29.0] povId param added back (was
// dropped in v2.23.0 when POV was "label only" — see the CE-INDEX v2.29.0 entry for
// why it's back and why this is a compatible change, not a breaking one).
async function upsertCharChatEntry(contact: CharacterRecord, povId: string, povName: string, msgs: WizardChatMessage[]): Promise<string> {
    let cat = await ensureCharChatCategory();
    let id = charChatEntryId(contact.id, povId);
    let text = serializeCharChatTranscript(contact.name, povName, msgs);
    let existing: any = null;
    try { existing = await api.v1.lorebook.entry(id); } catch (_e) {}
    if (existing) {
        await api.v1.lorebook.updateEntry(id, { text: text, displayName: 'Texting ' + contact.name, category: cat });
        return id;
    }
    // [DEVIATION from the CE-Chats pattern, deliberate] hidden:true — these entries are
    // pure archival storage for the Chat picker, never meant for manual lorebook
    // browsing/editing the way a CE Chats reference entry is.
    let newId = await api.v1.lorebook.createEntry({ id: id, category: cat, displayName: 'Texting ' + contact.name, text: text, keys: [], enabled: true, forceActivation: false, hidden: true });
    return newId || id;
}

// Pull a saved thread back into the story. POV is read from the entry itself, not
// re-asked — an established thread already has a POV, and re-prompting would break the
// "just click and continue" flow the badge exists to enable.
async function resumeCharChatFromEntry(entryId: string, contactId: string): Promise<void> {
    if (_aeCharChat.active) { api.v1.ui.toast('A character chat is already open in the story.', { type: 'warning', autoClose: 3000 }); return; }
    if (_aeLiveWiz.active)  { api.v1.ui.toast('A wizard chat is open in the story \u2014 end it before starting a character chat.', { type: 'warning', autoClose: 4000 }); return; }
    if (_aeWizardMode)      { api.v1.ui.toast('Close the classic wizard first \u2014 the modes are exclusive.', { type: 'warning', autoClose: 4000 }); return; }
    if (_aeYoink.active)    { api.v1.ui.toast('A background generation is running \u2014 try again in a moment.', { type: 'warning', autoClose: 3000 }); return; }

    let ccContact = await loadCharacter(contactId);
    if (!ccContact) { api.v1.ui.toast('Could not load that character.', { type: 'error', autoClose: 4000 }); return; }
    let entry: any = null;
    try { entry = await api.v1.lorebook.entry(entryId); } catch (_e) {}
    if (!entry || !entry.text) { api.v1.ui.toast('Could not load that saved chat.', { type: 'error', autoClose: 4000 }); return; }

    // [v2.23.0] POV NAME is read straight off the header, not re-derived from a
    // loadCharacter round trip — the header never stores anything else of theirs.
    // [v2.29.0] POV ID is now ALSO needed (it's half of endCharChat's save/clear
    // target once this chat is active again) — parsed off entryId itself, the same
    // source listCharChatThreads already used to build the picker's sublabel/onSelect
    // for this exact entry, so it is guaranteed consistent with what the user picked.
    let hdr = parseCharChatEntryHeader(entry.text);
    let ccPovName = hdr.povName;
    let ccEntryParsed = _charchatParseEntryId(entryId);
    let ccPovId = ccEntryParsed ? ccEntryParsed.povId : '';
    let parsed = parseCharChatTranscript(entry.text);
    if (parsed.msgs.length === 0) { api.v1.ui.toast('That saved chat is empty.', { type: 'warning', autoClose: 3000 }); return; }

    let paras: any[] = [ { text: AE_CHARCHAT_MARKER_TEXT, source: 'instruction' } ];
    for (let i = 0; i < parsed.msgs.length; i++) {
        let m = parsed.msgs[i];
        if (m.role === 'user') {
            // [v2.24.0] No inner padding — this is the canonical POV shape now
            // (_charchatCanonPov), and content already carries its own "Pov: " header
            // from collectCharChatTranscript. Rebuilding it any other way would just get
            // normalised back to this on the first turn anyway.
            paras.push({ text: '{' + m.content + '}', source: 'instruction' });
        } else {
            let chunks = m.content.split('\n');
            for (let j = 0; j < chunks.length; j++) {
                let c = chunks[j].replace(/^\s+/, '').replace(/\s+$/, '');
                if (c.length > 0) paras.push({ text: c });
            }
        }
    }

    let before = await api.v1.document.sectionIds();
    await api.v1.document.appendParagraphs(paras);
    let after = await api.v1.document.sectionIds();
    let added = after.slice(before.length);
    if (added.length === 0) { api.v1.ui.toast('Could not resume the chat \u2014 document append failed.', { type: 'error', autoClose: 4000 }); return; }
    let markerId = added[0];

    let snap: any = null;
    try {
        snap = await api.v1.generationParameters.get();
        await api.v1.generationParameters.update({ max_tokens: charChatMaxTokensFor(ccContact, await loadConfig()) });
    } catch (eP) { api.v1.log('[AE:charchat] param pin failed, continuing without pin:', eP); snap = null; }

    _aeCharChat = {
        active: true, markerId: markerId, setupIds: [],
        contactId: contactId, contactName: ccContact.name,
        povId: ccPovId, povName: ccPovName,   // [v2.29.0] povId now IS persisted/functional again — see the field's own comment
        paramSnapshot: snap, startedAt: Date.now(), lastEmotion: ''
    };
    await saveCharChatState();

    try { await _charchatRegisterDecorations(markerId); await refreshCharChatDecorations(); }
    catch (eD) { api.v1.log('[AE:charchat] decoration registration failed (cosmetic only):', eD); }

    api.v1.ui.toast('Chat with ' + ccContact.name + ' resumed \u2014 continue below the marker.', { type: 'info', autoClose: 6000 });
    await broadcastCharChatState();
}

// Non-ending preview, mirrors previewSummarizeLiveChat. [LOCKED PURPOSE, per user] this
// is a NARRATIVE recap matching the story's own prose — no chat-transcript formatting,
// no turn labels, no Emotion lines (that's what Close/save already preserves, separately,
// for resuming). Feeds the distiller a bare role:body transcript via _charchatBareBody
// (stripping the live "Name:"/Emotion formatting back out first). DESTINATION UNDECIDED:
// this only returns text, same as WIZLIVE's own preview — whether/where it auto-lands
// (Memory? the story itself? nothing?) is deferred, not guessed at.
async function previewSummarizeCharChat(): Promise<string> {
    if (!_aeCharChat.active) return '';
    let collected = await collectCharChatTranscript();
    if (collected.msgs.length === 0) return '';
    let cfg = await loadConfig();
    let sTranscript = collected.msgs.map(function(m) {
        let who = (m.role === 'user') ? (_aeCharChat.povName || 'They') : _aeCharChat.contactName;
        return who + ': ' + _charchatBareBody(m.content, who);
    }).join('\n');
    let styleHint = [cfg.projectGenre, cfg.projectConcept].filter(Boolean).join(' \u2014 ');

    // [BUGFIX v2.23.0] ROOT CAUSE of summaries reading like truncated fragments instead
    // of prose: executeYoinkGeneration rides api.v1.editor.generate(), which uses
    // whatever generationParameters are AMBIENT right now — including AE_CHARCHAT_MAX_TOKENS
    // (120, SMS-length), still pinned because Summarize is a preview that does not end
    // the chat. Bump the cap for just this one call, then restore the chat's own pin in a
    // finally — the NEXT real chat turn still needs the SMS-length cap back in place.
    let ccSumSnap: any = null;
    try {
        ccSumSnap = await api.v1.generationParameters.get();
        await api.v1.generationParameters.update({ max_tokens: AE_CHARCHAT_SUMMARY_MAX_TOKENS });
    } catch (ePin) { api.v1.log('[AE:charchat] summarize token bump failed, using whatever is ambient:', ePin); }

    let sOut = '';
    try {
        sOut = await executeYoinkGeneration([
            { role: 'system', content: 'Distill the following text-message conversation into a short third-person narrative recap, written in the story\u2019s own prose style' + (styleHint ? (' (' + styleHint + ')') : '') + '. Do NOT preserve chat formatting, turn labels, or timestamps \u2014 write it as prose summarizing what was exchanged, the way a narrator would recap it. Keep only what was actually established or decided. Be concise.' },
            { role: 'user', content: sTranscript }
        ], { tag: 'charChatSummarize' });
    } finally {
        if (ccSumSnap) {
            try { await api.v1.generationParameters.update({ max_tokens: ccSumSnap.max_tokens }); }
            catch (eUnpin) { api.v1.error('[AE:charchat] summarize token restore failed \u2014 chat may stay at the wider cap until closed:', eUnpin); }
        }
    }
    return (sOut || '').trim();
}

// [v2.22.0] 'save' (Close) now writes the one thread for this contact for real;
// 'discard' (Clear) now also DELETES that saved thread — one thread per contact means
// starting over with someone means clearing what's there, not accumulating saves.
async function endCharChat(action: string): Promise<void> {
    if (!_aeCharChat.active) { api.v1.ui.toast('No character chat is open.', { type: 'warning', autoClose: 2500 }); return; }
    let act = (action === 'save') ? 'save' : 'discard';
    let ccContactId = _aeCharChat.contactId;

    let collected: { ids: number[]; msgs: WizardChatMessage[] } = { ids: [], msgs: [] };
    try { collected = await collectCharChatTranscript(); }
    catch (eccC) { api.v1.error('[AE:charchat] transcript scan failed:', eccC); }

    // Save/delete FIRST, destroy the document LAST — a failure here returns early,
    // leaving the chat intact rather than losing it to a half-completed end.
    if (act === 'save') {
        if (collected.msgs.length > 0) {
            try {
                let ccContact = await loadCharacter(ccContactId);
                if (ccContact) {
                    await upsertCharChatEntry(ccContact, _aeCharChat.povId, _aeCharChat.povName, collected.msgs);
                    api.v1.ui.toast('Chat with ' + ccContact.name + ' saved.', { type: 'success', autoClose: 3000 });
                }
            } catch (eS) {
                api.v1.error('[AE:charchat] lorebook save failed:', eS);
                api.v1.ui.toast('Save failed \u2014 the chat is still in your document, nothing was removed.', { type: 'error', autoClose: 5000 });
                return;
            }
        }
    } else {
        // [v2.29.0] One thread per PAIR now, not per contact — clearing deletes only
        // THIS pov's thread with this contact; a different pov's thread with the same
        // contact is untouched. Non-fatal if nothing was ever saved for this pair.
        try { await api.v1.lorebook.removeEntry(charChatEntryId(ccContactId, _aeCharChat.povId)); } catch (_eDel) {}
    }

    try {
        if (collected.ids.length > 0) await api.v1.document.removeParagraphs(collected.ids);
    } catch (eccR) { api.v1.error('[AE:charchat] paragraph removal failed \u2014 clean up manually from the marker down:', eccR); }

    try { api.v1.editor.decorations.removeRules([AE_CHARCHAT_RULE_MARKER, AE_CHARCHAT_RULE_POV, AE_CHARCHAT_RULE_CONTACT]); } catch (_eccDr2) {}

    // Restore pinned generation params (same field-by-field shape as the WIZLIVE restore).
    if (_aeCharChat.paramSnapshot) {
        try {
            let ccPs: any = _aeCharChat.paramSnapshot;
            let ccR: any = { model: ccPs.model };
            if (ccPs.max_tokens !== undefined) ccR.max_tokens = ccPs.max_tokens;
            if (ccPs.temperature !== undefined) ccR.temperature = ccPs.temperature;
            if (ccPs.top_p !== undefined) ccR.top_p = ccPs.top_p;
            if (ccPs.top_k !== undefined) ccR.top_k = ccPs.top_k;
            if (ccPs.frequency_penalty !== undefined) ccR.frequency_penalty = ccPs.frequency_penalty;
            if (ccPs.presence_penalty !== undefined) ccR.presence_penalty = ccPs.presence_penalty;
            if (ccPs.min_p !== undefined) ccR.min_p = ccPs.min_p;
            await api.v1.generationParameters.update(ccR);
        } catch (eccRe) { api.v1.error('[AE:charchat] param restore failed:', eccRe); }
    }

    _aeCharChat = { active: false, markerId: null, setupIds: [], contactId: '', contactName: '', povId: '', povName: '', paramSnapshot: null, startedAt: 0, lastEmotion: '' };
    try { await api.v1.storyStorage.remove(STORAGE_CHARCHAT); } catch (_eccRm) {}
    api.v1.ui.toast(act === 'save' ? 'Story mode restored.' : 'Chat cleared \u2014 story mode restored.', { type: 'success', autoClose: act === 'save' ? 2000 : 3000 });
    await broadcastCharChatState();
}

// Startup rehydration — identical contract to restoreLiveWizOnStartup: a chat left open
// in this story comes back live IF its marker paragraph still exists, otherwise the stale
// state is cleared and any pinned params restored from the persisted snapshot. Restoring
// the pin matters more here than for WIZLIVE: a stranded 120-token cap would silently
// truncate every story generation until someone worked out why.
async function restoreCharChatOnStartup(): Promise<void> {
    let ccRaw = '';
    try { ccRaw = (await api.v1.storyStorage.getOrDefault(STORAGE_CHARCHAT, '')) as string; } catch (_ecc0) {}
    if (!ccRaw) return;
    let ccSt: any = null;
    try { ccSt = JSON.parse(ccRaw); } catch (_ecc1) { ccSt = null; }
    if (!ccSt || !ccSt.active || typeof ccSt.markerId !== 'number') {
        try { await api.v1.storyStorage.remove(STORAGE_CHARCHAT); } catch (_ecc2) {}
        return;
    }
    let ccSecIds: number[] = [];
    try { ccSecIds = await api.v1.document.sectionIds(); } catch (_ecc3) {}
    if (ccSecIds.indexOf(ccSt.markerId) < 0) {
        if (ccSt.paramSnapshot) {
            try {
                let ccRp: any = { model: ccSt.paramSnapshot.model };
                if (ccSt.paramSnapshot.max_tokens !== undefined) ccRp.max_tokens = ccSt.paramSnapshot.max_tokens;
                await api.v1.generationParameters.update(ccRp);
            } catch (_ecc4) {}
        }
        try { await api.v1.storyStorage.remove(STORAGE_CHARCHAT); } catch (_ecc5) {}
        api.v1.log('[AE:charchat] stale chat state cleared (marker no longer in document).');
        return;
    }
    _aeCharChat = {
        active: true,
        markerId: ccSt.markerId,
        setupIds: Array.isArray(ccSt.setupIds) ? ccSt.setupIds : [],
        contactId: (typeof ccSt.contactId === 'string') ? ccSt.contactId : '',
        contactName: (typeof ccSt.contactName === 'string') ? ccSt.contactName : '',
        povId: (typeof ccSt.povId === 'string') ? ccSt.povId : '',
        povName: (typeof ccSt.povName === 'string') ? ccSt.povName : '',
        paramSnapshot: ccSt.paramSnapshot || null,
        startedAt: ccSt.startedAt || Date.now(),
        lastEmotion: (typeof ccSt.lastEmotion === 'string') ? ccSt.lastEmotion : ''
    };
    // A chat whose contact was deleted between sessions would steer every generation at
    // a character that no longer exists. Fail loudly and close rather than limp.
    let ccChk = _aeCharChat.contactId ? await loadCharacter(_aeCharChat.contactId) : null;
    if (!ccChk) {
        api.v1.log('[AE:charchat] restored chat points at a missing character \u2014 closing it.');
        await endCharChat('discard');
        return;
    }
    try { await _charchatRegisterDecorations(ccSt.markerId); await refreshCharChatDecorations(); }
    catch (eccDr3) { api.v1.log('[AE:charchat] decoration restore failed (cosmetic only):', eccDr3); }
    api.v1.ui.toast('Still texting ' + _aeCharChat.contactName + ' \u2014 continue below the marker, or end it from the Chat button.', { type: 'info', autoClose: 6000 });
    await broadcastCharChatState();
}

// ── Native entry point ─────────────────────────────────────────
// [v2.22.0] Not-in-chat: characters with a saved thread show a message-count badge and
// resume directly (POV comes from the save, never re-asked) — characters without one
// go through the existing pick-a-POV-then-start flow. In-chat: Close (save + end),
// Clear (discard + end, deletes the saved thread), Summarize (preview, chat stays open).
async function openCharChatPicker(): Promise<void> {
    if (_aeCharChat.active) {
        // [v2.27.0 CHARCHAT-FRESH-THOUGHTS, was CHARCHAT-THINK] The switch lives here for now because this is
        // the only Character Chat surface a user is ever looking at. It is a GlobalConfig
        // value, so toggling it once sticks for every chat and every story. FLAGGED: the
        // tidier home is the Config modal (Section 24, Engine Tweaks) alongside the other
        // global engine switches — put it there when that section is next opened up,
        // rather than leaving it discoverable only from inside a chat.
        let ccCfgPk = await loadConfig();
        await openPickerModal({
            title: 'Texting ' + _aeCharChat.contactName,
            items: [
                { id: 'close', label: 'Close (save and end)' },
                { id: 'summarize', label: 'Summarize (preview, keeps the chat open)' },
                { id: 'thinking', label: 'Fresh thoughts: ' + (ccCfgPk.charChatFreshThoughts ? 'ON' : 'off') + ' \u2014 refresh ' + _aeCharChat.contactName + '\u2019s inner state after each reply' },
                { id: 'clear', label: 'Clear (discard and delete the saved thread)' }
            ],
            getId: function(i: any) { return i.id; },
            getLabel: function(i: any) { return i.label; },
            searchable: false,
            onSelect: async function(i: any) {
                if (i.id === 'close') { await endCharChat('save'); return; }
                if (i.id === 'clear') { await endCharChat('discard'); return; }
                if (i.id === 'thinking') {
                    // [v2.27.0] No re-pin needed anymore: generateEphemeral() is a fully
                    // separate call with its own budget, so toggling this never changes
                    // the reply's own max_tokens (unlike the old CHARCHAT-THINK, which
                    // shared the reply's budget and had to re-pin on toggle).
                    let ccC2 = await loadConfig();
                    ccC2.charChatFreshThoughts = !ccC2.charChatFreshThoughts;
                    await saveConfig(ccC2);
                    api.v1.ui.toast('Fresh thoughts ' + (ccC2.charChatFreshThoughts ? 'on \u2014 ' + _aeCharChat.contactName + '\u2019s state refreshes after each reply.' : 'off.'), { type: 'info', autoClose: 4000 });
                    return;
                }
                if (i.id === 'summarize') {
                    let ccPreview = await previewSummarizeCharChat();
                    if (!ccPreview) { api.v1.ui.toast('Nothing to summarize yet.', { type: 'warning', autoClose: 3000 }); return; }
                    // [v2.25.0 CHARCHAT-SUMMARY-SAVE] Real editable-preview modal, replacing
                    // the old toast+log stub — see _charchatShowSummaryModal.
                    _charchatSummaryPreview = ccPreview;
                    await _charchatShowSummaryModal();
                }
            }
        });
        return;
    }
    // [v2.29.0, per user] POV-first now, not contact-first: "Text as who?" then "who to
    // text?" — see the CE-INDEX v2.29.0 entry. Replaces the old contact-first flow
    // (_charchatPickPov, contact chosen then pov asked only for a brand-new thread)
    // entirely; it's gone; this is its only remaining caller's replacement.
    let ccIdx1 = await loadIndex();
    let ccPovCands = ccIdx1.filter(function(m: any) { return m && m.active; });
    if (ccPovCands.length === 0) { api.v1.ui.toast('No characters to text yet.', { type: 'warning', autoClose: 3000 }); return; }
    await openPickerModal({
        title: 'Text as who?',
        items: ccPovCands,
        getId: function(m: any) { return m.id; },
        getLabel: function(m: any) { return m.name; },
        searchable: true,
        pinnedOptions: [ { id: '__nopov__', label: 'No POV \u2014 just me', icon: '\ud83d\udcf1', onSelect: async function() { await _charchatShowContactsForPov('', ''); } } ],
        onSelect: async function(m: any) { await _charchatShowContactsForPov(m.id, m.name); }
    });
}

// [v2.29.0] Second step of the POV-first flow: given a chosen pov (or '' for none),
// list the contacts they could text, sublabelled with the message count for THIS
// SPECIFIC PAIR — a contact with a thread under a different pov shows as fresh here,
// exactly the "each character pair can have one chat between them" behavior per
// user. One listCharChatThreads() call (all pairs), filtered in memory by pov —
// same "one bulk call, never N lookups" discipline the old version already had.
async function _charchatShowContactsForPov(povId: string, povName: string): Promise<void> {
    let ccIdx2 = await loadIndex();
    let ccCands = ccIdx2.filter(function(m: any) { return m && m.active && m.id !== povId; });
    if (ccCands.length === 0) { api.v1.ui.toast('No characters to text yet.', { type: 'warning', autoClose: 3000 }); return; }
    let ccAllThreads = await listCharChatThreads();
    let ccThreads = _charchatThreadsForPov(ccAllThreads, povId);
    await openPickerModal({
        title: povName ? ('Texting as ' + povName) : 'Text which character?',
        items: ccCands,
        getId: function(m: any) { return m.id; },
        getLabel: function(m: any) { return m.name; },
        getSublabel: function(m: any) {
            let th = ccThreads.get(m.id);
            if (th) return th.turnCount + (th.turnCount === 1 ? ' message' : ' messages');
            return m.briefDescription || '';
        },
        searchable: true,
        onSelect: async function(m: any) {
            let th = ccThreads.get(m.id);
            if (th) { await resumeCharChatFromEntry(th.entryId, m.id); return; }
            await startCharChat(m.id, povId);
        }
    });
}
// ── [v2.21.0 CHARCHAT] end ─────────────────────────────────────


// [vNEXT] Run a budget-free generation against a custom message array. Resolves with
// the captured response text. Guards against overlapping with any in-flight gen.
// [v0.9.7.12] editor.generate() shares the same script-level rate limit as
// api.v1.generate(). Long wizard sessions can exhaust this budget. Added:
//   - api.v1.editor.isBlocked() check (editor already mid-generation)
//   - api.v1.script.getAllowedOutput() floor (< 80 tokens = budget near empty)
//   - friendly error surfaced as toast when the rate limit is hit
// [v1.21.0 YOINK-HARDEN] Renamed from executeYoinkGeneration — this is now the single-
// attempt primitive. executeYoinkGeneration (below) wraps this with model pinning,
// a language guard, and one corrective retry. Do not call this directly from wizard
// code; call executeYoinkGeneration.

// ── [DIAG BUDGET] Per-generation token-budget instrument ─────────────────────
// [DIAG] Additive, engine-only. Flip AE_DIAG_BUDGET=false to silence, or delete this
// block plus its call sites (all tagged [DIAG]) to remove entirely. Measures the
// api.v1.script output/input allowance deltas across each generation so we can SEE
// whether the yoink (editor.generate hijack) draws on the script budget vs a plain
// api.v1.generate(). Type /budgetprobe or /budgetlog into any wizard chat to run the
// A/B probe or dump the recent log; every real generation also logs a line + a toast.
var AE_DIAG_BUDGET = true;
var _diagProbeActive = false;      // true while ANY of our own nested api.v1.generate() calls is in flight (runBudgetProbe's probe; [v2.27.0] also generateEphemeral's pre-reply CharChat refresh) — api.v1.generate() fires the full hook lifecycle, so every hook checks this first and no-ops rather than treating the nested call as a story/chat/wizard turn.
interface DiagBudgetPre { out: number; inp: number; kind: string; continuityId: string | null; }
var _diagBudgetPre: DiagBudgetPre | null = null;
var _diagBudgetLog: string[] = [];
function diagBudO(): number { try { return api.v1.script.getAllowedOutput ? api.v1.script.getAllowedOutput() : -1; } catch (e) { return -1; } }
function diagBudI(): number { try { return api.v1.script.getAllowedInput ? api.v1.script.getAllowedInput() : -1; } catch (e) { return -1; } }
function diagReplenishSec(): number { try { let t = api.v1.script.getTimeUntilAllowedOutput ? api.v1.script.getTimeUntilAllowedOutput(1000) : -1; return t >= 0 ? Math.round(t / 1000) : -1; } catch (e) { return -1; } }
function diagBudgetSnapshot(kind: string, continuityId: string | null): void {
    if (!AE_DIAG_BUDGET) return;
    _diagBudgetPre = { out: diagBudO(), inp: diagBudI(), kind: kind, continuityId: continuityId };
}
function diagBudgetClose(continuityId: string | null): void {
    if (!AE_DIAG_BUDGET || !_diagBudgetPre) return;
    if (continuityId && _diagBudgetPre.continuityId && continuityId !== _diagBudgetPre.continuityId) return;
    let pre = _diagBudgetPre; _diagBudgetPre = null;
    let pO = diagBudO(), pI = diagBudI();
    let dO = pO - pre.out, dI = pI - pre.inp;
    let line = '[AE:budget] ' + pre.kind
        + '  out ' + pre.out + '\u2192' + pO + ' (\u0394' + (dO >= 0 ? '+' : '') + dO + ')'
        + '  in ' + pre.inp + '\u2192' + pI + ' (\u0394' + (dI >= 0 ? '+' : '') + dI + ')'
        + '  replenish~' + diagReplenishSec() + 's';
    api.v1.log(line);
    _diagBudgetLog.push(line);
    if (_diagBudgetLog.length > 30) _diagBudgetLog.shift();
}
function dumpBudgetLog(): string {
    if (!_diagBudgetLog.length) return 'No budget readings yet. Run a wizard turn or /budgetprobe first.\nCurrent: out=' + diagBudO() + ' in=' + diagBudI() + ' replenish~' + diagReplenishSec() + 's';
    return 'Recent generation budget readings (newest last):\n' + _diagBudgetLog.join('\n') + '\nCurrent: out=' + diagBudO() + ' in=' + diagBudI();
}
// A/B probe: measure a tiny api.v1.generate() vs a tiny yoink, back to back, so their
// real budget cost can be compared directly. api.v1.generate is glm-4-6-only for chat
// (per docs), which is why the probe pins that model. _diagProbeActive keeps a probe
// generation from advancing story state if api.v1.generate turns out to fire the hooks.
async function runBudgetProbe(): Promise<string> {
    let L: string[] = ['Budget A/B probe (out=output allowance, in=input allowance):'];
    L.push('start:            out=' + diagBudO() + ' in=' + diagBudI());
    let a0o = diagBudO(), a0i = diagBudI(), aOk = false, aErr = '';
    _diagProbeActive = true;
    try {
        let r: any = await aeDiagGenerate('diag:budgetprobe:direct', [{ role: 'user', content: 'Reply with exactly one word: ping' }], { model: 'glm-4-6', max_tokens: 8, temperature: 0 });
        aOk = !!(r && r.choices && r.choices[0]);
    } catch (e) { aErr = String((e && (e as any).message) || e); }
    _diagProbeActive = false;
    let a1o = diagBudO(), a1i = diagBudI();
    L.push('api.v1.generate:  ' + (aOk ? 'ok ' : ('ERR ' + aErr + ' ')) + ' out \u0394' + (a1o - a0o) + '  in \u0394' + (a1i - a0i));
    let b0o = diagBudO(), b0i = diagBudI(), bOk = false, bErr = '';
    try {
        let ry = await executeYoinkGeneration([{ role: 'system', content: 'Reply with exactly one word: ping' }, { role: 'user', content: 'ping' }], { tag: 'diag:budgetprobe' });
        bOk = !!(ry && ry.trim());
    } catch (e) { bErr = String((e && (e as any).message) || e); }
    let b1o = diagBudO(), b1i = diagBudI();
    L.push('yoink:            ' + (bOk ? 'ok ' : ('ERR ' + bErr + ' ')) + ' out \u0394' + (b1o - b0o) + '  in \u0394' + (b1i - b0i));
    L.push('end:              out=' + diagBudO() + ' in=' + diagBudI() + '  replenish~' + diagReplenishSec() + 's');
    let out = L.join('\n');
    api.v1.log(out);
    return out;
}
// ── [DIAG BUDGET] end ────────────────────────────────────────────────────────

// ── [DIAG GEN v1.0.0] Generation call diagnostics — engine-wide ──────────────
// [v2.20.0 GENDIAG] Root-caused report: "Generate All From Concept Dump" (and,
// less visibly, every other wizard/field generator) could die on a single
// transient failure — most often an AbortError surfacing from NAI's own
// generation pipeline on api.v1.editor.generate() — with nothing surfaced but a
// generic "Failed." toast and a bare console.error. There was also no shared
// visibility across the two call families: the budget-free YOINK path
// (executeYoinkGeneration, used by the World-Build Wizard + "Generate All") and
// the budgeted DIRECT path (api.v1.generate(), used by per-field regen,
// ephemeral/mid-range/relationship/hook updates, and image-prompt generation)
// each swallowed their own errors independently with no common record.
//
// This block gives every engine generation call — both paths — one shared,
// tagged ring buffer, so a failure of any kind can be reviewed after the fact
// via console (visible in eruda) or the in-UI viewer (Config modal's
// "🩺 Generation Diagnostics" section, and a matching entry point next to
// "Generate All From Concept Dump" in the character editor). See
// buildGenDiagContent() (Section 24 area) for the UI, and diagGenRecord() /
// aeDiagGenerate() below for the two recording points. Deliberately NOT wired
// into api.v1.storage/storyStorage — this is in-memory, session-only, cheap-by-
// design diagnostic scaffolding, not user data; it resets on script reload same
// as _diagBudgetLog above. No new storage key.
interface AEGenDiagEntry {
    id: number;
    tag: string;                 // which generator/feature (and often character) this call belongs to
    method: 'yoink' | 'direct';  // executeYoinkGeneration vs api.v1.generate
    startedAt: number;           // Date.now() when the call began
    ms: number;                  // wall-clock latency for this entry's outcome
    outcome: 'ok' | 'empty' | 'error';
    errorName: string;           // e.g. 'AbortError', 'Error' — '' when outcome !== 'error'
    errorMessage: string;
    retried: boolean;            // a same-messages retry was attempted after a thrown error (yoink only)
    driftDetected: boolean;      // non-Latin/CJK drift heuristic tripped (yoink only)
    validatorFailed: boolean;    // caller-supplied validator rejected the raw output (yoink only)
    outLen: number;              // length of the returned text, 0 on error
    budgetOut: number;
    budgetIn: number;
}
var AE_DIAG_GEN = true;          // flip-in-code kill switch, mirrors AE_DIAG_BUDGET above
var AE_DIAG_GEN_MAX = 60;        // ring buffer cap — oldest entries drop first
var _diagGenLog: AEGenDiagEntry[] = [];
var _diagGenSeq = 0;

function diagGenRecord(entry: {
    tag: string; method: 'yoink' | 'direct'; startedAt: number; ms: number;
    outcome: 'ok' | 'empty' | 'error'; errorName: string; errorMessage: string;
    retried: boolean; driftDetected: boolean; validatorFailed: boolean; outLen: number;
    budgetOut: number; budgetIn: number;
}): void {
    if (!AE_DIAG_GEN) return;
    _diagGenSeq++;
    let full: AEGenDiagEntry = { id: _diagGenSeq, tag: entry.tag, method: entry.method, startedAt: entry.startedAt,
        ms: entry.ms, outcome: entry.outcome, errorName: entry.errorName, errorMessage: entry.errorMessage,
        retried: entry.retried, driftDetected: entry.driftDetected, validatorFailed: entry.validatorFailed,
        outLen: entry.outLen, budgetOut: entry.budgetOut, budgetIn: entry.budgetIn };
    _diagGenLog.push(full);
    if (_diagGenLog.length > AE_DIAG_GEN_MAX) _diagGenLog.shift();
    let line = '[AE:gendiag] #' + full.id + ' ' + full.method + '  tag=' + full.tag
        + '  outcome=' + full.outcome
        + (full.errorName ? ('  ' + full.errorName + ': ' + full.errorMessage) : '')
        + '  ms=' + full.ms
        + (full.retried ? '  retried' : '')
        + (full.driftDetected ? '  drift' : '')
        + (full.validatorFailed ? '  validatorFailed' : '')
        + '  outLen=' + full.outLen
        + '  budget(out=' + full.budgetOut + ',in=' + full.budgetIn + ')';
    if (full.outcome === 'error') api.v1.error(line); else api.v1.log(line);
}

function dumpGenDiagLog(): string {
    if (!_diagGenLog.length) return 'No generation calls logged yet this session.';
    let lines = _diagGenLog.slice().reverse().map(function(e) {
        return '#' + e.id + ' [' + new Date(e.startedAt).toLocaleTimeString() + ']  ' + e.method + '  ' + e.tag
            + '\n    outcome=' + e.outcome
            + (e.errorName ? ('  ' + e.errorName + ': ' + e.errorMessage) : '')
            + '  ms=' + e.ms
            + (e.retried ? '  retried' : '')
            + (e.driftDetected ? '  drift' : '')
            + (e.validatorFailed ? '  validatorFailed' : '')
            + '  outLen=' + e.outLen
            + '  budget(out=' + e.budgetOut + ',in=' + e.budgetIn + ')';
    });
    let errCount = _diagGenLog.filter(function(e) { return e.outcome === 'error'; }).length;
    return 'Recent generation calls, newest first (' + _diagGenLog.length + ' logged, ' + errCount + ' error' + (errCount === 1 ? '' : 's') + '):\n' + lines.join('\n');
}

function clearGenDiagLog(): void { _diagGenLog = []; _diagGenSeq = 0; }

// Thin instrumented wrapper around api.v1.generate() — the DIRECT (budgeted)
// generation path. Every existing caller's messages/params pass through
// unchanged and the raw response is returned unchanged (including on success
// with empty text) so none of the callers' own parsing/fallback logic needs to
// change — this only adds a diagGenRecord() entry on the way through. Callers
// keep their own try/catch; a thrown error is recorded here AND rethrown so
// existing fallback behavior (return null/false, toast, etc.) is unaffected.
async function aeDiagGenerate(tag: string, messages: any[], params: any): Promise<any> {
    let t0 = Date.now();
    let b0o = diagBudO(), b0i = diagBudI();
    try {
        let resp: any = await api.v1.generate(messages, params);
        let outText = String((resp && resp.choices && resp.choices[0] &&
            (resp.choices[0].text || (resp.choices[0].message && resp.choices[0].message.content))) || (resp && resp.text) || '');
        diagGenRecord({ tag: tag, method: 'direct', startedAt: t0, ms: Date.now() - t0,
            outcome: outText.trim() ? 'ok' : 'empty', errorName: '', errorMessage: '',
            retried: false, driftDetected: false, validatorFailed: false,
            outLen: outText.length, budgetOut: b0o, budgetIn: b0i });
        return resp;
    } catch (e) {
        diagGenRecord({ tag: tag, method: 'direct', startedAt: t0, ms: Date.now() - t0,
            outcome: 'error', errorName: String((e && (e as any).name) || 'Error'), errorMessage: String((e && (e as any).message) || e),
            retried: false, driftDetected: false, validatorFailed: false,
            outLen: 0, budgetOut: b0o, budgetIn: b0i });
        throw e;
    }
}
// ── [DIAG GEN] end ────────────────────────────────────────────────────────────

function executeYoinkGenerationAttempt(messages: any[]): Promise<string> {
    return new Promise(function(resolve, reject) {
        if (_aeYoink.active) { reject(new Error('A yoink generation is already in progress')); return; }
        if (ae_genInFlight || ae_lock) { reject(new Error('Editor is busy; try again in a moment')); return; }
        // [v0.9.7.12] Budget floor: < 80 tokens remaining = rate limit imminent.
        // The runtime state generators already guard at 220; 80 is a softer floor for
        // interactive wizard calls so the user gets a clear message, not a raw API error.
        const ygBudget = api.v1.script.getAllowedOutput ? api.v1.script.getAllowedOutput() : 9999;
        if (ygBudget < 80) {
            const ygMsg = 'Script generation budget is low. Wait a moment, then try again.';
            api.v1.ui.toast(ygMsg, { type: 'warning', autoClose: 4000 });
            reject(new Error(ygMsg)); return;
        }
        _aeYoink.active = true;
        _aeYoink.messages = messages;
        _aeYoink.responseText = '';
        _aeYoink.resolve = resolve;
        _aeYoink.reject = reject;
        // [v1.22.1] Cleared here and captured in onContextBuilt, so this attempt only ever
        // accepts hook events belonging to the generation it actually started.
        _aeYoink.continuityId = null;
        diagBudgetSnapshot('YOINK', null);   // [DIAG] pre-read for this yoink; closed in onGenerationEnd
        api.v1.editor.generate().catch(function(ygErr) {
            _aeYoink.active = false;
            _aeYoink.resolve = null;
            _aeYoink.reject = null;
            _aeYoink.continuityId = null;
            // [v0.9.7.12] Surface rate-limit errors as a human-readable toast rather
            // than letting the raw NAI error bubble silently to the log.
            const ygEMsg = String((ygErr && ygErr.message) || ygErr || '');
            if (ygEMsg.toLowerCase().indexOf('limit') >= 0 || ygEMsg.toLowerCase().indexOf('budget') >= 0) {
                api.v1.ui.toast('Generation limit reached. Wait a moment before retrying.', { type: 'warning', autoClose: 5000 });
            }
            reject(ygErr);
        });
    });
}

// [v1.21.0 YOINK-HARDEN] Cheap non-Latin/CJK drift heuristic — not a language detector,
// just a signal that generation derailed into another script entirely. Users reported
// the World-Build Wizard occasionally outputting Chinese and/or bullet-pointed junk;
// root cause hypothesis is that executeYoinkGenerationAttempt rides whatever model the
// story's live generation settings currently point at, but NAI's api.v1 docs state
// role-tagged system/user/assistant messages are only currently supported by glm-4-6
// for scripted generation (see api.v1.generate / api.v1.generationParameters docs).
var AE_NONLATIN_DRIFT_RE = /[\u3040-\u30FF\u3400-\u4DBF\u4E00-\u9FFF\uAC00-\uD7AF\uF900-\uFAFF]/;

interface AEYoinkOptions {
    // Optional pass/fail check on the raw response (e.g. "contains NAME:"). A failing
    // check triggers the same one-shot corrective retry as language-drift detection.
    validator?: (raw: string) => boolean;
    // [v2.20.0 GENDIAG] Which generator/feature (and often character) this call belongs
    // to, for diagGenRecord() — see the [DIAG GEN] block above. Defaults to 'untagged'
    // when omitted; every call site in this file passes one.
    tag?: string;
}

// [v1.22.1 YOINK-WATCHDOG] Root cause of the July 2026 "wizard freezes all generation"
// report: NAI's own generation pipeline can wedge (observed as "Encoder Worker Timeout"
// in the browser console) WITHOUT ever calling onGenerationEnd. Every prior layer of
// this system — the _aeYoink.active guard, the v1.21.0 model-pin's try/finally restore,
// even the pre-existing onGenerationEnd catch-block failsafe — only runs in response to
// a NAI hook actually firing. None of them protect against NAI never calling back at
// all. A single stuck generation therefore left BOTH _aeYoink.active AND the pinned
// model (glm-4-6) stuck forever: every later normal story turn silently skipped AE's
// world-state injection (onBeforeContextBuild's `if (_aeYoink.active) return;` guard)
// AND ran on the wrong model, while every later wizard call was rejected outright.
//
// Fix has two independent parts:
//   1. A genuine client-side timeout (AE_YOINK_TIMEOUT_MS), via Promise.race against
//      api.v1.timers.sleep — NOT dependent on any NAI hook ever firing. On timeout we
//      force-recover _aeYoink ourselves rather than waiting for cleanup that may never
//      come.
//   2. Force-recovery must not corrupt a NEWER call that starts after we give up on the
//      old one. onContextBuilt/onResponse/onGenerationEnd all carry NAI's own per-
//      generation `continuityId`; we capture it when a yoink's context is built and
//      every subsequent hook checks it before touching _aeYoink, so a late event from
//      an abandoned generation is recognized as orphaned and ignored instead of
//      resolving (or corrupting the response buffer of) whatever call is active by then.
//      See onContextBuilt / onResponse / onGenerationEnd below.
var AE_YOINK_TIMEOUT_MS = 90000;

// [v1.22.1] The model pin is the prime suspect for triggering the encoder wedge in the
// first place — every yoink call was forcing a model switch (and switch-back) even
// when nothing needed it, and glm-4-6 uses a different tokenizer than most NAI story
// models, making repeated switching a plausible way to destabilize the encoder worker.
// Defaulting OFF until confirmed safe. The watchdog above is needed regardless of this
// setting — NAI's pipeline can wedge independent of any model-switching.
var AE_YOINK_MODEL_PIN_ENABLED = false;

function ygTimeoutRejection(ms: number): Promise<never> {
    return api.v1.timers.sleep(ms).then(function() {
        throw new Error('Yoink generation timed out after ' + Math.round(ms / 1000) + 's (encoder/generation pipeline appears stuck) \u2014 recovered automatically.');
    });
}

// Runs one attempt bounded by AE_YOINK_TIMEOUT_MS. If the timeout wins, the underlying
// attempt is NOT cancelled (NAI's api.v1 exposes no cancellation for editor.generate())
// — it may still be physically running — so we force-recover _aeYoink ourselves here
// rather than leaving that to cleanup code that may never run. Any state the abandoned
// call's own late callbacks would have touched is now guarded by continuityId (see
// hooks below), so this recovery cannot corrupt whatever call runs next.
async function ygAttemptWithWatchdog(msgs: any[], tag?: string): Promise<string> {
    try {
        return await Promise.race([executeYoinkGenerationAttempt(msgs), ygTimeoutRejection(AE_YOINK_TIMEOUT_MS)]);
    } catch (ygTimeoutErr) {
        if (_aeYoink.active) {
            api.v1.error('[AE:wizard] yoink watchdog fired (tag=' + (tag || 'untagged') + ') \u2014 force-recovering stuck generation state:', ygTimeoutErr);
            // [v1.2.0 WIZMODE] Remember this generation's id (if captured) so any late
            // output/end-event is still caught by the onResponse/onGenerationEnd zombie
            // check even after wizard mode has since exited.
            if (_aeYoink.continuityId) _wizZombieIds[_aeYoink.continuityId] = true;
            _aeYoink.active = false;
            _aeYoink.resolve = null;
            _aeYoink.reject = null;
            _aeYoink.continuityId = null;
            // [v1.2.0 WIZMODE] Don't leave a pending mode-exit blocked forever on a
            // generation that may never call back — resolve it now, bounded by this
            // same watchdog timeout.
            if (_wizModeExitPending) { aeCompleteWizardModeExit().catch(function(e) { api.v1.error('[AE:wizard] mode-exit completion after watchdog failed:', e); }); }
        }
        throw ygTimeoutErr;
    }
}

// [v2.20.0 GENDIAG] Classifies a thrown yoink error as worth one immediate same-messages
// retry. Root cause of the "Generate All From Concept Dump" report: a thrown error on the
// FIRST attempt (observed as AbortError, surfacing from NAI's own generation pipeline via
// api.v1.editor.generate() — see executeYoinkGenerationAttempt) used to skip straight past
// ALL retry logic below and fail the whole call on one transient hiccup. Excluded from
// retry: our OWN deterministic state guards (already-in-progress / editor-busy / budget-
// floor), which will reject identically on an immediate retry, and our own watchdog
// timeout, which already waited AE_YOINK_TIMEOUT_MS once — retrying blind risks doubling
// the wait for a pipeline that may be genuinely wedged. Everything else (AbortError and
// any other error NAI's pipeline can throw) is treated as transient and worth one retry.
function ygIsRetryableError(e: any): boolean {
    let msg = String((e && (e as any).message) || e || '');
    if (msg.indexOf('already in progress') >= 0) return false;
    if (msg.indexOf('Editor is busy') >= 0) return false;
    if (msg.indexOf('budget is low') >= 0) return false;
    if (msg.indexOf('timed out after') >= 0) return false;
    return true;
}

// [v1.21.0 YOINK-HARDEN, v1.22.1 YOINK-WATCHDOG, v2.20.0 GENDIAG] Orchestrates a yoink
// generation with defensive layers on top of executeYoinkGenerationAttempt, added after
// reports of the World-Build Wizard drifting into non-English output and dot-point
// formatting, batch generators silently returning zero parsed items, (v1.22.1) NAI's
// generation pipeline wedging and freezing all further generation, wizard or normal, and
// (v2.20.0) a single transient AbortError failing the whole call outright:
//
//   1. MODEL PIN (best-effort, off by default — see AE_YOINK_MODEL_PIN_ENABLED): when
//      enabled, snapshots api.v1.generationParameters, skips the update entirely if
//      already on glm-4-6 (avoids needless switching churn), pins for the duration of
//      this call, restores the snapshot in finally. The finally is now reliable even on
//      a stuck generation, because ygAttemptWithWatchdog guarantees the await it wraps
//      resolves or rejects within AE_YOINK_TIMEOUT_MS no matter what NAI's backend does.
//   2. LANGUAGE GUARD: appends an English-only instruction to the first system message,
//      once, on top of each call's existing format rules.
//   3. ERROR RETRY (new in v2.20.0): if the FIRST attempt throws (rather than returning
//      bad output), ygIsRetryableError() decides whether it's worth one same-messages
//      retry — see that function's comment. A non-retryable or twice-failing error still
//      propagates to the caller exactly as before; callers' existing catch blocks are
//      unaffected.
//   4. VALIDATE + ONE CORRECTIVE RETRY: once a response comes back (first attempt or the
//      error retry), checks the raw response against AE_NONLATIN_DRIFT_RE and the optional
//      caller-supplied validator. On failure (or an empty response), retries the SAME
//      messages once more (also watchdog-bounded) with a corrective out-of-band line
//      appended, then returns whatever that produced. Callers' existing empty/malformed-
//      output handling is unchanged.
//   5. DIAGNOSTICS (new in v2.20.0): every outcome — success, empty, or a propagated error
//      — is recorded via diagGenRecord() (tag from opts.tag, defaulting to 'untagged') so
//      it shows up in the shared ring buffer alongside the DIRECT path (aeDiagGenerate).
//      See the [DIAG GEN] block above and buildGenDiagContent() (Section 24 area) for the
//      viewer.
async function executeYoinkGeneration(messages: any[], opts?: AEYoinkOptions): Promise<string> {
    let ygTag = (opts && opts.tag) || 'untagged';
    let ygT0 = Date.now();
    let ygB0o = diagBudO(), ygB0i = diagBudI();
    let ygMessages = messages.slice();
    if (ygMessages.length > 0 && ygMessages[0] && ygMessages[0].role === 'system') {
        ygMessages[0] = { role: 'system', content: String(ygMessages[0].content || '') + '\n\nRespond in English only, regardless of any other language present in the reference context.' };
    }

    let ygPrior: any = null;
    if (AE_YOINK_MODEL_PIN_ENABLED) {
        try { ygPrior = await api.v1.generationParameters.get(); }
        catch (ygGetErr) { api.v1.log('[AE:wizard] generationParameters.get failed, skipping model pin:', ygGetErr); }

        if (ygPrior && ygPrior.model !== 'glm-4-6') {
            try { await api.v1.generationParameters.update({ model: 'glm-4-6' }); }
            catch (ygPinErr) { api.v1.log('[AE:wizard] glm-4-6 pin failed, continuing on current model:', ygPinErr); ygPrior = null; }
        } else if (ygPrior) {
            ygPrior = null;   // already on glm-4-6 — nothing to restore, nothing to skip past.
        }
    }

    try {
        let ygRaw = '';
        let ygErrorRetried = false;
        try {
            ygRaw = await ygAttemptWithWatchdog(ygMessages, ygTag);
        } catch (ygFirstErr) {
            if (!ygIsRetryableError(ygFirstErr)) {
                diagGenRecord({ tag: ygTag, method: 'yoink', startedAt: ygT0, ms: Date.now() - ygT0,
                    outcome: 'error', errorName: String((ygFirstErr && (ygFirstErr as any).name) || 'Error'),
                    errorMessage: String((ygFirstErr && (ygFirstErr as any).message) || ygFirstErr),
                    retried: false, driftDetected: false, validatorFailed: false, outLen: 0,
                    budgetOut: ygB0o, budgetIn: ygB0i });
                throw ygFirstErr;
            }
            api.v1.log('[AE:wizard] yoink attempt failed (' + String((ygFirstErr && (ygFirstErr as any).name) || 'Error') + ': ' + String((ygFirstErr && (ygFirstErr as any).message) || ygFirstErr) + ') \u2014 retrying once (tag=' + ygTag + ')');
            ygErrorRetried = true;
            try {
                ygRaw = await ygAttemptWithWatchdog(ygMessages, ygTag);
            } catch (ygSecondErr) {
                diagGenRecord({ tag: ygTag, method: 'yoink', startedAt: ygT0, ms: Date.now() - ygT0,
                    outcome: 'error', errorName: String((ygSecondErr && (ygSecondErr as any).name) || 'Error'),
                    errorMessage: String((ygSecondErr && (ygSecondErr as any).message) || ygSecondErr),
                    retried: true, driftDetected: false, validatorFailed: false, outLen: 0,
                    budgetOut: ygB0o, budgetIn: ygB0i });
                throw ygSecondErr;
            }
        }

        let ygEmpty = !ygRaw || !ygRaw.trim();
        let ygDrift = !ygEmpty && AE_NONLATIN_DRIFT_RE.test(ygRaw);
        let ygInvalid = !ygEmpty && !!(opts && opts.validator) && !opts.validator(ygRaw);
        let ygCorrectiveRetried = false;
        if (ygEmpty || ygDrift || ygInvalid) {
            ygCorrectiveRetried = true;
            let ygRetryMessages = ygMessages.slice();
            ygRetryMessages.push({ role: 'user', content: '[Your previous response broke format or used non-English text. Respond in English only, in plain prose, with no bullet points, lists, or markdown. Follow the FORMAT above exactly.]' });
            try {
                let ygRetryRaw = await ygAttemptWithWatchdog(ygRetryMessages, ygTag);
                if (ygRetryRaw && ygRetryRaw.trim()) ygRaw = ygRetryRaw;
            } catch (ygRetryErr) {
                api.v1.log('[AE:wizard] corrective retry failed, keeping first-attempt output:', ygRetryErr);
            }
        }
        diagGenRecord({ tag: ygTag, method: 'yoink', startedAt: ygT0, ms: Date.now() - ygT0,
            outcome: (ygRaw && ygRaw.trim()) ? 'ok' : 'empty', errorName: '', errorMessage: '',
            retried: ygErrorRetried || ygCorrectiveRetried, driftDetected: ygDrift, validatorFailed: ygInvalid,
            outLen: (ygRaw || '').length, budgetOut: ygB0o, budgetIn: ygB0i });
        return ygRaw;
    } finally {
        if (ygPrior) {
            let ygRestore: any = { model: ygPrior.model };
            if (ygPrior.max_tokens !== undefined) ygRestore.max_tokens = ygPrior.max_tokens;
            if (ygPrior.temperature !== undefined) ygRestore.temperature = ygPrior.temperature;
            if (ygPrior.top_p !== undefined) ygRestore.top_p = ygPrior.top_p;
            if (ygPrior.top_k !== undefined) ygRestore.top_k = ygPrior.top_k;
            if (ygPrior.frequency_penalty !== undefined) ygRestore.frequency_penalty = ygPrior.frequency_penalty;
            if (ygPrior.presence_penalty !== undefined) ygRestore.presence_penalty = ygPrior.presence_penalty;
            if (ygPrior.min_p !== undefined) ygRestore.min_p = ygPrior.min_p;
            try { await api.v1.generationParameters.update(ygRestore); }
            catch (ygRestoreErr) { api.v1.error('[AE:wizard] failed to restore generation params after yoink pin:', ygRestoreErr); }
        }
    }
}
var ae_sbcInFlight = false;  // [v0.9.36] a scene-state broadcast is running
var ae_sbcPending  = false;  // [v0.9.36] another scene-state broadcast was requested while one ran
var ae_cdbInFlight = false;  // [v0.9.36] a character-data broadcast is running
var ae_cdbPending  = false;  // [v0.9.36] another character-data broadcast was requested while one ran
var ae_pendingGenerate = false; // [v0.9.37] a move effect requested generation; the top-level handler fires it once after ALL effects

// ── Bridge Communication State ────────────────────────────────────────────────
// isBridgeReady: set true after first successful EVT_HANDSHAKE_ACK.
// engineScriptId is not stored here (this IS the engine); the bridge stores it.
var isBridgeReady = false;

// Debounce timers for broadcast functions (Section 18).
// Both functions are called frequently (on every save); debouncing prevents storms.
var _sceneBroadcastTimeout: any = null;
var _charDataBroadcastTimeout: any = null;

// ── Character Visual Cache ────────────────────────────────────────────────────
// [CHANGE] Renamed from cachedCharConfigs (bridge roster data) to cachedCharVisuals
// (engine character visual fields). Now populated TWO ways:
//   1. On init: seeded from storyStorage so the HUD has data before the bridge connects.
//   2. On EVT_CHAR_SYNC_PUSH: bridge can push overrides (kept for legacy compat).
// getCharacterData() reads from this cache. Bridge reads it via EVT_CHAR_DATA_SYNC.
var cachedCharVisuals: CharacterVisualRecord[] = [];

// ── Image Settings State ──────────────────────────────────────────────────────
// Loaded from api.v1.storage (global, not story-bound) by loadImageSettings().
var imagePromptFields: ImagePromptField[] = [];
var globalSettings: GlobalImageSettings = {
    autoDownload: false,
    contextSize: DEFAULT_CTX,
    architectPrompt: DEFAULT_ARCH,
    architectAutoSnap: true
};

// ── NAI Sidebar Modal Handles ─────────────────────────────────────────────────
// Handles for the NAI-side modal windows (GM authoring tools).
// Each is set when a modal opens and nulled when it closes.
var charEditModalHandle: any   = null;   // character editor modal
var configModalHandle: any     = null;   // global config/settings modal
var entityEditModalHandle: any = null;   // entity/location editor modal
var editingCharId: string | null   = null;  // ID of the character currently open in charEditModal
var editingEntityId: string | null = null;  // ID of the entity currently open in entityEditModal

// ============================================================================
// SECTION 4 — UTILITY FUNCTIONS
// Pure helpers and factory functions with no side effects.
// These are called throughout the script and must be defined before first use.
// ============================================================================


// ── ID Generation ─────────────────────────────────────────────────────────────

function generateId(): string {
    // Generates a collision-resistant ID from timestamp + random suffix.
    // Used for all new records (characters, entities, rules, milestones, etc.).
    return Date.now().toString(36) + Math.random().toString(36).substring(2);
}

// [v1.6.3 ICON-LIB] The entity `icon` field is free text shared by the engine and the bridge.
// The bridge can resolve a bare library name (e.g. "crown") to an SVG glyph; the engine's
// native labels can't, and would render the literal word ("crown Cave"). aeIconPfx returns a
// label prefix ONLY for glyph icons (emoji / non-ASCII symbols), suppressing bare ASCII
// library-name icons so native labels stay clean while the bridge shows the SVG. Returns the
// icon plus a trailing space, or '' when there is no glyph to show.
function aeIconPfx(icon?: string): string {
    if (!icon) return '';
    let s = String(icon).trim();
    if (!s) return '';
    // A library name is plain ASCII word characters (letters/digits/underscore/hyphen). Any
    // codepoint outside ASCII (emoji, arrows, symbols) marks a real glyph and is kept.
    let isBareName = /^[A-Za-z0-9_-]+$/.test(s);
    return isBareName ? '' : (s + ' ');
}

// ── World-Build Wizard: assemble + commit the Memory block ───────────────────
// [vNEXT] Assembles enabled, non-blank, memory-targeted sections into the static
// Memory block ("[ Label ]\n<content>", blank-separated) and returns it. Style and
// any other 'an'-targeted sections are NOT included here — they commit separately.
function assembleWizardMemory(sections: WizardMemorySection[]): string {
    let blocks: string[] = [];
    for (let s of (sections || [])) {
        if (!s || s.target !== 'memory') continue;
        if (!s.enabled) continue;
        let body = (s.content || '').trim();
        if (!body) continue;
        blocks.push('[ ' + s.label + ' ]\n' + body);
    }
    return blocks.join('\n\n');
}

// [vNEXT] Assembles 'an'-targeted sections (e.g. Style) into an Author's Note body.
function assembleWizardAuthorNote(sections: WizardMemorySection[]): string {
    let blocks: string[] = [];
    for (let s of (sections || [])) {
        if (!s || s.target !== 'an') continue;
        if (!s.enabled) continue;
        let body = (s.content || '').trim();
        if (!body) continue;
        // [v2.19.0 WIZARD-2.0] If the body is already a complete bracketed AN block
        // (e.g. a generated ATTG line "[ Author: ...; Genre: ... ]"), emit it verbatim;
        // otherwise wrap it as a labelled "[ Label: body ]" block (the Style default).
        if (body.charAt(0) === '[' && body.charAt(body.length - 1) === ']') {
            blocks.push(body);
        } else {
            blocks.push('[ ' + s.label + ': ' + body + ' ]');
        }
    }
    return blocks.join('\n\n');
}

// [v0.9.7.3 AN-FIX] Commits the assembled wizard sections to the real NAI surfaces.
// Memory sections OVERWRITE the Memory field (static world canon — stable, written once).
// AN sections (Style, etc.) are written into a NAMED REGION of the Author's Note using
// AE_WIZ_AN_SENTINEL so they coexist with the scene-state block injected at generation
// time by onBeforeContextBuild. The scene block is NEVER stored in the persisted AN —
// it is appended ephemerally per-generation. The wizard region always sits FIRST in the
// persisted AN; the scene block is appended AFTER it at generation time so it has the
// highest recency weight in the AN slot.
async function commitWizardMemory(cfg: GlobalConfig): Promise<boolean> {
    try {
        let mem = assembleWizardMemory(cfg.wizardSections || []);
        await api.v1.memory.set(mem);

        let wizAN = assembleWizardAuthorNote(cfg.wizardSections || []);

        // Read the current persisted AN and strip both managed regions before rewriting.
        // Safe to call repeatedly (idempotent). Strip scene sentinel first (defensive),
        // then strip any prior wizard region.
        let existingAN = '';
        try { existingAN = (await api.v1.an.get()) || ''; } catch (_eRead) {}

        // Strip stale scene block (defensive — should never be persisted).
        let sceneMarker = '\n\n' + AE_AN_SENTINEL;
        let sceneIdx = existingAN.lastIndexOf(sceneMarker);
        if (sceneIdx >= 0) {
            existingAN = existingAN.substring(0, sceneIdx);
        } else if (existingAN.indexOf(AE_AN_SENTINEL) === 0) {
            existingAN = '';
        }
        existingAN = existingAN.replace(/\s+$/, '');

        // Strip any prior wizard region.
        let wizMarker = '\n\n' + AE_WIZ_AN_SENTINEL;
        let wizIdx = existingAN.lastIndexOf(wizMarker);
        if (wizIdx >= 0) {
            existingAN = existingAN.substring(0, wizIdx);
        } else if (existingAN.indexOf(AE_WIZ_AN_SENTINEL) === 0) {
            existingAN = '';
        }
        existingAN = existingAN.replace(/\s+$/, '');

        // Re-assemble: any non-AE base content + wizard region (if any AN sections enabled).
        let finalAN: string;
        if (wizAN.trim()) {
            let wizRegion = AE_WIZ_AN_SENTINEL + '\n' + wizAN.trim();
            finalAN = existingAN ? (existingAN + '\n\n' + wizRegion) : wizRegion;
        } else {
            finalAN = existingAN;
        }

        await api.v1.an.set(finalAN);
        return true;
    } catch (e) {
        api.v1.error('[AE:wizard] commitWizardMemory error:', e);
        return false;
    }
}

// ── World-Build Wizard: context assembly ─────────────────────────────────────
// [vNEXT] Builds the read-only context preamble for a wizard chat from its selected
// sources: project concept fields, other wizard chats, lorebook entries, and recent
// story text. Each source is clearly delimited so the model treats it as reference.
// ── World-Build Wizard: token budget + transcript distillation (v1.23.0) ─────
// Until now buildWizardContext concatenated every linked chat's FULL raw transcript with
// no cap of any kind. That is invisible on a 28k-context account and fatal on a 12k one:
// a few long brainstorm chats linked as context sources can exceed the whole window, and
// NAI's handling of an oversized messages[] override is undocumented. Since almost every
// yoink call is [system, user] with ALL formatting rules living in the system message,
// losing the front of that array would strip the rules and produce exactly the
// ungoverned, malformed output this subsystem has been chasing.
//
// Two defences, applied together:
//   1. DISTILL — a linked chat contributes settled facts, not its deliberation. Cached on
//      the chat record; regenerated only when the chat grows.
//   2. CAP — measure the assembled blocks with the real tokenizer against the account's
//      real ceiling (api.v1.maxTokens is subscription-tier aware, so no tier is hardcoded)
//      and drop whole low-priority blocks until it fits.

// Reserve for the persona + format rules that ride in the system message alongside ctx.
var AE_CTX_RESERVE_INSTRUCTIONS = 2000;
// Reserve for the model's own output.
var AE_CTX_RESERVE_OUTPUT = 1200;
// Never hand back a budget smaller than this; below it, context is useless anyway.
var AE_CTX_MIN_BUDGET = 800;
// Chats shorter than this stay raw: distilling 3 messages costs a generation and saves
// nothing, and a short exchange is already close to "just the facts".
var AE_DISTILL_MIN_MESSAGES = 6;

// Which model's tokenizer/ceiling applies. editor.generate() runs on the story's live
// model, so ask generationParameters rather than assuming.
async function wizActiveModel(): Promise<string> {
    try {
        let gp = await api.v1.generationParameters.get();
        if (gp && gp.model) return String(gp.model);
    } catch (eModel) { api.v1.log('[AE:wizard] could not read active model, assuming glm-4-6:', eModel); }
    return 'glm-4-6';
}

// Real token count, with a coarse chars/4 fallback if the tokenizer is unavailable.
async function wizCountTokens(text: string, model: string): Promise<number> {
    let t = String(text || '');
    if (!t) return 0;
    try {
        let ids = await api.v1.tokenizer.encode(t, model);
        if (ids && typeof ids.length === 'number') return ids.length;
    } catch (eTok) { api.v1.log('[AE:wizard] tokenizer.encode failed, estimating:', eTok); }
    return Math.ceil(t.length / 4);
}

// Context tokens available for reference material, after instructions, output, and (for a
// live chat turn) the transcript that will be replayed alongside it.
async function wizContextBudget(model: string, ownMessagesTokens: number): Promise<number> {
    let ceiling = 0;
    try { ceiling = await api.v1.maxTokens(model); }
    catch (eMax) { api.v1.log('[AE:wizard] maxTokens unavailable, skipping context cap:', eMax); return 0; }
    if (!ceiling || ceiling <= 0) return 0;
    let budget = ceiling - AE_CTX_RESERVE_INSTRUCTIONS - AE_CTX_RESERVE_OUTPUT - (ownMessagesTokens || 0);
    if (budget < AE_CTX_MIN_BUDGET) budget = AE_CTX_MIN_BUDGET;
    return budget;
}

// A context block with a drop priority. Higher survives longer.
interface WizCtxBlock {
    text: string;
    priority: number;
    label: string;
}

// [v1.23.0] Trim whole blocks (never mid-block) until the total fits the budget. Drops
// the LOWEST priority first, and among equal priorities the LAST added first, so the
// project header and the earliest-linked chats survive longest. A budget of 0 means the
// ceiling could not be determined — in that case nothing is trimmed, matching pre-v1.23.0
// behaviour rather than guessing.
async function wizTrimBlocksToBudget(blocks: WizCtxBlock[], budget: number, model: string): Promise<{ kept: WizCtxBlock[]; dropped: string[]; tokens: number }> {
    let kept = blocks.slice();
    let dropped: string[] = [];
    if (!budget || budget <= 0) {
        let rawTotal = 0;
        for (let b of kept) rawTotal += await wizCountTokens(b.text, model);
        return { kept: kept, dropped: dropped, tokens: rawTotal };
    }

    let counts: number[] = [];
    for (let b of kept) counts.push(await wizCountTokens(b.text, model));
    let total = 0;
    for (let n of counts) total += n;

    while (total > budget && kept.length > 0) {
        // Find the drop candidate: lowest priority, latest index among ties.
        let victim = -1;
        for (let i = 0; i < kept.length; i++) {
            if (victim < 0) { victim = i; continue; }
            if (kept[i].priority < kept[victim].priority) victim = i;
            else if (kept[i].priority === kept[victim].priority) victim = i;
        }
        if (victim < 0) break;
        // The project header is priority 100 and must never be the last thing standing
        // that gets dropped; if only it remains, stop and accept the overage.
        if (kept.length === 1 || kept[victim].priority >= 100) break;
        total -= counts[victim];
        dropped.push(kept[victim].label);
        kept.splice(victim, 1);
        counts.splice(victim, 1);
    }

    return { kept: kept, dropped: dropped, tokens: total };
}

// [v1.23.0 DISTILL] Turn a chat transcript into declarative world facts. Reframed rather
// than merely constrained: the model is recording current world state, not summarizing a
// conversation. The contrastive pair targets SURFACE FORM (how a sentence is phrased),
// which is safe to name explicitly — unlike naming unwanted story CONCEPTS, which risks
// priming them. Abandoned ideas are simply absent from the output.
var AE_DISTILL_SYSTEM = [
    'You are recording the current state of a story world as established so far. You are not summarizing a conversation.',
    'Write only settled facts, in the present tense, as plain declarative prose. State each fact as though it has always been true of this world.',
    'Where a point was revised, record only the version that stands now.',
    'WRONG: "After some back-and-forth, they settled on a near-future dystopia."',
    'RIGHT: "The setting is a near-future dystopia where the water supply is privately owned."',
    'WRONG: "One idea raised was a rival guild, though it was set aside."',
    'RIGHT: (omit it entirely)',
    'Preserve every proper name, number, and concrete detail that still stands. Write in English. Use plain prose with no markdown, bullet points, headers, or numbering.',
    'Output only the world facts. No preamble, no commentary.'
].join('\n\n');

// Distill one chat, caching on the record. Returns notes text, or '' if distillation is
// unavailable — callers fall back to the raw transcript rather than losing the context.
// NOTE: this itself runs a yoink generation, so it must only ever be called BEFORE the
// caller starts its own yoink (buildWizardContext always runs first — see callers).
// allowGenerate=false returns only an existing cache and never generates, which is what
// the read-only context preview needs: pressing Preview must not spend a generation.
async function getWizardChatNotes(chat: WizardChat, allowGenerate: boolean): Promise<string> {
    if (!chat || !chat.messages || !chat.messages.length) return '';
    let msgCount = chat.messages.length;
    if (msgCount < AE_DISTILL_MIN_MESSAGES) return '';   // short chat: caller uses raw

    let cache = chat.notesCache;
    if (cache && cache.sourceMsgCount === msgCount && (cache.text || '').trim()) return cache.text;
    if (!allowGenerate) return '';   // stale or absent cache, and we may not generate

    let transcript = chat.messages.map(function(m) { return '[' + m.role.toUpperCase() + '] ' + m.content; }).join('\n');
    let notes = '';
    try {
        notes = await executeYoinkGeneration([
            { role: 'system', content: AE_DISTILL_SYSTEM },
            { role: 'user', content: transcript + '\n\nRecord the world facts established above.' }
        ], { tag: 'wizChatDistill:' + (chat.title || chat.id) });
    } catch (eDistill) {
        api.v1.error('[AE:wizard] distillation failed for chat "' + chat.title + '", falling back to raw transcript:', eDistill);
        return '';
    }
    notes = (notes || '').trim();
    if (!notes) return '';

    let fresh = await loadWizardChat(chat.id);
    if (fresh) {
        fresh.notesCache = { text: notes, sourceMsgCount: msgCount, updatedAt: Date.now() };
        await saveWizardChat(fresh);
    }
    return notes;
}

// [v1.23.0] allowDistill=false makes this a pure read (no generation), for the preview.
// The returned string is the same one the generator will receive.
async function buildWizardContext(chat: WizardChat, cfg: GlobalConfig, allowDistill?: boolean): Promise<string> {
    let res = await buildWizardContextDetailed(chat, cfg, allowDistill !== false);
    return res.text;
}

// [v1.23.0] Assembles the context as priority-tagged blocks, distills linked chats, then
// trims to the account's real token ceiling. Returns the joined text plus what was cut,
// so the preview can show it and the user can see WHY something is missing.
async function buildWizardContextDetailed(chat: WizardChat, cfg: GlobalConfig, allowDistill: boolean): Promise<{ text: string; dropped: string[]; tokens: number; budget: number; model: string }> {
    let blocks: WizCtxBlock[] = [];

    let pName = (cfg.projectName || '').trim();
    let pGenre = (cfg.projectGenre || '').trim();
    let pConcept = (cfg.projectConcept || '').trim();
    if (pName || pGenre || pConcept) {
        let head: string[] = [];
        if (pName)    head.push('Project: ' + pName);
        if (pGenre)   head.push('Genre: ' + pGenre);
        if (pConcept) head.push('Concept: ' + pConcept);
        blocks.push({ text: '--- PROJECT ---\n' + head.join('\n'), priority: 100, label: 'Project header' });
    }

    // [v1.23.0] Linked chats contribute their SETTLED FACTS, not their deliberation.
    // Falling back to the raw transcript when distillation is unavailable keeps the old
    // behaviour rather than silently dropping the chat entirely.
    let ctxIds = chat.contextChatIds || [];
    if (ctxIds.length > 0) {
        let allChats = await loadWizardChats();
        for (let cid of ctxIds) {
            let oc = allChats.find(function(c) { return c.id === cid; });
            if (!oc || !oc.messages || oc.messages.length === 0) continue;
            let notes = await getWizardChatNotes(oc, allowDistill);
            if (notes) {
                blocks.push({ text: '--- WORLD FACTS FROM: ' + oc.title + ' ---\n' + notes, priority: 80, label: 'Chat notes: ' + oc.title });
            } else {
                let transcript = oc.messages.map(function(m) { return '[' + m.role.toUpperCase() + '] ' + m.content; }).join('\n');
                blocks.push({ text: '--- CHAT: ' + oc.title + ' ---\n' + transcript, priority: 80, label: 'Chat transcript: ' + oc.title });
            }
        }
    }

    let loreIds = chat.lorebookEntryIds || [];
    for (let lid of loreIds) {
        try {
            let entry = await api.v1.lorebook.entry(lid);
            if (entry && entry.text && entry.text.trim()) {
                let lname = (entry as any).displayName || (entry as any).name || 'Lorebook Entry';
                blocks.push({ text: '--- LOREBOOK: ' + lname + ' ---\n' + entry.text.trim(), priority: 50, label: 'Lorebook: ' + lname });
            }
        } catch (e) { api.v1.log('[AE:wizard] lorebook context read failed for ' + lid); }
    }

    // [v0.9.99] Per-chat character context — the chat decides, independent of each
    // character's global charContextEnabled flag. Formatted straight from the record.
    let charCtxIds = chat.characterIds || [];
    for (let chCid of charCtxIds) {
        try {
            let cc = await loadCharacter(chCid);
            if (!cc) continue;
            let ccLines: string[] = [];
            if (cc.briefDescription) ccLines.push(cc.briefDescription);
            if (cc.species || cc.age || cc.gender || cc.occupationRole) ccLines.push([cc.species, cc.age, cc.gender, cc.occupationRole].filter(Boolean).join(', '));
            if (cc.personalityCore) ccLines.push('Personality: ' + cc.personalityCore);
            if (cc.background) ccLines.push('Background: ' + cc.background);
            if (ccLines.length) blocks.push({ text: '--- CHARACTER: ' + cc.name + ' ---\n' + ccLines.join('\n'), priority: 60, label: 'Character: ' + cc.name });
        } catch (eCc) { api.v1.log('[AE:wizard] character context read failed for ' + chCid); }
    }

    if (chat.includeStory) {
        let story = await getRecentStoryText(2000);
        if (story.trim()) blocks.push({ text: '--- RECENT STORY ---\n' + story.trim(), priority: 10, label: 'Recent story' });
    }

    // Cap against the account's REAL ceiling. maxTokens() is subscription-tier aware, so a
    // 12k Scroll account trims where a 28k account does not, with no tier hardcoded here.
    let model = await wizActiveModel();
    // One encode call, not one per message: this is only a reserve, and the transcript is
    // trimmed properly (per-message) by runWizardChatTurn.
    let ownJoined = (chat.messages || []).map(function(m) { return m.content; }).join('\n');
    let ownTokens = ownJoined ? await wizCountTokens(ownJoined, model) : 0;
    let budget = await wizContextBudget(model, ownTokens);
    let trimmed = await wizTrimBlocksToBudget(blocks, budget, model);

    if (trimmed.dropped.length) {
        api.v1.log('[AE:wizard] context over budget (' + budget + ' tok); dropped: ' + trimmed.dropped.join(', '));
    }

    return {
        text: trimmed.kept.map(function(b) { return b.text; }).join('\n\n'),
        dropped: trimmed.dropped,
        tokens: trimmed.tokens,
        budget: budget,
        model: model
    };
}

// ── World-Build Wizard: chat turn (yoink) ────────────────────────────────────
// [vNEXT] Appends the user's message, runs a budget-free yoink generation against
// the topic persona + assembled context + transcript, appends the assistant reply,
// and persists the chat. Returns the assistant text (or null on failure).
async function runWizardChatTurn(chatId: string, userText: string): Promise<string | null> {
    let cfg = await loadConfig();
    let chat = await loadWizardChat(chatId);
    if (!chat) return null;
    // [DIAG] Budget diagnostics via typed commands — engine-only. /budgetlog spends no budget.
    let _diagCmd = (userText || '').trim().toLowerCase();
    if (AE_DIAG_BUDGET && (_diagCmd === '/budgetprobe' || _diagCmd === '/budgetlog')) {
        let _diagOut = _diagCmd === '/budgetprobe' ? await runBudgetProbe() : dumpBudgetLog();
        chat.messages.push({ role: 'user', content: userText.trim() });
        chat.messages.push({ role: 'assistant', content: _diagOut });
        await saveWizardChat(chat);
        return _diagOut;
    }
    // [v2.20.0 GENDIAG] /gendiag dumps the shared yoink+direct generation-call log (see
    // the [DIAG GEN] block near the top of the file); /gendiagclear resets it. Spends no
    // budget — pure in-memory ring buffer read/reset, same convention as /budgetlog.
    if (AE_DIAG_GEN && (_diagCmd === '/gendiag' || _diagCmd === '/gendiagclear')) {
        let _genDiagOut = _diagCmd === '/gendiagclear' ? (clearGenDiagLog(), 'Generation diagnostics log cleared.') : dumpGenDiagLog();
        chat.messages.push({ role: 'user', content: userText.trim() });
        chat.messages.push({ role: 'assistant', content: _genDiagOut });
        await saveWizardChat(chat);
        return _genDiagOut;
    }
    let topic = getWizardTopic(cfg, chat.topicId);
    let persona = topic ? topic.instructions : 'You are a helpful worldbuilding assistant. Keep replies short and conversational.';

    if (userText && userText.trim()) {
        chat.messages.push({ role: 'user', content: userText.trim() });
    }

    // [v1.2.0 WIZMODE] While mode is on, assemble the source context ONCE per chat and
    // reuse it — only the transcript (appended below) grows per turn. Recomputed fresh
    // the first time a chat is used after mode turns on; cleared entirely on mode exit
    // and whenever this chat's context selection changes (AE_WIZ_SET_CHAT_CONTEXT).
    let ctx: string;
    if (_aeWizardMode && _wizFrozenCtx[chatId] !== undefined) {
        ctx = _wizFrozenCtx[chatId];
    } else {
        ctx = await buildWizardContext(chat, cfg);
        if (_aeWizardMode) _wizFrozenCtx[chatId] = ctx;
    }
    let sysParts: string[] = [persona];
    if (ctx.trim()) {
        sysParts.push('The following is READ-ONLY reference context. Use it to inform your replies, but do not quote it back verbatim.\n\n' + ctx);
    }

    let msgs: any[] = [{ role: 'system', content: sysParts.join('\n\n') }];

    // [v1.23.0] The transcript is replayed in full on every turn and grows without bound.
    // On a 12k-context account a long chat can push the system message (which carries the
    // topic persona and all formatting rules) out of the window. Keep the seed message —
    // it frames the whole topic — plus as many of the MOST RECENT turns as fit, dropping
    // from the middle. buildWizardContext has already trimmed ctx against the same ceiling.
    let turnModel = await wizActiveModel();
    let ctxTokens = await wizCountTokens(sysParts.join('\n\n'), turnModel);
    let turnCeiling = 0;
    try { turnCeiling = await api.v1.maxTokens(turnModel); }
    catch (eTurnMax) { api.v1.log('[AE:wizard] maxTokens unavailable, replaying full transcript:', eTurnMax); }

    let history = chat.messages.slice();
    if (turnCeiling > 0) {
        let transcriptBudget = turnCeiling - ctxTokens - AE_CTX_RESERVE_OUTPUT;
        if (transcriptBudget < AE_CTX_MIN_BUDGET) transcriptBudget = AE_CTX_MIN_BUDGET;

        // Cheap chars/4 estimate first. Only pay for per-message tokenization when we are
        // plausibly near the ceiling, so a normal-length chat costs zero extra encode calls.
        let roughChars = 0;
        for (let rm of history) roughChars += (rm.content || '').length;
        let roughTokens = Math.ceil(roughChars / 4);

        if (roughTokens > transcriptBudget * 0.8) {
            let seed = (history.length > 0 && history[0].role === 'assistant') ? history[0] : null;
            let rest = seed ? history.slice(1) : history.slice();
            let seedTokens = seed ? await wizCountTokens(seed.content, turnModel) : 0;

            let keptRev: WizardChatMessage[] = [];
            let used = seedTokens;
            for (let i = rest.length - 1; i >= 0; i--) {
                let mt = await wizCountTokens(rest[i].content, turnModel);
                if (used + mt > transcriptBudget && keptRev.length > 0) break;
                used += mt;
                keptRev.push(rest[i]);
            }
            keptRev.reverse();
            let trimmedCount = rest.length - keptRev.length;
            history = seed ? [seed].concat(keptRev) : keptRev;
            if (trimmedCount > 0) api.v1.log('[AE:wizard] transcript over budget; dropped ' + trimmedCount + ' older message(s) from the middle.');
        }
    }

    for (let m of history) {
        msgs.push({ role: m.role, content: m.content });
    }

    let reply = '';
    try {
        reply = await executeYoinkGeneration(msgs, { tag: 'wizChatTurn:' + (chat.title || chatId) });
    } catch (e) {
        api.v1.error('[AE:wizard] chat turn generation failed:', e);
        return null;
    }
    reply = (reply || '').trim();
    if (!reply) return null;

    chat.messages.push({ role: 'assistant', content: reply });
    await saveWizardChat(chat);
    return reply;
}

// ── World-Build Wizard: per-section generation (yoink) ───────────────────────
// [vNEXT] Generates ONE memory section's content from a chat transcript, scoped hard
// to that section's instructions so sections never bleed into each other. Already-
// written sections are passed as read-only context to avoid overlap. Returns the
// generated text (or null on failure).
async function generateWizardSection(section: WizardMemorySection, ctx: string, cfg: GlobalConfig, priorSections: WizardMemorySection[], hint?: string): Promise<string | null> {
    let sys = [
        'You are writing the "' + section.label + '" section of a story\'s static world canon.',
        section.instructions,
        'CONSTRAINT: Write ONLY the content of this section. Do not restate this section\'s name as a heading before the content. Do not write any other section\'s content. Be concise and concrete.',
        'CRITICAL RULE: DO NOT use any markdown, bolding, italics, or bullet points. Output plain text only.'
    ].join('\n\n');

    let priorLines: string[] = [];
    for (let ps of (priorSections || [])) {
        if (ps.id === section.id) continue;
        let body = (ps.content || '').trim();
        if (body) priorLines.push('[' + ps.label + '] ' + body);
    }

    let usrParts: string[] = [];
    if (ctx.trim()) usrParts.push(ctx);
    if (priorLines.length > 0) usrParts.push('--- ALREADY-WRITTEN SECTIONS (do not repeat these; stay in your own scope) ---\n' + priorLines.join('\n'));
    if (hint && hint.trim()) usrParts.push('--- EXTRA GUIDANCE FOR THIS REGENERATION ---\n' + hint.trim());
    usrParts.push('Now write the "' + section.label + '" section.');

    let msgs: any[] = [
        { role: 'system', content: sys },
        { role: 'user', content: usrParts.join('\n\n') }
    ];

    let result = '';
    try {
        result = await executeYoinkGeneration(msgs, { tag: 'wizSection:' + section.label });
    } catch (e) {
        api.v1.error('[AE:wizard] section generation failed (' + section.label + '):', e);
        return null;
    }
    return (result || '').trim() || null;
}

// [v2.11.0] Regenerate ONE section in place (does not commit memory). sourceChatIds
// mirrors the multi-source context model every other generator tab uses (Species/
// Factions/etc via buildWizardMultiContext) — was single-chat-only before, which also
// meant the bridge's AE_WIZ_REGEN_ENTITY handler was silently truncating its own
// already-array-shaped sourceChatIds payload down to just the first id. Writes the
// result into cfg.wizardSections.
async function regenerateWizardSection(sectionId: string, sourceChatIds: string[], hint: string): Promise<string | null> {
    let cfg = await loadConfig();
    let section = (cfg.wizardSections || []).find(function(s) { return s.id === sectionId; });
    if (!section) return null;
    let ctx = await buildWizardMultiContext(sourceChatIds || [], cfg);
    let prior = cfg.wizardSections || [];
    let gen = await generateWizardSection(section, ctx, cfg, prior, hint);
    if (!gen) return null;
    await mutConfig(function(c) {
        let target = (c.wizardSections || []).find(function(s) { return s.id === sectionId; });
        if (target) target.content = gen;
    });
    return gen;
}

// [v0.9.81] Build wizard context from MULTIPLE source chats (multi-select). Constructs a
// synthetic chat whose contextChatIds are the selected chats, so buildWizardContext pulls
// each selected chat's transcript (as a "--- CHAT: title ---" block) plus the project header.
// includeStory is on if ANY selected chat has it; selected chats' lorebook links are unioned.
// [v1.23.0] allowDistill=false makes this a pure read (used by the context preview).
async function buildWizardMultiContext(chatIds: string[], cfg: GlobalConfig, allowDistill?: boolean): Promise<string> {
    let res = await buildWizardMultiContextDetailed(chatIds, cfg, allowDistill !== false);
    return res.text;
}

async function buildWizardMultiContextDetailed(chatIds: string[], cfg: GlobalConfig, allowDistill: boolean): Promise<{ text: string; dropped: string[]; tokens: number; budget: number; model: string }> {
    let selIds = (chatIds || []).filter(Boolean);
    let allMultiChats = await loadWizardChats();
    let anyMultiStory = false;
    let unionLore: string[] = [];
    // [v2.6.0] Ids that resolve to NEITHER a classic chat NOR (checked below) fall through
    // to a direct lorebook-entry read — this is how a CE Chats entry (or any other saved
    // lorebook source a generator tab lets the user check) becomes generator context with
    // no owning classic-chat record required.
    let directLoreBlocks: WizCtxBlock[] = [];
    for (let sid of selIds) {
        let sc = allMultiChats.find(function(c) { return c.id === sid; });
        if (sc) {
            if (sc.includeStory) anyMultiStory = true;
            for (let lid of (sc.lorebookEntryIds || [])) { if (unionLore.indexOf(lid) < 0) unionLore.push(lid); }
            continue;
        }
        try {
            let le = await api.v1.lorebook.entry(sid);
            if (le && le.text && le.text.trim()) {
                let leName = (le as any).displayName || 'Saved Chat';
                directLoreBlocks.push({ text: '--- SAVED CHAT: ' + leName + ' ---\n' + le.text.trim(), priority: 80, label: 'Saved chat: ' + leName });
            }
        } catch (eLoreDirect) { api.v1.log('[AE:wizard] direct lorebook source read failed for ' + sid); }
    }
    let classicIds = selIds.filter(function(id) { return allMultiChats.some(function(c) { return c.id === id; }); });
    let synthChat: WizardChat = { id: 'transient', topicId: '', title: '', messages: [], contextChatIds: classicIds, includeStory: anyMultiStory, lorebookEntryIds: unionLore, createdAt: 0, updatedAt: 0 };
    let base = await buildWizardContextDetailed(synthChat, cfg, allowDistill);
    if (directLoreBlocks.length === 0) return base;
    // Splice the directly-selected lorebook sources in alongside the already-assembled
    // (already-budgeted) base text, then re-trim the combination to the same ceiling.
    let combined: WizCtxBlock[] = directLoreBlocks.concat([{ text: base.text, priority: 70, label: 'Chat/project context' }]);
    let trimmed2 = await wizTrimBlocksToBudget(combined, base.budget, base.model);
    return {
        text: trimmed2.kept.map(function(b) { return b.text; }).join('\n\n'),
        dropped: base.dropped.concat(trimmed2.dropped),
        tokens: trimmed2.tokens,
        budget: base.budget,
        model: base.model
    };
}

// [v1.22.0 PREVIEW] Return the exact reference context a batch generation for these
// source chats would receive, plus a short header describing what is (and is not)
// present. Read-only: no generation, no storage writes, no side effects.
//
// This exists because buildWizardContext's output was previously invisible. When a
// generation comes back empty or malformed, the first question is "was any context
// actually attached?" — and neither the user nor the author could answer it. An empty
// preview is now self-evident.
async function buildWizardContextPreview(sourceChatIds: string[]): Promise<string> {
    let cfg = await loadConfig();
    let res: { text: string; dropped: string[]; tokens: number; budget: number; model: string };
    try {
        // allowDistill=false: pressing Preview must never spend a generation.
        res = await buildWizardMultiContextDetailed(sourceChatIds || [], cfg, false);
    } catch (ePrev) {
        api.v1.error('[AE:wizard] context preview build failed:', ePrev);
        return 'Context preview failed to build. See the script log for details.';
    }
    let body = (res.text || '').trim();
    if (!body) {
        return 'NO CONTEXT ATTACHED.\n\nGeneration will run on the topic instructions alone, with nothing about your world.\n\nTo fix: set a project name/genre/concept in the Setup tab, or check one or more context-source chats above.';
    }

    let headLines: string[] = [];
    headLines.push('--- CONTEXT PREVIEW ---');
    headLines.push('This is the reference context the generator will receive, verbatim.');
    headLines.push('Model: ' + res.model);
    if (res.budget > 0) {
        let pct = Math.round((res.tokens / res.budget) * 100);
        headLines.push('Size: ' + res.tokens + ' of ' + res.budget + ' available context tokens (' + pct + '%).');
    } else {
        headLines.push('Size: ~' + res.tokens + ' tokens (context ceiling unavailable, so no cap is applied).');
    }
    if (res.dropped.length) {
        headLines.push('');
        headLines.push('TRIMMED TO FIT \u2014 these blocks were dropped, lowest priority first:');
        for (let dl of res.dropped) headLines.push('  - ' + dl);
    }
    // A stale/absent notes cache shows as a raw transcript here but will be distilled on
    // the real run, so the live context is usually SMALLER than this preview. Say so
    // rather than letting the number look alarming.
    if (body.indexOf('--- CHAT: ') >= 0) {
        headLines.push('');
        headLines.push('Note: chats shown as raw transcripts have not been distilled yet. They will be condensed into world facts on the next generation, which usually shrinks this considerably.');
    }
    headLines.push('');
    return headLines.join('\n') + body;
}

// [v1.22.0 PREVIEW] A "Preview context" button UIPart for any wizard generator tab.
// Opens a read-only modal showing exactly what buildWizardMultiContext will hand the
// generator for the given source chats. Pure read; safe to press at any time.
function wizContextPreviewPart(effSrcIds: string[]): UIPart {
    return { type: 'button', text: '\ud83d\udd0d Preview context', style: { width: '100%', marginBottom: '8px', fontSize: '10px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() {
        let previewText = await buildWizardContextPreview(effSrcIds);
        await openEngineModal({ title: 'Context Preview', size: 'large', content: [
            { type: 'multilineTextInput', initialValue: previewText, disabled: true, style: { minHeight: '380px', fontSize: '11px', lineHeight: '1.45' } } as UIPart
        ]});
    } } as UIPart;
}

// [v2.6.0] Extra checkbox rows letting a generator tab's context-source picker ALSO
// select a saved CE Chats lorebook entry directly (no owning classic chat record needed
// — buildWizardMultiContextDetailed resolves these ids straight against the lorebook).
// Shares the same srcKey/redraw plumbing as the classic-chat checkboxes above it.
function _wizCeSourceCheckboxParts(ceEntries: any[], storedSrcIds: string[], srcKey: string, redraw: () => Promise<void>): UIPart[] {
    if (!ceEntries || ceEntries.length === 0) return [];
    let out: UIPart[] = [];
    out.push({ type: 'text', text: 'Saved CE Chats (lorebook)', style: { fontSize: '9px', opacity: '0.5', marginTop: '4px', marginBottom: '2px' } });
    ceEntries.forEach(function(e: any) {
        let onSrc = storedSrcIds.indexOf(e.id) >= 0;
        out.push({ type: 'checkboxInput', label: (e.displayName || 'Untitled chat'), initialValue: onSrc, onChange: async function(val: boolean) {
            let curRaw = await api.v1.tempStorage.getOrDefault(srcKey, '') as string;
            let curIds: string[] = [];
            try { let pj = JSON.parse(curRaw || '[]'); if (Array.isArray(pj)) curIds = pj.filter(Boolean); } catch (eCe) { curIds = []; }
            if (val && curIds.indexOf(e.id) < 0) curIds.push(e.id);
            else if (!val) curIds = curIds.filter(function(x) { return x !== e.id; });
            await api.v1.tempStorage.set(srcKey, JSON.stringify(curIds));
            await redraw();
        } } as UIPart);
    });
    return out;
}

// [v1.22.0 STAGING] The staging review block for a generator tab. Renders every staged
// draft of `kind` as an editable box (fields driven by WIZ_DRAFT_FIELDS), with a
// per-draft Discard, and a Commit all / Discard all footer.
//
// Returns an empty array when nothing is staged, so a tab can unconditionally spread it.
// Nothing here writes records: edits land on the draft, and only "Commit all" calls
// commitStagedDrafts().
async function wizStagingParts(kind: string, redrawFn: () => Promise<void>): Promise<UIPart[]> {
    let stagedDrafts = await loadWizardDraftsOfKind(kind);
    if (!stagedDrafts.length) return [];

    let schema = WIZ_DRAFT_FIELDS[kind] || [];
    let stageParts: UIPart[] = [];

    stageParts.push({ type: 'text', text: '\ud83e\uddea Staged ' + wizKindLabel(kind) + ' (' + stagedDrafts.length + ') \u2014 not saved yet', style: { fontSize: '11px', fontWeight: 'bold', marginTop: '10px', marginBottom: '2px', color: '#e0c068' } });
    stageParts.push({ type: 'text', text: 'Review and edit below. Nothing is written to your world (or the lorebook) until you commit.', style: { fontSize: '9px', opacity: '0.5', marginBottom: '6px' } });

    stagedDrafts.forEach(function(sd) {
        let sdId = sd.id;
        let sdBox: UIPart[] = [];

        schema.forEach(function(fld) {
            let fKey = fld.key;
            let curVal = sd.fields[fKey] || '';
            if (fld.multiline) {
                // [v1.22.3] Size to content. Lore/concept fields routinely run 5-8 sentences;
                // a fixed 44px box turned every staging card into a cramped scroll surface.
                sdBox.push({ type: 'multilineTextInput', label: fld.label, initialValue: curVal, placeholder: '(' + fld.label.toLowerCase() + ')', style: { minHeight: wizTextareaHeight(curVal, 56, 300), marginBottom: '3px', fontSize: '11px', lineHeight: '1.45' }, onChange: async function(v: string) {
                    await updateWizardDraftField(sdId, fKey, v);
                } } as UIPart);
            } else {
                sdBox.push({ type: 'textInput', initialValue: curVal, placeholder: fld.label, style: { margin: '0 0 3px 0', fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) {
                    await updateWizardDraftField(sdId, fKey, v);
                } } as UIPart);
            }
        });

        // [v1.22.2] Per-draft actions. Regenerate reuses this draft's own source chats and
        // excludes only its own name from the do-not-recreate list, so it can legitimately
        // produce the same subject again with better prose. A failed regen leaves the draft
        // untouched rather than blanking it.
        sdBox.push({ type: 'row', style: { gap: '5px', marginTop: '2px' }, content: [
            { type: 'button', text: '\u267b Regenerate', style: { flex: '1 1 0', margin: 0, fontSize: '10px', backgroundColor: 'rgba(136,204,255,0.12)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                api.v1.ui.toast('Regenerating\u2026', { id: 'wiz-regen', autoClose: false, type: 'info' });
                let rgOk = await regenerateWizardDraft(sdId);
                api.v1.ui.toast(rgOk ? 'Regenerated.' : 'Regeneration failed \u2014 draft left unchanged.', { id: 'wiz-regen', type: rgOk ? 'success' : 'error', autoClose: 2200 });
                await redrawFn();
            } },
            { type: 'button', text: '\ud83d\uddd1 Discard', style: { flex: '1 1 0', margin: 0, fontSize: '10px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() {
                await discardWizardDraft(sdId);
                await redrawFn();
            } }
        ] } as UIPart);

        stageParts.push({ type: 'box', style: { backgroundColor: 'rgba(224,192,104,0.06)', border: '1px solid rgba(224,192,104,0.25)', padding: '7px', borderRadius: '5px', marginBottom: '6px' }, content: sdBox } as UIPart);
    });

    let stagedCount = stagedDrafts.length;
    stageParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '10px' }, content: [
        { type: 'button', text: '\u2705 Commit all (' + stagedCount + ')', style: { flex: '2 1 0', margin: 0, fontSize: '11px', fontWeight: 'bold', backgroundColor: 'rgba(126,200,160,0.22)', color: '#7ec8a0', border: '1px solid rgba(126,200,160,0.5)' }, disabledWhileCallbackRunning: true, callback: async function() {
            api.v1.ui.toast('Committing ' + wizKindLabel(kind) + '\u2026', { id: 'wiz-stage-commit', autoClose: false, type: 'info' });
            let madeN = await commitStagedDrafts(kind);
            let leftN = (await loadWizardDraftsOfKind(kind)).length;
            let commitMsg = madeN > 0 ? ('Committed ' + madeN + ' ' + wizKindLabel(kind) + '.') : 'Nothing committed.';
            if (leftN > 0) commitMsg += ' ' + leftN + ' left staged (needs a name).';
            api.v1.ui.toast(commitMsg, { id: 'wiz-stage-commit', type: madeN > 0 ? 'success' : 'error', autoClose: 3000 });
            await redrawFn();
        } },
        { type: 'button', text: '\ud83d\uddd1 Discard all', style: { flex: '1 1 0', margin: 0, fontSize: '10px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() {
            let goneN = await discardAllWizardDrafts(kind);
            api.v1.ui.toast('Discarded ' + goneN + ' staged ' + wizKindLabel(kind) + '.', { type: 'info', autoClose: 2000 });
            await redrawFn();
        } }
    ] } as UIPart);

    return stageParts;
}

// ── World-Build Wizard: species / faction batch generation (yoink) ───────────
// [vNEXT] Generate a batch of named items (species or factions), each with a short
// lore description, in one budget-free pass. Output is parsed from a simple
// NAME:/LORE: block format. Returns an array of {name, description} (may be < count
// if the model returns fewer). kind is 'species' or 'faction' for prompt phrasing.
// [v1.22.0 STAGING] avoidNames carries names discarded during this staging session
// (tombstones) plus any staged-but-uncommitted names, so a regenerate after deleting a
// bad entry does not hand the same entry straight back.
async function generateEntityBatch(kind: string, count: number, sourceChatIds: string[], avoidNames?: string[]): Promise<{ name: string; description: string }[]> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let noun = (kind === 'faction') ? 'factions (organizations, powers, or groups)' : 'species (peoples or creature-types)';

    // [v0.9.80] Feed existing same-kind names in so the batch never recreates them.
    let batchExistingNames = ((kind === 'faction') ? (cfg.factions || []) : (cfg.species || []))
        .map(function(x: any) { return (x && x.name) ? String(x.name).trim() : ''; })
        .filter(Boolean);
    for (let avName of (avoidNames || [])) {
        if (avName && batchExistingNames.indexOf(avName) < 0) batchExistingNames.push(avName);
    }

    let batchSysLines: string[] = [
        'You are generating ' + noun + ' for a story world.',
        'Produce EXACTLY ' + count + ' distinct entries that fit the world and feel like they belong together without being repetitive.',
        'CRITICAL RULE: DO NOT use any markdown. DO NOT bold headers or names. Output plain text only.'
    ];
    if (batchExistingNames.length) {
        batchSysLines.push('These ' + (kind === 'faction' ? 'factions' : 'species') + ' ALREADY EXIST — do NOT recreate, rename, or duplicate any of them. Generate entirely new, distinct entries:\n' + batchExistingNames.map(function(bn) { return '- ' + bn; }).join('\n'));
    }
    batchSysLines.push('FORMAT: For each entry output exactly:\nNAME: <short proper name>\nLORE: <a full, substantial description (roughly 5-8 sentences, one or two solid paragraphs) covering what it is, what matters about it, and the specific details that distinguish it>\nSeparate entries with a line containing only ---');
    batchSysLines.push('Draw on the specific names, ideas, and details raised in the brainstorming chat below — do not stay generic.');
    batchSysLines.push('Output ONLY the entries in that format. No preamble, no numbering, no extra commentary.');
    let sys = batchSysLines.join('\n\n');

    let usrParts: string[] = [];
    if (ctx.trim()) usrParts.push(ctx);
    usrParts.push('Generate ' + count + ' ' + (kind === 'faction' ? 'factions' : 'species') + ' now.');

    let raw = '';
    try {
        raw = await executeYoinkGeneration([{ role: 'system', content: sys }, { role: 'user', content: usrParts.join('\n\n') }], { validator: function(r) { return /NAME:/i.test(r); }, tag: 'entityBatch:' + kind });
    } catch (e) {
        api.v1.error('[AE:wizard] batch generation failed (' + kind + '):', e);
        return [];
    }

    // Parse NAME:/LORE: blocks split on --- lines.
    let out: { name: string; description: string }[] = [];
    let chunks = (raw || '').split(/\n-{3,}\n/);
    for (let ch of chunks) {
        let nameMatch = ch.match(/NAME:\s*(.+)/i);
        let loreMatch = ch.match(/LORE:\s*([\s\S]+)/i);
        if (!nameMatch) continue;
        let nm = nameMatch[1].trim();
        let lore = loreMatch ? loreMatch[1].trim() : '';
        // Trim a trailing stray --- or NAME: bleed if the split missed.
        lore = lore.replace(/\n-{3,}[\s\S]*$/, '').replace(/\nNAME:[\s\S]*$/i, '').trim();
        if (nm) out.push({ name: nm, description: lore });
    }
    return out;
}

// [vNEXT] Generate (or regenerate) the lore description for ONE named species/faction,
// scoped to that single item, with optional hint. Returns description text or null.
async function generateEntityLore(kind: string, name: string, sourceChatIds: string[], hint: string): Promise<string | null> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let kindNoun = (kind === 'faction') ? 'faction' : 'species';
    let sys = [
        'You are writing the lore description for a single ' + kindNoun + ' named "' + name + '" in a story world.',
        'Write a full, substantial description (roughly 5-8 sentences, one or two solid paragraphs) covering what it is, what matters about it, and the specific details that distinguish it. Stay focused on THIS ' + kindNoun + ' only, and draw on the specific ideas and details in the reference context rather than staying generic.',
        'Output ONLY the description prose. Do not begin with the name or a label.'
    ].join('\n\n');
    let usrParts: string[] = [];
    if (ctx.trim()) usrParts.push(ctx);
    if (hint && hint.trim()) usrParts.push('--- EXTRA GUIDANCE ---\n' + hint.trim());
    usrParts.push('Write the description for "' + name + '" now.');
    let result = '';
    try {
        result = await executeYoinkGeneration([{ role: 'system', content: sys }, { role: 'user', content: usrParts.join('\n\n') }], { tag: 'entityLore:' + kind + ':' + name });
    } catch (e) {
        api.v1.error('[AE:wizard] entity lore generation failed (' + name + '):', e);
        return null;
    }
    return (result || '').trim() || null;
}

// ── World-Build Wizard: stage / commit (v1.22.0 STAGING) ─────────────────────
// [v1.22.0] Every batch kind now follows: stage*Batch (generate -> park as drafts) ->
// user reviews/edits/discards -> commitStagedDrafts (write records + lorebook, clear
// drafts + tombstones). The legacy run*Batch wrappers preserve the old one-shot
// behavior for existing callers (notably the bridge's AE_WIZ_GENERATE handler) by
// staging and then committing ONLY the ids they just created — so a one-shot call never
// sweeps up drafts the user is still reviewing in the native wizard.

// Names currently staged-but-uncommitted for a kind. Combined with tombstones to form
// the do-not-recreate list, so a second Generate pass extends the batch rather than
// duplicating it.
// [v1.22.2] Do-not-recreate list for a kind = names of drafts STILL STAGED, so a second
// Generate press extends the batch rather than duplicating what is already on screen.
// Discarded names are deliberately NOT included (see discardWizardDraft).
// excludeDraftId omits one draft's own name — used by per-draft Regenerate, which must
// be free to produce the same place/person again with better prose.
async function avoidNamesForKind(kind: string, excludeDraftId?: string): Promise<string[]> {
    let staged = await loadWizardDraftsOfKind(kind);
    let merged: string[] = [];
    for (let sd of staged) {
        if (excludeDraftId && sd.id === excludeDraftId) continue;
        let mn = (sd.fields.name || '').trim();
        if (mn && merged.indexOf(mn) < 0) merged.push(mn);
    }
    return merged;
}

// Stage N species/factions as drafts. Returns the created draft ids (empty on failure).
async function stageEntityBatch(kind: string, count: number, sourceChatIds: string[]): Promise<string[]> {
    let avoid = await avoidNamesForKind(kind);
    let items = await generateEntityBatch(kind, count, sourceChatIds, avoid);
    if (!items.length) return [];
    let rows = items.map(function(it) { return { name: it.name, description: it.description || '' }; });
    return await addWizardDrafts(kind, rows, sourceChatIds, null);
}

// Stage N minor-NPC archetypes as drafts.
// [CE-STRIP v2.1.6] stageArchetypeBatch() removed — Bestiary + Item Templates cut.

// Stage N item templates as drafts.
// [CE-STRIP v2.1.6] stageItemBatch() removed — Bestiary + Item Templates cut.

// Stage N locations as drafts under parentId. parentId rides on the draft record so a
// commit long after staging still files them in the right place in the tree.
async function stageLocationBatch(count: number, parentId: string | null, sourceChatIds: string[]): Promise<string[]> {
    let avoid = await avoidNamesForKind('location');
    let items = await generateLocationBatch(count, parentId, sourceChatIds, avoid);
    if (!items.length) return [];
    let rows = items.map(function(it) { return { name: it.name, description: it.description || '', lore: it.lore || '' }; });
    return await addWizardDrafts('location', rows, sourceChatIds, parentId || null);
}

// [v1.22.3 REPROMPT] Re-roll the assistant's most recent reply without the user having to
// type anything. Drops the trailing assistant message, then re-runs the turn against the
// unchanged transcript — runWizardChatTurn already skips pushing a user message when
// userText is empty, so the same last user message is answered again.
//
// Guards: a chat with no user message yet has nothing to answer (the seed message is an
// assistant turn and must never be popped, or the topic's framing is lost). If generation
// fails, the popped reply is restored so a failed re-roll never destroys the old one.
async function regenerateWizardChatReply(chatId: string): Promise<string | null> {
    let chat = await loadWizardChat(chatId);
    if (!chat || !chat.messages || !chat.messages.length) return null;

    let hasUser = chat.messages.some(function(m) { return m.role === 'user'; });
    if (!hasUser) return null;

    let popped: any = null;
    let last = chat.messages[chat.messages.length - 1];
    if (last && last.role === 'assistant') {
        popped = chat.messages.pop();
        await saveWizardChat(chat);
    }

    let reply = await runWizardChatTurn(chatId, '');
    if (!reply && popped) {
        // Restore: re-load (runWizardChatTurn may have saved) and push the old reply back.
        let restored = await loadWizardChat(chatId);
        if (restored) {
            restored.messages.push(popped);
            await saveWizardChat(restored);
        }
    }
    return reply;
}

// [v1.22.2 CHAR-STAGE] Stage N characters as name + concept-dump drafts. The expensive
// per-character field extraction is deferred to commit, so a user who dislikes a name or
// concept can fix or discard it before any generation is spent structuring it.
async function stageCharacterBatch(count: number, sourceChatIds: string[]): Promise<string[]> {
    let names = await generateCharacterNames(count, sourceChatIds);
    if (!names.length) return [];
    let rows: { [k: string]: string }[] = [];
    for (let nm of names) {
        let dump = '';
        try { dump = await generateCharacterDump(nm, sourceChatIds); }
        catch (eCharDump) { api.v1.error('[AE:wizard] character dump failed for "' + nm + '":', eCharDump); }
        rows.push({ name: nm, dump: dump || '' });
    }
    return await addWizardDrafts('character', rows, sourceChatIds, null);
}

// [v1.22.2] Regenerate a single staged draft in place, reusing the chat sources it was
// generated from. Its own name is excluded from the do-not-recreate list so the model may
// legitimately produce the same subject again with better prose. Returns false on failure
// and leaves the existing draft untouched, so a bad regen never destroys good content.
async function regenerateWizardDraft(draftId: string): Promise<boolean> {
    let all = await loadWizardDrafts();
    let target = all.find(function(d) { return d.id === draftId; });
    if (!target) return false;

    let rgKind = target.kind;
    let rgSrc = target.sourceChatIds || [];
    let rgAvoid = await avoidNamesForKind(rgKind, draftId);
    let rgFields: { [k: string]: string } | null = null;

    try {
        if (rgKind === 'species' || rgKind === 'faction') {
            let rows = await generateEntityBatch(rgKind, 1, rgSrc, rgAvoid);
            if (rows.length) rgFields = { name: rows[0].name, description: rows[0].description || '' };
        // [CE-STRIP v2.1.6] 'archetype'/'item' draft-regen branches removed — Bestiary + Item Templates cut.
        } else if (rgKind === 'location') {
            let rows = await generateLocationBatch(1, target.parentId || null, rgSrc, rgAvoid);
            if (rows.length) rgFields = { name: rows[0].name, description: rows[0].description || '', lore: rows[0].lore || '' };
        } else if (rgKind === 'character') {
            // Keep the name the user is already looking at; regenerate only the concept.
            let rgName = (target.fields.name || '').trim();
            if (!rgName) return false;
            let rgDump = await generateCharacterDump(rgName, rgSrc);
            if (rgDump && rgDump.trim()) rgFields = { name: rgName, dump: rgDump.trim() };
        }
    } catch (eRegen) {
        api.v1.error('[AE:wizard] regenerate failed for draft ' + draftId + ':', eRegen);
        return false;
    }

    if (!rgFields) return false;
    let fresh = await loadWizardDrafts();
    let live = fresh.find(function(d) { return d.id === draftId; });
    if (!live) return false;
    live.fields = rgFields;
    await saveWizardDrafts(fresh);
    return true;
}

// [v1.22.0 STAGING] The single irreversible write path. Commits staged drafts of a kind
// to real records (+ lorebook entries where that kind has them), then removes exactly
// the committed drafts and clears the kind's tombstones. Drafts with a blank name are
// skipped and LEFT STAGED rather than silently dropped, so the user can see and fix them.
//
// onlyIds restricts the commit to a specific set (used by the legacy run*Batch wrappers).
// Returns the number of records actually created.
async function commitStagedDrafts(kind: string, onlyIds?: string[]): Promise<number> {
    let drafts = await loadWizardDraftsOfKind(kind);
    if (onlyIds && onlyIds.length) {
        drafts = drafts.filter(function(d) { return onlyIds.indexOf(d.id) >= 0; });
    }
    if (!drafts.length) return 0;

    let committedIds: string[] = [];
    let made = 0;

    for (let d of drafts) {
        let dName = (d.fields.name || '').trim();
        if (!dName) continue;   // leave nameless drafts staged for the user to fix

        try {
            if (kind === 'species') {
                let spId = 'sp_' + generateId();
                await mutConfig(function(c) {
                    if (!c.species) c.species = [];
                    c.species.push({ id: spId, name: dName, description: d.fields.description || '', lorebookTags: [] });
                });
                await createLinkedSpeciesLorebookEntry(spId).catch(function() {});
            } else if (kind === 'faction') {
                let facId = 'fac_' + generateId();
                await mutConfig(function(c) {
                    if (!c.factions) c.factions = [];
                    c.factions.push({ id: facId, name: dName, description: d.fields.description || '', relationshipStates: ['Hostile', 'Wary', 'Neutral', 'Friendly', 'Allied'], lorebookTags: [] });
                });
                await createLinkedFactionLorebookEntry(facId).catch(function() {});
            } else if (kind === 'archetype') {
                let archId = 'arch_' + generateId();
                await mutConfig(function(c) {
                    if (!(c as any).npcArchetypes) (c as any).npcArchetypes = [];
                    (c as any).npcArchetypes.push({ id: archId, name: dName, briefTemplate: d.fields.brief || '', charResourceDefs: [], actionInstances: [], tagSubscriptions: [] });
                });
            } else if (kind === 'item') {
                let itmId = 'item_' + generateId();
                await mutConfig(function(c) {
                    if (!(c as any).itemArchetypes) (c as any).itemArchetypes = [];
                    (c as any).itemArchetypes.push({ id: itmId, name: dName, descriptionTemplate: d.fields.description || '', tagSubscriptions: [], spawnTarget: 'inventory' });
                });
            } else if (kind === 'location') {
                await createLocationEntity(dName, d.fields.description || '', d.fields.lore || '', d.parentId || null);
            } else if (kind === 'character') {
                // [v1.22.2 CHAR-STAGE] Structured fields are derived HERE, from the concept
                // dump as the user left it. If field extraction fails, the character is still
                // created with its name + dump rather than being lost, and the dump remains
                // visible on the record for a manual per-field regenerate.
                let chDump = d.fields.dump || '';
                let chFields: WizardCharFields | null = null;
                try { chFields = await generateCharacterFields(dName, chDump); }
                catch (eChFields) { api.v1.error('[AE:wizard] field extraction failed for "' + dName + '":', eChFields); }
                await createWizardCharacter(dName, chDump, chFields);
            } else {
                api.v1.log('[AE:wizard] commitStagedDrafts unknown kind: ' + kind);
                continue;
            }
            committedIds.push(d.id);
            made++;
        } catch (eCommit) {
            // Leave this draft staged so the user can retry; keep going with the rest.
            api.v1.error('[AE:wizard] commit failed for staged ' + kind + ' "' + dName + '":', eCommit);
        }
    }

    await removeWizardDrafts(committedIds);
    return made;
}

// [vNEXT] Batch-create species records from a chat: generate, push records, and
// create+link a lorebook entry (with tags = name) for each. Returns count created.
// [v1.22.0 STAGING] Now a thin stage -> commit wrapper. Commits only its own new drafts.
async function runWizardSpeciesBatch(count: number, sourceChatIds: string[]): Promise<number> {
    let newIds = await stageEntityBatch('species', count, sourceChatIds);
    if (!newIds.length) return 0;
    return await commitStagedDrafts('species', newIds);
}

// [vNEXT] Batch-create faction records from a chat. Factions also get the default
// standing track (relationshipStates) so the existing index-based standing works.
// [v1.22.0 STAGING] Now a thin stage -> commit wrapper. Commits only its own new drafts.
async function runWizardFactionsBatch(count: number, sourceChatIds: string[]): Promise<number> {
    let newIds = await stageEntityBatch('faction', count, sourceChatIds);
    if (!newIds.length) return 0;
    return await commitStagedDrafts('faction', newIds);
}

// [vNEXT] Batch-create minor-NPC archetypes from a wizard chat: generate NAME +
// one-line BRIEF pairs and push NpcArchetypeDef records to cfg.npcArchetypes.
// Resources/tags start empty (edit in the Bestiary: "+ Default Resources", tags);
// no lorebook entry — archetypes are spawn templates, not world lore. Returns count.
// [v1.22.0 STAGING] Pure generator: parses and RETURNS archetypes, writing nothing.
// Committing to cfg.npcArchetypes is commitStagedDrafts()'s job.
// [CE-STRIP v2.1.6] generateArchetypeBatch() removed — Bestiary + Item Templates cut.

// [v1.22.0 STAGING] Legacy one-shot: stage then commit only the drafts just created.
// Retained for the bridge's AE_WIZ_GENERATE handler and any direct callers.
// [CE-STRIP v2.1.6] runWizardArchetypesBatch() removed — Bestiary + Item Templates cut.

// [v1.14.0 ITEMS] Generate item templates from a wizard chat: NAME + one-line DESC
// pairs. Mechanics (skill bonuses, actions, tags) start EMPTY by design and are filled
// in the Item Template editor \u2014 the model only authors the name + description, the
// same shallow-generation split the Bestiary uses.
// [v1.22.0 STAGING] Pure generator: parses and RETURNS item templates, writing nothing.
// Committing to cfg.itemArchetypes is commitStagedDrafts()'s job.
// [CE-STRIP v2.1.6] generateItemBatch() removed — Bestiary + Item Templates cut.

// [v1.22.0 STAGING] Legacy one-shot: stage then commit only the drafts just created.
// [CE-STRIP v2.1.6] runWizardItemsBatch() removed — Bestiary + Item Templates cut.

// [v0.9.80] Manually add a single blank species/faction record (default name, empty
// lore) and link a lorebook entry, so the user can rename it and then ⚡ Regen its
// fields — the regen path re-syncs the existing entry. Returns the new record id.
async function addBlankWizardEntity(kind: string): Promise<string> {
    let blankId = ((kind === 'faction') ? 'fac_' : 'sp_') + generateId();
    let blankName = (kind === 'faction') ? 'New Faction' : 'New Species';
    await mutConfig(function(c) {
        if (kind === 'faction') {
            if (!c.factions) c.factions = [];
            c.factions.push({ id: blankId, name: blankName, description: '', relationshipStates: ['Hostile', 'Wary', 'Neutral', 'Friendly', 'Allied'], lorebookTags: [] });
        } else {
            if (!c.species) c.species = [];
            c.species.push({ id: blankId, name: blankName, description: '', lorebookTags: [] });
        }
    });
    if (kind === 'faction') await createLinkedFactionLorebookEntry(blankId).catch(function() {});
    else await createLinkedSpeciesLorebookEntry(blankId).catch(function() {});
    return blankId;
}

// [vNEXT] Regenerate one species/faction's description in place and re-sync its
// lorebook entry. kind is 'species' or 'faction'. Returns the new text or null.
async function regenerateWizardEntity(kind: string, itemId: string, sourceChatIds: string[], hint: string): Promise<string | null> {
    let cfg = await loadConfig();
    let list: any[] = (kind === 'faction') ? (cfg.factions || []) : (cfg.species || []);
    let item = list.find(function(x) { return x.id === itemId; });
    if (!item) return null;
    let gen = await generateEntityLore(kind, item.name, sourceChatIds, hint);
    if (!gen) return null;
    await mutConfig(function(c) {
        let arr: any[] = (kind === 'faction') ? (c.factions || []) : (c.species || []);
        let t = arr.find(function(x) { return x.id === itemId; });
        if (t) t.description = gen;
    });
    if (kind === 'faction') await syncFactionLorebookEntry(itemId).catch(function() {});
    else await syncSpeciesLorebookEntry(itemId).catch(function() {});
    return gen;
}

// ── World-Build Wizard: Locations (tier model + generators) ───────────
// [v0.9.82] Depth of an entity from the world root (top-level/parentId-null = 0).
async function computeEntityTier(entityId: string): Promise<number> {
    let tierIdx = await loadEntityIndex();
    let depth = 0; let cur: string | null = entityId; let guard = 0;
    while (cur && guard < 64) {
        let tm = tierIdx.find(function(m) { return m.id === cur; });
        if (!tm || !tm.parentId) break;
        depth++; cur = tm.parentId; guard++;
    }
    return depth;
}

// [CE-STRIP v2.0.0] tierBandIndexForDepth / entryActionIdForDepth / syncTierTemplate
// removed — tier-travel cost templates cut with Actions + Travel. Locations no longer
// stamp an entryActionId.

// [v0.9.82] Yoink-generate a batch of locations as {name, description}. parentId null =
// top-level. Existing sibling names are fed in to avoid duplicates; the parent's own
// description anchors children. Multi-chat context via buildWizardMultiContext.
//
// [v1.18.0 LOCGEN] >>> PAIRED PROMPT: generateSceneLocation() (Items block, near
// >>> generateSceneItem) emits the SAME NAME/DESC/LORE contract from story context
// >>> instead of chat context, and parses it with the same regexes. If you change the
// >>> format instructions or the parse here, change them there too.
// [v1.22.0 STAGING] avoidNames carries tombstoned + staged-uncommitted names.
async function generateLocationBatch(count: number, parentId: string | null, sourceChatIds: string[], avoidNames?: string[]): Promise<{ name: string; description: string; lore: string }[]> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let parentEnt = parentId ? await loadEntity(parentId) : null;
    let locIdx = await loadEntityIndex();
    let existingLoc = locIdx.filter(function(m) { return m.type === 'location' && m.parentId === (parentId || null); }).map(function(m) { return m.name; }).filter(Boolean);
    for (let avLoc of (avoidNames || [])) {
        if (avLoc && existingLoc.indexOf(avLoc) < 0) existingLoc.push(avLoc);
    }
    let scopeNoun = parentEnt ? ('sub-locations inside "' + parentEnt.name + '"') : 'top-level locations (regions / major places) of the world';

    let locSysLines: string[] = [
        'You are generating ' + scopeNoun + ' for a story world.',
        'Produce EXACTLY ' + count + ' distinct locations that fit the world and belong together without being repetitive.',
        // [v1.22.2] The brainstorming chat is the AUTHORITY on which places to build, not
        // mere background flavour. Users reported discussing Hogwarts / Diagon Alley /
        // Hogsmeade and receiving unrelated inventions instead. State this first and
        // positively: name the places the chat names, and invent only to fill a shortfall.
        'The brainstorming chat below is your source of truth. If it names specific places, use those exact names and build those locations first, preserving the chat\'s own details about each. Invent additional locations only if the chat names fewer than ' + count + '.',
        'CRITICAL RULE: DO NOT use any markdown. DO NOT bold headers or names. Output plain text only.'
    ];
    if (parentEnt && (parentEnt.description || '').trim()) {
        locSysLines.push('They are all inside this parent location:\n' + parentEnt.name + ': ' + parentEnt.description.trim());
    }
    if (existingLoc.length) {
        // [v1.22.2] Scoped wording: these are records that already exist in the world, so
        // recreating one would make a duplicate. This list no longer contains names the
        // user merely discarded (v1.22.0 tombstones), which is what previously caused the
        // generator to be forbidden from producing the very places the chat was about.
        locSysLines.push('Locations with these names already exist in the world, so choose different ones \u2014 build any OTHER places the chat names:\n' + existingLoc.map(function(ln) { return '- ' + ln; }).join('\n'));
    }
    locSysLines.push('FORMAT: For each location output exactly:\nNAME: <short place name>\nDESC: <1-2 sentences capturing ONLY what a camera physically senses on arrival (light, texture, scale). No history.>\nLORE: <a full, comprehensive entry (roughly 5-8 sentences) covering history, significance, culture, and tensions>\nSeparate entries with a line containing only ---');
    locSysLines.push('Draw every name and detail from the brainstorming chat. Output ONLY the entries in the exact format requested. No preamble, no numbering, no commentary.');
    let locSys = locSysLines.join('\n\n');

    let locUsr: string[] = [];
    if (ctx.trim()) locUsr.push(ctx);
    // [v1.22.2] Restate the priority immediately before generation, where it carries the
    // most recency weight, rather than relying on the system message alone.
    locUsr.push('Generate ' + count + ' locations now, starting with the places named in the chat above.');

    let locRaw = '';
    try {
        locRaw = await executeYoinkGeneration([{ role: 'system', content: locSys }, { role: 'user', content: locUsr.join('\n\n') }], { validator: function(r) { return /NAME:/i.test(r); }, tag: 'locationBatch' + (parentEnt ? (':' + parentEnt.name) : '') });
    } catch (eLocGen) {
        api.v1.error('[AE:wizard] location batch generation failed:', eLocGen);
        return [];
    }

    let locOut: { name: string; description: string; lore: string }[] = [];
    let locChunks = (locRaw || '').split(/\n-{3,}\n/);
    for (let lch of locChunks) {
        let lnm = lch.match(/NAME:\s*(.+)/i);
        let lde = lch.match(/DESC:\s*([\s\S]+?)(?:\nLORE:|$)/i);
        let llo = lch.match(/LORE:\s*([\s\S]+)/i);
        if (!lnm) continue;
        let lName = lnm[1].trim();
        let lDesc = lde ? lde[1].trim() : '';
        lDesc = lDesc.replace(/\nLORE:[\s\S]*$/i, '').replace(/\n-{3,}[\s\S]*$/, '').replace(/\nNAME:[\s\S]*$/i, '').trim();
        let lLore = llo ? llo[1].trim() : '';
        lLore = lLore.replace(/\n-{3,}[\s\S]*$/, '').replace(/\nNAME:[\s\S]*$/i, '').trim();
        if (lName) locOut.push({ name: lName, description: lDesc, lore: lLore });
    }
    return locOut;
}

// [v1.18.0 LOCGEN] The ONE place a generated {name, description, lore} triple becomes a
// persisted `location` entity plus its linked lorebook entry. Two callers, deliberately:
//
//   runWizardLocationsBatch()  (directly below)  — authoring-time, wizard chat context,
//                                                  Yoink generation, N at a time.
//   spawnLocation()            (Items block, next to spawnItem/generateSceneItem) —
//                                                  in-play, story context, one at a time.
//
// >>> PAIRED CODE: if you add a field stamped onto new locations here, make sure BOTH
// >>> callers can supply it. If you change what a location needs at birth, this helper
// >>> is the only place to change it — do not re-inline entity assembly in a caller.
//
// Siblings need no connectedEntityIds edge: locationGraph derives lateral adjacency from
// a shared parentId (see "Lateral siblings" in buildSceneStatePayload).
async function createLocationEntity(name: string, description: string, lore: string, parentId: string | null): Promise<string> {
    let cle = makeDefaultEntity(name || 'New Location');
    cle.type = 'location';
    cle.parentId = parentId || null;
    cle.description = description || '';
    (cle as any).lorebookText = lore || '';
    // [CE-STRIP v2.1.5] entryActionId param/assignment removed — always dead, no consumer.
    await saveEntity(cle);
    if ((lore || '').trim()) { await createLinkedEntityLorebookEntry(cle.id).catch(function() {}); }
    return cle.id;
}

// [v0.9.82] Batch-create location entities under parentId, stamping each with the tier
// template for its depth. Returns the count created.
// [v1.22.0 STAGING] Legacy one-shot: stage then commit only the drafts just created.
// Tier/entry-action resolution now happens inside commitStagedDrafts, from the parentId
// carried on each draft record.
async function runWizardLocationsBatch(count: number, parentId: string | null, sourceChatIds: string[]): Promise<number> {
    let newIds = await stageLocationBatch(count, parentId || null, sourceChatIds);
    if (!newIds.length) return 0;
    return await commitStagedDrafts('location', newIds);
}

// [v0.9.82] Create one blank location under parentId. Returns id.
async function addBlankWizardLocation(parentId: string | null): Promise<string> {
    let le = makeDefaultEntity('New Location');
    le.type = 'location';
    le.parentId = parentId || null;
    await saveEntity(le);
    return le.id;
}

// [v0.9.83] Regenerate one location's short description AND comprehensive lorebook in a
// single pass; updates both fields and re-syncs (or creates) its lorebook entry.
async function regenerateWizardLocation(locId: string, sourceChatIds: string[], hint: string): Promise<string | null> {
    let ent = await loadEntity(locId);
    if (!ent) return null;
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let parentEnt = ent.parentId ? await loadEntity(ent.parentId) : null;
    let locSys = [
        'You are writing the entry for a single location named "' + ent.name + '"' + (parentEnt ? (' inside "' + parentEnt.name + '"') : '') + ' in a story world.',
        'Output exactly two labelled blocks and nothing else:\nDESC: <1-2 sentences of scene-present description — what a person directly sees, hears, and senses on arrival. Keep it short.>\nLORE: <a full, comprehensive entry (roughly 5-8 sentences) covering history, significance, who or what is here, how it connects to the wider world, and any secrets or tensions>',
        'Stay focused on THIS location, drawing on the specific ideas in the reference context. Do not add any other labels, preamble, or commentary.'
    ].join('\n\n');
    let locUsr: string[] = [];
    if (ctx.trim()) locUsr.push(ctx);
    if (hint && hint.trim()) locUsr.push('--- EXTRA GUIDANCE ---\n' + hint.trim());
    locUsr.push('Write the DESC and LORE for "' + ent.name + '" now.');
    let locRes = '';
    try {
        locRes = await executeYoinkGeneration([{ role: 'system', content: locSys }, { role: 'user', content: locUsr.join('\n\n') }], { validator: function(r) { return /DESC:|LORE:/i.test(r); }, tag: 'locationRegen:' + ent.name });
    } catch (eLocReg) {
        api.v1.error('[AE:wizard] location regen failed:', eLocReg);
        return null;
    }
    let locOutRaw = (locRes || '').trim();
    if (!locOutRaw) return null;
    let rde = locOutRaw.match(/DESC:\s*([\s\S]+?)(?:\nLORE:|$)/i);
    let rlo = locOutRaw.match(/LORE:\s*([\s\S]+)/i);
    let newDesc = rde ? rde[1].trim() : '';
    newDesc = newDesc.replace(/\nLORE:[\s\S]*$/i, '').trim();
    let newLore = rlo ? rlo[1].trim() : '';
    if (!newDesc && !newLore) { newLore = locOutRaw; }
    let freshEnt = await loadEntity(locId);
    if (!freshEnt) return null;
    if (newDesc) freshEnt.description = newDesc;
    if (newLore) (freshEnt as any).lorebookText = newLore;
    await saveEntity(freshEnt);
    if (newLore) {
        if ((freshEnt as any).lorebookEntryId) await syncEntityLorebookEntry(locId, true).catch(function() {});
        else await createLinkedEntityLorebookEntry(locId).catch(function() {});
    }
    return newLore || newDesc;
}

// ── World-Build Wizard: Characters (seed-and-go via comprehensive concept dump) ──
// [v0.9.84] Flow: generate names from chat (dedup) -> per character, generate a
// comprehensive concept dump from chat -> derive all dramatis-personae + static fields
// from THAT dump (not chat) -> create the character (entity body + record + lorebook).
// The dump is the persistent source; later per-field regens in the editor read it.

interface WizardCharFields {
    species: string; age: string; gender: string; occupationRole: string; briefDescription: string;
    physicalDescription: string; personalityCore: string; voiceAndMannerisms: string; background: string;
    coreValues: string[];
}

async function generateCharacterNames(count: number, sourceChatIds: string[]): Promise<string[]> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let charIdx = await loadIndex();
    let existingNames = charIdx.map(function(m) { return m.name; }).filter(Boolean);
    let nameSys: string[] = [
        'You are identifying distinct CHARACTERS (individual people) for a story world.',
        'Produce EXACTLY ' + count + ' character names that the brainstorming context establishes or clearly implies. Real individuals, not groups, roles, or species.'
    ];
    if (existingNames.length) nameSys.push('These characters ALREADY EXIST \u2014 do NOT repeat them:\n' + existingNames.map(function(n) { return '- ' + n; }).join('\n'));
    nameSys.push('FORMAT: one name per line, each prefixed with "NAME: ". Nothing else \u2014 no descriptions, numbering, or commentary.');
    let nameUsr: string[] = [];
    if (ctx.trim()) nameUsr.push(ctx);
    nameUsr.push('List ' + count + ' character names now.');
    let nameRaw = '';
    try { nameRaw = await executeYoinkGeneration([{ role: 'system', content: nameSys.join('\n\n') }, { role: 'user', content: nameUsr.join('\n\n') }], { validator: function(r) { return /NAME:/i.test(r); }, tag: 'charNames' }); }
    catch (eCharNames) { api.v1.error('[AE:wizard] character names failed:', eCharNames); return []; }
    let names: string[] = [];
    let nameLines = (nameRaw || '').split('\n');
    for (let nl of nameLines) {
        let mm = nl.match(/NAME:\s*(.+)/i);
        if (!mm) continue;
        let nm = mm[1].trim().replace(/^[-*0-9.\s]+/, '').trim();
        if (nm && names.indexOf(nm) < 0) names.push(nm);
    }
    return names.slice(0, count);
}

async function generateCharacterDump(name: string, sourceChatIds: string[]): Promise<string> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let dumpSys = [
        'You are assembling a COMPREHENSIVE concept profile (a "concept dump") for a single character named "' + name + '" based entirely on the brainstorming context.',
        'Organize EVERYTHING the context establishes or implies about ' + name + ' into one thorough, well-structured profile: who they are, anatomical appearance, psychological contradictions, vocal timbre, formative history, relationships, and goals.',
        'CRITICAL RULE: Write entirely in plain prose. DO NOT use markdown, bolding, italics, or bullet points. DO NOT invent tragic backstories or cliché tropes unless explicitly stated in the context.',
        'Output ONLY the plain prose profile for ' + name + '. No preamble, no headers, no commentary.'
    ].join('\n\n');
    let dumpUsr: string[] = [];
    if (ctx.trim()) dumpUsr.push(ctx);
    dumpUsr.push('Write the comprehensive concept profile for "' + name + '" now.');
    let dumpRaw = '';
    try { dumpRaw = await executeYoinkGeneration([{ role: 'system', content: dumpSys }, { role: 'user', content: dumpUsr.join('\n\n') }], { tag: 'charDump:' + name }); }
    catch (eCharDump) { api.v1.error('[AE:wizard] character dump failed:', eCharDump); return ''; }
    return (dumpRaw || '').trim();
}

async function generateCharacterFields(name: string, dump: string): Promise<WizardCharFields | null> {
    if (!(dump || '').trim()) return null;
    let fieldSys = [
        'You are filling structured fields for the character "' + name + '", extracting data ONLY from the concept profile provided. Do not contradict it; where the profile is silent, infer the most fitting objective value.',
        'CRITICAL RULE: DO NOT use any markdown, bolding, or italics. Output EXACTLY these labelled lines, in this exact order, and nothing else:\n' +
        'SPECIES: <one or two words>\n' +
        'AGE: <a number or short phrase>\n' +
        'GENDER: <short>\n' +
        'ROLE: <occupation or role, a few words>\n' +
        'BRIEF: <one tight sentence identifying who they are at a glance>\n' +
        'PHYSICAL: <Camera-view physical anatomy, skin, hair, eyes, and build. Sensual or striking details if applicable. No clothing. No mannerisms.>\n' +
        'PERSONALITY: <Psychological baseline and a core contradiction/hidden facet. No tragic tropes. Declarative.>\n' +
        'VOICE: <Vocal timbre, speech rhythm, and one signature physical mannerism.>\n' +
        'BACKGROUND: <One or two formative past events that shaped their current worldview. Past tense.>\n' +
        'VALUES: <3-5 deeply held values, semicolon-separated>'
    ].join('\n\n');
    let fieldUsr = '--- CONCEPT PROFILE ---\n' + dump.trim() + '\n\nFill the fields for "' + name + '" now.';
    let fieldRaw = '';
    try { fieldRaw = await executeYoinkGeneration([{ role: 'system', content: fieldSys }, { role: 'user', content: fieldUsr }], { validator: function(r) { return /SPECIES:|BRIEF:/i.test(r); }, tag: 'charFields:' + name }); }
    catch (eCharFields) { api.v1.error('[AE:wizard] character fields failed:', eCharFields); return null; }

    function parseCharFields(txt: string): Record<string, string> {
        let labels = ['SPECIES', 'AGE', 'GENDER', 'ROLE', 'BRIEF', 'PHYSICAL', 'PERSONALITY', 'VOICE', 'BACKGROUND', 'VALUES'];
        let result: Record<string, string> = {};
        let fLines = (txt || '').split('\n');
        let cur = '';
        for (let fl of fLines) {
            let trimmed = fl.trim();
            let up = trimmed.toUpperCase();
            let hit = '';
            for (let lb of labels) { if (up.indexOf(lb + ':') === 0) { hit = lb; break; } }
            if (hit) { result[hit] = trimmed.slice(hit.length + 1).trim(); cur = hit; }
            else if (cur && trimmed) { result[cur] = (result[cur] ? result[cur] + ' ' : '') + trimmed; }
        }
        return result;
    }

    let parsed = parseCharFields(fieldRaw);
    let valuesRaw = parsed['VALUES'] || '';
    return {
        species: parsed['SPECIES'] || '', age: parsed['AGE'] || '', gender: parsed['GENDER'] || '',
        occupationRole: parsed['ROLE'] || '', briefDescription: parsed['BRIEF'] || '',
        physicalDescription: parsed['PHYSICAL'] || '', personalityCore: parsed['PERSONALITY'] || '',
        voiceAndMannerisms: parsed['VOICE'] || '', background: parsed['BACKGROUND'] || '',
        coreValues: valuesRaw.split(';').map(function(s) { return s.trim(); }).filter(Boolean)
    };
}

async function createWizardCharacter(name: string, dump: string, fields: WizardCharFields | null): Promise<string> {
    let cfg = await loadConfig();
    let body = makeDefaultEntity(name);
    body.type = 'character';
    body.parentId = null;
    await saveEntity(body);
    let ch = makeDefaultCharacter(name, cfg);
    ch.entityId = body.id;
    ch.conceptDump = dump || '';
    if (fields) {
        ch.species = fields.species || '';
        ch.age = fields.age || '';
        ch.gender = fields.gender || '';
        ch.occupationRole = fields.occupationRole || '';
        ch.briefDescription = fields.briefDescription || '';
        ch.physicalDescription = fields.physicalDescription || '';
        ch.personalityCore = fields.personalityCore || '';
        ch.voiceAndMannerisms = fields.voiceAndMannerisms || '';
        ch.background = fields.background || '';
        ch.coreValues = fields.coreValues || [];
    }
    await saveCharacter(ch);
    try { await createLinkedLorebookEntry(ch.id); } catch (eCharLb) { /* non-fatal */ }
    return ch.id;
}

// [v0.9.84] Generate ONE character end-to-end (dump from chat -> fields from dump -> create).
async function runWizardCharacterSingle(name: string, sourceChatIds: string[]): Promise<boolean> {
    let nm = (name || '').trim();
    if (!nm) return false;
    let dump = await generateCharacterDump(nm, sourceChatIds);
    let fields = await generateCharacterFields(nm, dump);
    await createWizardCharacter(nm, dump, fields);
    return true;
}

// [v0.9.84] Batch: names from chat (dedup) -> each character end-to-end. Returns count created.
// [v1.22.2 CHAR-STAGE] Now a thin stage -> commit wrapper, committing only its own drafts.
// The per-character dump/field calls still happen, just split across the two halves.
async function runWizardCharactersBatch(count: number, sourceChatIds: string[]): Promise<number> {
    let newIds = await stageCharacterBatch(count, sourceChatIds);
    if (!newIds.length) return 0;
    return await commitStagedDrafts('character', newIds);
}

// ── World-Build Wizard: Intro / Opening scene ────────────────────────────────
// [v0.9.85] Pick where the story opens and who is present; generate the opening
// prose (yoink, budget-free), place the player + cast there, and insert into the editor.

async function generateIntroProse(locationId: string, charIds: string[], sourceChatIds: string[]): Promise<string> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let loc = locationId ? await loadEntity(locationId) : null;
    let allChars = await loadAllCharacters();
    let protag = allChars.find(function(c) { return c.isProtagonist; });
    let castLines: string[] = [];
    for (let cid of (charIds || [])) {
        let ch = allChars.find(function(c) { return c.id === cid; });
        if (!ch) continue;
        castLines.push('- ' + ch.name + (ch.briefDescription ? (': ' + ch.briefDescription) : ''));
    }
    let introSys: string[] = [
        'You are writing the OPENING of an interactive story \u2014 the very first scene, in immersive second-person present tense ("You ...") from the protagonist\'s point of view.',
        'Establish the setting, mood, and immediate situation, and bring any present characters to life through concrete action and detail. Start *in media res* (already in the location, mid-action). End on a beat that invites the player to act; do not resolve the situation.',
        'CRITICAL RULE: Avoid all backstory, lore-dumping, and exposition. DO NOT use any markdown, bolding, italics, or headings.'
    ];
    if (loc) {
        let locLore = ((loc as any).lorebookText || '').trim();
        introSys.push('SETTING (where the scene opens):\n' + loc.name + ((loc.description || '').trim() ? (' \u2014 ' + loc.description.trim()) : '') + (locLore ? ('\nBackground: ' + locLore) : ''));
    }
    if (protag) {
        introSys.push('THE PROTAGONIST ("you"):\n' + protag.name + ((protag.briefDescription || '').trim() ? (': ' + protag.briefDescription.trim()) : ''));
    }
    if (castLines.length) introSys.push('PRESENT IN THE SCENE:\n' + castLines.join('\n'));
    introSys.push('Write 2-4 vivid paragraphs. Output ONLY the opening prose \u2014 no title, headings, labels, or commentary.');
    let introUsr: string[] = [];
    if (ctx.trim()) introUsr.push(ctx);
    introUsr.push('Write the opening scene now.');
    let introRaw = '';
    try { introRaw = await executeYoinkGeneration([{ role: 'system', content: introSys.join('\n\n') }, { role: 'user', content: introUsr.join('\n\n') }], { tag: 'introProse' }); }
    catch (eIntroGen) { api.v1.error('[AE:wizard] intro generation failed:', eIntroGen); return ''; }
    return (introRaw || '').trim();
}

async function placeIntroCast(locationId: string, charIds: string[]): Promise<void> {
    // Move each chosen character's body into the location and make them active/present.
    for (let cid of (charIds || [])) {
        let ch = await loadCharacter(cid);
        if (!ch || !ch.entityId) continue;
        let body = await loadEntity(ch.entityId);
        if (body) { body.parentId = locationId; await saveEntity(body); }
        let fc = await loadCharacter(cid);
        if (fc) { fc.active = true; fc.scenePresent = true; await saveCharacter(fc); }
    }
    // Move the protagonist (silent); this also recalculates scene presence so the placed
    // cast registers as present in the new room.
    await commitTravel(locationId, true);
}

// [v0.9.85] Generate prose first (so a failure leaves world state untouched), then place
// the cast + player, then insert the prose into the story editor as paragraphs.
// [v1.6.3 INTRO-STAGE] The intro generator now stages its output like the other wizard
// tabs: generate -> review/edit/regenerate -> commit. generateIntroDraft yoinks the opening
// prose and stores it as an editable draft WITHOUT touching the story; commitIntroDraft
// travels the player in and writes the (possibly edited) draft, then clears it.
async function generateIntroDraft(locationId: string, sourceChatIds: string[]): Promise<boolean> {
    if (!locationId) { api.v1.ui.toast('Pick an intro location first.', { type: 'error', autoClose: 2500 }); return false; }
    let loc = await loadEntity(locationId);
    if (!loc) { api.v1.ui.toast('That location no longer exists.', { type: 'error', autoClose: 2500 }); return false; }
    // [v0.9.86] Cast placement removed — characters get intro locations set in their character cards.
    let prose = await generateIntroProse(locationId, [], sourceChatIds);
    if (!(prose || '').trim()) return false;
    // [v1.22.0 STAGING] storyStorage, not tempStorage — a staged draft the user is asked
    // to review must survive a script reload / story switch.
    await api.v1.storyStorage.set(STORAGE_WIZ_INTRO_DRAFT, JSON.stringify({ locationId: locationId, prose: prose.trim() })).catch(function() {});
    return true;
}

// [v1.22.0 STAGING] Read the staged intro draft, tolerating both the new storyStorage
// JSON string and any legacy tempStorage object left over from before the migration.
async function loadIntroDraft(): Promise<any> {
    let rawIntro = await api.v1.storyStorage.getOrDefault(STORAGE_WIZ_INTRO_DRAFT, '') as string;
    if (rawIntro && String(rawIntro).trim()) {
        try { return JSON.parse(rawIntro as string); }
        catch (eIntroParse) { api.v1.error('[AE:wizard] intro draft parse error:', eIntroParse); }
    }
    let legacyIntro = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_DRAFT, null) as any;
    if (legacyIntro && legacyIntro.locationId) return legacyIntro;
    return null;
}

async function commitIntroDraft(): Promise<boolean> {
    let draft = await loadIntroDraft();
    if (!draft || !draft.locationId || !((draft.prose || '') as string).trim()) { api.v1.ui.toast('No intro draft to commit.', { type: 'error', autoClose: 2500 }); return false; }
    let loc = await loadEntity(draft.locationId);
    if (!loc) { api.v1.ui.toast('That location no longer exists.', { type: 'error', autoClose: 2500 }); return false; }
    await commitTravel(draft.locationId, true);
    let introParas = String(draft.prose).split(/\n\n+/);
    for (let para of introParas) {
        if (para.trim()) { await api.v1.document.appendParagraph({ text: para.trim() }).catch(function() {}); }
    }
    await api.v1.storyStorage.remove(STORAGE_WIZ_INTRO_DRAFT).catch(function() {});
    await api.v1.tempStorage.remove(STORAGE_WIZ_INTRO_DRAFT).catch(function() {});
    return true;
}

// [legacy] one-shot generate+insert, retained for any direct/scripted callers. The wizard
// UI now uses the staged path (generateIntroDraft then commitIntroDraft) instead.
async function runWizardIntro(locationId: string, sourceChatIds: string[]): Promise<boolean> {
    let okGen = await generateIntroDraft(locationId, sourceChatIds);
    if (!okGen) return false;
    return await commitIntroDraft();
}

// ── World-Build Wizard: Drama (hooks, NPC web, narrative threads) ─────────────
// [vNEXT] The Drama wizard seeds the three primitives the live Drama tab and the
// dynamic engine maintain: per-character UnresolvedHooks, bilateral WebLinks, and
// narrative-thread entities. Hooks and web links are CHARACTER-AWARE — the generators
// are fed the established roster and must resolve to real records; nothing is written
// against a person who does not exist. Seeded hooks deliberately mirror the dynamic
// engine's spawn shape (pressure 20-50, one concrete directed sentence) so they read
// identically to tension the engine raises later during play.

// Compact cast roster for drama generators: protagonist marked, each active character
// on one identifying line. Shared context so generated tensions reference real people.
function buildWizardCastContext(allChars: CharacterRecord[]): string {
    let castLines: string[] = [];
    let castProtag = allChars.find(function(c) { return c.isProtagonist; });
    if (castProtag) {
        let pBrief = (castProtag.briefDescription || '').trim();
        castLines.push('PROTAGONIST (the player, "you"): ' + castProtag.name + (pBrief ? (' — ' + pBrief) : ''));
    }
    for (let cc of allChars) {
        if (cc.isProtagonist) continue;
        if (!cc.active) continue;
        let ccBrief = (cc.briefDescription || '').trim();
        let ccRole = (cc.occupationRole || '').trim();
        let ccTail = ccBrief ? (' — ' + ccBrief) : (ccRole ? (' — ' + ccRole) : '');
        castLines.push('- ' + cc.name + ccTail);
    }
    if (castLines.length === 0) return '';
    return '--- CAST ---\n' + castLines.join('\n');
}

// Resolve a generated target name to the canonical hook target: the protagonist maps
// to the '__player__' token (the Drama tab and injection logic expect it); an exact
// cast name/nickname maps to that name; anything else is kept verbatim (the engine
// tolerates free-text targets so a near-miss is still editable rather than dropped).
function resolveHookTarget(raw: string, allChars: CharacterRecord[]): string {
    let rt = (raw || '').trim();
    if (!rt) return '';
    let rtLow = rt.toLowerCase();
    if (rtLow === 'none' || rtLow === 'n/a') return '';
    let rtProtag = allChars.find(function(c) { return c.isProtagonist; });
    if (rtProtag && (rtLow === rtProtag.name.toLowerCase() || rtLow === 'the protagonist' || rtLow === 'protagonist' || rtLow === 'you' || rtLow === 'the player' || rtLow === 'player')) return '__player__';
    for (let rc of allChars) {
        if (rc.isProtagonist) continue;
        if (rc.name.toLowerCase() === rtLow) return rc.name;
        if ((rc.nicknames || []).some(function(n) { return (n || '').toLowerCase() === rtLow; })) return rc.name;
    }
    return rt;
}

// Resolve a generated name to an existing character id (protagonist included), or ''.
function findWizardCharIdByName(allChars: CharacterRecord[], raw: string): string {
    let fn = (raw || '').trim().toLowerCase();
    if (!fn) return '';
    let fProtag = allChars.find(function(c) { return c.isProtagonist; });
    if (fProtag && (fn === 'the protagonist' || fn === 'protagonist' || fn === 'you' || fn === 'the player' || fn === 'player')) return fProtag.id;
    for (let fc of allChars) {
        if (fc.name.toLowerCase() === fn) return fc.id;
        if ((fc.nicknames || []).some(function(n) { return (n || '').toLowerCase() === fn; })) return fc.id;
    }
    return '';
}

// [vNEXT] Generate ONE starting hook for a character: a concrete unresolved tension
// directed at another existing cast member or the protagonist. Mirrors the dynamic
// engine's hook-spawn prompt for tonal parity. Returns {targetName, description,
// pressureLevel} (targetName already resolved) or null when no clean tension exists.
async function generateCharacterHook(char: CharacterRecord, sourceChatIds: string[], hint: string): Promise<{ targetName: string; description: string; pressureLevel: number } | null> {
    let cfg = await loadConfig();
    let allChars = await loadAllCharacters();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let cast = buildWizardCastContext(allChars);
    let dump = (char.conceptDump || '').trim();

    let hookSys = [
        'You are a dramaturg seeding the OPENING dramatic tension for the character "' + char.name + '" at the very start of a story.',
        'Identify ONE specific, unresolved tension this character carries toward another person: a conflict, a threat they pose or face, a debt, a secret they guard, a betrayal, or an urgent unfulfilled want. Passive moods and general feelings do NOT qualify. It must be directed at a named person and demand eventual action.',
        'The target MUST be one of the established cast, named EXACTLY as written, OR the protagonist. Do not invent a new person.',
        'Write the hook as a single, punchy sentence naming the core tension in concrete terms: what happened, what is owed, what is at stake.',
        '  Wrong: "feels uneasy about her place in the household"',
        '  Right: "Owes the magister a debt she cannot pay, and the collector arrives within the week"',
        'Set the pressure between 20 and 50 — this is a fresh hook that has not yet escalated.',
        'If this character has no plausible directed tension, set the target to "None".',
        'CRITICAL RULE: DO NOT use any markdown, bolding, italics, or bullet points. Output EXACTLY these three labelled lines and nothing else:\nTARGET: <exact cast name, the protagonist, or None>\nPRESSURE: <a number from 20 to 50>\nHOOK: <one concrete sentence>'
    ].join('\n\n');

    let hookUsr: string[] = [];
    if (cast) hookUsr.push(cast);
    if (dump) hookUsr.push('--- ' + char.name.toUpperCase() + ' (concept profile) ---\n' + dump);
    if (ctx.trim()) hookUsr.push(ctx);
    if (hint && hint.trim()) hookUsr.push('--- EXTRA GUIDANCE FOR THIS REGENERATION ---\n' + hint.trim());
    hookUsr.push('Write the opening hook for "' + char.name + '" now.');

    let hookRaw = '';
    try { hookRaw = await executeYoinkGeneration([{ role: 'system', content: hookSys }, { role: 'user', content: hookUsr.join('\n\n') }], { tag: 'wizHookSeed:' + char.name }); }
    catch (eHookGen) { api.v1.error('[AE:wizard] hook generation failed (' + char.name + '):', eHookGen); return null; }

    function parseHookFields(txt: string): { target: string; pressure: number; hook: string } {
        let pTarget = ''; let pPressure = 30; let pHookLines: string[] = []; let pCur = '';
        let pLines = (txt || '').split('\n');
        for (let pl of pLines) {
            let pt = pl.trim();
            let pu = pt.toUpperCase();
            if (pu.indexOf('TARGET:') === 0) { pTarget = pt.slice(7).trim(); pCur = 'target'; }
            else if (pu.indexOf('PRESSURE:') === 0) { let pm = pt.slice(9).match(/-?\d+/); if (pm) pPressure = parseInt(pm[0], 10); pCur = 'pressure'; }
            else if (pu.indexOf('HOOK:') === 0) { let hb = pt.slice(5).trim(); if (hb) pHookLines.push(hb); pCur = 'hook'; }
            else if (pCur === 'hook' && pt) { pHookLines.push(pt); }
        }
        return { target: pTarget, pressure: pPressure, hook: pHookLines.join(' ').trim() };
    }

    let parsedHook = parseHookFields(hookRaw);
    let resolvedTarget = resolveHookTarget(parsedHook.target, allChars);
    if (!resolvedTarget || !parsedHook.hook) return null;
    let clampedPressure = Math.min(50, Math.max(20, parsedHook.pressure || 30));
    return { targetName: resolvedTarget, description: parsedHook.hook, pressureLevel: clampedPressure };
}

// [vNEXT] Seed (or reseed) the single starting hook on one character. Replaces hooks[0]
// — the model is one-active-hook-per-character. Stamps lastHookGen with the current
// story gen count so the dynamic engine's escalator picks it up on schedule.
async function runWizardHookSingle(charId: string, sourceChatIds: string[], hint: string): Promise<boolean> {
    let baseChar = await loadCharacter(charId);
    if (!baseChar) return false;
    let gen = await generateCharacterHook(baseChar, sourceChatIds, hint);
    if (!gen) return false;
    let freshHookChar = await loadCharacter(charId);
    if (!freshHookChar) return false;
    let gc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;
    freshHookChar.hooks = [{
        id: api.v1.uuid(),
        targetName: gen.targetName,
        description: (gen.description || '').substring(0, 300),
        pressureLevel: Math.min(100, Math.max(0, gen.pressureLevel || 30)),
        developmentNotes: [],
        resolved: false
    }];
    freshHookChar.lastHookGen = Number(gc) || 0;
    await saveCharacter(freshHookChar);
    return true;
}

// [vNEXT] Seed one hook on each selected character. Returns the count successfully seeded.
async function runWizardHooksBatch(charIds: string[], sourceChatIds: string[]): Promise<number> {
    let hookMade = 0;
    for (let hcid of (charIds || [])) {
        let hookOk = await runWizardHookSingle(hcid, sourceChatIds, '');
        if (hookOk) hookMade++;
    }
    return hookMade;
}

// [vNEXT] Generate a batch of bilateral cast dynamics (NPC web). Each names two distinct
// existing people and one concrete charged sentence between them. Parsed from labelled
// A:/B:/DYNAMIC:/PRIORITY: blocks. Mapping to ids + dedup happens in runWizardWebBatch.
async function generateWebBatch(count: number, sourceChatIds: string[]): Promise<{ aName: string; bName: string; dynamic: string; priority: number }[]> {
    let cfg = await loadConfig();
    let allChars = await loadAllCharacters();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let cast = buildWizardCastContext(allChars);
    if (!cast) return [];

    let webSys: string[] = [
        'You are a dramaturg defining the web of bilateral dynamics between the established cast of a story.',
        'Produce EXACTLY ' + count + ' distinct PAIR dynamics. Each names two DIFFERENT people from the cast below (the protagonist may be one of them) and states the charged relationship between them in one concrete sentence.',
        'Focus on friction, history, and asymmetry: rivalries, old debts, unspoken attraction, divided loyalty, mutual dependence. Avoid bland "they are friends" pairings, and do not repeat the same pair twice.',
        'Assign each a priority from 0 to 100: how strongly this dynamic should colour scenes where both are present (default 30; use 70+ only for defining relationships).',
        'CRITICAL RULE: DO NOT use any markdown, bolding, or bullet points. Output plain text only.',
        'FORMAT: for each pair output exactly:\nA: <exact cast name>\nB: <exact cast name>\nDYNAMIC: <one concrete sentence>\nPRIORITY: <a number from 0 to 100>\nSeparate pairs with a line containing only ---',
        'Output ONLY the pairs in that format. No preamble, no numbering, no commentary.'
    ];

    let webUsr: string[] = [];
    if (ctx.trim()) webUsr.push(ctx);
    webUsr.push('Generate ' + count + ' bilateral dynamics now.');

    let webRaw = '';
    try { webRaw = await executeYoinkGeneration([{ role: 'system', content: webSys.join('\n\n') }, { role: 'user', content: webUsr.join('\n\n') }], { tag: 'webBatch' }); }
    catch (eWebGen) { api.v1.error('[AE:wizard] web batch generation failed:', eWebGen); return []; }

    let webOut: { aName: string; bName: string; dynamic: string; priority: number }[] = [];
    let webChunks = (webRaw || '').split(/\n-{3,}\n/);
    for (let wch of webChunks) {
        let aMatch = wch.match(/(?:^|\n)\s*A:\s*(.+)/i);
        let bMatch = wch.match(/(?:^|\n)\s*B:\s*(.+)/i);
        let dMatch = wch.match(/DYNAMIC:\s*([\s\S]+?)(?:\nPRIORITY:|$)/i);
        let pMatch = wch.match(/PRIORITY:\s*(-?\d+)/i);
        if (!aMatch || !bMatch) continue;
        let aNm = aMatch[1].trim();
        let bNm = bMatch[1].trim();
        let dyn = dMatch ? dMatch[1].trim().replace(/\n-{3,}[\s\S]*$/, '').trim() : '';
        let pri = pMatch ? parseInt(pMatch[1], 10) : 30;
        if (aNm && bNm) webOut.push({ aName: aNm, bName: bNm, dynamic: dyn, priority: pri });
    }
    return webOut;
}

// [vNEXT] Generate web dynamics, map names to existing character ids, drop self-pairs,
// unresolved names, and pairs already present (unordered). Returns the count added.
async function runWizardWebBatch(count: number, sourceChatIds: string[]): Promise<number> {
    let allChars = await loadAllCharacters();
    let pairs = await generateWebBatch(count, sourceChatIds);
    if (pairs.length === 0) return 0;
    let web = await loadNpcWeb();
    let webMade = 0;
    for (let wp of pairs) {
        let aId = findWizardCharIdByName(allChars, wp.aName);
        let bId = findWizardCharIdByName(allChars, wp.bName);
        if (!aId || !bId || aId === bId) continue;
        let already = web.some(function(l) { return (l.charA_id === aId && l.charB_id === bId) || (l.charA_id === bId && l.charB_id === aId); });
        if (already) continue;
        web.push({ id: api.v1.uuid(), charA_id: aId, charB_id: bId, dynamic: (wp.dynamic || '').substring(0, 300), priority: Math.min(100, Math.max(0, wp.priority || 30)) });
        webMade++;
    }
    if (webMade > 0) await saveNpcWeb(web);
    return webMade;
}

// [vNEXT] Regenerate the dynamic sentence on ONE existing web link in place (no new link).
async function regenerateWebLink(linkId: string, sourceChatIds: string[], hint: string): Promise<string | null> {
    let cfg = await loadConfig();
    let allChars = await loadAllCharacters();
    let web = await loadNpcWeb();
    let link = web.find(function(l) { return l.id === linkId; });
    if (!link) return null;
    let wa = allChars.find(function(c) { return c.id === link.charA_id; });
    let wb = allChars.find(function(c) { return c.id === link.charB_id; });
    if (!wa || !wb) return null;
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let regSys = [
        'You are writing the charged bilateral dynamic between "' + wa.name + '" and "' + wb.name + '" in a story.',
        'State their relationship in one concrete sentence — friction, history, or asymmetry. Avoid bland pairings.',
        'Output ONLY the single sentence. No names prefix, no label, no markdown.'
    ].join('\n\n');
    let regUsr: string[] = [];
    if (ctx.trim()) regUsr.push(ctx);
    if (hint && hint.trim()) regUsr.push('--- EXTRA GUIDANCE ---\n' + hint.trim());
    regUsr.push('Write the dynamic between "' + wa.name + '" and "' + wb.name + '" now.');
    let regRaw = '';
    try { regRaw = await executeYoinkGeneration([{ role: 'system', content: regSys }, { role: 'user', content: regUsr.join('\n\n') }], { tag: 'webLinkRegen:' + wa.name + '-' + wb.name }); }
    catch (eWebReg) { api.v1.error('[AE:wizard] web regen failed:', eWebReg); return null; }
    let regTxt = (regRaw || '').trim();
    if (!regTxt) return null;
    let web2 = await loadNpcWeb();
    let t2 = web2.find(function(l) { return l.id === linkId; });
    if (t2) { t2.dynamic = regTxt.substring(0, 300); await saveNpcWeb(web2); }
    return regTxt;
}

// [vNEXT] Generate a batch of narrative-thread descriptors. Each is a short name, a
// story state (locked/active/completed), and a 1-2 sentence current-situation hook.
// Parsed from labelled NAME:/STATE:/DESC: blocks. Records are created in runWizard...Batch.
async function generateNarrativeBatch(count: number, sourceChatIds: string[]): Promise<{ name: string; state: string; description: string }[]> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let narrIdx = await loadEntityIndex();
    let narrExisting = narrIdx.filter(function(n) { return n.type === 'narrative'; }).map(function(n) { return n.name; }).filter(Boolean);

    let narrSys: string[] = [
        'You are a dramaturg outlining the plot threads of a story — the quests, mysteries, conflicts, and obligations that will drive play.',
        'Produce EXACTLY ' + count + ' distinct narrative threads that fit the world and connect to the established cast and tensions.',
        'For each thread give a short evocative NAME, a STATE, and a DESC of one to two sentences stating the thread\'s current situation and what it pushes the player toward — concrete and unresolved, never a summary of how it ends.',
        'STATE must be exactly one of: locked (set up but not yet in play), active (currently driving the story), completed (already resolved). Most opening threads are "locked" or "active".',
        'CRITICAL RULE: DO NOT use any markdown, bolding, or bullet points. Output plain text only.'
    ];
    if (narrExisting.length) narrSys.push('These threads ALREADY EXIST — do NOT recreate, rename, or duplicate them:\n' + narrExisting.map(function(n) { return '- ' + n; }).join('\n'));
    narrSys.push('FORMAT: for each thread output exactly:\nNAME: <short thread name>\nSTATE: <locked|active|completed>\nDESC: <1-2 concrete sentences>\nSeparate threads with a line containing only ---');
    narrSys.push('Output ONLY the threads in that format. No preamble, no numbering, no commentary.');

    let narrUsr: string[] = [];
    if (ctx.trim()) narrUsr.push(ctx);
    narrUsr.push('Generate ' + count + ' narrative threads now.');

    let narrRaw = '';
    try { narrRaw = await executeYoinkGeneration([{ role: 'system', content: narrSys.join('\n\n') }, { role: 'user', content: narrUsr.join('\n\n') }], { tag: 'narrativeBatch' }); }
    catch (eNarrGen) { api.v1.error('[AE:wizard] narrative batch generation failed:', eNarrGen); return []; }

    let narrOut: { name: string; state: string; description: string }[] = [];
    let narrChunks = (narrRaw || '').split(/\n-{3,}\n/);
    for (let nch of narrChunks) {
        let nNameMatch = nch.match(/NAME:\s*(.+)/i);
        let nStateMatch = nch.match(/STATE:\s*(\w+)/i);
        let nDescMatch = nch.match(/DESC:\s*([\s\S]+)/i);
        if (!nNameMatch) continue;
        let nName = nNameMatch[1].trim();
        let nState = nStateMatch ? nStateMatch[1].trim().toLowerCase() : 'locked';
        let nDesc = nDescMatch ? nDescMatch[1].trim() : '';
        nDesc = nDesc.replace(/\n-{3,}[\s\S]*$/, '').replace(/\nNAME:[\s\S]*$/i, '').trim();
        if (nName) narrOut.push({ name: nName, state: nState, description: nDesc });
    }
    return narrOut;
}

// [vNEXT] Create top-level narrative-thread entities from a generated batch. Mirrors the
// Drama tab's manual "+ New Thread" path exactly (entity only, no lorebook entry). The
// existing narrative tree editor handles nesting and state changes afterward.
async function runWizardNarrativesBatch(count: number, sourceChatIds: string[]): Promise<number> {
    let items = await generateNarrativeBatch(count, sourceChatIds);
    let narrCreated = 0;
    for (let nit of items) {
        if (!nit.name) continue;
        let nEnt = makeDefaultEntity(nit.name);
        nEnt.type = 'narrative';
        let nSt = (nit.state || 'locked');
        nEnt.storyState = (nSt === 'active' || nSt === 'completed') ? nSt as any : 'locked';
        nEnt.description = nit.description || '';
        nEnt.narrativeParentId = null;
        await saveEntity(nEnt);
        narrCreated++;
    }
    return narrCreated;
}

// [vNEXT] Add a single blank top-level narrative thread (rename + ⚡ Regen its situation).
async function addBlankWizardNarrative(): Promise<string> {
    let blankEnt = makeDefaultEntity('New Thread');
    blankEnt.type = 'narrative';
    blankEnt.storyState = 'locked';
    blankEnt.narrativeParentId = null;
    await saveEntity(blankEnt);
    return blankEnt.id;
}

// [vNEXT] Regenerate ONE narrative thread's situation description in place.
async function regenerateNarrativeThread(entId: string, sourceChatIds: string[], hint: string): Promise<string | null> {
    let cfg = await loadConfig();
    let nEntity = await loadEntity(entId);
    if (!nEntity || nEntity.type !== 'narrative') return null;
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let nSys = [
        'You are writing the current situation of the narrative thread "' + nEntity.name + '" in a story.',
        'State in one to two concrete sentences what this thread is and what it pushes the player toward right now — unresolved, never a summary of how it ends.',
        'Output ONLY the description prose. No name prefix, no label, no markdown.'
    ].join('\n\n');
    let nUsr: string[] = [];
    if (ctx.trim()) nUsr.push(ctx);
    if (hint && hint.trim()) nUsr.push('--- EXTRA GUIDANCE ---\n' + hint.trim());
    nUsr.push('Write the situation for "' + nEntity.name + '" now.');
    let nRaw = '';
    try { nRaw = await executeYoinkGeneration([{ role: 'system', content: nSys }, { role: 'user', content: nUsr.join('\n\n') }], { tag: 'narrativeRegen:' + nEntity.name }); }
    catch (eNarrReg) { api.v1.error('[AE:wizard] narrative regen failed:', eNarrReg); return null; }
    let nTxt = (nRaw || '').trim();
    if (!nTxt) return null;
    let nFresh = await loadEntity(entId);
    if (nFresh) { nFresh.description = nTxt; await saveEntity(nFresh); }
    return nTxt;
}


// ── World-Build Wizard: memory fan-out commit ────────────────────────────────────────────
// [vNEXT] For a 'memoryFanout' topic chat: regenerate each ENABLED section in its own
// scoped pass (sequential — NAI serializes generation; never parallel), write results
// back into cfg.wizardSections, persist config, then commit to Memory + Author's Note.
// Generation is sequential and order-stable so the "already-written" context grows as
// it goes. Returns the number of sections generated, or -1 on a hard failure.
async function runWizardMemoryFanout(chatId: string): Promise<number> {
    let cfg = await loadConfig();
    let chat = await loadWizardChat(chatId);
    if (!chat) return -1;

    // [v2.11.0] generateWizardSection now takes a pre-built ctx string rather than a
    // chat object — build it once here the same way it used to build it internally:
    // buildWizardContext (referenced chats/lorebook/story) plus this chat's OWN
    // transcript (buildWizardContext only resolves REFERENCED chats, not the given
    // chat's own messages, so that still needs its own block).
    let fanoutTranscript = (chat.messages || []).map(function(m) { return '[' + m.role.toUpperCase() + '] ' + m.content; }).join('\n');
    let fanoutExtraCtx = await buildWizardContext(chat, cfg);
    let fanoutCtxParts: string[] = [];
    if (fanoutExtraCtx.trim()) fanoutCtxParts.push(fanoutExtraCtx);
    if (fanoutTranscript.trim()) fanoutCtxParts.push('--- BRAINSTORMING CHAT ---\n' + fanoutTranscript);
    let fanoutCtx = fanoutCtxParts.join('\n\n');

    let sections = cfg.wizardSections || [];
    let enabled = sections.filter(function(s) { return s.enabled; });
    let written = 0;

    for (let i = 0; i < enabled.length; i++) {
        let sec = enabled[i];
        // Pass the live (progressively updated) section list as prior context.
        let priorNow = (await loadConfig()).wizardSections || [];
        let gen = await generateWizardSection(sec, fanoutCtx, cfg, priorNow);
        if (gen) {
            await mutConfig(function(c) {
                let target = (c.wizardSections || []).find(function(s) { return s.id === sec.id; });
                if (target) target.content = gen;
            });
            written++;
        }
    }

    let freshCfg = await loadConfig();
    await commitWizardMemory(freshCfg);
    return written;
}

// ── Emotion Resolution ────────────────────────────────────────────────────────
// [CHANGE] Added from AI engine. Normalises freeform model output to the
// canonical 24-state list used by bridge portrait selection and direct chat.

function resolveEmotion(raw: any): string {
    if (!raw) return 'neutral';
    const key = String(raw).toLowerCase().trim().replace(/[^a-z_]/g, '');
    return EMOTION_MAP[key] || 'neutral';
}

// ── Entity Factory ────────────────────────────────────────────────────────────

function makeDefaultEntity(name: string): EntityRecord {
    // Returns a new EntityRecord with all required fields initialised to safe defaults.
    // callers typically override type, parentId, and description immediately after.
    return {
        id: generateId(),
        name: name,
        type: 'location',
        parentId: null,
        narrativeParentId: null,
        storyState: 'locked',
        description: '',
        atmosphere: '',
        state: 'default',
        stateDescriptions: { 'default': '' },
        connectedEntityIds: [],
        presentCharacterIds: [],
        // [CE-STRIP v2.1.5] actions/rules/skillBonuses/showActionWidget/isVehicle/gated removed — dead Actions remnants.
        // encounters: removed v0.9.25 E4
        inventoryIds: [],
        notes: '',
        knowledgeString: '',
        lorebookTags: [],
        lorebookText: '',
        locationVisuals: '',
        questTarget: '',
        createdAt: Date.now(),
        updatedAt: Date.now()
    };
}

// ── Character Factory ─────────────────────────────────────────────────────────

function makeDefaultCharacter(name: string, cfg: GlobalConfig): CharacterRecord {
    // Returns a new CharacterRecord with all required fields initialised.
    // [CHANGE] New visual fields initialised with safe empty/numeric defaults.
    // avatarWidth/Height default to 1024×1024 (square) so new records never have
    // undefined dimensions when the bridge constructs image generation requests.
    const char: CharacterRecord = {
        id: api.v1.uuid(),
        name: name,
        conceptDump: '',
        nicknames: [],
        species: '',
        age: '',
        gender: '',
        occupationRole: '',
        briefDescription: '',
        // [CHANGE] portraitKey omitted — no longer part of CharacterRecord
        // Visual identity (image generation)
        visuals: '',
        uc: '',
        sceneVisuals: '',
        avatarVisuals: '',
        avatarWidth: 1024,
        avatarHeight: 1024,
        avatarSeed: 0,
        // Flags
        scenePresent: false,
        active: true,
        lorebookEntryId: undefined,
        featuredForEphemeral: false,
        // Static narrative
        physicalDescription: '',
        voiceAndMannerisms: '',
        personalityCore: '',
        background: '',
        customFieldValues: {},
        coreValues: [],
        // Relationships and hooks
        primaryRelationship: {
            targetName: '', enabled: false, archetype: '', howItStarted: '',
            threads: [], currentStatus: '', trajectory: '', summary: '', milestones: []
        },
        hooks: [],
        activeConditions: [],  // [v2.7.0 CONDITIONS]
        // Dynamic state
        ephemeral: null,
        ephemeralHistory: [],
        lastEphemeralGen: 0,  // [v0.9.24 E1]
        midRange: null,
        midRangeHistory: [],       // [v2.14.0 GENESIS]
        relationshipHistory: [],   // [v2.14.0 GENESIS]
        lastMidrangeGen: 0,
        lastArcGen: 0,
        lastHookGen: 0,
        // Equipment and resources
        equippedItemIds: [],
        charFactionRelationships: {},
        // Sheet
        sheetValues: {},
        // Engine flags
        charContextEnabled: true,
        autoUpdateEnabled: cfg.autoUpdateDefault,
        autoThoughtsEnabled: cfg.autoThoughtsDefault,
        hooksEnabled: true,
        lastTokenEstimate: 0,
        // World graph
        entityId: undefined,
        createdAt: Date.now(),
        updatedAt: Date.now()
    };
    return char;
}
// ============================================================================
// SECTION 5 — STORAGE: CHARACTER DATA
// All reads and writes for CharacterRecord and the character index.
// Every function here operates on api.v1.storyStorage.
// ============================================================================

// ── Index (CharacterMeta[]) ───────────────────────────────────────────────────
// The index is the lightweight list used for sidebar rendering and fast lookups.
// Full CharacterRecord data lives in individual keys (STORAGE_CHAR_PFX + id).

async function loadIndex(): Promise<CharacterMeta[]> {
    return await api.v1.storyStorage.getOrDefault(STORAGE_INDEX, []) as CharacterMeta[];
}

async function saveIndex(idx: CharacterMeta[]): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_INDEX, idx.filter(Boolean));
}

// ── Migration ─────────────────────────────────────────────────────────────────
// migrateCharacter runs every time a CharacterRecord is loaded from storage.
// It forward-migrates old save formats and ensures all required fields exist.
// Safe to call multiple times on the same record.

function migrateCharacter(raw: any, cfg: GlobalConfig): CharacterRecord {
    const d = makeDefaultCharacter('Unnamed', cfg);
    const c = { ...d, ...raw };

    // ── Deprecated field removal ──────────────────────────────────────────────
    delete (c as any).storyRole;
    delete (c as any).conditions;
    delete (c as any).activeConditionId;
    delete (c as any).tier;
    delete (c as any).budgetCap;
    // [CHANGE] portraitKey removed — bridge derives portrait key from char.id directly.
    delete (c as any).portraitKey;
    // [CHANGE] homeLocationId was an unimplemented idea with no read path. Removed.
    delete (c as any).homeLocationId;

    // ── Equipment migration (equippedItemId → equippedItemIds) ────────────────
    if (!c.equippedItemIds) {
        c.equippedItemIds = (c as any).equippedItemId ? [(c as any).equippedItemId] : [];
    }
    delete (c as any).equippedItemId;
    if ('equippedItems' in c) delete (c as any).equippedItems;
    if ('wardrobe' in c) delete (c as any).wardrobe;

    // ── v0.9.3 field guards ───────────────────────────────────────────────────

    if (!c.charFactionRelationships) c.charFactionRelationships = {};

    // [v0.9.89] Migrate #gold → #currency on existing character resource defs.
    if (Array.isArray(c.charResourceDefs)) {
        c.charResourceDefs = c.charResourceDefs.map(function(r: any) {
            if (r.tag === '#gold') {
                return { ...r, id: r.id === 'cres_gold' ? 'cres_currency' : r.id, name: r.name === 'Wealth' ? 'Currency' : r.name, tag: '#currency' };
            }
            return r;
        });
    }

    // ── Structural guards ─────────────────────────────────────────────────────
    if (!c.hooks) c.hooks = [];
    if (!c.ephemeralHistory) c.ephemeralHistory = [];
    // [v2.14.0 GENESIS] change-gated trend trails + baseline backfill
    if (!c.midRangeHistory) c.midRangeHistory = [];
    if (!c.relationshipHistory) c.relationshipHistory = [];
    if (c.midRange && (c.midRange as any).baselineView === undefined) (c.midRange as any).baselineView = '';
    
    // Purge old character arc properties from database memory
    delete (c as any).arcEnabled;
    delete (c as any).arcType;
    delete (c as any).developingAspects;
    delete (c as any).arcCurrentState;
    delete (c as any).arcTrajectory;
    delete (c as any).arcEndState;
    delete (c as any).arcMilestones;

    if (!c.primaryRelationship) c.primaryRelationship = {
        targetName: '', enabled: false, archetype: '', howItStarted: '',
        threads: [], currentStatus: '', trajectory: '', summary: '', milestones: []
    };
    if (c.primaryRelationship.enabled === undefined) c.primaryRelationship.enabled = false;
    if (!c.customFieldValues) c.customFieldValues = {};
    if (!c.sheetValues) c.sheetValues = {};
    if (!c.conceptDump) c.conceptDump = '';
    // [v0.9.24 E1] Remove deprecated token stamps; add gen stamps with 0 defaults
    delete (c as any).lastEphemeralTokens;
    delete (c as any).lastMidrangeTokens;
    delete (c as any).lastArcTokens;
    delete (c as any).lastHookTokens;
    if (c.lastEphemeralGen === undefined) c.lastEphemeralGen = 0;
    if (c.lastMidrangeGen  === undefined) c.lastMidrangeGen  = 0;
    if (c.lastArcGen       === undefined) c.lastArcGen       = 0;
    if (c.lastHookGen      === undefined) c.lastHookGen      = 0;
    if (c.charContextEnabled === undefined) c.charContextEnabled = true;
    if (c.hooksEnabled === undefined) c.hooksEnabled = true;

    // ── Visual field guards (v1.0.0) ──────────────────────────────────────────
    // [CHANGE] New fields. Old records won't have these; default to empty strings
    // and safe numeric values so bridge image generation never receives undefined.
    if (!c.visuals)       c.visuals       = '';
    if (!c.uc)            c.uc            = '';
    if (!c.sceneVisuals)  c.sceneVisuals  = '';
    if (!c.avatarVisuals) c.avatarVisuals = '';
    if (c.avatarWidth  === undefined || c.avatarWidth  === null) c.avatarWidth  = 1024;
    if (c.avatarHeight === undefined || c.avatarHeight === null) c.avatarHeight = 1024;
    if (c.avatarSeed   === undefined || c.avatarSeed   === null) c.avatarSeed   = 0;

    return c as CharacterRecord;
}

// ── Load ──────────────────────────────────────────────────────────────────────

async function loadCharacter(id: string): Promise<CharacterRecord | null> {
    const raw = await api.v1.storyStorage.get(STORAGE_CHAR_PFX + id);
    if (!raw) return null;
    const cfg = await loadConfig();
    return migrateCharacter(raw, cfg);
}

async function loadCharacterListForPicker(excludeId?: string): Promise<CharacterMeta[]> {
    // Returns active characters suitable for UI pickers (relationship target, entity link, etc.).
    // Validates that each index entry still has a backing storage record (handles stale entries).
    const idx = await loadIndex();
    const validated: CharacterMeta[] = [];
    for (const m of idx) {
        if (m.id === excludeId) continue;
        if (!m.active && !m.isProtagonist) continue;
        const exists = await api.v1.storyStorage.get(STORAGE_CHAR_PFX + m.id);
        if (exists) validated.push(m);
    }
    return validated;
}

async function loadAllCharacters(): Promise<CharacterRecord[]> {
    // [CHANGE] Performance fix: original called loadCharacter() per character,
    // which called loadConfig() per character — N+1 storage reads for N characters.
    // Now loads config once and passes it into migrateCharacter directly.
    const idx = await loadIndex();
    const cfg = await loadConfig();
    const chars = await Promise.all(
        idx.filter(Boolean).map(async function(m) {
            try {
                const raw = await api.v1.storyStorage.get(STORAGE_CHAR_PFX + m.id);
                return raw ? migrateCharacter(raw, cfg) : null;
            } catch (e) {
                api.v1.error('[AE] loadAllCharacters: failed to load char ' + m.id, e);
                return null;
            }
        })
    );
    return chars.filter(Boolean) as CharacterRecord[];
}

// ── Save ──────────────────────────────────────────────────────────────────────

async function saveCharacter(char: CharacterRecord): Promise<void> {
    const cfg = await loadConfig();

    // Derive equipped item names from equippedItemIds for the index
    const equippedItemNames: string[] = [];
    for (const itemId of (char.equippedItemIds || [])) {
        try {
            const itemEnt = await loadEntity(itemId);
            if (itemEnt) equippedItemNames.push(itemEnt.name);
        } catch (ignoredErr) { /* non-fatal — item may not exist yet */ }
    }

    // Derive the character's current location from their entity body's parentId.
    // This is the single source of truth for character location — not a stored field.
    let currentLocationId: string | undefined = undefined;
    if (char.entityId) {
        try {
            const charEntBody = await loadEntity(char.entityId);
            if (charEntBody) currentLocationId = charEntBody.parentId !== null ? charEntBody.parentId : undefined;
        } catch (ignoredErr) { /* non-fatal — entity may not exist yet */ }
    }

    // Build the lightweight index entry
    // [CHANGE] portraitKey removed from CharacterMeta — bridge derives from char.id
    const meta: CharacterMeta = {
        id: char.id,
        name: char.name,
        isProtagonist: char.isProtagonist,
        entityId: char.entityId,
        hasCriticalHook: !!(char.hooks && char.hooks.some(function(h) { return !h.resolved && h.pressureLevel >= 85; })),
        scenePresent: char.scenePresent,
        active: char.active,
        briefDescription: char.briefDescription,
        species: char.species,
        age: char.age,
        occupationRole: char.occupationRole,
        currentStance: char.midRange ? char.midRange.socialMask : undefined,
        lastThought: char.ephemeral ? char.ephemeral.compressedLine : undefined,
        lastTokenEstimate: char.lastTokenEstimate,
        equippedItemNames: equippedItemNames.length > 0 ? equippedItemNames : undefined,
        currentLocationId: currentLocationId,
        isStatic: !!((char as any).isStatic),   // [v0.9.31 DYN1] propagate so card reads correct state
        dynamicPriorityRank: (typeof (char as any).dynamicPriorityRank === 'number' && (char as any).dynamicPriorityRank > 0) ? (char as any).dynamicPriorityRank : undefined  // [vNEXT] propagate rank so the cap sorts off the index
    };

    const idx = await loadIndex();
    const existingIdx = idx.findIndex(function(m) { return m.id === char.id; });
    if (existingIdx >= 0) { idx[existingIdx] = meta; } else { idx.push(meta); }

    await saveIndex(idx);
    await api.v1.storyStorage.set(STORAGE_CHAR_PFX + char.id, char);

    // Keep cfg.protagonistName in sync so __player__ resolves correctly in injections
    if (char.isProtagonist && char.name) {
        try {
            const cfgSync = await api.v1.storyStorage.get(STORAGE_CONFIG) as any;
            if (cfgSync && cfgSync.protagonistName !== char.name) {
                cfgSync.protagonistName = char.name;
                await api.v1.storyStorage.set(STORAGE_CONFIG, cfgSync);
            }
        } catch (e) { /* non-fatal */ }
    }

    // [CHANGE] Queue a debounced broadcast to keep the bridge's character visual
    // cache in sync. Defined in Section 18. Batches rapid sequential saves.
    queueCharacterDataBroadcast();
}

// ── Delete ────────────────────────────────────────────────────────────────────

async function deleteCharacter(id: string): Promise<void> {
    const char = await loadCharacter(id);
    if (char && char.entityId) {
        await deleteEntity(char.entityId); // Scrub the physical body from the world
    }
    await api.v1.storyStorage.remove(STORAGE_CHAR_PFX + id);
    const idx = await loadIndex();
    await saveIndex(idx.filter(function(m) { return m.id !== id; }));
    
    // Dispatch cascade event to bridge to clean up IndexedDB assets
    await broadcastToTM('AE_DELETE_PORTRAIT_CASCADE', { charId: id });
}


// ============================================================================
// SECTION 6 — STORAGE: ENTITY DATA
// All reads and writes for EntityRecord and the entity index.
// Entities are the world graph: locations, items, narrative nodes, character bodies.
// ============================================================================

// ── Index (EntityMeta[]) ──────────────────────────────────────────────────────

async function loadEntityIndex(): Promise<EntityMeta[]> {
    return await api.v1.storyStorage.getOrDefault(STORAGE_ENTITY_INDEX, []) as EntityMeta[];
}

async function saveEntityIndex(idx: EntityMeta[]): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_ENTITY_INDEX, idx.filter(Boolean));
}

// ── Migration ─────────────────────────────────────────────────────────────────
// migrateEntity runs every time an EntityRecord is loaded from storage.
// Handles all legacy field shapes from prior engine versions.

function migrateEntity(raw: any): EntityRecord {
    const ent = raw as any;
    if (!ent.id) ent.id = generateId();
    if (!ent.name) ent.name = 'Unnamed Entity';

    // Force legacy spatial sub-types into the current functional type system
    if (!ent.type || ['interior', 'exterior', 'transit', 'abstract'].includes(ent.type)) {
        ent.type = 'location';
    }
    // Migrate legacy shop type → narrative
    if (ent.type === 'shop') ent.type = 'narrative';

    if (ent.narrativeParentId === undefined) ent.narrativeParentId = null;
    if (ent.parentId === undefined) ent.parentId = null;
    if (!ent.storyState) ent.storyState = 'locked';

    // [v0.9.25 E4] Encounter migration removed; delete stale field from old saves
    delete (ent as any).encounters;

    // [CE-STRIP v2.1.5] rules/skillBonuses/isVehicle field guards and the
    // migrateEntityAction() flat-action migration removed — dead Actions remnants.

    if (!ent.description) ent.description = '';
    if (!ent.atmosphere) ent.atmosphere = '';
    if (!ent.state) ent.state = 'default';
    if (!ent.stateDescriptions) ent.stateDescriptions = {};

    // Migrate old connection array key to current key
    ent.connectedEntityIds = ent.connectedEntityIds || ent.connectedLocationIds || [];
    delete ent.connectedLocationIds;

    if (!ent.presentCharacterIds) ent.presentCharacterIds = [];

    // Remove legacy commerce fields
    delete ent.price;
    if (!ent.inventoryIds) ent.inventoryIds = [];

    if (!ent.notes) ent.notes = '';
    if (!ent.lorebookTags) ent.lorebookTags = [];
    if (ent.lorebookText === undefined) ent.lorebookText = '';
    if (ent.locationVisuals === undefined) ent.locationVisuals = '';
    if (!ent.tagSubscriptions) ent.tagSubscriptions = [];
    if (!ent.createdAt) ent.createdAt = Date.now();
    if (!ent.updatedAt) ent.updatedAt = Date.now();

    // Filter null entries in all arrays for safety
    ent.connectedEntityIds  = ent.connectedEntityIds.filter(Boolean);
    ent.presentCharacterIds = ent.presentCharacterIds.filter(Boolean);

    return ent as EntityRecord;
}

// [CE-STRIP v2.1.5] migrateEntityAction() removed via brace-matched deletion.

// ── Load ──────────────────────────────────────────────────────────────────────

async function loadEntity(id: string): Promise<EntityRecord | null> {
    const raw = await api.v1.storyStorage.getOrDefault(STORAGE_ENTITY_PFX + id, null);
    return raw ? migrateEntity(raw) : null;
}

// ── Save ──────────────────────────────────────────────────────────────────────

async function saveEntity(ent: EntityRecord): Promise<void> {
    ent.updatedAt = Date.now();
    // [v0.9.24 E3] Auto-clear tracking when a narrative is completed.
    if (ent.type === 'narrative' && ent.storyState === 'completed') {
        try {
            let _trackedId = await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string;
            if (_trackedId === ent.id) {
                await api.v1.storyStorage.set(STORAGE_TRACKED_NARRATIVE, '');
                api.v1.ui.toast('📍 Tracking cleared — narrative completed.', { type: 'info', autoClose: 2000 });
            }
        } catch (_e3) { /* non-fatal */ }
    }
    await api.v1.storyStorage.set(STORAGE_ENTITY_PFX + ent.id, ent);

    const idx = await loadEntityIndex();
    const meta: EntityMeta = {
        id: ent.id,
        name: ent.name,
        type: ent.type,
        parentId: ent.parentId,
        narrativeParentId: ent.narrativeParentId,
        storyState: ent.storyState,
        childCount: idx.filter(function(m) { return m.parentId === ent.id; }).length,
        presentCharacterCount: ent.presentCharacterIds.filter(Boolean).length,
        state: ent.state,
        icon: ent.icon || undefined
        // [CE-STRIP v2.1.5] gated/isVehicle/hasGlobalAutoTrigger removed — dead Actions/Travel remnants.
    };

    const i = idx.findIndex(function(m) { return m.id === ent.id; });
    if (i >= 0) { idx[i] = meta; } else { idx.push(meta); }
    await saveEntityIndex(idx);

    // [CHANGE] Queue a debounced scene state broadcast. Any entity change — location
    // state, available actions, connection changes — may affect the HUD. Debouncing
    // at 200ms coalesces the storm of saves during bulk operations like imports.
    // Defined in Section 18. No-ops if bridge is not yet connected.
    queueSceneStateBroadcast();
}

// [UNIFY] One-time migration: canonicalise faction-standing args (name → index) on
// entity-ATTACHED action instances. migrateConfig (above) already converts every
// action TEMPLATE in the Library on every load, because cfg is cheap to touch on
// every load. Entity instances live one-per-entity in storyStorage, so scanning all
// of them is comparatively expensive — not something to repeat on every session
// load. Instead this runs exactly once per story, gated by a storyStorage flag, and
// is safe to skip even if it never runs: aeResolveResourceCompareValue (used by every
// faction condition/effect at evaluation time) still accepts a saved NAME as a
// fallback, so un-migrated instances keep working correctly either way — this pass
// only tidies the underlying data to indices so a later faction rename can't strip
// old actions. Called once from onScriptsLoaded, after config is available.
async function migrateFactionArgsOnEntities(cfg: GlobalConfig): Promise<void> {
    try {
        const already = await api.v1.storyStorage.getOrDefault(STORAGE_FAC_ENTITY_MIGRATED, false) as boolean;
        if (already) return;

        let facById: Record<string, FactionDef> = {};
        (cfg.factions || []).forEach(function(f) { facById[f.id] = f; });

        const idx = await loadEntityIndex();
        let touched = 0;
        for (const meta of idx.filter(Boolean)) {
            let ent = await loadEntity(meta.id).catch(function() { return null; });
            if (!ent) continue;
            let insts = ((ent as any).actionInstances || []) as ActionInstance[];
            if (!insts.length) continue;
            let before = JSON.stringify(insts);
            insts.forEach(function(inst) { aeWalkActionForFactionArgs(inst, facById); });
            if (JSON.stringify(insts) !== before) {
                await saveEntity(ent);
                touched++;
            }
        }

        await api.v1.storyStorage.set(STORAGE_FAC_ENTITY_MIGRATED, true);
        if (touched > 0) api.v1.log('[AE:migrate] Faction-standing args canonicalised on ' + touched + ' entit' + (touched === 1 ? 'y' : 'ies') + '.');
    } catch (eFacEnt) {
        // Non-fatal: leave the flag unset so a future load can retry, and the
        // runtime name-fallback keeps everything working in the meantime.
        api.v1.error('[AE:migrate] migrateFactionArgsOnEntities error:', eFacEnt);
    }
}

// ── Delete ────────────────────────────────────────────────────────────────────

async function deleteEntity(id: string): Promise<void> {
    await api.v1.storyStorage.remove(STORAGE_ENTITY_PFX + id);
    const idx = await loadEntityIndex();

    // Collect orphaned children BEFORE removing the entry from the index,
    // since we need their parentId reference while it still points to the deleted entity.
    const orphaned = idx.filter(function(m) { return m.parentId === id; });

    await saveEntityIndex(idx.filter(function(m) { return m.id !== id; }));

    // Re-parent any child entities to the world root (null parent).
    // [CHANGE] Fixes a pre-existing dead-code bug: the original code checked
    // CharacterRecord.currentLocationId which is never stored on that type
    // (it is derived and only stored in CharacterMeta). Now correctly iterates
    // child entities via their parentId relationship in the entity index.
    for (const m of orphaned) {
        try {
            const child = await loadEntity(m.id);
            if (child) { child.parentId = null; await saveEntity(child); }
        } catch (ignoredErr) { /* non-fatal */ }
    }
}

// ── Copy ──────────────────────────────────────────────────────────────────────

async function copyEntity(id: string, deep: boolean = false): Promise<void> {
    try {
        const src = await loadEntity(id);
        if (!src) return;

        const newId = generateId();
        const copy: EntityRecord = JSON.parse(JSON.stringify(src));

        copy.id = newId;
        copy.name = 'Copy of ' + src.name;
        copy.createdAt = Date.now();
        copy.updatedAt = Date.now();

        // Clear runtime state — copy starts fresh, not carrying over scene presence
        copy.connectedEntityIds = [];
        copy.presentCharacterIds = [];

        // [v0.9.25 E4] Encounter range copy removed
        if (false && (copy as any).encounters) {
            (copy as any).encounters.ranges = ((copy as any).encounters.ranges || []).map(function(r) {
                return Object.assign({}, r, { id: generateId(), triggered: false });
            });
        }

        await saveEntity(copy);

        if (deep) {
            const allMeta = await loadEntityIndex();
            const children = allMeta.filter(function(m) { return m.parentId === src.id; });

            for (const childMeta of children) {
                const childSrc = await loadEntity(childMeta.id);
                if (!childSrc) continue;

                const childCopy: EntityRecord = JSON.parse(JSON.stringify(childSrc));
                childCopy.id = generateId();
                childCopy.name = childSrc.name;
                childCopy.parentId = newId;
                childCopy.createdAt = Date.now();
                childCopy.updatedAt = Date.now();
                childCopy.connectedEntityIds = [];
                childCopy.presentCharacterIds = [];
                if (false && (childCopy as any).encounters) {
                    (childCopy as any).encounters.ranges = ((childCopy as any).encounters.ranges || []).map(function(r) {
                        return Object.assign({}, r, { id: generateId(), triggered: false });
                    });
                }
                await saveEntity(childCopy);
            }

            api.v1.ui.toast('Copied "' + src.name + '" with ' + children.length + ' child(ren).', { type: 'success' });
        } else {
            api.v1.ui.toast('Copied "' + src.name + '".', { type: 'success' });
        }

        await refreshSidebar();
        await openEntityEditModal(newId);
    } catch (e) {
        api.v1.error('[AE] copyEntity:', e);
        api.v1.ui.toast('Copy failed.', { type: 'error' });
    }
}

// ── History (recent location breadcrumb) ─────────────────────────────────────

async function loadEntityHistory(): Promise<string[]> {
    return await api.v1.storyStorage.getOrDefault(STORAGE_ENTITY_HISTORY, []) as string[];
}

async function saveEntityHistory(ids: string[]): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_ENTITY_HISTORY, ids.slice(0, 10));
}


// ============================================================================
// SECTION 7 — STORAGE: GLOBAL CONFIG
// Single GlobalConfig record per story. Governs engine intervals, field labels,
// resources, factions, skill modifiers, and generation style.
// ============================================================================

// [CE-STRIP v2.0.x] DEFAULT_TIME_BANDS removed — Clock/Calendar cut.

function makeDefaultConfig(): GlobalConfig {
    return {
        contextTemplates: JSON.parse(JSON.stringify(DEFAULT_TEMPLATES)),
        lorebookTemplates: JSON.parse(JSON.stringify(DEFAULT_LOREBOOK_TEMPLATES)),  // [v2.7.0 CONDITIONS]
        lorebookFields: JSON.parse(JSON.stringify(DEFAULT_LOREBOOK_FIELDS)),  // [v2.9.0 LOREFOLD]
        interfaceMode: 'native',   // [v0.9.9.6] default to the native HUD; bridge is opt-in
        thoughtIntervalGens: 2,    // [v0.9.24 E1] ephemeral every 2 generations
        dynamicIntervalGens: 4,    // mid-range every 4 generations
        arcIntervalGens: 10,       // arc/relationship every 10 generations
        hookIntervalGens: 6,       // hooks every 6 generations
        totalGenerations: 0,
        ephemeralCap: 3,
        maxDynamicCharacters: 0,   // [vNEXT] 0 = no cap (all present dynamic chars process)
        sheetCategories: [], // [PATCH] DEFAULT_SHEET_CATEGORIES removed; full Sheet Categories cut deferred to its own pass.
        autoUpdateDefault: true,
        autoThoughtsDefault: true,
        showFieldHeaders: true,
        generalStyle: DEFAULT_GENERAL_STYLE,
        fieldLabels: {},
        fieldInstructions: {},
        fieldBudgets: {},
        customStaticFields: [],
        relationshipArchetypes: [...DEFAULT_REL_ARCHETYPES],
        conditions: [...DEFAULT_CONDITIONS],  // [v2.7.0 CONDITIONS]
        species: [],
        factions: [],
        projectName: '',
        projectGenre: '',
        projectConcept: '',
        wizardSections: JSON.parse(JSON.stringify(DEFAULT_WIZARD_SECTIONS)),
        defaultBackgroundUrl: '',
        // [CE-STRIP v2.0.x] time* defaults removed — Clock/Calendar cut.
    };
}

// [UNIFY] Shared faction-standing-arg normaliser — converts a saved NAME on any
// faction condition/effect rule to its index, in place, on a single action's full
// rule tree (conditions, all three effect buckets, resolution bands, branches).
// Idempotent: a value that already parses as a number, or doesn't match any
// standing, is left untouched (the runtime resolver still handles bare names as
// a fallback either way). Used by migrateConfig (action templates) and by
// migrateFactionArgsOnEntities (entity-attached action instances) so both surfaces
// share one conversion path instead of two copies that could drift apart.
const AE_FAC_STANDING_RULE_TYPES: Record<string, number> = { char_faction: 1, set_char_faction: 1 };
function aeConvertFactionStandingArgs(rule: any, facById: Record<string, FactionDef>): void {
    if (!rule || !rule.args || !AE_FAC_STANDING_RULE_TYPES[rule.type]) return;
    let raw = rule.args.state;
    if (raw === undefined || raw === null || raw === '__ask__') return;
    if (!isNaN(Number(String(raw).trim())) && String(raw).trim() !== '') return; // already an index
    let fdef = facById[String(rule.args.factionId || '')];
    if (!fdef || !fdef.relationshipStates) return;
    let idx = fdef.relationshipStates.findIndex(function(s) { return String(s).toLowerCase() === String(raw).toLowerCase(); });
    if (idx >= 0) rule.args.state = String(idx);
}
// [PATCH v0998] Generic rule-arg repair — driven off UIRuleManifest so it covers
// every current 'string'/'number' arg automatically, not just the two known
// culprits. Two things it fixes, both idempotent:
//   1) manifest says 'string' but the stored value is a number/boolean -> stringify.
//   2) manifest says 'number' but the stored value is a string -> resolve to a real
//      number. For char_resource.amount / char_skill.amount this means running the
//      SAME name-or-index lookup the runtime already uses (aeResolveResourceCompareValue),
//      so a legacy "dead" keeps matching the "dead" state's current index rather than
//      being silently discarded. Anything that can't be resolved is left untouched and
//      logged to AE_ARG_REPAIR_LOG for the Scan & Repair report instead of guessed at.
// NOTE: aeResolveResourceCompareValue is defined later in the file; safe because
// function declarations are hoisted and this only ever runs after script load.
let AE_ARG_REPAIR_LOG: string[] = [];
function aeCoerceRuleArgTypes(rule: any, cfg: GlobalConfig, ctx: string): void {
    if (!rule || !rule.type || !rule.args) return;
    const manifest = (typeof UIRuleManifest !== 'undefined') ? UIRuleManifest[rule.type] : undefined;
    if (!manifest || !manifest.args) return;

    manifest.args.forEach(function(argDef: any) {
        const key = argDef.key;
        const v = rule.args[key];
        if (v === undefined || v === null) return;

        if ((argDef.type === 'string' || argDef.type === 'longtext') && typeof v !== 'string') {
            if (typeof v === 'number' || typeof v === 'boolean') {
                AE_ARG_REPAIR_LOG.push(`${ctx}: ${rule.type}.${key} ${JSON.stringify(v)} -> "${String(v)}"`);
                rule.args[key] = String(v);
            } else {
                AE_ARG_REPAIR_LOG.push(`\u26a0 ${ctx}: ${rule.type}.${key} = ${JSON.stringify(v)} \u2014 could not auto-repair (unexpected type), please check manually`);
            }
            return;
        }

        if (argDef.type === 'number' && typeof v !== 'number') {
            let resolved: number = NaN;
            if (rule.type === 'char_resource' && key === 'amount') {
                const rdef = (cfg.characterResourceDefs || []).find(function(r: any) { return r.tag === rule.args.tag; });
                resolved = aeResolveResourceCompareValue(v, rdef ? rdef.states : undefined);
            } else if (rule.type === 'char_skill' && key === 'amount') {
                const parts = String(rule.args.fieldRef || '').split('.');
                const cat = (cfg.sheetCategories || []).find(function(c: any) { return c.id === parts[0]; });
                resolved = aeResolveResourceCompareValue(v, (cat && cat.fieldType === 'enum') ? cat.enumValues : undefined);
            } else {
                resolved = Number(v);
            }
            if (!isNaN(resolved)) {
                AE_ARG_REPAIR_LOG.push(`${ctx}: ${rule.type}.${key} ${JSON.stringify(v)} -> ${resolved}`);
                rule.args[key] = resolved;
            } else {
                AE_ARG_REPAIR_LOG.push(`\u26a0 ${ctx}: ${rule.type}.${key} = ${JSON.stringify(v)} \u2014 could not resolve to an index/number, please check manually`);
            }
        }
    });
}
function aeWalkActionForArgTypeRepair(act: any, cfg: GlobalConfig, ctx: string): void {
    if (!act) return;
    (act.conditions      || []).forEach(function(r: any) { aeCoerceRuleArgTypes(r, cfg, ctx); });
    (act.successEffects  || []).forEach(function(r: any) { aeCoerceRuleArgTypes(r, cfg, ctx); });
    (act.failureEffects  || []).forEach(function(r: any) { aeCoerceRuleArgTypes(r, cfg, ctx); });
    (act.alwaysEffects   || []).forEach(function(r: any) { aeCoerceRuleArgTypes(r, cfg, ctx); });
    if (act.resolution && Array.isArray(act.resolution.bands)) {
        act.resolution.bands.forEach(function(b: any) { (b.effects || []).forEach(function(r: any) { aeCoerceRuleArgTypes(r, cfg, ctx + ' [band]'); }); });
    }
    (act.branches || []).forEach(function(b: any) { aeWalkActionForArgTypeRepair(b, cfg, ctx + ' [branch:' + (b.name || '?') + ']'); });
}

function aeWalkActionForFactionArgs(act: any, facById: Record<string, FactionDef>): void {
    if (!act) return;
    (act.conditions || []).forEach(function(r: any) { aeConvertFactionStandingArgs(r, facById); });
    (act.successEffects || []).forEach(function(r: any) { aeConvertFactionStandingArgs(r, facById); });
    (act.failureEffects || []).forEach(function(r: any) { aeConvertFactionStandingArgs(r, facById); });
    (act.alwaysEffects  || []).forEach(function(r: any) { aeConvertFactionStandingArgs(r, facById); });
    if (act.resolution && Array.isArray(act.resolution.bands)) {
        act.resolution.bands.forEach(function(b: any) { (b.effects || []).forEach(function(r: any) { aeConvertFactionStandingArgs(r, facById); }); });
    }
    (act.branches || []).forEach(function(b: any) { aeWalkActionForFactionArgs(b, facById); });
}

function migrateConfig(raw: any): GlobalConfig {
    // Merges raw saved data over defaults so new fields always have values.
    // Strips deprecated keys so old saves don't carry stale data.
    const d = makeDefaultConfig();
    const c = { ...d, ...raw };

    // Deprecated field removal
    delete c.storyRolePresets;
    delete c.conditionPresets;
    delete (c as any).defaultBudgetCap;
    delete (c as any).globalRules;
    delete (c as any).arcTypePresets; // Purge old config properties

    // Structural guards
    // [REMOVED v2.30.0, per user] Was: [HOLDING] Seed the baked-in default player
    // faction (idempotent by id). This existed to give the Holding system's roster a
    // default source — but Holding Document authoring + the player-faction picker
    // were already CE-STRIPped out (see buildFactionsWorkspace's own removal note,
    // "[CE-STRIP v2.0.x] Holding Document authoring + player-faction picker removed").
    // Nothing has read DEFAULT_PLAYER_FACTION_ID except this seed since that strip —
    // verified zero remaining callers before deleting both the seed and the constant
    // (grep DEFAULT_PLAYER_FACTION_ID / 'fac_player' turns up nothing else). A fresh
    // config no longer gets an uneditable "The Player" faction it never asked for;
    // existing saves that already have one are UNTOUCHED (this only ever ran on
    // migration, never as a delete pass) — remove it by hand via the Factions Manager
    // if you don't want it.
    if (!c.factions) c.factions = [];
    if (!c.relationshipArchetypes) c.relationshipArchetypes = JSON.parse(JSON.stringify(DEFAULT_REL_ARCHETYPES));
    // [v2.7.0 CONDITIONS] Old saves get the default set seeded once; existing saves
    // that already have SOME conditions (even a custom, edited list) are left alone —
    // same non-destructive pattern as relationshipArchetypes above.
    if (!c.conditions) c.conditions = JSON.parse(JSON.stringify(DEFAULT_CONDITIONS));
    if (!c.lorebookTemplates) c.lorebookTemplates = JSON.parse(JSON.stringify(DEFAULT_LOREBOOK_TEMPLATES));
    else {
        // [v2.9.0 LOREFOLD] backfill every lorebook template key so old saves gain the
        // new equipment/relationship/mid-range lines without clobbering customised ones.
        for (const _ltk of Object.keys(DEFAULT_LOREBOOK_TEMPLATES)) {
            if (!(c.lorebookTemplates as any)[_ltk]) (c.lorebookTemplates as any)[_ltk] = (DEFAULT_LOREBOOK_TEMPLATES as any)[_ltk];
        }
        // [v2.14.0 GENESIS] Reshape prior-default templates whose wording changed this
        // pass — only when still byte-identical to the old default (never clobber edits).
        for (const _mk of Object.keys(LOREBOOK_TEMPLATE_MIGRATIONS_V214)) {
            const _mig = LOREBOOK_TEMPLATE_MIGRATIONS_V214[_mk];
            if ((c.lorebookTemplates as any)[_mk] === _mig.old) (c.lorebookTemplates as any)[_mk] = _mig.neu;
        }
    }
    // [v2.9.0 LOREFOLD] Per-field include switches — default any missing key to on.
    if (!c.lorebookFields) c.lorebookFields = JSON.parse(JSON.stringify(DEFAULT_LOREBOOK_FIELDS));
    else {
        for (const _lfk of Object.keys(DEFAULT_LOREBOOK_FIELDS)) {
            if ((c.lorebookFields as any)[_lfk] === undefined) (c.lorebookFields as any)[_lfk] = (DEFAULT_LOREBOOK_FIELDS as any)[_lfk];
        }
    }
    // Migrate legacy string[] archetypes → RelationshipArchetypeDef[]
    if (Array.isArray(c.relationshipArchetypes) && c.relationshipArchetypes.length > 0 && typeof c.relationshipArchetypes[0] === 'string') {
        c.relationshipArchetypes = (c.relationshipArchetypes as any[]).map(function(s: any) {
            return { id: 'arch_' + String(s).toLowerCase().replace(/[^a-z0-9]+/g, '_').slice(0, 24) + '_' + Math.random().toString(36).slice(2, 6), name: String(s), stages: [] };
        });
    }
    if (!c.customStaticFields)     c.customStaticFields = [];
    if (!c.fieldLabels)            c.fieldLabels = {};
    if (!c.fieldInstructions)      c.fieldInstructions = {};
    if (!c.fieldBudgets)           c.fieldBudgets = {};
    if (!c.sheetCategories)        c.sheetCategories = [];
    if (c.ephemeralCap === undefined) c.ephemeralCap = 3;

    // [CE-STRIP v2.0.x] Global/party resources migration removed — Resources cut.

    // v0.9.3 fields
    if (!c.species)  c.species  = [];
    if (!c.factions) c.factions = [];

    // [v0.9.24 E1] Remove deprecated token-interval fields from old saves
    delete (c as any).thoughtIntervalTokens;
    delete (c as any).dynamicIntervalTokens;
    delete (c as any).arcIntervalTokens;
    delete (c as any).hookIntervalTokens;
    // Ensure gen-interval fields exist (new saves via makeDefaultConfig will have them)
    if (!c.thoughtIntervalGens) c.thoughtIntervalGens = 2;
    if (!c.dynamicIntervalGens) c.dynamicIntervalGens = 4;
    if (!c.arcIntervalGens)     c.arcIntervalGens     = 10;
    if (!c.hookIntervalGens)    c.hookIntervalGens    = 6;
    if (c.maxDynamicCharacters === undefined) c.maxDynamicCharacters = 0;  // [vNEXT] no cap by default
    if (c.totalGenerations === undefined) c.totalGenerations = 0;
    if (c.defaultBackgroundUrl === undefined) c.defaultBackgroundUrl = ''; // [v0.9.40]
    if (!c.contextTemplates) c.contextTemplates = JSON.parse(JSON.stringify(DEFAULT_TEMPLATES));
    if (typeof (c as any).interfaceMode !== 'string') (c as any).interfaceMode = 'native';  // [v0.9.9.6]
    // [CE-STRIP v2.6.0 CTX-CUT] The old v0.9.8.4 template-upgrade loop (location/
    // trackedNarrative/player/npc) is gone along with those keys. A save from before
    // this pass still has a contextTemplates object, just missing the new
    // criticalHook key — backfill it so old saves don't render a blank hook line.
    // Any orphaned location/player/npcWeb/trackedNarrative/activeNarrative string
    // values left on old saves are harmless — unread by anything now.
    if (c.contextTemplates && !(c.contextTemplates as any).criticalHook) {
        (c.contextTemplates as any).criticalHook = DEFAULT_TEMPLATES.criticalHook;
    }
    // [v2.9.0 LOREFOLD] Backfill the re-added NPC-web AN template, and migrate the
    // pre-LOREFOLD fat npc template to thoughts-only so relationship/goal/conditions
    // are not injected in BOTH the AN and the lorebook. Hand-authored npc strings
    // (anything other than the known old default) are preserved untouched.
    if (c.contextTemplates && !(c.contextTemplates as any).npcWeb) {
        (c.contextTemplates as any).npcWeb = DEFAULT_TEMPLATES.npcWeb;
    }
    if (c.contextTemplates && (c.contextTemplates as any).npc === OLD_NPC_TEMPLATE_V28) {
        (c.contextTemplates as any).npc = DEFAULT_TEMPLATES.npc;
    }
    
    // [vNEXT] Seed the World-Build Wizard's Memory section list and concept fields.
    if (!c.wizardSections) {
        c.wizardSections = JSON.parse(JSON.stringify(DEFAULT_WIZARD_SECTIONS));
    }
    if (c.projectName === undefined) c.projectName = '';
    if (c.projectGenre === undefined) c.projectGenre = '';
    if (c.projectConcept === undefined) c.projectConcept = '';

    // [CE-STRIP v2.0.x] time* migration-fill removed — Clock/Calendar cut.

    return c as GlobalConfig;
}

async function loadConfig(): Promise<GlobalConfig> {
    const raw = await api.v1.storyStorage.getOrDefault(STORAGE_CONFIG, null);
    // [v0.9.37 SEED1] Run migrateConfig on the DEFAULT too, so a brand-new story is
    // seeded with sys_default_travel / sys_return_travel. Previously makeDefaultConfig
    // bypassed migrateConfig, leaving fresh stories with no travel templates until the
    // action editor happened to save a config -> travel silently did nothing.
    return migrateConfig(raw ? raw : makeDefaultConfig());
}

async function saveConfig(cfg: GlobalConfig): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_CONFIG, cfg);
}

// ── Relationship archetype helpers ──────────────────────────────────────────
function findArchetypeDef(cfg: GlobalConfig, rel: PrimaryRelationship | undefined): RelationshipArchetypeDef | null {
    if (!rel) return null;
    let defs = (cfg.relationshipArchetypes || []) as RelationshipArchetypeDef[];
    // Prefer explicit ID; fall back to name match (lazy migration for old saves).
    if (rel.archetypeId) {
        let byId = defs.find(function(d) { return d.id === rel.archetypeId; });
        if (byId) return byId;
    }
    if (rel.archetype) {
        let byName = defs.find(function(d) { return d.name.toLowerCase() === String(rel.archetype).toLowerCase(); });
        if (byName) return byName;
    }
    return null;
}

// Returns the current stage label for a relationship, or '' if no stages defined.
function resolveArchetypeStage(cfg: GlobalConfig, rel: PrimaryRelationship | undefined): string {
    let def = findArchetypeDef(cfg, rel);
    if (!def || !def.stages || !def.stages.length) return '';
    let idx = (rel && typeof rel.stageIndex === 'number') ? rel.stageIndex : 0;
    idx = Math.max(0, Math.min(def.stages.length - 1, idx));
    return def.stages[idx] || '';
}

// ── Unified search picker ───────────────────────────────────────────────────
// Any picker with potentially >5 options should use this. Renders a live search
// box that re-filters as the user types. items: { id, label }[]. onSelect gets the
// chosen id. Auto-omits the search box when there are 5 or fewer items.
interface PickItem { id: string; label: string; selected?: boolean; }
async function openSearchPicker(title: string, items: PickItem[], onSelect: (id: string) => Promise<void>, extraTop?: UIPart[]): Promise<void> {
    let searchKey = 'temp:ce_uipick_' + title.toLowerCase().replace(/[^a-z0-9]+/g, '_').slice(0, 24);
    await api.v1.tempStorage.set(searchKey, '');
    let showSearch = items.length > 5;
    let pmP: any = null;
    async function draw() {
        let term = ((await api.v1.tempStorage.getOrDefault(searchKey, '')) as string).toLowerCase();
        let filtered = (showSearch && term) ? items.filter(function(it) { return it.label.toLowerCase().includes(term); }) : items;
        let content: UIPart[] = [];
        if (extraTop && extraTop.length) { for (const e of extraTop) content.push(e); }
        if (showSearch) {
            content.push({ type: 'textInput', placeholder: '\ud83d\udd0d Search\u2026', initialValue: term, onChange: async function(v: string) { await api.v1.tempStorage.set(searchKey, v); await draw(); } } as UIPart);
        }
        for (const it of filtered) {
            content.push({ type: 'button', text: it.label, style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: it.selected ? 'rgba(126,200,160,0.2)' : 'rgba(255,255,255,0.02)', color: it.selected ? '#7ec8a0' : undefined }, callback: async function() { if (pmP) pmP.close(); await onSelect(it.id); } } as UIPart);
        }
        if (!filtered.length) content.push({ type: 'text', text: 'No matches.', style: { fontSize: '11px', opacity: '0.5' } } as UIPart);
        if (pmP && !pmP.isClosed()) { await pmP.update({ content: content }); }
        else { pmP = await openEngineModal({ id: 'ce-search-picker', title: title, size: 'small', content: content }); }
    }
    await draw();
}


// ============================================================================
// SECTION 8 — STORAGE: PARTY STATE, NPC WEB, QUICK ACTION PRESETS
// Three independent storyStorage records that don't fit in the character or
// entity systems but are story-persistent.
// ============================================================================


// ── NPC Web ───────────────────────────────────────────────────────────────────
// The bilateral dynamic relationship graph between NPCs (WebLink[]).
// Stored as a JSON string because it can grow large and benefits from direct
// string serialization rather than NAI's object storage path.

async function loadNpcWeb(): Promise<WebLink[]> {
    const raw = await api.v1.storyStorage.get(STORAGE_NPC_WEB) as string;
    try { return raw ? JSON.parse(raw) : []; } catch { return []; }
}

async function saveNpcWeb(web: WebLink[]): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_NPC_WEB, JSON.stringify(web));
}

// ============================================================================
// SECTION 9 — STORAGE: IMAGE SETTINGS
// Image generation presets and global image settings.
// Stored in api.v1.storage (global, not story-bound) so they persist across
// stories without being part of the adventure module export.
// ============================================================================

// NOTE FOR ASSEMBLY: EVT_IMG_FIELDS_SYNC = 'AE_IMG_FIELDS_SYNC' was missed from
// Section 2 and should be added to the Bridge Event Name Constants block there.
// Used by saveImageSettings() below. [v2.13.0] Replaces the old PRESET_SYNC /
// AE_ALL_PRESETS_SYNC pair — one message carries the whole field library plus the
// default dimensions/scale/steps, since there's no more single "active preset".

async function loadImageSettings(): Promise<void> {
    // [CHANGE] Renamed from loadSettings() to clarify scope.
    // [CHANGE] Removed tempStorage mirroring (the 20 img_p*_steps/scale/etc. writes).
    //   Those keys only fed the now-removed AI engine NAI modal. Settings live
    //   in-memory (imagePromptFields[], globalSettings) for the engine and are
    //   broadcast to the bridge via saveImageSettings() → AE_IMG_FIELDS_SYNC.
    // [CHANGE] Removed cachedCharConfigs load from old STORAGE_KEY_CHAR_CONFIGS key.
    //   Character visual data is now seeded by buildCharacterDataPayload() in
    //   onScriptsLoaded (Section 27) and kept current by saveCharacter() calls.
    // [v2.13.0 IMGFIELDS] No preset migration — starts empty on a fresh install
    // (user's explicit call), replacing the old 5-slot generateDefaultPresets().

    const sf = await api.v1.storage.get(STORAGE_KEY_PROMPT_FIELDS);
    imagePromptFields = Array.isArray(sf) ? sf : [];

    const sg = await api.v1.storage.get(STORAGE_KEY_GLOBAL);
    if (sg) globalSettings = Object.assign({}, globalSettings, sg);

    // Guard every globalSettings field so partial saves from older versions work
    if (globalSettings.contextSize        === undefined) globalSettings.contextSize        = DEFAULT_CTX;
    if (!globalSettings.architectPrompt)                  globalSettings.architectPrompt   = DEFAULT_ARCH;
    if (globalSettings.architectAutoSnap   === undefined) globalSettings.architectAutoSnap   = true;
    if (globalSettings.autoDownload        === undefined) globalSettings.autoDownload        = false;
    if (globalSettings.defaultWidth        === undefined) globalSettings.defaultWidth        = 832;
    if (globalSettings.defaultHeight       === undefined) globalSettings.defaultHeight       = 1216;
    if (globalSettings.defaultScale        === undefined) globalSettings.defaultScale        = 5.0;
    if (globalSettings.defaultSteps        === undefined) globalSettings.defaultSteps        = 28;
}

async function saveImageSettings(): Promise<void> {
    // [CHANGE] Renamed from saveSettings() to clarify scope.
    await api.v1.storage.set(STORAGE_KEY_PROMPT_FIELDS, imagePromptFields);
    await api.v1.storage.set(STORAGE_KEY_GLOBAL,        globalSettings);

    // Keep bridge in sync with the field library + defaults so the Image Studio
    // widget and avatar/snapshot generation pick up changes immediately.
    if (isBridgeReady) {
        try {
            await broadcastToTM('AE_IMG_FIELDS_SYNC', {
                fields: imagePromptFields,
                defaults: { width: globalSettings.defaultWidth, height: globalSettings.defaultHeight, scale: globalSettings.defaultScale, steps: globalSettings.defaultSteps }
            });
        } catch (e) { api.v1.error('[AE] saveImageSettings: AE_IMG_FIELDS_SYNC failed:', e); }
    }
}

// [v2.13.0 IMGFIELDS] Compiles every currently-ACTIVE field into the final
// quality/negative prompt strings. A field's weight only wraps its contribution
// in NAI's N::text:: syntax when weight != 1 (unweighted fields stay plain text,
// keeping the compiled result readable). Same compiled pair feeds every
// generation path (Auto-Snap, manual Director's Cut, Snapshot) — there's no
// per-generation selection step; "active" is a standing toggle per field.
function compileActiveImageFields(): { quality: string; negative: string } {
    const qualityParts: string[] = [];
    const negativeParts: string[] = [];
    for (const f of (imagePromptFields || [])) {
        if (!f.active) continue;
        const w = (typeof f.weight === 'number' && f.weight > 0) ? Math.max(0.1, Math.min(10, f.weight)) : 1;
        const bp = (f.basePrompt || '').trim();
        const uc = (f.uc || '').trim();
        if (bp) qualityParts.push(w !== 1 ? (w + '::' + bp + '::') : bp);
        if (uc) negativeParts.push(w !== 1 ? (w + '::' + uc + '::') : uc);
    }
    return { quality: qualityParts.join(', '), negative: negativeParts.join(', ') };
}

async function restoreImageDefaults(): Promise<void> {
    // [CHANGE] Renamed from restoreDefaults() to clarify scope.
    // [CHANGE] Simplified: removed modal.close() and renderModal() calls since
    //   the Director's Cut NAI modal no longer exists. Settings live in the
    //   AE config modal (Section 22) which uses its own refresh pattern.
    globalSettings.contextSize     = DEFAULT_CTX;
    globalSettings.architectPrompt = DEFAULT_ARCH;
    await saveImageSettings();
    api.v1.ui.toast('🔄 Image defaults restored.');
}
// ============================================================================
// SECTION 10 — LOREBOOK HELPERS
// Functions that build, create, and sync NAI lorebook entries for characters,
// factions, and species. Lorebook entries are how static character profiles
// get injected into context via NAI's native keyword-matching system.
//
// PATTERN NOTE: All three record types (character, faction, species) share an
// identical four-function family: getKeys / buildContent / createLinked / sync.
// This is a future candidate for a generalized syncLorebookRecord<T>(spec) helper
// once the refactor stabilizes. Not changing now — the calls are simple enough
// that the abstraction would add indirection without immediate benefit.
// ============================================================================

// ── Character Lorebook ────────────────────────────────────────────────────────

function getLorebookKeys(char: CharacterRecord): string[] {
    // Returns the name + all nicknames as lorebook trigger keys.
    return [char.name, ...char.nicknames.filter(Boolean)].filter(Boolean);
}

async function buildLorebookContent(char: CharacterRecord): Promise<string> {
    // Assembles the lorebook entry text from a character's static fields.
    // showFieldHeaders controls whether field labels are prepended.
    // This is the single authoritative builder — used by both create and sync.
    const cfg = await loadConfig();
    const showHeaders = cfg.showFieldHeaders;
    const lines: string[] = [];

    function addField(label: string, value: string | undefined | null) {
        if (!value || value.trim() === '') return;
        lines.push(showHeaders ? `${label}: ${value.trim()}` : value.trim());
    }

    // [v0.9.8.5] Identity line — collapsed from five separate Name/Age/Species/
    // Gender/Role fields into a single dossier header, e.g. "Gareth — human male,
    // 34, blacksmith". Header-agnostic by design (it reads as a header itself).
    let idLeader = [char.species, char.gender].map(function(s) { return (s || '').trim(); }).filter(Boolean).join(' ');
    let idMid = [idLeader, (char.age || '').trim(), (char.occupationRole || '').trim()].filter(Boolean).join(', ');
    let identityLine = (char.name || '').trim();
    if (identityLine && idMid) identityLine += ' \u2014 ' + idMid;
    else if (!identityLine && idMid) identityLine = idMid;
    if (identityLine) lines.push(identityLine);

    // Core static fields — label keys are customisable via cfg.fieldLabels
    addField(cfg.fieldLabels['physicalDescription'] || 'Physical Description', char.physicalDescription);
    addField(cfg.fieldLabels['personalityCore']     || 'Personality Core',     char.personalityCore);
    addField(cfg.fieldLabels['voiceAndMannerisms']  || 'Voice & Mannerisms',   char.voiceAndMannerisms);
    addField(cfg.fieldLabels['background']          || 'Background',           char.background);

    // Core values
    if (char.coreValues && char.coreValues.length > 0) {
        addField('Core Values', char.coreValues.filter(Boolean).join(', '));
    }

    // Author-defined custom static fields
    if (cfg.customStaticFields && char.customFieldValues) {
        for (const cf of cfg.customStaticFields) {
            addField(cf.label, char.customFieldValues[cf.id]);
        }
    }

    // [v2.9.0 LOREFOLD] Equipment (and the rest of the dynamic layer) is NOT in this
    // static builder. buildCharDynamicBlock() produces it fresh each generation and
    // buildSceneLorebookActivation() appends it onto this entry's content per-build, so
    // the STORED entry stays static identity (equip/unequip triggers no lorebook re-sync).
    return lines.join('\n');
}

// [v2.7.0 CONDITIONS] ── Dynamic Lorebook (narrative prose, NOT the wiki-style
// dossier above) ──────────────────────────────────────────────────────────────
// Deliberately a separate builder from buildLorebookContent: that one is static
// identity (labeled fields, content-stable, cache-friendly); this one is dynamic
// state (conditions today), rebuilt fresh every generation like equipment, and
// reads as prose rather than a field list per user's explicit call.

// Resolves one active condition to its narrative line, or '' if the def was
// deleted out from under an active state (orphaned reference — skip gracefully,
// don't throw) or the line template itself resolves empty.
function buildConditionLine(char: CharacterRecord, def: ConditionDef, stageIndex: number, cfg: GlobalConfig): string {
    let stageText = '';
    if (def.stages && def.stages.length > 0) {
        let idx = Math.max(0, Math.min(def.stages.length - 1, stageIndex || 0));
        stageText = def.stages[idx] || '';
    }
    const data = { name: char.name, conditionName: def.name, stageText: stageText };
    return parseMacroTemplate(cfg.lorebookTemplates.condition, data).trim();
}

// One line per active condition (user's call — not combined into one sentence).
// Returns '' if the character has no active conditions (or none resolve to text),
// so callers can skip emitting an empty temp lorebook entry.
async function buildDynamicLorebookContent(char: CharacterRecord, cfg: GlobalConfig): Promise<string> {
    const lines: string[] = [];
    const defs = cfg.conditions || [];
    for (const state of (char.activeConditions || [])) {
        const def = defs.find(function(d) { return d.id === state.defId; });
        if (!def) continue;
        const line = buildConditionLine(char, def, state.stageIndex, cfg);
        if (line) lines.push(line);
    }
    return lines.join('\n');
}

// [v2.9.0 LOREFOLD] Composite dynamic block folded into a character's lorebook entry:
// equipment + conditions + relationship + mid-range. Each line is gated by
// cfg.lorebookFields and rendered as prose via cfg.lorebookTemplates. Returns '' when
// nothing is enabled/populated so callers can skip an empty append. Rebuilt fresh every
// generation (state, not identity) — same cadence the old ae_equip_/ae_dynamic_ temp
// entries had, just consolidated into one entry so ordering is deterministic.
async function buildCharDynamicBlock(char: CharacterRecord, cfg: GlobalConfig): Promise<string> {
    const lines: string[] = [];
    const tpl = cfg.lorebookTemplates || ({} as LorebookTemplates);
    const inc = cfg.lorebookFields || ({} as LorebookFieldToggles);
    const data = Object.assign({}, char, buildCharMacroExtras(char, cfg));

    // Equipment — resolve each worn item to "name (detail)".
    if (inc.equipment && char.equippedItemIds && char.equippedItemIds.length > 0) {
        const worn: string[] = [];
        for (const itemId of char.equippedItemIds) {
            try {
                const item = await loadEntity(itemId);
                if (!item) continue;
                const detail = (item.description || '').trim() || ((item as any).atmosphere || '').trim();
                worn.push(detail ? (item.name + ' (' + detail + ')') : item.name);
            } catch (eItem) { /* non-fatal: skip unreadable item */ }
        }
        if (worn.length > 0) {
            const line = parseMacroTemplate(tpl.equipment, Object.assign({}, data, { equipList: worn.join(', ') })).trim();
            if (line) lines.push(line);
        }
    }

    // Conditions — one line per active condition (reuses the existing builder).
    if (inc.conditions) {
        const condBlock = await buildDynamicLorebookContent(char, cfg);
        if (condBlock.trim()) lines.push(condBlock.trim());
    }

    // Relationship — only when the primary relationship is enabled and has a target.
    if (char.primaryRelationship && char.primaryRelationship.enabled && char.primaryRelationship.targetName) {
        if (inc.relationship)  { const l = parseMacroTemplate(tpl.relationship,  data).trim(); if (l) lines.push(l); }
        if (inc.relTrajectory) { const l = parseMacroTemplate(tpl.relTrajectory, data).trim(); if (l) lines.push(l); }
        if (inc.relStatus)     { const l = parseMacroTemplate(tpl.relStatus,     data).trim(); if (l) lines.push(l); }
    }

    // Mid-range psychological state.
    if (inc.goal)        { const l = parseMacroTemplate(tpl.goal,        data).trim(); if (l) lines.push(l); }
    if (inc.socialMask)  { const l = parseMacroTemplate(tpl.socialMask,  data).trim(); if (l) lines.push(l); }
    if (inc.shiftedView) { const l = parseMacroTemplate(tpl.shiftedView, data).trim(); if (l) lines.push(l); }

    // Journal — [v2.12.0 CHARJOURNAL] this character's own running notes, folded in
    // exactly like conditions: active (non-archived) bubbles only, joined as prose.
    // Unbounded on purpose (user's call) — archiving/merge-down are the user's own
    // tools for keeping this from growing unbounded, same as the main journal.
    if (inc.journal) {
        const jState = await loadCharJournal(char.id);
        const activeBubbles = (jState.bubbles || []).filter(function(b) { return !b.archived; });
        const journalBody = activeBubbles.map(function(b) { return (b.text || '').trim(); }).filter(Boolean).join('\n\n');
        if (journalBody) {
            const line = parseMacroTemplate(tpl.journal, Object.assign({}, data, { journalBody: journalBody })).trim();
            if (line) lines.push(line);
        }
    }

    return lines.join('\n');
}

async function createLinkedLorebookEntry(charId: string, silent?: boolean): Promise<void> {
    const char = await loadCharacter(charId);
    if (!char) return;
    try {
        const content  = await buildLorebookContent(char);
        const keys     = getLorebookKeys(char);
        const entryId  = await api.v1.lorebook.createEntry({ displayName: char.name, text: content, keys, enabled: true });
        char.lorebookEntryId = entryId;
        await saveCharacter(char);
        if (!silent) api.v1.ui.toast(`Lorebook entry created for ${char.name}.`, { type: 'success' });
    } catch (e) {
        if (!silent) api.v1.ui.toast('Failed to create lorebook entry.', { type: 'error' });
        if (silent) throw e;
    }
}

async function syncLorebookEntry(charId: string, silent?: boolean): Promise<void> {
    const char = await loadCharacter(charId);
    if (!char?.lorebookEntryId) return;
    try {
        const content = await buildLorebookContent(char);
        await api.v1.lorebook.updateEntry(char.lorebookEntryId, {
            text: content,
            keys: getLorebookKeys(char),
            displayName: char.name
        });
        if (!silent) api.v1.ui.toast('Lorebook entry synced.', { type: 'success' });
    } catch (e) {
        api.v1.error('[AE] syncLorebookEntry:', e);
        if (!silent) api.v1.ui.toast('Failed to sync lorebook entry.', { type: 'error' });
    }
}

// [v0.9.8.5] Builds the per-generation lorebook activation package for the current
// scene. For every active, scene-present character (and the protagonist):
//   - permanent entry present  -> force-activate it ([id, {active:true}])
//   - permanent entry absent    -> emit its static identity as an ephemeral temp
//                                  entry (no permanent lorebook needed, no regression)
//   - equipped items present    -> emit a separate ephemeral equipment temp entry
// Returned from onBeforeContextBuild so static identity lives in the lorebook block
// while the Author's Note carries only the dynamic layer.
// [v2.9.0 LOREFOLD] paramLoreEntries is onBeforeContextBuild's params.lorebookEntries
// ([id, {active, content}][]) — used to APPEND the dynamic block onto a linked entry's
// CURRENT content (preserving any hand-edits) rather than rebuilding identity. Folding
// equipment + conditions + relationship + mid-range into the one character entry (per
// user's call) makes ordering deterministic: the dynamic layer can no longer land as a
// stray temp entry before its own character (the old ae_equip_/ae_dynamic_ ordering bug).
async function buildSceneLorebookActivation(paramLoreEntries?: any[]): Promise<{ lorebookEntries: any[]; temporaryLorebookEntries: any[] }> {
    const lorebookEntries: any[] = [];
    const temporaryLorebookEntries: any[] = [];
    try {
        const slaCfg = await loadConfig();
        const slaIdx = await loadIndex();
        const slaLoreMap = new Map<string, string>();
        for (const _pt of (paramLoreEntries || [])) {
            if (Array.isArray(_pt) && _pt.length >= 2 && _pt[0]) slaLoreMap.set(_pt[0], (_pt[1] && _pt[1].content) || '');
        }
        for (const meta of slaIdx.filter(Boolean)) {
            if (!meta.active) continue;
            if (!meta.scenePresent && !meta.isProtagonist) continue;
            const slaChar = await loadCharacter(meta.id);
            if (!slaChar) continue;

            // The full dynamic layer for this character, as one prose block.
            const slaDyn = (await buildCharDynamicBlock(slaChar, slaCfg)).trim();

            if (slaChar.lorebookEntryId) {
                // Linked: force-activate the permanent identity entry. If there's a
                // dynamic layer, override its content = current entry text + dynamic
                // block (append, don't clobber). Otherwise activate it untouched.
                if (slaDyn) {
                    let slaBase = slaLoreMap.has(slaChar.lorebookEntryId)
                        ? slaLoreMap.get(slaChar.lorebookEntryId)!
                        : await buildLorebookContent(slaChar);
                    slaBase = (slaBase || '').replace(/\s+$/, '');
                    lorebookEntries.push([slaChar.lorebookEntryId, { active: true, content: slaBase ? (slaBase + '\n\n' + slaDyn) : slaDyn }]);
                } else {
                    lorebookEntries.push([slaChar.lorebookEntryId, { active: true }]);
                }
            } else {
                // Unlinked: emit ONE ephemeral temp entry = identity + dynamic block.
                let slaStatic = (await buildLorebookContent(slaChar)).trim();
                let slaCombined = [slaStatic, slaDyn].filter(Boolean).join('\n\n');
                if (slaCombined) {
                    temporaryLorebookEntries.push({
                        id: 'ae_static_' + slaChar.id,
                        name: slaChar.name || 'Character',
                        content: slaCombined,
                        active: true,
                        appearWithPermanent: true
                    });
                }
            }
        }

        // [v1.6.3 LOC-LORE] Force-activate the player's CURRENT room's own dossier entry
        // the same way a scene-present character's entry is activated above. If the player
        // is in the Haunted House, the Haunted House's own lorebook entry activates. This
        // is immediate/single-location only — no ancestor walking up the location tree.
        try {
            const slaRoomId = await aeGetPlayerRoomId();
            if (slaRoomId) {
                const slaRoom = await loadEntity(slaRoomId);
                if (slaRoom && (slaRoom as any).lorebookEntryId) {
                    lorebookEntries.push([(slaRoom as any).lorebookEntryId, { active: true }]);
                }
            }
        } catch (eSlaLoc) { api.v1.error('[AE:context] current-location activation:', eSlaLoc); }
    } catch (eSla) { api.v1.error('[AE:context] buildSceneLorebookActivation:', eSla); }
    return { lorebookEntries: lorebookEntries, temporaryLorebookEntries: temporaryLorebookEntries };
}

// ── Faction Lorebook ──────────────────────────────────────────────────────────

function getFactionLorebookKeys(faction: FactionDef): string[] {
    return [faction.name].concat(faction.lorebookTags || []).filter(Boolean);
}

function buildFactionLorebookContent(faction: FactionDef): string {
    const lines: string[] = [];
    if (faction.name) lines.push(faction.name);
    if (faction.description?.trim()) lines.push(faction.description.trim());
    if (faction.relationshipStates && faction.relationshipStates.length > 0) {
        lines.push(`Relationship standings: ${faction.relationshipStates.join(' → ')}`);
    }
    return lines.join('\n');
}

async function createLinkedFactionLorebookEntry(factionId: string, silent?: boolean): Promise<void> {
    const cfg  = await loadConfig();
    const fIdx = (cfg.factions || []).findIndex(function(f) { return f.id === factionId; });
    if (fIdx < 0) return;
    const faction = cfg.factions[fIdx];
    try {
        let catId = await ensureLorebookCategory('AE Factions');
        let entry: any = {
            displayName: faction.name,
            text: buildFactionLorebookContent(faction),
            keys: getFactionLorebookKeys(faction),
            enabled: true
        };
        if (catId) entry.category = catId;
        const entryId = await api.v1.lorebook.createEntry(entry);
        cfg.factions[fIdx].lorebookEntryId = entryId;
        await saveConfig(cfg);
        if (!silent) api.v1.ui.toast(`Lorebook entry created for ${faction.name}.`, { type: 'success' });
    } catch (e) { if (!silent) api.v1.ui.toast('Failed to create faction lorebook entry.', { type: 'error' }); if (silent) throw e; }
}

async function syncFactionLorebookEntry(factionId: string, silent?: boolean): Promise<void> {
    const cfg     = await loadConfig();
    const faction = (cfg.factions || []).find(function(f) { return f.id === factionId; });
    if (!faction?.lorebookEntryId) return;
    try {
        await api.v1.lorebook.updateEntry(faction.lorebookEntryId, {
            text: buildFactionLorebookContent(faction),
            keys: getFactionLorebookKeys(faction),
            displayName: faction.name
        });
        if (!silent) api.v1.ui.toast('Faction lorebook synced.', { type: 'success' });
    } catch (e) { if (!silent) api.v1.ui.toast('Failed to sync faction lorebook.', { type: 'error' }); if (silent) throw e; }
}

async function unlinkFactionLorebookEntry(factionId: string): Promise<void> {
    const cfg = await loadConfig();
    const fIdx = (cfg.factions || []).findIndex(function(f) { return f.id === factionId; });
    if (fIdx < 0) return;
    if (cfg.factions[fIdx].lorebookEntryId) {
        try { await api.v1.lorebook.removeEntry(cfg.factions[fIdx].lorebookEntryId!); } catch(e) {}
        cfg.factions[fIdx].lorebookEntryId = undefined;
        await saveConfig(cfg);
        api.v1.ui.toast('Faction lorebook unlinked.', { type: 'info' });
    }
}

// ── Species Lorebook ──────────────────────────────────────────────────────────

function getSpeciesLorebookKeys(sp: SpeciesDef): string[] {
    return [sp.name].concat(sp.lorebookTags || []).filter(Boolean);
}

function buildSpeciesLorebookContent(sp: SpeciesDef): string {
    const lines: string[] = [];
    if (sp.name) lines.push(sp.name);
    if (sp.description?.trim()) lines.push(sp.description.trim());
    return lines.join('\n');
}

async function createLinkedSpeciesLorebookEntry(speciesId: string, silent?: boolean): Promise<void> {
    const cfg  = await loadConfig();
    const sIdx = (cfg.species || []).findIndex(function(s) { return s.id === speciesId; });
    if (sIdx < 0) return;
    const sp = cfg.species[sIdx];
    try {
        let catId = await ensureLorebookCategory('AE Species');
        let entry: any = {
            displayName: sp.name,
            text: buildSpeciesLorebookContent(sp),
            keys: getSpeciesLorebookKeys(sp),
            enabled: true
        };
        if (catId) entry.category = catId;
        const entryId = await api.v1.lorebook.createEntry(entry);
        cfg.species[sIdx].lorebookEntryId = entryId;
        await saveConfig(cfg);
        if (!silent) api.v1.ui.toast(`Lorebook entry created for ${sp.name}.`, { type: 'success' });
    } catch (e) { if (!silent) api.v1.ui.toast('Failed to create species lorebook entry.', { type: 'error' }); if (silent) throw e; }
}

async function syncSpeciesLorebookEntry(speciesId: string, silent?: boolean): Promise<void> {
    const cfg = await loadConfig();
    const sp  = (cfg.species || []).find(function(s) { return s.id === speciesId; });
    if (!sp?.lorebookEntryId) return;
    try {
        await api.v1.lorebook.updateEntry(sp.lorebookEntryId, {
            text: buildSpeciesLorebookContent(sp),
            keys: getSpeciesLorebookKeys(sp),
            displayName: sp.name
        });
        if (!silent) api.v1.ui.toast('Species lorebook synced.', { type: 'success' });
    } catch (e) { if (!silent) api.v1.ui.toast('Failed to sync species lorebook.', { type: 'error' }); if (silent) throw e; }
}

async function unlinkSpeciesLorebookEntry(speciesId: string): Promise<void> {
    const cfg = await loadConfig();
    const sIdx = (cfg.species || []).findIndex(function(s) { return s.id === speciesId; });
    if (sIdx < 0) return;
    if (cfg.species[sIdx].lorebookEntryId) {
        try { await api.v1.lorebook.removeEntry(cfg.species[sIdx].lorebookEntryId!); } catch(e) {}
        cfg.species[sIdx].lorebookEntryId = undefined;
        await saveConfig(cfg);
        api.v1.ui.toast('Species lorebook unlinked.', { type: 'info' });
    }
}
// ── Entity Lorebook (locations / items / narratives) ────────────────────────
// New in [WP-1]. Same getKeys/buildContent/create/sync family as the character
// lorebook above, but for world entities, filed under an "AE <Type>s" category.
// ensureLorebookCategory() is the shared find-or-create helper (reusable by the
// character/faction/species families on a later unification pass).

async function ensureLorebookCategory(name: string): Promise<string> {
    // Returns the id of the named lorebook category, creating it if absent.
    // Returns '' on failure — callers then create the entry uncategorised.
    try {
        let cats = await api.v1.lorebook.categories();
        let found = (cats || []).find(function(c) { return c.name === name; });
        if (found) return found.id;
        let newId = await api.v1.lorebook.createCategory({ id: api.v1.uuid(), name: name, enabled: true });
        return newId || '';
    } catch (e) { api.v1.error('[AE:lore] ensureLorebookCategory:', e); return ''; }
}

function entityLorebookCategoryName(ent: EntityRecord): string {
    if (ent.type === 'item')      return 'AE Items';
    if (ent.type === 'narrative') return 'AE Narratives';
    if (ent.type === 'character') return 'AE Characters';
    return 'AE Locations';
}

function getEntityLorebookKeys(ent: EntityRecord): string[] {
    // Entity name is always a key; lorebookTags add extra trigger words.
    return [ent.name].concat(ent.lorebookTags || []).filter(Boolean);
}

function buildEntityLorebookContent(ent: EntityRecord): string {
    // [WP-1] The dedicated extended-lore body, injected when a key (the entity
    // name or an added key) appears in the story. Deliberately NOT the
    // description/state — those already inject via the world-state block while
    // the player is present, so echoing them here would double them in context.
    return (ent.lorebookText || '').trim();
}

async function createLinkedEntityLorebookEntry(entId: string, silent?: boolean): Promise<void> {
    let ent = await loadEntity(entId);
    if (!ent) return;
    if (!(ent.lorebookText || '').trim()) { if (!silent) api.v1.ui.toast('Add Lorebook Entry text first, then create the entry.', { type: 'info' }); return; }
    try {
        let catId = await ensureLorebookCategory(entityLorebookCategoryName(ent));
        let entry: any = { id: api.v1.uuid(), displayName: ent.name, text: buildEntityLorebookContent(ent), keys: getEntityLorebookKeys(ent), enabled: true };
        if (catId) entry.category = catId;
        let newId = await api.v1.lorebook.createEntry(entry);
        ent.lorebookEntryId = newId;
        await saveEntity(ent);
        if (!silent) api.v1.ui.toast('Lorebook entry created for ' + ent.name + '.', { type: 'success' });
    } catch (e) {
        api.v1.error('[AE:lore] createLinkedEntityLorebookEntry:', e);
        if (!silent) api.v1.ui.toast('Failed to create lorebook entry.', { type: 'error' });
        if (silent) throw e;
    }
}

async function syncEntityLorebookEntry(entId: string, silent?: boolean): Promise<void> {
    let ent = await loadEntity(entId);
    if (!ent || !ent.lorebookEntryId) return;
    try {
        await api.v1.lorebook.updateEntry(ent.lorebookEntryId, { text: buildEntityLorebookContent(ent), keys: getEntityLorebookKeys(ent), displayName: ent.name });
        if (!silent) api.v1.ui.toast('Lorebook entry synced.', { type: 'success' });
    } catch (e) {
        api.v1.error('[AE:lore] syncEntityLorebookEntry:', e);
        if (!silent) api.v1.ui.toast('Failed to sync lorebook entry.', { type: 'error' });
    }
}

async function unlinkEntityLorebookEntry(entId: string): Promise<void> {
    let ent = await loadEntity(entId);
    if (!ent || !ent.lorebookEntryId) return;
    try { await api.v1.lorebook.removeEntry(ent.lorebookEntryId); }
    catch (e) { api.v1.error('[AE:lore] unlinkEntityLorebookEntry:', e); }
    ent.lorebookEntryId = undefined;
    await saveEntity(ent);
    api.v1.ui.toast('Lorebook entry unlinked.', { type: 'info' });
}

// ── Sync-All Lorebooks ──────────────────────────────────────────────────────
// [vNEXT] The individual sync helpers all early-return when a record has no
// lorebookEntryId, and none of them notice when a stored id points at an entry the
// user has since deleted in NAI. syncAllLorebooks fixes both: it never assumes an
// entry exists. It pulls the full live entry-id set ONCE (single API call), then per
// record decides create-vs-sync from that set in memory — so a run over the whole
// world costs one entries() call plus one update/create per record, no per-record
// existence probing. A record is (re)created when it has no id OR its id is stale
// (missing from the live set); otherwise it is synced. Returns per-type tallies.
//
// liveIds: pass the prebuilt Set so a single sync-all shares one snapshot across all
// four families. _ensure* helpers below are also individually callable.
async function _liveLorebookIdSet(): Promise<Set<string>> {
    let set = new Set<string>();
    try {
        let all = await api.v1.lorebook.entries();
        (all || []).forEach(function(e: any) { if (e && e.id) set.add(e.id); });
    } catch (e) { api.v1.error('[AE:lore] _liveLorebookIdSet:', e); }
    return set;
}

async function ensureCharacterLorebook(charId: string, liveIds: Set<string>): Promise<'created' | 'synced' | 'skipped'> {
    let char = await loadCharacter(charId);
    if (!char) return 'skipped';
    let hasLive = !!(char.lorebookEntryId && liveIds.has(char.lorebookEntryId));
    if (hasLive) { await syncLorebookEntry(charId, true).catch(function() {}); return 'synced'; }
    // No id, or a stale id whose entry was deleted in NAI: clear + recreate.
    if (char.lorebookEntryId && !hasLive) { char.lorebookEntryId = undefined; await saveCharacter(char).catch(function() {}); }
    await createLinkedLorebookEntry(charId, true).catch(function() {});
    return 'created';
}

async function ensureFactionLorebook(factionId: string, liveIds: Set<string>): Promise<'created' | 'synced' | 'skipped'> {
    let cfg = await loadConfig();
    let f = (cfg.factions || []).find(function(x) { return x.id === factionId; });
    if (!f) return 'skipped';
    let hasLive = !!(f.lorebookEntryId && liveIds.has(f.lorebookEntryId));
    if (hasLive) { await syncFactionLorebookEntry(factionId, true).catch(function() {}); return 'synced'; }
    if (f.lorebookEntryId && !hasLive) {
        // Clear the stale id before recreate so create doesn't leave a dangling ref.
        let cfg2 = await loadConfig();
        let f2i = (cfg2.factions || []).findIndex(function(x) { return x.id === factionId; });
        if (f2i >= 0) { cfg2.factions[f2i].lorebookEntryId = undefined; await saveConfig(cfg2).catch(function() {}); }
    }
    await createLinkedFactionLorebookEntry(factionId, true).catch(function() {});
    return 'created';
}

async function ensureSpeciesLorebook(speciesId: string, liveIds: Set<string>): Promise<'created' | 'synced' | 'skipped'> {
    let cfg = await loadConfig();
    let s = (cfg.species || []).find(function(x) { return x.id === speciesId; });
    if (!s) return 'skipped';
    let hasLive = !!(s.lorebookEntryId && liveIds.has(s.lorebookEntryId));
    if (hasLive) { await syncSpeciesLorebookEntry(speciesId, true).catch(function() {}); return 'synced'; }
    if (s.lorebookEntryId && !hasLive) {
        let cfg2 = await loadConfig();
        let s2i = (cfg2.species || []).findIndex(function(x) { return x.id === speciesId; });
        if (s2i >= 0) { cfg2.species[s2i].lorebookEntryId = undefined; await saveConfig(cfg2).catch(function() {}); }
    }
    await createLinkedSpeciesLorebookEntry(speciesId, true).catch(function() {});
    return 'created';
}

async function ensureEntityLorebook(entId: string, liveIds: Set<string>): Promise<'created' | 'synced' | 'skipped'> {
    let ent = await loadEntity(entId);
    if (!ent) return 'skipped';
    // Entity entries only carry the dedicated extended-lore body; with none there is
    // nothing to store, so skip (matches createLinkedEntityLorebookEntry's own guard).
    if (!((ent as any).lorebookText || '').trim()) return 'skipped';
    let hasLive = !!(ent.lorebookEntryId && liveIds.has(ent.lorebookEntryId));
    if (hasLive) { await syncEntityLorebookEntry(entId, true).catch(function() {}); return 'synced'; }
    if (ent.lorebookEntryId && !hasLive) { ent.lorebookEntryId = undefined; await saveEntity(ent).catch(function() {}); }
    await createLinkedEntityLorebookEntry(entId, true).catch(function() {});
    return 'created';
}

interface SyncAllTally { created: number; synced: number; skipped: number; }
async function syncAllLorebooks(): Promise<{ characters: SyncAllTally; locations: SyncAllTally; species: SyncAllTally; factions: SyncAllTally }> {
    let mk = function(): SyncAllTally { return { created: 0, synced: 0, skipped: 0 }; };
    let out = { characters: mk(), locations: mk(), species: mk(), factions: mk() };
    let bump = function(t: SyncAllTally, r: 'created' | 'synced' | 'skipped') { if (r === 'created') t.created++; else if (r === 'synced') t.synced++; else t.skipped++; };

    // One live snapshot shared by every family — the only lorebook read of the run.
    let liveIds = await _liveLorebookIdSet();

    try {
        // Characters (from the lightweight index).
        let cIdx = await loadIndex();
        for (let m of cIdx.filter(Boolean)) {
            bump(out.characters, await ensureCharacterLorebook(m.id, liveIds));
        }
    } catch (e) { api.v1.error('[AE:lore] syncAll characters:', e); }

    try {
        // Locations (location-type entities).
        let eIdx = await loadEntityIndex();
        for (let em of eIdx.filter(function(x) { return x && x.type === 'location'; })) {
            bump(out.locations, await ensureEntityLorebook(em.id, liveIds));
        }
    } catch (e) { api.v1.error('[AE:lore] syncAll locations:', e); }

    try {
        let cfg = await loadConfig();
        for (let sp of (cfg.species || [])) { bump(out.species, await ensureSpeciesLorebook(sp.id, liveIds)); }
        for (let fa of (cfg.factions || [])) { bump(out.factions, await ensureFactionLorebook(fa.id, liveIds)); }
    } catch (e) { api.v1.error('[AE:lore] syncAll species/factions:', e); }

    return out;
}



// ============================================================================
// SECTION 10b — PLAYER JOURNAL  [v1.7.0 JOURNAL]
// A player-authored running record ("The story so far") that survives context
// pressure by living in the lorebook. Bubbles are the source of truth in
// storyStorage; two lorebook entries are a *projection* of them:
//   - Active  entry: Always-On, keyless — non-archived bubbles, injected every turn.
//   - Archive entry: keyless + disabled — archived bubbles, retained but NEVER
//                    injected; unarchiving moves a bubble back to the active set.
// Renderer (native HUD) lives in Section 27; this section is pure state + lore +
// generation so the bridge can later drive the same verbs over a message pair.
// ============================================================================

async function loadJournal(): Promise<JournalState> {
    try {
        const raw = await api.v1.storyStorage.getOrDefault(STORAGE_JOURNAL, null);
        if (raw && typeof raw === 'object' && Array.isArray((raw as any).bubbles)) {
            const s = raw as JournalState;
            s.bubbles = (s.bubbles || []).filter(Boolean);
            return s;
        }
    } catch (e) { api.v1.error('[AE:journal] loadJournal:', e); }
    return { bubbles: [] };
}

async function saveJournal(state: JournalState): Promise<void> {
    try {
        await api.v1.storyStorage.set(STORAGE_JOURNAL, {
            bubbles: (state.bubbles || []).filter(Boolean),
            activeLoreId: state.activeLoreId,
            archiveLoreId: state.archiveLoreId
        });
    } catch (e) { api.v1.error('[AE:journal] saveJournal:', e); }
}

// [v1.7.0 JOURNAL] Stamp reflects the STORY's in-world calendar at the moment the
// entry was written (captured as storyHours at creation), not wall-clock time.
// Formatted via the same clockFormatStamp the calendar/Author's-Note use.

// Ordered prose body from a bubble list. Stamped bubbles carry their in-story stamp
// inline (the only place a stamp reaches context), so a merge preserves them.
function buildJournalBody(bubbles: JournalBubble[], cfg: GlobalConfig): string {
    // [CE-STRIP v2.0.x] In-story stamps removed — Clock cut. Plain text join only.
    return (bubbles || []).map(function(b) {
        return (b.text || '').trim();
    }).filter(Boolean).join('\n\n');
}

function buildActiveJournalText(bubbles: JournalBubble[], cfg: GlobalConfig): string {
    const body = buildJournalBody(bubbles, cfg);
    return body ? ('The story so far:\n\n' + body) : '';
}

function buildArchiveJournalText(bubbles: JournalBubble[], cfg: GlobalConfig): string {
    const body = buildJournalBody(bubbles, cfg);
    return body ? ('The story so far (archived):\n\n' + body) : '';
}

// Update an existing lore entry, or (re)create it if the id is missing/stale
// (e.g. the user deleted it in NAI's lorebook UI). Returns the live entry id.
async function ensureJournalEntry(existingId: string | undefined, spec: Partial<LorebookEntry>): Promise<string> {
    if (existingId) {
        try {
            const cur = await api.v1.lorebook.entry(existingId);
            if (cur) { await api.v1.lorebook.updateEntry(existingId, spec); return existingId; }
        } catch (e) { /* fall through and recreate */ }
    }
    return await api.v1.lorebook.createEntry(spec);
}

// Re-project bubbles onto the two lorebook entries. Best-effort: never throws,
// mutates state.activeLoreId / state.archiveLoreId in place. Does NOT save —
// persistJournal() owns the single authoritative save after ids settle.
async function syncJournalLore(state: JournalState): Promise<void> {
    try {
        const cfg = await loadConfig();
        const active   = (state.bubbles || []).filter(function(b) { return !b.archived; });
        const archived = (state.bubbles || []).filter(function(b) { return b.archived; });

        const activeText = buildActiveJournalText(active, cfg);
        const hasActive  = activeText.trim().length > 0;

        // The Always-On entry only force-activates when it has content; empty, it
        // is disabled so a lone "The story so far:" header never enters context.
        state.activeLoreId = await ensureJournalEntry(state.activeLoreId, {
            displayName: 'The story so far',
            keys: [],
            text: activeText,
            forceActivation: hasActive,
            enabled: hasActive
        });

        // Archive entry is created lazily — only once something is archived (or it
        // already exists) — so untouched stories don't accrue an empty keyless entry.
        if (archived.length > 0 || state.archiveLoreId) {
            state.archiveLoreId = await ensureJournalEntry(state.archiveLoreId, {
                displayName: 'Journal — Archived (unarchive to restore)',
                keys: [],
                text: buildArchiveJournalText(archived, cfg),
                forceActivation: false,
                enabled: false
            });
        }
    } catch (e) {
        api.v1.error('[AE:journal] syncJournalLore:', e);
    }
}

// Single persistence path for every mutator: project to lore, then one save.
async function persistJournal(state: JournalState): Promise<JournalState> {
    await syncJournalLore(state);
    await saveJournal(state);
    // Keep an open bridge HUD in sync when native mutates the journal (both-mode).
    if (isBridgeReady) { broadcastJournal().catch(function() {}); }
    return state;
}

// Bridge-facing projection: the bridge has no clock/cfg access, so the engine
// precomputes each bubble's in-story stampLabel here. stampLabel is always sent
async function journalPayloadForBridge(): Promise<Record<string, any>> {
    const state = await loadJournal();
    const bubbles = (state.bubbles || []).filter(Boolean).map(function(b) {
        return {
            id: b.id,
            text: b.text || '',
            archived: !!b.archived,
            createdAt: b.createdAt || 0
        };
    });
    return { bubbles: bubbles };
}

async function broadcastJournal(): Promise<void> {
    try { await broadcastToTM('AE_JOURNAL_STATE', await journalPayloadForBridge()); }
    catch (e) { api.v1.error('[AE:journal] broadcast:', e); }
}

async function journalAddBubble(text: string): Promise<JournalState> {
    const state = await loadJournal();
    const t = (text || '').trim();
    if (!t) return state;
    state.bubbles.push({ id: api.v1.uuid(), text: t, createdAt: Date.now(), archived: false });
    return await persistJournal(state);
}

async function journalUpdateBubble(id: string, text: string): Promise<JournalState> {
    const state = await loadJournal();
    const b = state.bubbles.find(function(x) { return x.id === id; });
    if (b) b.text = (text || '').trim();
    return await persistJournal(state);
}

async function journalDeleteBubble(id: string): Promise<JournalState> {
    const state = await loadJournal();
    state.bubbles = state.bubbles.filter(function(x) { return x.id !== id; });
    return await persistJournal(state);
}


async function journalSetArchived(id: string, archived: boolean): Promise<JournalState> {
    const state = await loadJournal();
    const b = state.bubbles.find(function(x) { return x.id === id; });
    if (b) b.archived = !!archived;
    return await persistJournal(state);
}

// Merge-down: append all non-archived bubbles (in order) into a single bubble.
// Archived bubbles are untouched. Inline stamps survive via buildJournalBody.
async function journalMergeDown(): Promise<JournalState> {
    const state = await loadJournal();
    const active = state.bubbles.filter(function(b) { return !b.archived; });
    if (active.length <= 1) return state;
    const mergedText = buildJournalBody(active, await loadConfig());
    const earliest = active.reduce(function(m, b) { return b.createdAt < m ? b.createdAt : m; }, active[0].createdAt);
    const merged: JournalBubble = { id: api.v1.uuid(), text: mergedText, createdAt: earliest, archived: false };
    const archived = state.bubbles.filter(function(b) { return b.archived; });
    state.bubbles = [merged].concat(archived);
    return await persistJournal(state);
}

// ── Generation verbs (story-aware, so voice matches the current model/style) ──
// Both run in 'background' mode and suppress this script's own context hooks so
// the journal doesn't re-inject itself while being rewritten.

async function journalGenerateRewrite(text: string): Promise<string | null> {
    const src = (text || '').trim();
    if (!src) return null;
    try {
        const cfg = await loadConfig();
        const sys = [
            (cfg.generalStyle || '').trim(),
            '',
            'Rewrite the player\'s journal note below in the narrative voice of this story.',
            'Absolute priority: preserve every fact, name, event, number, and decision exactly as written \u2014 invent nothing, omit nothing.',
            'Be token-efficient: tighten wording and cut filler while keeping all content.',
            'Past tense, third-person recap voice. Output ONLY the rewritten note \u2014 no preamble, no quotes, no commentary.'
        ].filter(Boolean).join('\n');
        const maxTok = Math.max(120, Math.min(700, Math.ceil(src.length / 3) + 80));
        const resp = await api.v1.generateWithStory(
            [ { role: 'system', content: sys }, { role: 'user', content: src } ],
            { model: 'glm-4-6', max_tokens: maxTok, temperature: 0.7 },
            { suppressScriptHooks: 'self', contextLimitReduction: 600 },
            undefined,
            'background'
        );
        if (resp && resp.choices && resp.choices.length > 0) return (resp.choices[0].text || '').trim() || null;
        return null;
    } catch (e) { api.v1.error('[AE:journal] rewrite:', e); return null; }
}

async function journalGenerateCompress(text: string): Promise<string | null> {
    const src = (text || '').trim();
    if (!src) return null;
    try {
        const cfg = await loadConfig();
        const sys = [
            (cfg.generalStyle || '').trim(),
            '',
            'Compress the player\'s journal note below into a shorter recap for long-term memory.',
            'Keep the load-bearing details: names, places, relationships, commitments, and outcomes. Drop atmosphere and repetition.',
            'Aim for roughly half the length or less. Past tense, plain and dense.',
            'Output ONLY the compressed recap \u2014 no preamble, no quotes, no commentary.'
        ].filter(Boolean).join('\n');
        const maxTok = Math.max(60, Math.min(400, Math.ceil(src.length / 6) + 40));
        const resp = await api.v1.generateWithStory(
            [ { role: 'system', content: sys }, { role: 'user', content: src } ],
            { model: 'glm-4-6', max_tokens: maxTok, temperature: 0.5 },
            { suppressScriptHooks: 'self', contextLimitReduction: 600 },
            undefined,
            'background'
        );
        if (resp && resp.choices && resp.choices.length > 0) return (resp.choices[0].text || '').trim() || null;
        return null;
    } catch (e) { api.v1.error('[AE:journal] compress:', e); return null; }
}

// ============================================================================
// SECTION 10c — PER-CHARACTER JOURNAL  [v2.12.0 CHARJOURNAL]
// Same bubble shape and verb set as Section 10b's player journal, scoped to one
// character instead of the whole story. The key difference: NO dedicated lorebook
// entry pair. Active bubbles fold straight into that character's OWN lorebook
// entry via buildCharDynamicBlock (see LOREFOLD, Section 6-ish) as one more
// toggleable field — same "rebuilt fresh every generation" treatment equipment/
// conditions already get, gated by cfg.lorebookFields.journal. Rewrite/compress
// reuse journalGenerateRewrite/journalGenerateCompress directly (pure text
// transforms with no journal-identity dependency — nothing to duplicate).
// Renderer lives in Section 27 (openCharJournalModal) so the bridge can drive the
// same verbs over the AE_CHAR_JOURNAL_* message pair.
// ============================================================================

async function loadCharJournal(charId: string): Promise<CharJournalState> {
    try {
        const raw = await api.v1.storyStorage.getOrDefault(STORAGE_CHAR_JOURNAL_PFX + charId, null);
        if (raw && typeof raw === 'object' && Array.isArray((raw as any).bubbles)) {
            const s = raw as CharJournalState;
            s.bubbles = (s.bubbles || []).filter(Boolean);
            return s;
        }
    } catch (e) { api.v1.error('[AE:charjournal] loadCharJournal:', e); }
    return { bubbles: [] };
}

async function saveCharJournal(charId: string, state: CharJournalState): Promise<void> {
    try {
        await api.v1.storyStorage.set(STORAGE_CHAR_JOURNAL_PFX + charId, {
            bubbles: (state.bubbles || []).filter(Boolean)
        });
    } catch (e) { api.v1.error('[AE:charjournal] saveCharJournal:', e); }
}

// Single persistence path for every mutator. No lorebook-lore sync step (unlike
// the main journal's persistJournal) — buildCharDynamicBlock reads storage fresh
// every generation, same as conditions/equipment, so there's nothing to pre-sync.
async function persistCharJournal(charId: string, state: CharJournalState): Promise<CharJournalState> {
    await saveCharJournal(charId, state);
    if (isBridgeReady) { broadcastCharJournal(charId).catch(function() {}); }
    return state;
}

async function charJournalPayloadForBridge(charId: string): Promise<Record<string, any>> {
    const state = await loadCharJournal(charId);
    const bubbles = (state.bubbles || []).filter(Boolean).map(function(b) {
        return { id: b.id, text: b.text || '', archived: !!b.archived, createdAt: b.createdAt || 0 };
    });
    return { charId: charId, bubbles: bubbles };
}

async function broadcastCharJournal(charId: string): Promise<void> {
    try { await broadcastToTM('AE_CHAR_JOURNAL_STATE', await charJournalPayloadForBridge(charId)); }
    catch (e) { api.v1.error('[AE:charjournal] broadcast:', e); }
}

async function charJournalAddBubble(charId: string, text: string): Promise<CharJournalState> {
    const state = await loadCharJournal(charId);
    const t = (text || '').trim();
    if (!t) return state;
    state.bubbles.push({ id: api.v1.uuid(), text: t, createdAt: Date.now(), archived: false });
    return await persistCharJournal(charId, state);
}

async function charJournalUpdateBubble(charId: string, id: string, text: string): Promise<CharJournalState> {
    const state = await loadCharJournal(charId);
    const b = state.bubbles.find(function(x) { return x.id === id; });
    if (b) b.text = (text || '').trim();
    return await persistCharJournal(charId, state);
}

async function charJournalDeleteBubble(charId: string, id: string): Promise<CharJournalState> {
    const state = await loadCharJournal(charId);
    state.bubbles = state.bubbles.filter(function(x) { return x.id !== id; });
    return await persistCharJournal(charId, state);
}

async function charJournalSetArchived(charId: string, id: string, archived: boolean): Promise<CharJournalState> {
    const state = await loadCharJournal(charId);
    const b = state.bubbles.find(function(x) { return x.id === id; });
    if (b) b.archived = !!archived;
    return await persistCharJournal(charId, state);
}

async function charJournalMergeDown(charId: string): Promise<CharJournalState> {
    const state = await loadCharJournal(charId);
    const active = state.bubbles.filter(function(b) { return !b.archived; });
    if (active.length <= 1) return state;
    const mergedText = active.map(function(b) { return (b.text || '').trim(); }).filter(Boolean).join('\n\n');
    const earliest = active.reduce(function(m, b) { return b.createdAt < m ? b.createdAt : m; }, active[0].createdAt);
    const merged: CharJournalBubble = { id: api.v1.uuid(), text: mergedText, createdAt: earliest, archived: false };
    const archived = state.bubbles.filter(function(b) { return b.archived; });
    state.bubbles = [merged].concat(archived);
    return await persistCharJournal(charId, state);
}

// ============================================================================
// SECTION 12 — CHARACTER SNAPSHOT GENERATION
//
// CHARACTER SNAPSHOT (GLM-backed — AI generation)
//    generateCharacterSnapshot: writes a present-tense appearance description
//    of a character as the protagonist encounters them. Used as scene flavor
//    text for the entity system's character-type nodes.
//
// NOTE — CONTEXT BUILDER SEPARATION:
// The injection sub-builders that feed into the Author's Note (buildCharInjection,
// buildMidRangeInjection, buildEphemeralInjection, charIsRelevant,
// buildEntityContextBlock, buildProtagonistInjection, buildDramatisPersonae)
// are NOT in this section. They live in Section 13 (Context Injection Builders)
// because they are pipeline components — the output of this section feeds them
// but they are architecturally distinct.
// ============================================================================

// ── Character Snapshot (AI generation) ───────────────────────────────────────

async function generateCharacterSnapshot(charRec: CharacterRecord, ent: EntityRecord, cfg: GlobalConfig): Promise<string | null> {
    // Generates a brief present-tense appearance description for a character
    // as encountered in their current location. Used by the entity system
    // for character-type nodes when a snapshot hasn't been generated yet.
    //
    // Uses api.v1.generateWithStory in 'background' mode so it runs without
    // surfacing a visible generation progress indicator.
    try {
        // Resolve location name for scene grounding
        let locationName = 'Unknown';
        let locationDesc = '';
        if (ent.parentId) {
            const locEnt = await loadEntity(ent.parentId);
            if (locEnt) { locationName = locEnt.name; locationDesc = locEnt.description || ''; }
        }

        // Resolve equipped item names for appearance context
        const equippedItems: string[] = [];
        for (const itemId of (charRec.equippedItemIds || [])) {
            try {
                const itemEnt = await loadEntity(itemId);
                if (itemEnt) equippedItems.push(itemEnt.name);
            } catch (ignoredErr) { /* non-fatal */ }
        }

        const idParts  = [charRec.gender, charRec.species, charRec.age, charRec.occupationRole].filter(Boolean);
        const idLine   = idParts.length > 0 ? ' (' + idParts.join(', ') + ')' : '';

        const sysPrompt = [
            cfg.generalStyle || '',
            '',
            `Write a brief present-tense description of ${charRec.name} as the protagonist notices them.`,
            '1 short paragraph. No internal thoughts, no dialogue, no summary statements.',
            '',
            'Capture:',
            '- Physical appearance including anything worn or carried',
            `- What they appear to be doing in ${locationName} (work here? live here? passing through? with the protagonist?)`,
            '- One behavioral or expressive detail reflecting their current state',
            '',
            'Concrete and specific. Show rather than tell.'
        ].join('\n');

        const userPrompt = [
            charRec.name + idLine,
            charRec.briefDescription         ? 'Brief: '     + charRec.briefDescription : '',
            charRec.physicalDescription      ? 'Appearance: ' + charRec.physicalDescription : '',
            charRec.background               ? 'Background: ' + charRec.background.slice(0, 100) : '',
            equippedItems.length > 0         ? 'Wearing/Carrying: ' + equippedItems.join(', ') : '',
            'Location: ' + locationName,
            locationDesc                     ? 'Setting: '    + locationDesc.slice(0, 80) : '',
            ent.atmosphere                   ? 'Thoughts: '   + ent.atmosphere : '',
            charRec.midRange?.currentDesire  ? 'Drive: '      + charRec.midRange.currentDesire : '',
            charRec.ephemeral?.compressedLine ? 'State: '     + charRec.ephemeral.compressedLine : ''
        ].filter(Boolean).join('\n');

        const response = await api.v1.generateWithStory(
            [
                { role: 'system', content: sysPrompt },
                { role: 'user',   content: userPrompt }
            ],
            { model: 'glm-4-6', max_tokens: 200 },
            { suppressScriptHooks: 'self', contextLimitReduction: 450 },
            undefined,
            'background'
        );

        if (response && response.choices && response.choices.length > 0) {
            return response.choices[0].text || null;
        }
        return null;
    } catch (e) {
        api.v1.error('[AE:knowledge] generateCharacterSnapshot:', e);
        return null;
    }
}

// ============================================================================
// SECTION 13 — CONTEXT INJECTION BUILDERS
//
// All functions that construct content injected into the AI's context window.
//
// [CE-STRIP v2.6.0 CTX-CUT] Location, scene roster ("present with"), and the
// tracked-narrative quest line are REMOVED from injection entirely — dramatis
// persona / static identity are lorebook's job, and location/quest tracking now
// has no AN presence at all (the underlying Narrative Threads / STORAGE_
// TRACKED_NARRATIVE feature is untouched, only its injection is gone).
// buildTrackedNarrativeBlock and buildDramaContextBlock are deleted. Critical
// (85%+) hooks moved off the Imperative splice and into the same AN block as
// character thoughts. See the CE-INDEX PASS 9 note at the top of this file for
// full rationale and what's flagged-but-not-yet-built (urgent hooks / background
// NPC web currently have no injection destination).
//
// ── CURRENT INJECTION PIPELINE MAP ──────────────────────────────────────────
//
// onBeforeContextBuild  →  Author's Note (AN) slot
//   └── buildWorldStateBlock()
//         └── Per scene-present character (within the dynamic cap):
//               ├── Thoughts line — ephemeral + midRange (cfg.contextTemplates.npc)
//               └── Critical hook line, if pressureLevel ≥ 85 and unresolved
//                     (cfg.contextTemplates.criticalHook)
//
// onContextBuilt  →  Spliced before player input (highest recency weight)
//   └── Imperative block  [Section 26 — inline in hook]
//         ├── Pending GM note (fires once)
//         ├── Pending knowledge query (fires once)
//         └── High-priority NPC web links (priority ≥ 70, both parties present)
//
// onContextBuilt  →  Replaces player input (tag-based dice roll)
//   └── ⚠️ note: replaced probability system 
//         └── #tagname in player input → 1d6 + skill modifier → outcome line
//
// ── NOT CURRENTLY INJECTED ANYWHERE (flagged, not silently dropped) ─────────
// Urgent hooks (60–84%) and background/sub-70 NPC web links lost their
// destination when buildDramaContextBlock was deleted. Planned home: a per-scene
// temporary lorebook entry (dynamic fields + relationship web, narrative prose,
// per-field exclude option) — not built yet, separate pass.
//
// ── SUB-BUILDER STATUS ────────────────────────────────────────────────────────
// buildWorldStateBlock: called from onBeforeContextBuild (live).
// charIsRelevant: called from runDynamicEngine (live).
// buildProtagonistInjection, buildDramatisPersonae, buildEntityContextBlock,
// buildCharInjection, buildMidRangeInjection, buildEphemeralInjection:
//   defined but NOT currently called from the generation pipeline. Preserved as
//   utilities. buildDramatisPersonae is the likely starting point for the
//   to-do'd optional Dramatis Personae reference lorebook.
// ============================================================================

// Builds macro-accessible fields for a character: relArchetype, relStage, and one
// entry per character resource keyed res_<tag> (tag '#' stripped). Discrete/track
// resources resolve to their current state label; pools to their numeric value.
// Blank/index-0 discrete values resolve to '' so the [ ... ] block self-suppresses.
function buildCharMacroExtras(char: CharacterRecord, cfg: GlobalConfig): Record<string, any> {
    let extras: Record<string, any> = {};
    // Relationship archetype + stage
    if (char.primaryRelationship) {
        extras.relArchetype = char.primaryRelationship.archetype || '';
        extras.relStage = resolveArchetypeStage(cfg, char.primaryRelationship);
        // [v0.9.17] Resolve the relationship target-name macro: __player__ -> protagonist name.
        let _relTgt = char.primaryRelationship.targetName;
        if (_relTgt === '__player__') _relTgt = (cfg as any).protagonistName || 'the player';
        extras.primaryRelationship = Object.assign({}, char.primaryRelationship, { targetName: _relTgt });
    } else {
        extras.relArchetype = '';
        extras.relStage = '';
    }
    // Character resources → res_<tag>
    let resMap: Record<string, any> = {};
    for (const rdef of (char.charResourceDefs || [])) {
        let key = String(rdef.tag || '').replace('#', '').trim();
        if (!key) continue;
        let val = (char.charResourceValues && char.charResourceValues[rdef.id] !== undefined) ? char.charResourceValues[rdef.id] : 0;
        if (rdef.type === 'pool') {
            resMap[key] = String(val);
        } else {
            // track / discrete → state label; index 0 of a discrete is the clear/none slot → blank
            let states = rdef.states || [];
            let label = states[val] || '';
            if (rdef.type === 'discrete' && val === 0) label = '';
            resMap[key] = label;
        }
    }
    extras.res = resMap;

    // [v0.9.8.4] conditionStates: a convenience join of every active condition-type
    // resource (discrete/track with a non-blank current label), e.g. "drunk, poisoned".
    // Per-tag |res.<tag>| macros still work for precise references.
    let condParts: string[] = [];
    for (const cdef of (char.charResourceDefs || [])) {
        if (!cdef || cdef.type === 'pool') continue;
        let condVal = (char.charResourceValues && char.charResourceValues[cdef.id] !== undefined) ? char.charResourceValues[cdef.id] : 0;
        let condStates = cdef.states || [];
        let condLabel = condStates[condVal] || '';
        if (cdef.type === 'discrete' && condVal === 0) condLabel = '';
        if (condLabel) condParts.push(condLabel);
    }
    extras.conditionStates = condParts.join(', ');

    return extras;
}

function parseMacroTemplate(template: string, data: any): string {
    if (!template) return '';
    return template.replace(/\[([^\[\]]+)\]/g, function(match, inner) {
        let isValid = true;
        
        // Globally find and evaluate all |macro.path| tokens inside this specific bracket block
        const evaluatedInner = inner.replace(/\|([^\|]+)\|/g, function(macroMatch, path) {
            let val: any = data;
            const keys = path.trim().split('.');
            for (const k of keys) {
                if (val === undefined || val === null) break;
                val = val[k];
            }
            
            // If any token evaluates to empty/null, flag the entire bracket block for deletion
            if (val === undefined || val === null || String(val).trim() === '') {
                isValid = false;
                return '';
            }
            
            return String(val);
        });
        
        if (!isValid) return '';
        
        // Finalize block formatting
        return evaluatedInner.replace(/\\n/g, '\n');
    });
}


// NOTE FOR ASSEMBLY: STORAGE_RETRY_CHARS = 'ae_retry_chars' (used in Section 15's
// runDynamicEngine) was declared mid-file at line 8039 in the original alongside
// STORAGE_ENGINE_SKIP. Both belong in Section 2 constants. Add:
//   var STORAGE_RETRY_CHARS = 'ae_retry_chars';

// ── Per-character sub-builders ────────────────────────────────────────────────
// These build individual string fragments for one character at a time.
// buildWorldStateBlock calls equivalent inline logic rather than these helpers,
// but they are available for future pipeline refactoring and UI previews.

function buildProtagonistInjection(protag: CharacterRecord): string {
    // Builds the [ Player: ... ] header line for the protagonist in the AN.
    const idParts = [protag.gender, protag.species, protag.age, protag.occupationRole].filter(Boolean);
    const header  = idParts.length > 0 ? `${protag.name} (${idParts.join(', ')})` : protag.name;
    const lines: string[] = [`[ Player: ${header} ]`];
    if (protag.briefDescription?.trim()) lines.push(protag.briefDescription.trim());
    return lines.join('\n');
}

function buildDramatisPersonae(index: CharacterMeta[]): string {
    // Builds the [ Dramatis Personae ] cast list from the character index.
    // Marks offstage characters explicitly so the AI knows who is not present.
    const active = index.filter(function(m) { return m.active; });
    if (active.length === 0) return '';
    const lines = ['[ Dramatis Personae ]'];
    for (const m of active) {
        const idParts = [m.species?.trim(), m.age?.trim(), m.occupationRole?.trim()].filter(Boolean);
        const header  = idParts.length > 0 ? `${m.name} (${idParts.join(', ')})` : m.name;
        const brief   = m.briefDescription?.trim() ? ` — ${m.briefDescription.trim()}` : '';
        lines.push(`${header}${(m.scenePresent || m.isProtagonist) ? '' : ' [offstage]'}${brief}`);
    }
    return lines.join('\n');
}

function buildCharInjection(
    char: CharacterRecord,
    cfg: GlobalConfig,              // [CHANGE] was a free variable bug — now explicit param
    equippedItemNames?: string[]    // [CHANGE] removed three unused _-prefixed params
): string {
    // Builds a compact [ CharName ] block with arc, relationship, and equipment.
    // Currently not called from buildWorldStateBlock (which inlines all assembly),
    // but preserved as a utility for future pipeline use.
    if (!char.active || !char.scenePresent) return '';
    const contentLines: string[] = [];

    function tryQueue(line: string): void {
        if (!line?.trim()) return;
        contentLines.push(line);
    }

    if (char.primaryRelationship?.targetName && char.primaryRelationship.enabled && char.charContextEnabled !== false) {
        let relTarget = char.primaryRelationship.targetName;
        if (relTarget === '__player__') {
            relTarget = (cfg as any).protagonistName || 'the player';
        }
        let stageName = resolveArchetypeStage(cfg, char.primaryRelationship);
        let archName  = char.primaryRelationship.archetype || '';
        let relPrefix = '';
        if (archName && stageName) relPrefix = archName + ' \u2014 ' + stageName + ': ';
        else if (archName) relPrefix = archName + ': ';
        tryQueue(`Relationship (${relTarget}): ${relPrefix}${char.primaryRelationship.currentStatus}`);
    }

    if (equippedItemNames && equippedItemNames.length > 0) {
        tryQueue(`Equipped: ${equippedItemNames.join(', ')}`);
    }

    if (contentLines.length === 0) return '';
    return `[ ${char.name} ]\n${contentLines.join('\n')}`;
}

function buildMidRangeInjection(char: CharacterRecord): string {
    // Builds a single attributed line from the character's mid-range state
    // (goal / mask / view). Three distinct beats in one line.
    if (char.charContextEnabled === false) return '';
    const mid = char.midRange;
    if (!mid) return '';
    const parts = [mid.currentDesire, mid.socialMask, mid.shiftedView].filter(Boolean);
    return parts.length > 0 ? `${char.name} — ${parts.join('. ')}` : '';
}

function buildEphemeralInjection(char: CharacterRecord): string {
    // Builds an attributed ephemeral injection from the character's immediate state.
    // Prefers the three structured sub-fields; falls back to compressedLine.
    if (char.charContextEnabled === false) return '';
    if (!char.ephemeral) return '';
    const eph = char.ephemeral;
    const parts = [eph.eventAnchor, eph.emotionalResponse, eph.immediateDesire].filter(Boolean);
    if (parts.length >= 2) return `${char.name} — ${parts.join(' — ')}`;
    if (eph.compressedLine) return `${char.name} — ${eph.compressedLine}`;
    return '';
}

function charIsRelevant(c: CharacterRecord, activeEntryIds: Set<string>): boolean {
    // Returns true if a character should receive dynamic engine updates this turn.
    // A character is relevant if they are scene-present OR their lorebook entry fired.
    return c.active && c.scenePresent; // [v0.9.24 E2] removed lorebook-entry clause
}

// [vNEXT] Dynamic-priority cap. Given the already-loaded character index and the
// configured cap, returns the Set of character ids permitted to run as dynamic this
// turn. Pure in-memory over the index metas — NO storage reads, so it costs nothing
// on the generation path beyond a sort of the present-dynamic subset.
//
// Eligible pool = active, scene-present, non-protagonist, non-static (static chars
// are already excluded from dynamics by their own gate; excluding them here too means
// they never occupy a cap slot). Ordering: ranked characters first by ascending rank
// (1 = highest priority), then unranked characters by name. Unranked present-dynamic
// characters DO consume slots, after all ranked ones. cap <= 0 means no cap — every
// eligible id is returned.
function computeDynamicAllowedSet(index: CharacterMeta[], cap: number): Set<string> {
    const eligible = (index || []).filter(function(m) {
        return m && m.active && m.scenePresent && !m.isProtagonist && !(m as any).isStatic;
    });
    if (!(cap > 0) || eligible.length <= cap) {
        // No cap, or everyone fits — allow all eligible.
        return new Set(eligible.map(function(m) { return m.id; }));
    }
    eligible.sort(function(a, b) {
        const ar = (typeof (a as any).dynamicPriorityRank === 'number' && (a as any).dynamicPriorityRank > 0) ? (a as any).dynamicPriorityRank : Infinity;
        const br = (typeof (b as any).dynamicPriorityRank === 'number' && (b as any).dynamicPriorityRank > 0) ? (b as any).dynamicPriorityRank : Infinity;
        if (ar !== br) return ar - br;                       // ranked ascending; unranked (Infinity) last
        return String(a.name || '').localeCompare(String(b.name || '')); // stable tiebreak
    });
    return new Set(eligible.slice(0, cap).map(function(m) { return m.id; }));
}

// [vNEXT] Assign (or clear) a character's dynamic-priority rank, enforcing "one
// character per rank" by swapping. If another character already holds newRank, they
// inherit the assignee's OLD rank (which may be undefined -> they become unranked).
// Pass newRank <= 0 or undefined to simply clear the assignee's rank (no swap).
// Writes only the (at most) two affected records. Returns nothing; callers refresh UI.
async function assignDynamicPriorityRank(charId: string, newRank: number | undefined): Promise<void> {
    try {
        const target = await loadCharacter(charId);
        if (!target) return;
        const oldRank = (typeof (target as any).dynamicPriorityRank === 'number' && (target as any).dynamicPriorityRank > 0) ? (target as any).dynamicPriorityRank : undefined;
        const wantRank = (typeof newRank === 'number' && newRank > 0) ? Math.floor(newRank) : undefined;

        if (wantRank === oldRank) return; // no change

        // Clear case: just drop the rank.
        if (wantRank === undefined) {
            (target as any).dynamicPriorityRank = undefined;
            await saveCharacter(target);
            return;
        }

        // Find whoever currently holds wantRank (excluding the target) via the index
        // (cheap — no full character loads for the scan).
        const idx = await loadIndex();
        const holderMeta = idx.find(function(m) { return m && m.id !== charId && (m as any).dynamicPriorityRank === wantRank; });

        if (holderMeta) {
            const holder = await loadCharacter(holderMeta.id);
            if (holder) {
                // Swap: holder takes the target's old rank (may be undefined -> unranked).
                (holder as any).dynamicPriorityRank = oldRank;
                await saveCharacter(holder);
            }
        }
        (target as any).dynamicPriorityRank = wantRank;
        await saveCharacter(target);
    } catch (e) {
        api.v1.error('[AE:dynrank] assignDynamicPriorityRank:', e);
    }
}

// [vNEXT] Shared rank-picker modal for a character. Offers "Unranked" plus ranks
// 1..maxRank, where maxRank is the configured dynamic cap (or, if no cap is set, the
// count of eligible present characters, floored at a small minimum so the control is
// always usable). Shows which character currently holds each rank. onDone (optional)
// is invoked after assignment so the caller can refresh its own view.
async function openDynamicRankPicker(charId: string, onDone?: () => (void | Promise<void>)): Promise<void> {
    try {
        const cfg = await loadConfig();
        const idx = await loadIndex();
        const self = idx.find(function(m) { return m.id === charId; });
        const selfName = self ? (self.name || 'Character') : 'Character';
        const curRank = (self && typeof (self as any).dynamicPriorityRank === 'number' && (self as any).dynamicPriorityRank > 0) ? (self as any).dynamicPriorityRank : undefined;

        const cap = Number((cfg as any).maxDynamicCharacters) || 0;
        // How many rank slots to offer. With a cap, offer exactly the cap. Without a
        // cap, offer as many as there are eligible present characters (min 4 so the
        // control is meaningful even in a small scene).
        let eligibleCount = idx.filter(function(m) {
            return m && m.active && !m.isProtagonist;
        }).length;
        const maxRank = cap > 0 ? cap : Math.max(4, eligibleCount);

        // Rank -> holder name lookup (from the index; no character loads).
        const holderByRank: Record<number, string> = {};
        idx.forEach(function(m) {
            const r = (m as any).dynamicPriorityRank;
            if (typeof r === 'number' && r > 0) holderByRank[r] = m.name || 'Character';
        });

        const items: { id: string; label: string; selected?: boolean }[] = [];
        items.push({ id: '__unranked__', label: 'Unranked' + (curRank === undefined ? '  (current)' : ''), selected: curRank === undefined });
        for (let r = 1; r <= maxRank; r++) {
            let holder = holderByRank[r];
            let suffix = '';
            if (r === curRank) suffix = '  (current)';
            else if (holder && holder !== selfName) suffix = '  — held by ' + holder;
            items.push({ id: String(r), label: 'Rank ' + r + suffix, selected: r === curRank });
        }

        await openPickerModal({
            title: 'Dynamic Priority — ' + selfName,
            items: items,
            getId: function(item: any) { return item.id; },
            getLabel: function(item: any) { return item.label; },
            searchable: false,
            selectedId: curRank === undefined ? '__unranked__' : String(curRank),
            emptyText: 'No ranks available.',
            onSelect: async function(item: any) {
                const pick = item && item.id;
                if (pick === '__unranked__') await assignDynamicPriorityRank(charId, undefined);
                else await assignDynamicPriorityRank(charId, parseInt(pick, 10));
                if (onDone) await onDone();
            }
        });
    } catch (e) {
        api.v1.error('[AE:dynrank] openDynamicRankPicker:', e);
    }
}

async function buildEntityContextBlock(ent: EntityRecord): Promise<string> {
    // Builds a [ Type: Name ] header with state-resolved description and atmosphere.
    // Used when injecting a specific entity into context (e.g. from a HUD action).
    const resolved = (ent.state !== 'default' && ent.stateDescriptions[ent.state])
        ? ent.stateDescriptions[ent.state]
        : ent.description;
    const lines: string[] = [`[ ${ent.type.charAt(0).toUpperCase() + ent.type.slice(1)}: ${ent.name} ]`];
    if (resolved?.trim()) lines.push(resolved.trim());
    if (ent.atmosphere?.trim()) lines.push(ent.atmosphere.trim());
    return lines.join('\n');
}

// ── Primary builders ──────────────────────────────────────────────────────────

async function buildWorldStateBlock(protagChar: CharacterRecord | null): Promise<string> {
    // [CE-STRIP v2.6.0 CTX-CUT] Location, the present-roster line, and the quest
    // line are gone (see CE-INDEX PASS 9 / this file's Section 13 header). Static
    // identity still rides each character's force-activated lorebook entry. This
    // block is now ONLY per-character thoughts (ephemeral + midRange) plus, merged
    // in per user's call, that character's critical (85%+) hook line — previously
    // injected separately via the onContextBuilt Imperative splice.
    // [pending protagonist pass] protagChar is now unused in this function body —
    // left on the signature/call site deliberately; the protag/player elimination
    // pass (flagged, not started) is where this actually gets cleaned up.
    const parts: string[] = [];
    const cfg = await loadConfig();

    const charIndex = await loadIndex();
    const presentMetas = charIndex.filter(function(m) { return m && m.active && m.scenePresent && !m.isProtagonist; });
    const _wsDynCap = Number((cfg as any).maxDynamicCharacters) || 0;
    const _wsDynAllowed = computeDynamicAllowedSet(charIndex as any, _wsDynCap);

    // ── PER-CHARACTER THOUGHTS + CRITICAL HOOK ────────────────────────────────
    try {
        const presentChars: string[] = [];

        for (const meta of presentMetas) {
            // [vNEXT] Under a dynamic cap, only inject for characters within the cap.
            if (_wsDynCap > 0 && !_wsDynAllowed.has(meta.id)) continue;
            const char = await loadCharacter(meta.id);
            if (!char) continue;

            // [v0.9.30 HOOK-TIER] Ambient hooks (<60) remain available via the
            // |hookDescription| macro for anyone who hand-edits cfg.contextTemplates.npc
            // directly, but are omitted from the default template.
            let hookDesc = '';
            if (char.hooks && char.hooks.length > 0 && !char.hooks[0].resolved && char.hooks[0].pressureLevel < 60) {
                hookDesc = char.hooks[0].description;
            }

            const npcData = Object.assign({}, char, buildCharMacroExtras(char, cfg), { hookDescription: hookDesc });
            // [BUGFIX v2.28.0 WORLDSTATE-STALE-THOUGHTS, per user's report] A character
            // with auto-thoughts (or auto-dynamics) turned OFF must not leak a snapshot
            // that's just sitting on the record from before the toggle was flipped, or
            // from an import/migration — char.ephemeral/midRange are NOT cleared when
            // the toggle goes off, they just stop being refreshed. Omitting the field
            // here (rather than special-casing the template string) is enough:
            // parseMacroTemplate already self-suppresses a bracket block whose
            // referenced macro resolves to undefined/empty (see its own comment above).
            // Mirrors the exact same per-character gate the retry queue already uses
            // (_rcType === 'eph' && autoThoughtsEnabled / 'mid' && autoUpdateEnabled).
            // Object.assign above already made npcData a fresh object, so this cannot
            // mutate the loaded character record.
            if (!char.autoThoughtsEnabled) npcData.ephemeral = null;
            if (!char.autoUpdateEnabled) npcData.midRange = null;
            let thoughtsLine = parseMacroTemplate(cfg.contextTemplates.npc, npcData).trim();
            // Drop a thoughts line that rendered to nothing but the bare name.
            if (thoughtsLine === (char.name || '').trim()) thoughtsLine = '';

            // [CE-STRIP v2.6.0 CTX-CUT] Critical (85%+, unresolved) hook — now built
            // here instead of the onContextBuilt Imperative block. Urgent (60-84%)
            // hooks have no injection destination this pass (see Section 13 header).
            let hookLine = '';
            const topHook = (char.hooks && char.hooks.length > 0) ? char.hooks[0] : null;
            if (topHook && !topHook.resolved && topHook.pressureLevel >= 85 && topHook.description && topHook.description.trim()) {
                hookLine = parseMacroTemplate(cfg.contextTemplates.criticalHook, { name: char.name, hookDescription: topHook.description }).trim();
            }

            const combined = [thoughtsLine, hookLine].filter(Boolean).join('\n');
            if (combined) presentChars.push(combined);
        }

        if (presentChars.length > 0) {
            parts.push(presentChars.join('\n'));
        }
    } catch (e) { api.v1.error('[AE:context] buildWorldStateBlock scene chars:', e); }

    // [v2.9.0 LOREFOLD] NPC web — bilateral dynamics between two scene-present
    // characters, bundled into the AN alongside thoughts (user's call). Injected only
    // when BOTH parties are present, so the shared fact appears exactly once (no
    // per-character double injection) and only when contextually relevant. Sorted by
    // priority (higher first), rendered via cfg.contextTemplates.npcWeb.
    try {
        const wsWeb = await loadNpcWeb();
        if (wsWeb && wsWeb.length > 0) {
            const wsPresentIds = new Set(presentMetas.map(function(m) { return m.id; }));
            const wsNameById = new Map<string, string>();
            for (const m of presentMetas) wsNameById.set(m.id, (m as any).name || '');
            const wsTpl = (cfg.contextTemplates as any).npcWeb || '';
            const wsLines: { line: string; priority: number }[] = [];
            for (const wl of wsWeb) {
                if (!wsPresentIds.has(wl.charA_id) || !wsPresentIds.has(wl.charB_id)) continue;
                if (!wl.dynamic || !wl.dynamic.trim()) continue;
                const wsLine = parseMacroTemplate(wsTpl, {
                    nameA: wsNameById.get(wl.charA_id) || '',
                    nameB: wsNameById.get(wl.charB_id) || '',
                    dynamic: wl.dynamic
                }).trim();
                if (wsLine) wsLines.push({ line: wsLine, priority: typeof wl.priority === 'number' ? wl.priority : 30 });
            }
            if (wsLines.length > 0) {
                wsLines.sort(function(a, b) { return b.priority - a.priority; });
                parts.push(wsLines.map(function(w) { return w.line; }).join('\n'));
            }
        }
    } catch (eWeb) { api.v1.error('[AE:context] npc web injection:', eWeb); }

    return parts.join('\n\n');
}

// [CE-STRIP v2.6.0 CTX-CUT] buildTrackedNarrativeBlock and buildDramaContextBlock
// PHYSICALLY DELETED — each had exactly one caller (onBeforeContextBuild's
// questLine/dramaBlock locals), verified zero-referenced after those calls were
// removed. See CE-INDEX PASS 9 for full rationale.

// ============================================================================
// SECTION 14 — [RETIRED] legacy freeform #tag 1d6 skill-check system.
// Removed [vNEXT]: typing #force etc. directly in the story box no longer rolls.
// All skill checks now run through the Quick Action composer (2d6 fail-forward +
// the Stakes library below). UNIVERSAL_OUTCOMES / DEFAULT_OUTCOME_BANDS / rollD6 /
// getUniversalOutcome / getConsumedRoll / markRollConsumed removed with it.
// ============================================================================

// ============================================================================
// SECTION 15 — DYNAMIC ENGINE
//
// All AI generation that runs AFTER a story generation completes. This is the
// "background engine" — it updates character states (ephemeral thoughts,
// mid-range dynamics, arcs, hooks) based on the new story content.
//
// Execution order in runDynamicEngine (per character, per turn):
//   1. Retry queue — flushes characters deferred from previous budget-limited turn
//   2. Per character (active, non-protagonist, non-static):
//      a. Ephemeral thoughts (interval: thoughtIntervalTokens, ~600)
//      b. Mid-range dynamics (interval: dynamicIntervalTokens, ~1200)
//      c. Arc + Relationship update (interval: arcIntervalTokens, ~3000)
//      d. Hook update or spawn (interval: hookIntervalTokens, ~1800)
//
// Budget gates: checks api.v1.script.getAllowedOutput() before dispatching.
// If budget < threshold, the character is queued in STORAGE_RETRY_CHARS for
// the next generation rather than blocking this one.
//
// HELPERS IN THIS SECTION:
//   extractJSON, extractJSONArray     — GLM output parsers
//   getRecentStoryText                — story context reader
//   generateFieldContent              — character field AI generator
//   buildCharacterStateContext        — assembles character state for generator prompts
//     [v2.16.0] now async — also folds in active charJournal bubbles (Section 10c) as a
//     directed input, not just the passive lorebook fold buildCharDynamicBlock already did
//   generateArcMilestones             — milestone generator (called from UI)
// ============================================================================

// ── GLM Output Parsers ────────────────────────────────────────────────────────

function extractJSON(text: string): any {
    // Attempts multiple strategies to parse a JSON object from model output.
    // GLM sometimes omits the outer braces or wraps output in markdown fences.
    if (!text) return null;
    let clean = text.trim();

    // Fallback: model responded with key-value pairs missing the opening brace
    if (clean.startsWith('"') && !clean.includes('{')) {
        clean = '{' + clean;
        if (!clean.endsWith('}')) clean += '}';
    }

    try { return JSON.parse(clean); } catch {}
    try { const stripped = clean.replace(/```json\s*/gi, '').replace(/```\s*/gi, '').trim(); return JSON.parse(stripped); } catch {}
    try {
        const s = clean.indexOf('{'); const e = clean.lastIndexOf('}');
        if (s !== -1 && e !== -1 && e > s) return JSON.parse(clean.substring(s, e + 1));
    } catch (e) {}

    api.v1.log('[AE:engine] extractJSON failed on:', text.slice(0, 80));
    return null;
}

function extractJSONArray(text: string): any[] | null {
    // Attempts multiple strategies to parse a JSON array from model output.
    if (!text) return null;
    let clean = text.trim();

    // Fallback: model output a single object instead of an array
    if (clean.startsWith('{') && !clean.startsWith('[')) clean = '[' + clean + ']';

    try { return JSON.parse(clean); } catch {}
    try { const stripped = clean.replace(/```json\s*/gi, '').replace(/```\s*/gi, '').trim(); return JSON.parse(stripped); } catch {}
    try {
        const s = clean.indexOf('['); const e = clean.lastIndexOf(']');
        if (s !== -1 && e !== -1 && e > s) return JSON.parse(clean.substring(s, e + 1));
    } catch (e) {}

    api.v1.log('[AE:engine] extractJSONArray failed on:', text.slice(0, 80));
    return null;
}

// ── Story Context Reader ──────────────────────────────────────────────────────

async function getRecentStoryText(maxTokens: number): Promise<string> {
    // Returns the most recent story text fitting within maxTokens.
    // Reads backward from the end so the freshest content is always included.
    try {
        const ids = await api.v1.document.sectionIds();
        if (ids.length === 0) return '';
        const si       = Math.max(0, ids.length - Math.ceil(maxTokens / 10) - 20);
        const sections = await api.v1.document.scan(undefined, { from: ids[si] });
        let text = ''; let used = 0;
        for (let i = sections.length - 1; i >= 0; i--) {
            const t = sections[i].section?.text || '';
            if (!t.trim()) continue;
            const enc = await api.v1.tokenizer.encode(t, 'glm-4-6');
            if (used + enc.length > maxTokens) break;
            text = t + '\n\n' + text;
            used += enc.length;
        }
        return text.trim();
    } catch { return ''; }
}

// ── Character Field Generator ─────────────────────────────────────────────────

async function generateFieldContent(
    char: CharacterRecord,
    fieldLabel: string,
    instructions: string,
    generalStyle: string,
    hint: string,
    maxTokens: number
): Promise<string | null> {
    // Generates content for a single character field using GLM.
    // Used by the character editor's auto-generate buttons.
    // NOTE: waitForAllowedOutput is intentionally absent — this runs from modal
    // button callbacks where the signal never fires (deadlock risk).
    const recentText  = await getRecentStoryText(2000);
    const targetWords = Math.max(20, Math.floor(maxTokens * 0.75));

    const sys = [
        generalStyle,
        `You are writing the "${fieldLabel}" field for a character. This field has specific scope — stay inside it.`,
        instructions,
        `CONSTRAINT: Strictly under ~${targetWords} words. Finish your thought completely. ` +
        `Your output must be the content itself — do not begin with a label, header, or category name. ` +
        `Outputs that begin with words like "Voice:", "Appearance:", "Core Drive:", or any descriptor of what follows are invalid. ` +
        `Your first word must be content.`
    ].filter(Boolean).join('\n\n');

    const usrParts: string[] = [
        `Character: ${char.name}`,
        char.briefDescription ? `Anchor (do not contradict): ${char.briefDescription}` : '',
        char.conceptDump?.trim()
            ? `Reference notes (extract only what is directly relevant to the ${fieldLabel} field — ignore the rest):\n${char.conceptDump.trim()}`
            : '',
        hint?.trim() ? `Focus constraint: ${hint.trim()}` : '',
        recentText   ? `Recent story context:\n${recentText}` : '',
        `\nNow write the ${fieldLabel} field for ${char.name}.`
    ];

    try {
        const resp = await aeDiagGenerate(
            'field:' + fieldLabel + ':' + char.name,
            [{ role: 'system', content: sys }, { role: 'user', content: usrParts.filter(Boolean).join('\n\n') }],
            { model: 'glm-4-6', max_tokens: maxTokens + 30, temperature: 0.8 }
        );
        return (resp.choices[0]?.text || '').trim() || null;
    } catch (e) {
        api.v1.error('[AE:engine] generateFieldContent:', e);
        return null;
    }
}

// ── Character State Context Builder ──────────────────────────────────────────

async function buildCharacterStateContext(char: CharacterRecord): Promise<string> {
    // Assembles a compact multi-line summary of a character's current dynamic state.
    // Passed as context to all generator prompts so GLM can update fields correctly.
    const lines: string[] = [];

    if (char.ephemeral && char.ephemeral.compressedLine) {
        lines.push(`Current moment (${char.name}): "${char.ephemeral.compressedLine}"`);
        if (char.ephemeral.eventAnchor)     lines.push(`  → Triggered by: ${char.ephemeral.eventAnchor}`);
        if (char.ephemeral.immediateDesire) lines.push(`  → Driving them to: ${char.ephemeral.immediateDesire}`);
    }
    if (char.midRange) {
        if (char.midRange.currentDesire) lines.push(`Current Desire: ${char.midRange.currentDesire}`);
        if (char.midRange.socialMask)    lines.push(`Social Mask: ${char.midRange.socialMask}`);
        if (char.midRange.baselineView)  lines.push(`Baseline View (their starting belief): ${char.midRange.baselineView}`);
        if (char.midRange.shiftedView)   lines.push(`Shifted View (belief now): ${char.midRange.shiftedView}`);
    }
    // [v2.16.0 CHARJOURNAL-WEIGHT] Active (non-archived) journal bubbles are now a
    // directed generator input, not just passive lorebook filler (buildCharDynamicBlock
    // still folds them into the lorebook separately — this is additive, not a replacement).
    // Read failures here must never break a dynamic-update cycle, so they're swallowed.
    try {
        const journal = await loadCharJournal(char.id);
        const activeBubbles = (journal.bubbles || []).filter(function(b) { return !b.archived && (b.text || '').trim(); });
        if (activeBubbles.length > 0) {
            lines.push(`${char.name}'s own journal notes (weigh these — they reflect what the character considers significant):`);
            activeBubbles.slice(-4).forEach(function(b) { lines.push(`  - ${b.text.trim()}`); });
        }
    } catch (e) { api.v1.error('[AE:engine] buildCharacterStateContext journal read:', e); }
    return lines.join('\n');
}

// ── Generators ────────────────────────────────────────────────────────────────

async function generateEphemeral(
    char: CharacterRecord,
    cfg: GlobalConfig,
    genCount: number = 0 // [v0.9.24 E1] was tokenCount
): Promise<boolean> {
    try {
        const recentText = await getRecentStoryText(1500);
        const sys = [
            cfg.generalStyle,
            `Generate a three-part internal snapshot for ${char.name} based on the current moment.`,
            // [v0.9.33 AIR1] Explicit isolation: when multiple characters are present,
            // each generation call must produce only this character's perspective.
            `Focus exclusively on ${char.name}. Do not generate, reference, or echo the internal states, reactions, or thoughts of any other character present in the scene.`,
            // [v2.14.0 GENESIS] Examples describe SHAPE ONLY — no sample story content to
            // copy (observed failure: output lifted the old worked examples verbatim).
            `Return ONLY valid JSON with these exact keys:`,
            `  "eventAnchor": The one concrete, observable thing in the latest story beat ${char.name} is reacting to — a specific action, object, line, or silence, never a mood or abstraction. One sentence. Capitalized. Ends with a period.`,
            `  "emotionalResponse": How it landed, as ${char.name}'s own unspoken reaction. Show it through a concrete thought, not an emotion-label word ('felt', 'angry', 'sad'). Do not use ${char.name}'s name. One sentence. Capitalized. Ends with a period.`,
            `  "immediateDesire": The single action ${char.name} intends right now — a bare verb phrase, under 10 words, no name/subject prefix. Capitalized. Ends with a period.`,
            `Every detail must come from the story and character context below, never from the wording of these instructions. No markdown fences. No extra keys. Return nothing but the JSON object.`
        ].join('\n');

        const ephHistLines = (char.ephemeralHistory || []).slice(0, 2)
            .map(function(h: any) { return h.compressedLine || ''; }).filter(Boolean);

        const usr = [
            `Character: ${char.name}`,
            char.personalityCore       ? `Personality: ${char.personalityCore}` : '',
            char.voiceAndMannerisms    ? `Voice/manner: ${char.voiceAndMannerisms}` : '',
            char.midRange?.currentDesire ? `Current goal: ${char.midRange.currentDesire}` : '',
            char.midRange?.socialMask  ? `Performing: ${char.midRange.socialMask}` : '',
            char.midRange?.shiftedView ? `Currently believes: ${char.midRange.shiftedView}` : '',
            char.primaryRelationship?.enabled && char.primaryRelationship?.targetName
                ? `Primary relationship (${char.primaryRelationship.targetName}): ${char.primaryRelationship.currentStatus || 'unresolved'}` : '',
            ephHistLines.length > 0    ? `Previous thoughts (do not repeat): ${ephHistLines.join(' / ')}` : '',
            recentText                 ? `\nRecent Story:\n${recentText}` : '',
            '\n```json\n'
        ].filter(Boolean).join('\n');

        const resp   = await aeDiagGenerate('ephemeral:' + char.name, [{ role: 'system', content: sys }, { role: 'user', content: usr }],
            { model: 'glm-4-6', max_tokens: 220, temperature: 0.85 }
        );
        const parsed = extractJSON(resp.choices[0]?.text || '');
        if (!parsed || (!parsed.eventAnchor && !parsed.emotionalResponse && !parsed.immediateDesire)) return false;

        const fresh = await loadCharacter(char.id);
        if (!fresh) return false;

        const _ea = String(parsed.eventAnchor       || '').trim();
        const _er = String(parsed.emotionalResponse || '').trim();
        const _id = String(parsed.immediateDesire   || '').trim();
        const _composed: string = (_ea || _er || _id)
            ? [_ea, _er, _id].filter(Boolean).join(' — ')
            : String(parsed.compressedLine || '').trim();

        const snapshot: EphemeralSnapshot = {
            eventAnchor: _ea, emotionalResponse: _er, immediateDesire: _id,
            compressedLine: _composed, generatedAtGen: genCount // [v0.9.24 E1]
        };

        fresh.ephemeral        = snapshot;
        fresh.ephemeralHistory = [snapshot, ...(fresh.ephemeralHistory || [])].slice(0, Number(cfg.ephemeralCap) || 3);
        fresh.lastEphemeralGen = genCount; // [v0.9.24 E1]
        await saveCharacter(fresh);
        await refreshSidebar();
        return true;
    } catch (e) {
        api.v1.error('[AE:engine] generateEphemeral:', e);
        return false;
    }
}

async function generateMidRange(
    char: CharacterRecord,
    cfg: GlobalConfig,
    genCount: number = 0 // [v0.9.24 E1] was tokenCount
): Promise<boolean> {
    // [v2.14.0 GENESIS] Two modes. GENESIS (no midRange, or a midRange with no frozen
    // baselineView) establishes a fleshed-out STARTING state from character canon so a
    // character never enters play blank — it writes baselineView (their default belief
    // BEFORE the story touches them) and seeds shiftedView equal to it (no shift yet).
    // ONGOING re-assesses each field against the frozen baseline + the previous values
    // and is explicitly allowed to return a field unchanged — stability is signal, not a
    // failed update. History appends only on genuine change (the change gate below).
    try {
        const HIST_CAP    = 4;
        const isGenesis   = !char.midRange || !char.midRange.baselineView;
        const recentText  = await getRecentStoryText(3000);
        const rel         = char.primaryRelationship;
        const relOn       = !!(rel && rel.enabled && rel.targetName);

        // Ephemeral (moment) feeds UP into this layer.
        const midEphContext: string[] = [];
        if (char.ephemeral?.eventAnchor)       midEphContext.push(`Reacting to: ${char.ephemeral.eventAnchor}`);
        if (char.ephemeral?.emotionalResponse)  midEphContext.push(`Felt: ${char.ephemeral.emotionalResponse}`);
        if (char.ephemeral?.immediateDesire)    midEphContext.push(`Immediate drive: ${char.ephemeral.immediateDesire}`);
        const charState = char.ephemeral ? `Recent moment: "${char.ephemeral.compressedLine}"` : '';

        // Compact change-trail (most recent first) so the model can see what has held.
        const midHist = (char.midRangeHistory || []).slice(0, 2).map(function(h: any) {
            return `  (gen ${h.atGen}) wants ${h.currentDesire || '—'} / believes ${h.shiftedView || '—'}`;
        }).filter(Boolean);

        // Field contracts shared by both modes — wordings match the lorebook templates
        // that embed each value mid-sentence, so the rendered line reads grammatically.
        const RULE_DESIRE = `"currentDesire": ${char.name}'s sustained overarching goal — what they are actively working toward or protecting across scenes, NOT a momentary urge (that is the ephemeral layer). Phrase it to complete "${char.name} currently wants ___": an infinitive or noun phrase, lowercase first word, no closing period. Do not use the word "currently".`;
        const RULE_MASK   = `"socialMask": what ${char.name} outwardly performs to others AND what that performance conceals. Phrase it to complete "Outwardly, ${char.name} is presenting as ___": name the outward projection, then a comma with "while"/"though" and what is really underneath. Lowercase first word, no closing period.`;
        const BOUNDARY    = `This is ${char.name}'s standing psychological state — goals, self-presentation, worldview. It is NOT a summary of any one relationship, nor a faster copy of their current mood; reference a relationship only when it shapes something broader than that relationship itself.`;

        let sys: string;
        if (isGenesis) {
            sys = [
                cfg.generalStyle,
                `Establish the STARTING dynamic state for ${char.name}, who is entering the story. Build it from who they ALREADY are — core personality, background, and how their key relationship began — not from a reaction to the latest beat.`,
                BOUNDARY,
                `Return ONLY valid JSON with exactly these three keys, each genuinely distinct.`,
                RULE_DESIRE,
                RULE_MASK,
                `"baselineView": ${char.name}'s DEFAULT operating belief about their situation, role, or key relationship as they come INTO the story — the assumption they hold before its events change anything. Phrase it to complete "${char.name} believes that ___": a natural clause, no closing period; keep proper nouns capitalized but do not capitalize the first word unless it is a proper noun.`,
                `Do not restate one idea across fields. No markdown fences. No emotion-label words.`
            ].join('\n');
        } else {
            sys = [
                cfg.generalStyle,
                `Re-assess ${char.name}'s dynamic profile. For each field, decide whether the story since the last update genuinely changed it. If a field is still accurate, return the PREVIOUS value EXACTLY — do not rephrase for variety; a stable goal or belief is meaningful signal, not a failure to update.`,
                BOUNDARY,
                `Return ONLY valid JSON with exactly these three keys, each genuinely distinct from the others.`,
                RULE_DESIRE + ` This is the stickiest field — change it only if the story redirected what they are working toward.`,
                RULE_MASK,
                `"shiftedView": ${char.name}'s CURRENT operating belief, measured against the frozen baseline below. If events have genuinely reframed how they read the situation, a person, or themselves, state the new belief; if not, return the previous shifted view unchanged. Phrase it to complete "${char.name} has come to believe that ___": a natural clause, no closing period; keep proper nouns capitalized but do not capitalize the first word unless it is a proper noun.`,
                `No markdown fences. No emotion-label words.`
            ].join('\n');
        }

        const usr = [
            `Character: ${char.name}`,
            char.personalityCore ? `Core personality: ${char.personalityCore}` : '',
            char.background      ? `Background: ${char.background}` : '',
            relOn && rel.archetype     ? `Key relationship (${rel.targetName}): ${rel.archetype}` : '',
            relOn && rel.howItStarted  ? `  how it began: ${rel.howItStarted}` : '',
            relOn && rel.currentStatus ? `  where it stands now: ${rel.currentStatus}` : '',
            relOn && rel.trajectory    ? `  what is pushing it: ${rel.trajectory}` : '',
            midEphContext.length > 0 ? `Immediate state:\n${midEphContext.join('\n')}` : charState,
            !isGenesis && char.midRange?.baselineView ? `Frozen baseline belief (do not restate — measure change against it): ${char.midRange.baselineView}` : '',
            !isGenesis && char.midRange?.currentDesire ? `Previous goal: ${char.midRange.currentDesire}` : '',
            !isGenesis && char.midRange?.socialMask    ? `Previous mask: ${char.midRange.socialMask}` : '',
            !isGenesis && char.midRange?.shiftedView   ? `Previous shifted view: ${char.midRange.shiftedView}` : '',
            !isGenesis && midHist.length > 0 ? `Earlier states (most recent first):\n${midHist.join('\n')}` : '',
            recentText ? `\n${isGenesis ? 'The situation they are entering' : 'Recent Story'}:\n${recentText}` : '',
            '\n```json\n'
        ].filter(Boolean).join('\n');

        const resp   = await aeDiagGenerate('midRange:' + char.name + (isGenesis ? ':genesis' : ''), [{ role: 'system', content: sys }, { role: 'user', content: usr }],
            { model: 'glm-4-6', max_tokens: 220, temperature: isGenesis ? 0.85 : 0.75 }
        );
        const result = extractJSON(resp.choices[0]?.text || '');
        if (!result) return false;

        const fresh = await loadCharacter(char.id);
        if (!fresh) return false;
        const prev = fresh.midRange;

        if (isGenesis) {
            const baseline = String(result.baselineView || result.shiftedView || prev?.baselineView || '').trim();
            const nd = String(result.currentDesire || prev?.currentDesire || '').trim();
            const nm = String(result.socialMask    || prev?.socialMask    || '').trim();
            fresh.midRange = { baselineView: baseline, currentDesire: nd, socialMask: nm, shiftedView: baseline, updatedAtGen: genCount };
            // Seed the trail with the genesis state so "held since" has an origin point.
            fresh.midRangeHistory = [{ currentDesire: nd, socialMask: nm, shiftedView: baseline, atGen: genCount }, ...(fresh.midRangeHistory || [])].slice(0, HIST_CAP);
        } else {
            const nd = String(result.currentDesire || prev?.currentDesire || '').trim();
            const nm = String(result.socialMask    || prev?.socialMask    || '').trim();
            const nv = String(result.shiftedView   || prev?.shiftedView   || '').trim();
            const changed = !prev || prev.currentDesire !== nd || prev.socialMask !== nm || prev.shiftedView !== nv;
            fresh.midRange = { baselineView: prev?.baselineView || nv, currentDesire: nd, socialMask: nm, shiftedView: nv, updatedAtGen: genCount };
            // Change gate: log a distinct new state only. A field stable for many scenes
            // leaves a short history rather than a duplicate-filled churn log.
            if (changed) fresh.midRangeHistory = [{ currentDesire: nd, socialMask: nm, shiftedView: nv, atGen: genCount }, ...(fresh.midRangeHistory || [])].slice(0, HIST_CAP);
        }
        fresh.lastMidrangeGen = genCount; // [v0.9.24 E1]
        await saveCharacter(fresh);
        await refreshSidebar();
        return true;
    } catch (e) {
        api.v1.error('[AE:engine] generateMidRange:', e);
        return false;
    }
}

async function generateRelationshipUpdate(
    char: CharacterRecord,
    cfg: GlobalConfig,
    genCount: number // [v0.9.24 E1] was tokenCount
): Promise<boolean> {
    if (!char.primaryRelationship.targetName) {
        api.v1.ui.toast('Requires a Target Name first.', { type: 'warning' });
        return false;
    }
    const rel        = char.primaryRelationship;
    const recentText = await getRecentStoryText(5000);
    const charState  = await buildCharacterStateContext(char);
    const HIST_CAP   = 4;

    // [v2.14.0 GENESIS] Field wordings match the lorebook templates so each renders
    // grammatically: currentStatus is a PASSTHROUGH (self-contained sentence naming both
    // parties), trajectory is fed as a bare predicate after "...bond with X is ___".
    // Examples describe SHAPE ONLY — no copyable story content. Fields are re-assessed for
    // real change and may return the previous value unchanged; history logs only changes.
    const sys = [
        cfg.generalStyle,
        `Re-assess the relationship between ${char.name} and ${rel.targetName}. For each field, decide whether the story since the previous value (shown below) genuinely moved it. If it did not, return the previous value EXACTLY rather than rephrasing. These three answer different questions — do not let them overlap.`,
        ``,
        `"currentStatus": what their interaction LOOKS LIKE right now — a self-contained sentence naming BOTH ${char.name} and ${rel.targetName} and describing only observable surface behaviour (how they speak, move, occupy space when together). No inner states, no "feels". Written as a complete sentence, capitalized, ending with a period.`,
        `  Avoid: naming an emotion instead of a behaviour.`,
        ``,
        `"trajectory": the specific force or recent event pushing this relationship — an action, a revelation, a silence — not a destination it is "heading toward". Phrase it to complete "${char.name}'s bond with ${rel.targetName} is ___": a lowercase gerund or noun phrase, no closing period.`,
        `  Avoid: a prediction of where it ends up; name the pressure acting on it now.`,
        ``,
        `"summary": the core incompatibility — what one needs from the other that they cannot or will not give, the structural knot that keeps this relationship charged. One sentence.`,
        `  Avoid: a vague feelings label.`,
        ``,
        `No markdown fences. Return ONLY valid JSON with exactly these three keys.`
    ].join('\n');

    const relStageName = resolveArchetypeStage(cfg, rel);
    const usr = [
        rel.archetype     ? `Archetype: ${rel.archetype}${relStageName ? ' (current stage: ' + relStageName + ')' : ''}` : '',
        rel.howItStarted  ? `Origin: ${rel.howItStarted}` : '',
        rel.threads.filter(Boolean).length > 0 ? `Active threads: ${rel.threads.filter(Boolean).join('; ')}` : '',
        rel.currentStatus ? `Previous status: ${rel.currentStatus}` : '',
        rel.trajectory    ? `Previous trajectory: ${rel.trajectory}` : '',
        rel.summary       ? `Previous core knot: ${rel.summary}` : '',
        charState         ? `${char.name}'s current state:\n${charState}` : '',
        recentText        ? `\nRecent Story:\n${recentText}` : '',
        '\n```json\n'
    ].filter(Boolean).join('\n');

    try {
        const resp   = await aeDiagGenerate('relationship:' + char.name, [{ role: 'system', content: sys }, { role: 'user', content: usr }],
            { model: 'glm-4-6', max_tokens: 200, temperature: 0.75 }
        );
        const parsed = extractJSON(resp.choices[0]?.text || '');
        if (!parsed) return false;

        const ch = await loadCharacter(char.id);
        if (!ch) return false;
        const pr = ch.primaryRelationship;
        const prevStatus = pr.currentStatus, prevTraj = pr.trajectory, prevSum = pr.summary;

        const nStatus = String(parsed.currentStatus || prevStatus || '').substring(0, 400);
        const nTraj   = String(parsed.trajectory    || prevTraj   || '').substring(0, 400);
        const nSum    = String(parsed.summary       || prevSum    || '').substring(0, 600);
        pr.currentStatus = nStatus;
        pr.trajectory    = nTraj;
        pr.summary       = nSum;

        // Change gate: append a trend snapshot only when something actually moved.
        const changed = nStatus !== prevStatus || nTraj !== prevTraj || nSum !== prevSum;
        if (changed) {
            ch.relationshipHistory = [{ currentStatus: nStatus, trajectory: nTraj, summary: nSum, atGen: genCount }, ...(ch.relationshipHistory || [])].slice(0, HIST_CAP);
        }
        ch.lastArcGen = genCount; // [v0.9.24 E1]
        await saveCharacter(ch);
        return true;
    } catch (e) {
        api.v1.log('[AE:engine] generateRelationshipUpdate:', e);
        return false;
    }
}

async function generateHookUpdates(
    char: CharacterRecord,
    cfg: GlobalConfig,
    genCount: number // [v0.9.24 E1] was tokenCount
): Promise<boolean> {
    const recentText = await getRecentStoryText(4000);
    if (!recentText) return false;
    const charState = await buildCharacterStateContext(char);

    // SCENARIO 1: Update existing hook (the escalator)
    if (char.hooks && char.hooks.length > 0) {
        const hook = char.hooks[0];
        const sys = [
            `Evaluate ${char.name}'s active tension regarding ${hook.targetName}.`,
            `Current hook: "${hook.description}" (Pressure: ${hook.pressureLevel}%)`,
            ``,
            `1. PRESSURE: Adjust "pressureLevel" (0-100) based on what actually happened. Did something force it closer to confrontation, or did it cool? Be specific.`,
            ``,
            `2. REWRITE: Rewrite "description" as a single sentence that reflects the current state. The tone MUST match the pressure tier:`,
            `   0-59 (Latent): Observational. Something noticed, not yet acted on. ("Still hasn't asked why she lied about the docks.")`,
            `   60-84 (Urgent): Active. Demands action, can't be ignored. ("Has to confront him before he tells the captain what he saw.")`,
            `   85-100 (Critical): Explosive. Desperate, do-or-die imperative. ("End this before he destroys everything — one way or another.")`,
            ``,
            `Return ONLY valid JSON: {"pressureLevel": 50, "description": "..."}. No isResolved field needed.`,
            `No markdown fences.`
        ].join('\n');

        const usr = [
            charState ? `${char.name}'s current state:\n${charState}` : '',
            `Story:\n${recentText}`,
            '\n```json\n'
        ].filter(Boolean).join('\n\n');

        try {
            const resp   = await aeDiagGenerate('hookUpdate:' + char.name + ':escalate', [{ role: 'system', content: sys }, { role: 'user', content: usr }],
                { model: 'glm-4-6', max_tokens: 200, temperature: 0.6 }
            );
            const update = extractJSON(resp.choices[0]?.text || '');
            if (!update) return false;

            const f = await loadCharacter(char.id);
            if (!f) return false;

            const targetHook = f.hooks[0];

            // Surface detection (≥85% only) — two consecutive YES clears the hook
            if (targetHook.pressureLevel >= 85 && recentText) {
                const hookWords = [targetHook.targetName, ...targetHook.description.split(' ')]
                    .filter(function(w) { return w && w.length > 3; })
                    .map(function(w) { return w.toLowerCase().replace(/[^a-z]/g, ''); })
                    .filter(Boolean);
                const recentLower = recentText.toLowerCase();
                const matchCount  = hookWords.filter(function(w) { return recentLower.includes(w); }).length;
                const surfaced    = matchCount >= Math.max(2, Math.floor(hookWords.length * 0.3));
                if (surfaced) {
                    const prevCount = targetHook.surfacedCount || 0;
                    if (prevCount >= 1) {
                        // Second YES — hook surfaced and lingered. Clear it, queue a new spawn.
                        f.hooks = [];
                        f.lastHookGen = genCount; // [v0.9.24 E1]
                        await saveCharacter(f);
                        api.v1.ui.toast('🔥 ' + char.name + ': hook surfaced — ' + hook.description.substring(0, 50), { type: 'success', autoClose: 4000 });
                        const _hr = await api.v1.tempStorage.getOrDefault(STORAGE_RETRY_CHARS, '[]') as string;
                        const _hi: string[] = JSON.parse(_hr);
                        if (!_hi.includes(char.id + ':hook')) { _hi.push(char.id + ':hook'); await api.v1.tempStorage.set(STORAGE_RETRY_CHARS, JSON.stringify(_hi)); }
                        return true;
                    } else {
                        targetHook.surfacedCount = 1;
                        api.v1.log('[AE:engine] Hook surfaced (1/2) for ' + char.name + ': ' + hook.description.substring(0, 40));
                    }
                } else {
                    targetHook.surfacedCount = 0;
                }
            }

            targetHook.pressureLevel = Math.min(100, Math.max(0, Number(update.pressureLevel) || targetHook.pressureLevel));
            if (update.description && update.description.trim() !== '') {
                targetHook.description = update.description.substring(0, 300);
            }
            f.lastHookGen = genCount; // [v0.9.24 E1]
            await saveCharacter(f);
            return true;
        } catch (e) {
            api.v1.log('[AE:engine] generateHookUpdates escalator error:', e);
            return false;
        }

    // SCENARIO 2: Spawn a new hook
    } else {
        const sys = [
            `Analyze the recent story for a specific, unresolved tension involving ${char.name}.`,
            ``,
            `You are looking for: a direct conflict with another person, a threat that demands response, or an urgent unfulfilled need that recent events created. Passive feelings and general mood do NOT qualify.`,
            ``,
            `If a clear tension exists, set "targetName" to the other person's name and write "description" as a single, punchy sentence naming the core conflict. Use concrete language — what happened, what is owed, what is at stake.`,
            `  Wrong: "feels betrayed by the situation"`,
            `  Right: "Cassius read the letter — he knows, and hasn't said anything yet"`,
            ``,
            `If no qualifying tension exists, set "targetName" to "None".`,
            `Set "pressureLevel" between 20-50 for a new hook (it hasn't had time to escalate).`,
            ``,
            `Return ONLY valid JSON: {"targetName": "Name or None", "description": "...", "pressureLevel": 30}`,
            `No markdown fences.`
        ].join('\n');

        const usr = [
            charState ? `${char.name}'s current state:\n${charState}` : '',
            `Story:\n${recentText}`,
            '\n```json\n'
        ].filter(Boolean).join('\n\n');

        try {
            const resp  = await aeDiagGenerate('hookUpdate:' + char.name + ':spawn', [{ role: 'system', content: sys }, { role: 'user', content: usr }],
                { model: 'glm-4-6', max_tokens: 200, temperature: 0.65 }
            );
            const spawn = extractJSON(resp.choices[0]?.text || '');
            if (!spawn || !spawn.targetName || spawn.targetName.toLowerCase() === 'none') return false;

            const f = await loadCharacter(char.id);
            if (!f) return false;

            f.hooks = [{
                id:           api.v1.uuid(),
                targetName:   spawn.targetName.substring(0, 50),
                description:  String(spawn.description || '').substring(0, 300),
                pressureLevel: Math.min(100, Math.max(0, Number(spawn.pressureLevel) || 30)),
                developmentNotes: [],
                resolved: false
            }];
            f.lastHookGen = genCount; // [v0.9.24 E1]
            await saveCharacter(f);
            return true;
        } catch (e) {
            api.v1.log('[AE:engine] generateHookUpdates spawn error:', e);
            return false;
        }
    }
}

// ── Engine Orchestrator ───────────────────────────────────────────────────────

// ── AUTO-TRIGGERS ───────────────────────────────────────────────────────────
// Scans scene-present entities for ActionInstances flagged autoTrigger, evaluates
// their conditions, and fires the ones that pass. Runs post-generation (onGenerationEnd)
// so it never recurses into the active generation. Auto-triggered actions always run
// silently (no nested api.v1.editor.generate) to avoid generation-in-generation.
// ── Tag-Subscription Action Resolver ─────────────────────────────────────────
// [v0.9.86] Returns the merged action list for an entity: its manually-added
// actionInstances PLUS every library template whose tags intersect the entity's
// tagSubscriptions. Templates are returned by reference (not copied) so all
// conditions, effects, branches, and resolution data are fully intact at call time.
// Deduplication is by template id — if a user already imported a template manually
// (templateId back-ref), the live copy from cfg takes precedence over the snapshot.
// [CE-STRIP v2.0.0] getTagSubscribedActions always returned [] once actionTemplates/
// actionInstances were removed from the data model (both inputs are permanently empty).
// Simplified to a stub so callers don't need the AERule/ActionInstance machinery.
function getTagSubscribedActions(ent: EntityRecord, cfg: GlobalConfig): any[] {
    return [];
}

// [CE-STRIP v2.0.0] Auto-trigger scanning always found zero candidates once
// getTagSubscribedActions became a stub (above) — the scan body is gone, callers
// (Schedule tick, travel/teleport, native toolbar) keep calling this harmlessly.
async function runAutoTriggers(): Promise<void> {
    return;
}

async function runDynamicEngine(): Promise<void> {
    // [v0.9.24 E1] Generation-based intervals replace token-based.
    // genCount is the story-persistent generation counter incremented in onGenerationEnd.
    let genCount = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;
    genCount = Number(genCount) || 0;
    if (genCount < 1) {
        api.v1.log('[AE:engine] genCount=0, skipping dynamic engine');
        return;
    }

    ae_lock = true; // [v0.9.34 LOCK1] block travel generates while background gen runs
    api.v1.log('[AE:TRACE] dynamic engine ACQUIRED ae_lock');
    const index = await loadIndex();
    const cfg   = await loadConfig();
    const raw   = await api.v1.tempStorage.get(STORAGE_LORE_IDS) as string | undefined;
    const activeEntryIds = new Set<string>(raw ? JSON.parse(raw) : []);

    // ── Retry queue ───────────────────────────────────────────────────────────
    const _retryRaw = await api.v1.tempStorage.getOrDefault(STORAGE_RETRY_CHARS, '[]') as string;
    const _retryQ: string[] = JSON.parse(_retryRaw);
    if (_retryQ.length > 0) {
        await api.v1.tempStorage.set(STORAGE_RETRY_CHARS, '[]');
        for (const entry of _retryQ) {
            if (api.v1.script.getAllowedOutput() < 220) break;
            const [_rcId, _rcType] = entry.split(':');
            const _rc = await loadCharacter(_rcId);
            if (!_rc || _rc.isProtagonist) continue;
            if (_rcType === 'eph' && _rc.autoThoughtsEnabled) {
                const _ok = await generateEphemeral(_rc, cfg, genCount).catch(function() { return false; });
                if (_ok) api.v1.ui.toast('💭 ' + _rc.name + ': thoughts updated', { type: 'info', autoClose: 2000 });
            } else if (_rcType === 'mid' && _rc.autoUpdateEnabled) {
                const _ok2 = await generateMidRange(_rc, cfg, genCount).catch(function() { return false; });
                if (_ok2) api.v1.ui.toast('🌀 ' + _rc.name + ': dynamics updated', { type: 'info', autoClose: 2000 });
            }
        }
        api.v1.log('[AE:engine] Retry queue processed.');
    }

    api.v1.log('[AE:engine] genCount=' + genCount + ', active chars=' + index.filter(function(m: any) { return m.active; }).length);

    // [vNEXT] Dynamic-priority cap. Compute the permitted id set ONCE from the index
    // (no storage reads). When a cap is set, characters outside the top-N by rank are
    // skipped this turn without touching their records — the user's manual Static
    // toggle is untouched; they simply aren't processed while over the cap.
    const _dynCap = Number((cfg as any).maxDynamicCharacters) || 0;
    const _dynAllowed = computeDynamicAllowedSet(index as any, _dynCap);
    if (_dynCap > 0) api.v1.log('[AE:engine] dynamic cap=' + _dynCap + ', allowed=' + _dynAllowed.size);

    // ── Per-character dispatch ────────────────────────────────────────────────
    for (const meta of index.filter(Boolean)) {
        if (!meta.active) continue;
        if (meta.isProtagonist) continue;
        // [v0.9.34 PERF1] Skip storage read for chars flagged static in the index
        // (propagated there by saveCharacter since v0.9.31). Avoids a DB load per
        // static character per generation end.
        if ((meta as any).isStatic) { api.v1.log('[AE:engine] Static (index), skipping: ' + meta.name); continue; }
        // [vNEXT] Enforce the dynamic cap from the index before any storage read, so
        // a capped-out character costs nothing this turn.
        if (_dynCap > 0 && !_dynAllowed.has(meta.id)) { api.v1.log('[AE:engine] Over dynamic cap, skipping: ' + meta.name); continue; }
        const char = await loadCharacter(meta.id);
        if (!char) continue;
        if ((char as any).isStatic) { api.v1.log('[AE:engine] Static, skipping: ' + char.name); continue; }

        const relevant = charIsRelevant(char, activeEntryIds);

        // NaN-safe — old saves without gen stamps default to 0 (triggers update immediately)
        const lastEph  = Number(char.lastEphemeralGen) || 0;
        const lastMid  = Number(char.lastMidrangeGen)  || 0;
        const lastArc  = Number(char.lastArcGen)       || 0;
        const lastHook = Number(char.lastHookGen)      || 0;
        const intEph   = Number(cfg.thoughtIntervalGens)  || 2;
        const intMid   = Number(cfg.dynamicIntervalGens)  || 4;
        const intArc   = Number(cfg.arcIntervalGens)      || 10;
        const intHook  = Number(cfg.hookIntervalGens)     || 6;

        api.v1.log('[AE:engine] ' + char.name
            + ' rel=' + relevant
            + ' eph=' + char.autoThoughtsEnabled + '(' + (genCount - lastEph) + '/' + intEph + 'gen)'
            + ' mid=' + char.autoUpdateEnabled + '(' + (genCount - lastMid) + '/' + intMid + 'gen)'
            + ' budget=' + api.v1.script.getAllowedOutput());

        // [v2.17.0 CHAREDIT-TABS] Toggle semantics split, backing the Dynamic Profile
        // tab's 4-button "Enabled" bar. Previously Midrange/Relationship/Hooks all
        // shared this one autoUpdateEnabled flag (Ephemeral was already independent);
        // Relationship now runs on primaryRelationship.enabled alone, and hooksEnabled
        // (declared on every CharacterRecord since day one, serialized to the bridge,
        // but never actually read by any dispatch condition here) now genuinely gates
        // Hooks. Midrange keeps autoUpdateEnabled as its sole gate.
        if (char.autoThoughtsEnabled && relevant && (genCount - lastEph) >= intEph) {
            if (api.v1.script.getAllowedOutput() >= 220) {
                const ephOk = await generateEphemeral(char, cfg, genCount).catch(function(e) { api.v1.log('[AE:engine] Eph err:', e); return false; });
                if (ephOk) api.v1.ui.toast('💭 ' + char.name + ': thoughts updated', { type: 'info', autoClose: 2000 });
            } else {
                const _rr = await api.v1.tempStorage.getOrDefault(STORAGE_RETRY_CHARS, '[]') as string;
                const _ri: string[] = JSON.parse(_rr);
                if (!_ri.includes(char.id + ':eph')) { _ri.push(char.id + ':eph'); await api.v1.tempStorage.set(STORAGE_RETRY_CHARS, JSON.stringify(_ri)); }
            }
        }
        if (char.autoUpdateEnabled && relevant && (genCount - lastMid) >= intMid) {
            if (api.v1.script.getAllowedOutput() >= 220) {
                const midOk = await generateMidRange(char, cfg, genCount).catch(function(e) { api.v1.log('[AE:engine] Mid err:', e); return false; });
                if (midOk) api.v1.ui.toast('🌀 ' + char.name + ': dynamics updated', { type: 'info', autoClose: 2000 });
            } else {
                const _rr2 = await api.v1.tempStorage.getOrDefault(STORAGE_RETRY_CHARS, '[]') as string;
                const _ri2: string[] = JSON.parse(_rr2);
                if (!_ri2.includes(char.id + ':mid')) { _ri2.push(char.id + ':mid'); await api.v1.tempStorage.set(STORAGE_RETRY_CHARS, JSON.stringify(_ri2)); }
            }
        }
        if (relevant && char.primaryRelationship?.targetName && char.primaryRelationship?.enabled && (genCount - lastArc) >= intArc) {
            if (api.v1.script.getAllowedOutput() >= 200) {
                const relOk = await generateRelationshipUpdate(char, cfg, genCount).catch(function(e) { api.v1.log('[AE:engine] Rel err:', e); return false; });
                if (relOk) api.v1.ui.toast('💞 ' + char.name + ': relationship updated', { type: 'info', autoClose: 2000 });
            }
        }
        if (char.hooksEnabled && relevant && (genCount - lastHook) >= intHook) {
            if (api.v1.script.getAllowedOutput() >= 200) {
                const hookOk = await generateHookUpdates(char, cfg, genCount).catch(function(e) { api.v1.log('[AE:engine] Hook err:', e); return false; });
                if (hookOk) api.v1.ui.toast('🎯 ' + char.name + ': hook updated', { type: 'info', autoClose: 2000 });
            }
        }
    }

    await recalculateScenePresence();
    queueSceneStateBroadcast();
    api.v1.log('[AE:TRACE] dynamic engine RELEASING ae_lock');
    ae_lock = false; // [v0.9.34 LOCK1] release after all background generates complete
}

// ============================================================================
// SECTION 16 — IMAGE PROMPT GENERATION
// Assembles image prompts for auto-snap and Director's Cut, and dispatches
// generation requests to the bridge via EVT_GENERATE_IMAGE.
//
// [CHANGE] Widget system fully removed. All functions that formerly wrote to
// KEY_PENDING and called rebuildWidgets() now call broadcastToTM(EVT_GENERATE_IMAGE, payload)
// directly. No story document writes for image generation.
//
// [CHANGE] getCharacterData() now reads from cachedCharVisuals (CharacterVisualRecord[])
// instead of cachedCharConfigs. Field names updated: c.visuals (was c.characterVisuals),
// c.sceneVisuals, c.uc (was c.characterUC). baseSceneVisuals/baseSceneUC are not tracked
// in CharacterVisualRecord — extractBaseAdditions() returns empty strings naturally.
// Nickname matching added (CharacterVisualRecord includes nicknames[]).
//
// [CHANGE] loadSettings() renamed to loadImageSettings() throughout.
//
// [CHANGE] enhanceDirectorPrompt() and submitDirectorPhoto() extracted as standalone
// pure functions with explicit parameters — no modal state or module-level director vars.
// Called from handleBridgeMessage() (Section 18) when EVT_DIRECTOR_SUBMIT arrives.
//
// NOTE FOR ASSEMBLY: Add to Section 2 Bridge Event constants:
//   const EVT_DIRECTOR_ENHANCE_RESULT = 'DIRECTOR_ENHANCE_RESULT'; // engine→bridge
// ============================================================================

// ── Character Data Lookup ─────────────────────────────────────────────────────

// [v0.9.7.6] Whole-word presence test. Substring matching caused short names
// (e.g. "Nev") to fire inside longer words ("never"). Boundary = anything that
// is not an ASCII letter/digit/underscore, or string start/end. Multi-word names
// match on their outer boundaries; internal spaces are unaffected.
function _nameAppearsAsWord(hayLower: string, needleLower: string): boolean {
    if (!needleLower) return false;
    let esc = needleLower.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    let re = new RegExp('(?:^|[^a-z0-9_])' + esc + '(?:[^a-z0-9_]|$)');
    return re.test(hayLower);
}

function getCharacterData(promptText: string): { name: string; visuals: string; uc: string; baseSceneVisuals: string; baseSceneUC: string; }[] {
    // Returns an array of matched character visual records for characters mentioned in promptText.
    // [CHANGE] Reads from cachedCharVisuals (CharacterVisualRecord[]) instead of old cachedCharConfigs.
    // [CHANGE] Added nickname matching — CharacterVisualRecord includes nicknames[].
    // [CHANGE] baseSceneVisuals and baseSceneUC always return '' — not tracked in CharacterVisualRecord.
    //          extractBaseAdditions() will return empty strings for these, which is correct behaviour:
    //          the bridge receives an empty extraBaseVisuals/extraBaseUC and generates normally.
    if (!promptText || !cachedCharVisuals.length) return [];
    const lower = promptText.toLowerCase();
    return cachedCharVisuals
        .filter(function(c) {
            if (!c.name || !c.name.trim()) return false;
            if (_nameAppearsAsWord(lower, c.name.trim().toLowerCase())) return true;
            return (c.nicknames || []).some(function(nick) {
                return nick && nick.trim() && _nameAppearsAsWord(lower, nick.trim().toLowerCase());
            });
        })
        .map(function(c) {
            return {
                name:             c.name,
                // Combine core visuals + scene-specific additions for character captions
                visuals:          [c.visuals, c.sceneVisuals].filter(Boolean).join(', '),
                uc:               c.uc || '',
                baseSceneVisuals: '', // not stored in CharacterVisualRecord
                baseSceneUC:      ''  // not stored in CharacterVisualRecord
            };
        });
}

function extractBaseAdditions(matchedChars: { baseSceneVisuals: string; baseSceneUC: string }[]): { extraBaseVisuals: string; extraBaseUC: string } {
    // Extracts base-level prompt additions (added to main fp/fu, not char captions).
    // Preserved verbatim — in the merged system these fields are always '' (see getCharacterData note),
    // so this function will always return { extraBaseVisuals: '', extraBaseUC: '' }.
    return {
        extraBaseVisuals: matchedChars.map(function(c) { return c.baseSceneVisuals; }).filter(Boolean).join(', '),
        extraBaseUC:      matchedChars.map(function(c) { return c.baseSceneUC;      }).filter(Boolean).join(', ')
    };
}

// ── Auto-Snap ─────────────────────────────────────────────────────────────────

async function getCurrentLocationPromptLine(): Promise<string> {
    // [WP-img] Returns "Location: <name> — <resolved description>" for the
    // protagonist's current location, or '' if none. Feeds the image architect so
    // generated scenes reflect where the player is. Uses the (state-resolved)
    // description, NOT locationVisuals — locationVisuals is reserved for renders
    // that are specifically about a location.
    try {
        let locId = await loadPlayerLocation();
        if (!locId) return '';
        let loc = await loadEntity(locId);
        if (!loc) return '';
        let desc = (loc.state && loc.state !== 'default' && loc.stateDescriptions && loc.stateDescriptions[loc.state])
            ? loc.stateDescriptions[loc.state]
            : (loc.description || '');
        desc = (desc || '').trim();
        if (!loc.name && !desc) return '';
        return 'Location: ' + (loc.name || '') + (desc ? ' — ' + desc : '');
    } catch (e) { api.v1.error('[AE:img] getCurrentLocationPromptLine:', e); return ''; }
}

// [v0.9.8.0] Reusable architect pass over the recent story. Reads the last
// `paragraphs` sections, detects characters (whole-word), runs the GLM architect,
// and returns the raw prompt plus the resolved character records. Shared by
// executeAutoSnap (generate now) and the AUTO_SNAP_PROMPT path (fill the Image
// Studio composer for the user to review/edit before generating).
async function buildArchitectPromptFromStory(paragraphs?: number): Promise<{ prompt: string; matchedChars: { name: string; visuals: string; uc: string; baseSceneVisuals: string; baseSceneUC: string; }[]; } | null> {
    await loadImageSettings();
    const nodeId = await api.v1.document.history.currentNodeId();
    const node   = await api.v1.document.history.nodeState(nodeId);
    if (!node || !node.sections) { api.v1.ui.toast('Error: Could not read document.'); return null; }

    const ctxSize = (typeof paragraphs === 'number' && paragraphs > 0) ? paragraphs : (globalSettings.contextSize || DEFAULT_CTX);
    let asContextText = '';
    const asStartIndex = Math.max(0, node.sections.length - ctxSize);
    for (let i = asStartIndex; i < node.sections.length; i++) {
        if (node.sections[i].section && node.sections[i].section.text) asContextText += node.sections[i].section.text + '\n';
    }

    const asMatched   = getCharacterData(asContextText);
    const asNames     = asMatched.map(function(c) { return c.name; }).join(', ');
    const asLocLine   = await getCurrentLocationPromptLine();
    const asCharCtx   = asNames ? '\n\nCharacters identified in scene: ' + asNames + '. Apply their specific visual tags.' : '';

    try {
        const asResp = await aeDiagGenerate('imgArchitect:manual',
            [
                { role: 'system', content: globalSettings.architectPrompt || DEFAULT_ARCH },
                { role: 'user',   content: 'Current Scene:\n' + asContextText.trim() + asCharCtx + (asLocLine ? '\n\n' + asLocLine : '') + '\n\nGenerate the image prompt:' }
            ],
            { model: 'glm-4-6', max_tokens: 300 }
        );
        const asPrompt = ((asResp.choices && asResp.choices[0] &&
            (asResp.choices[0].message && asResp.choices[0].message.content || asResp.choices[0].text)) || asResp.text || '').trim();
        if (!asPrompt) return null;
        return { prompt: asPrompt, matchedChars: asMatched };
    } catch (asErr) {
        api.v1.log('[AE:img] buildArchitectPromptFromStory failed:', asErr);
        return null;
    }
}

async function executeAutoSnap(): Promise<void> {
    // [CHANGE] Widget system removed. Previously wrote to KEY_PENDING + rebuildWidgets().
    //          Now broadcasts EVT_GENERATE_IMAGE directly to bridge.
    // [CHANGE] loadSettings() → loadImageSettings().
    // [CHANGE] Bridge guard added — auto-snap requires the bridge to be connected.
    api.v1.ui.toast('📸 Architect Pass: Analysing scene…');
    await loadImageSettings();

    if (!isBridgeReady) {
        api.v1.ui.toast('⚠️ Bridge not connected — auto-snap requires bridge.', { type: 'warning', autoClose: 3000 });
        return;
    }

    const nodeId = await api.v1.document.history.currentNodeId();
    const node   = await api.v1.document.history.nodeState(nodeId);
    if (!node || !node.sections) { api.v1.ui.toast('Error: Could not read document.'); return; }

    const ctxSize = globalSettings.contextSize || DEFAULT_CTX;
    let contextText = '';
    const startIndex = Math.max(0, node.sections.length - ctxSize);
    for (let i = startIndex; i < node.sections.length; i++) {
        if (node.sections[i].section && node.sections[i].section.text) contextText += node.sections[i].section.text + '\n';
    }

    const matchedChars = getCharacterData(contextText);
    const { extraBaseVisuals, extraBaseUC } = extractBaseAdditions(matchedChars);
    const charNames   = matchedChars.map(function(c) { return c.name; }).join(', ');
    const locLine     = await getCurrentLocationPromptLine();
    const charContext = charNames ? '\n\nCharacters identified in scene: ' + charNames + '. Apply their specific visual tags.' : '';

    try {
        const response = await aeDiagGenerate('imgArchitect:autosnap',
            [
                { role: 'system', content: globalSettings.architectPrompt || DEFAULT_ARCH },
                { role: 'user',   content: 'Current Scene:\n' + contextText.trim() + charContext + (locLine ? '\n\n' + locLine : '') + '\n\nGenerate the image prompt:' }
            ],
            { model: 'glm-4-6', max_tokens: 300 }
        );
        const rawPrompt = ((response.choices && response.choices[0] &&
            (response.choices[0].message && response.choices[0].message.content || response.choices[0].text)) || response.text || '').trim();
        if (!rawPrompt) throw new Error('GLM returned an empty prompt.');

        const compiled = compileActiveImageFields();
        await broadcastToTM(EVT_GENERATE_IMAGE, {
            uuid:             api.v1.uuid(),
            prompt:           rawPrompt,
            characters:       matchedChars.map(function(c) { return { name: c.name, visuals: c.visuals, uc: c.uc }; }),
            extraBaseVisuals: extraBaseVisuals,
            extraBaseUC:      extraBaseUC,
            settings: {
                width:    globalSettings.defaultWidth,
                height:   globalSettings.defaultHeight,
                steps:    Math.min(globalSettings.defaultSteps || 28, 28),
                scale:    globalSettings.defaultScale || 5.0,
                quality:  compiled.quality,
                negative: compiled.negative
            },
            autoDownload: globalSettings.autoDownload
        });
        api.v1.ui.toast('📸 Auto-Snap complete! Image generating in bridge…');
    } catch (err) {
        api.v1.ui.toast('Architect Error: ' + ((err as any).message || String(err)));
    }
}

// ── Director's Cut — Enhance & Submit ─────────────────────────────────────────

async function enhanceDirectorPrompt(
    prompt: string,
    chars: { name: string; visuals: string; uc?: string }[]
): Promise<{ enhancedPrompt: string; charVisuals: { name: string; visuals: string }[] } | null> {
    // [CHANGE] Extracted as pure function with explicit parameters.
    //          Old version mutated module-level state (currentDirectorPrompt, char1Vis_in, etc.)
    //          and called renderModal(). New version returns the enhanced data as a value
    //          so the caller (handleBridgeMessage / EVT_DIRECTOR_SUBMIT) can broadcast it back.
    // [v2.13.0 IMGFIELDS] Generalized from hardcoded char1/char2 (2-slot) to up to 4
    // characters, matching the new click-to-add picker's cap. No more fuzzy
    // getCharacterData(name) lookup here -- the bridge's picker already resolved
    // c.visuals from its own synced character cache before the user could edit it
    // (and per user's call, those edits are one-off, never written back), so
    // c.visuals IS the "known visuals" context; nothing left to re-look-up by name.
    if (!prompt.trim()) return null;

    const capped = (chars || []).slice(0, 4);
    const locLine = await getCurrentLocationPromptLine();

    const charContextLines: string[] = capped.map(function(c, i) {
        const label = 'Character ' + (i + 1) + (c.name && c.name.trim() ? ' (' + c.name.trim() + ')' : ' (unnamed)');
        return c.visuals && c.visuals.trim()
            ? '\n' + label + ': Known visuals are "' + c.visuals.trim() + '". Enhance and adapt for the scene.'
            : '\n' + label + ': No known visuals. Generate appropriate tags.';
    });

    const sysPrompt = 'You are an uncompromising art director. Output ONLY a valid JSON object, no markdown:\n{\n  "enhanced_prompt": "5-10 core tags + 1-2 sentences of observational prose. No quality tags or negative weights.",\n  "char_visuals": ["Tags for character 1 if present, else empty string", "...character 2...", "...character 3...", "...character 4..."]\n}\nThe char_visuals array must have exactly ' + capped.length + ' entries, in the same order as the characters listed below.';

    try {
        const response = await aeDiagGenerate('imgDirectorEnhance',
            [
                { role: 'system', content: sysPrompt },
                { role: 'user',   content: 'Rough Concept: ' + prompt + charContextLines.join('') + (locLine ? '\n' + locLine : '') + '\n\nOutput the JSON:' }
            ],
            { model: 'glm-4-6', max_tokens: 350, temperature: 0.7 }
        );
        let rawOutput = ((response.choices && response.choices[0] &&
            (response.choices[0].message && response.choices[0].message.content || response.choices[0].text)) || response.text || '').trim();
        const jsonMatch = rawOutput.match(/\{[\s\S]*\}/);
        if (!jsonMatch) throw new Error('No JSON block found in architect response.');
        const parsed = JSON.parse(jsonMatch[0]);
        const cv: string[] = Array.isArray(parsed.char_visuals) ? parsed.char_visuals : [];

        const enhancedChars = capped.map(function(c, i) {
            return { name: c.name, visuals: (cv[i] && String(cv[i]).trim()) ? String(cv[i]).trim() : c.visuals };
        });

        return {
            enhancedPrompt: parsed.enhanced_prompt || prompt,
            charVisuals:    enhancedChars
        };
    } catch (err) {
        api.v1.log('[AE:img] enhanceDirectorPrompt failed:', err);
        return null;
    }
}

async function submitDirectorPhoto(
    prompt: string,
    uc: string,
    chars: { name: string; visuals: string; uc?: string }[]
): Promise<void> {
    // [CHANGE] Extracted as pure function with explicit parameters.
    //          Old version read module-level state (currentDirectorPrompt, char1Name_in, etc.)
    //          and wrote to KEY_PENDING + rebuildWidgets().
    //          New version takes all data from parameters and broadcasts EVT_GENERATE_IMAGE.
    // [CHANGE] Bridge guard added.
    // [v2.13.0 IMGFIELDS] No more fuzzy getCharacterData(name) re-resolution here —
    // the bridge's click-to-add picker already resolved {name, visuals, uc} from its
    // own synced character cache (or left them blank for a one-off unnamed slot) and
    // the user could edit any of it; those edits are one-off, per user's call, never
    // written back to the character record, so what the bridge sends IS final. Cap
    // raised from 2 to 4 (matching the picker's own cap). A blank/unnamed slot is a
    // legitimate one-off figure now — no longer filtered out for lacking a name.
    const rawPrompt = prompt.trim();
    if (!rawPrompt) return;

    if (!isBridgeReady) {
        api.v1.ui.toast('⚠️ Bridge not connected — Director\'s Cut requires bridge.', { type: 'warning', autoClose: 3000 });
        return;
    }

    const compiled = compileActiveImageFields();
    const finalUC = uc || compiled.negative;

    const cappedChars: { name: string; visuals: string; uc: string }[] = (chars || []).slice(0, 4).map(function(c) {
        return { name: c.name || '', visuals: c.visuals || '', uc: c.uc || '' };
    }).filter(function(c) { return c.name.trim() || c.visuals.trim() || c.uc.trim(); });

    await broadcastToTM(EVT_GENERATE_IMAGE, {
        uuid:             api.v1.uuid(),
        prompt:           rawPrompt,
        characters:       cappedChars,
        extraBaseVisuals: '',
        extraBaseUC:      '',
        settings: {
            width:    globalSettings.defaultWidth,
            height:   globalSettings.defaultHeight,
            steps:    Math.min(globalSettings.defaultSteps || 28, 28),
            scale:    globalSettings.defaultScale || 5.0,
            quality:  compiled.quality,
            negative: finalUC
        },
        autoDownload: globalSettings.autoDownload
    });
    api.v1.ui.toast('📸 Manual Snap dispatched!');
}


// ---- Snapshot Image (callable: button or future actions) -------------------
// Reads the stored GLM appearance snapshot for charId, resolves the character's
// cached visuals and any location visuals, and broadcasts a tagged
// EVT_GENERATE_IMAGE { entityId, kind:'snapshot' } so the bridge can land the
// result in the snapshot gallery section and the entity's top pane.
async function assembleSnapshotImage(charId: string): Promise<void> {
    try {
        if (!isBridgeReady) {
            api.v1.ui.toast('Bridge not connected - image generation requires bridge.', { type: 'warning', autoClose: 3000 });
            return;
        }
        let aChar = await loadCharacter(charId);
        if (!aChar) { api.v1.log('[AE:img] assembleSnapshotImage: char not found'); return; }
        let aEntId = (aChar as any).entityId || null;
        let aEnt = aEntId ? await loadEntity(aEntId) : null;
        let snapText = await api.v1.storyStorage.getOrDefault(STORAGE_CHAR_SNAP_PFX + charId, '') as string;
        if (!snapText) {
            api.v1.ui.toast('Generate a text snapshot first.', { type: 'warning', autoClose: 3000 });
            return;
        }
        let locVisuals = '';
        if (aEnt && aEnt.parentId) {
            let aLoc = await loadEntity(aEnt.parentId);
            if (aLoc && (aLoc as any).visuals) locVisuals = String((aLoc as any).visuals);
        }
        let basePrompt = [snapText, locVisuals].filter(Boolean).join(', ');
        let found = getCharacterData(aChar.name);
        let charVisuals = found.length ? found[0].visuals : '';
        let charUC = found.length ? found[0].uc : '';
        let compiled = compileActiveImageFields();
        await broadcastToTM(EVT_GENERATE_IMAGE, {
            uuid:             api.v1.uuid(),
            prompt:           basePrompt,
            characters:       charVisuals ? [{ name: aChar.name, visuals: charVisuals, uc: charUC }] : [],
            extraBaseVisuals: '',
            extraBaseUC:      '',
            charId:           aChar.id,
            entityId:         aEntId,
            kind:             'snapshot',
            settings: {
                width:    globalSettings.defaultWidth,
                height:   globalSettings.defaultHeight,
                steps:    Math.min(globalSettings.defaultSteps || 28, 28),
                scale:    globalSettings.defaultScale || 5.0,
                quality:  compiled.quality,
                negative: compiled.negative
            },
            autoDownload: globalSettings.autoDownload
        });
        api.v1.ui.toast('Generating snapshot image for ' + aChar.name + '...', { type: 'info', autoClose: 2500 });
    } catch (snapImgGenErr) {
        api.v1.error('[AE:img] assembleSnapshotImage:', snapImgGenErr);
    }
}

// [CE-STRIP v2.0.0] aeGenerateActionImage removed — action-triggered image gen
// (the 'generate_image' effect type) was only reachable through the Actions
// effects pipeline, which is gone. Auto-Snap, Snapshot, and Director's Cut image
// generation are separate paths and are untouched.


// ============================================================================
// SECTION 18 — BRIDGE MESSAGING LAYER
// All communication between the engine (Web Worker) and bridge (Tampermonkey
// page-context script). Engine→Bridge via api.v1.messaging.broadcast().
// Bridge→Engine via the onMessage listener registered in initMessaging().
//
// Broadcast functions queue and debounce to avoid redundant round-trips when
// multiple storage writes fire in rapid succession (e.g., during runDynamicEngine).
//
// buildSceneStatePayload() is the most complex new function. It loads the
// protagonist's location + one-hop entity graph and packages the data the bridge
// needs to render the Scene HUD. Capped to one-hop range for performance (<200ms).
//
// handleBridgeMessage() is the inbound message router. New event handlers:
//   EVT_DIRECTOR_SUBMIT — bridge submitted Director's Cut (enhance or generate)
//   EVT_REQ_SCENE_STATE — bridge requests immediate SCENE_STATE_UPDATE push
//   EVT_REQ_CHAR_DATA   — bridge requests immediate CHARACTER_DATA_SYNC push
// On EVT_HANDSHAKE_ACK: immediately push char data then scene state, then AE_IMG_FIELDS_SYNC.
// ============================================================================

// ── Broadcast Primitives ──────────────────────────────────────────────────────

// openEngineModal — wraps api.v1.ui.modal.open to signal the bridge.
// Bridge adds ae-behind-modal class (display:none) on OPENED and removes on CLOSED.
// Use this instead of api.v1.ui.modal.open directly throughout the engine.
async function openEngineModal(opts: any): Promise<any> {
    // [FIX] Was calling openEngineModal(opts) recursively — infinite recursion.
    // Corrected to call api.v1.ui.modal.open(opts) which is the actual NAI API.
    broadcastToTM('AE_MODAL_OPENED', {}).catch(function() {});
    let handle: any;
    try {
        handle = await api.v1.ui.modal.open(opts);
    } catch (modalErr) {
        broadcastToTM('AE_MODAL_CLOSED', {}).catch(function() {});
        throw modalErr;
    }
    if (handle && handle.closed) {
        handle.closed.then(function() {
            broadcastToTM('AE_MODAL_CLOSED', {}).catch(function() {});
        });
    }
    return handle;
}

// ============================================================================
// UNIFIED PICKER  —  openPickerModal<T>()
//
// One modal for every "pick one item from a list" selection. Replaces the
// scattered bespoke pickers (parent, entity, resource, skill, lorebook tag, ...)
// so that search, item rendering, and selected-highlighting are consistent and
// changing them all is a one-place edit. Migrate inline pickers onto this as
// they are touched (look for leftover drawSearchablePicker / openEngineModal
// list pickers).
//
// Items render as full-width buttons: "<icon> <label>  ·  <sublabel>".
// A search box appears automatically for lists > 8 (force with searchable:true).
// The picker closes itself first, THEN runs onSelect — matching the prior
// close-then-act pattern so a reopened parent modal never stacks under it.
//
//   await openPickerModal({
//       title:       'Nest Under Entity',
//       items:       allNodes,
//       getId:       function(m) { return m.id; },
//       getLabel:    function(m) { return m.name; },
//       getIcon:     function(m) { return m.icon || '\ud83d\udccd'; },  // optional
//       getSublabel: function(m) { return m.type; },                       // optional
//       selectedId:  ent.parentId || undefined,                            // optional highlight
//       searchable:  true,                                                 // optional
//       pinnedOptions: [{ id: '__none__', label: 'None', icon: '\u2715',
//                         onSelect: function() { ... } }],                 // optional, unfiltered, on top
//       onSelect:    function(item) { ... }                               // required
//   });
// ============================================================================
interface PickerPinnedOption { id: string; label: string; icon?: string; sublabel?: string; onSelect: () => void | Promise<void>; }
interface PickerConfig {
    title: string;
    items: any[];
    getId: (item: any) => string;
    getLabel: (item: any) => string;
    getIcon?: (item: any) => string | undefined;
    getSublabel?: (item: any) => string | undefined;
    selectedId?: string;
    searchable?: boolean;
    pinnedOptions?: PickerPinnedOption[];
    onSelect: (item: any) => void | Promise<void>;
    size?: string;
    emptyText?: string;
}

async function openPickerModal(cfg: PickerConfig): Promise<void> {
    let handle: any = null;
    let term = '';
    const forceSearch = cfg.searchable === true;
    const allowSearch = cfg.searchable !== false && (forceSearch || cfg.items.length > 8);
    const pickerSize  = cfg.size || 'medium';

    // Close the picker first, then run the caller's handler. This mirrors the
    // prior bespoke order (pm.close() then reopen parent modal) so a modal a
    // handler opens never ends up stacked beneath the (still-open) picker.
    function closingCallback(fn: () => void | Promise<void>) {
        return async function() {
            try { if (handle && !handle.isClosed()) await handle.close(); } catch (e0) {}
            try { await fn(); } catch (e) { api.v1.error('[AE:picker] select handler:', e); }
        };
    }

    function itemButton(label: string, selected: boolean, fn: () => void | Promise<void>): UIPart {
        return {
            type: 'button',
            text: label,
            style: {
                width: '100%', marginBottom: '2px', textAlign: 'left', fontSize: '12px',
                backgroundColor: selected ? 'rgba(126,200,160,0.2)' : 'rgba(255,255,255,0.04)',
                border: selected ? '1px solid rgba(126,200,160,0.4)' : '1px solid rgba(255,255,255,0.08)'
            },
            callback: closingCallback(fn)
        };
    }

    function buildContent(): UIPart[] {
        const parts: UIPart[] = [];
        if (allowSearch) {
            parts.push({ type: 'textInput', placeholder: '\ud83d\udd0d Search\u2026', initialValue: term, onChange: async function(v: string) { term = v; await render(); } });
        }
        if (cfg.pinnedOptions && cfg.pinnedOptions.length > 0) {
            for (const po of cfg.pinnedOptions) {
                parts.push(itemButton(aeIconPfx(po.icon) + po.label + (po.sublabel ? '  \u00b7  ' + po.sublabel : ''), false, po.onSelect));
            }
        }
        const needle = term.trim().toLowerCase();
        const filtered = (!allowSearch || needle === '') ? cfg.items : cfg.items.filter(function(it) {
            const lbl = cfg.getLabel(it).toLowerCase();
            const sub = cfg.getSublabel ? (cfg.getSublabel(it) || '').toLowerCase() : '';
            return lbl.indexOf(needle) >= 0 || sub.indexOf(needle) >= 0;
        });
        if ((cfg.pinnedOptions && cfg.pinnedOptions.length > 0) && filtered.length > 0) {
            parts.push({ type: 'text', text: '\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500', style: { opacity: '0.2', fontSize: '10px', textAlign: 'center', marginTop: '4px', marginBottom: '4px' } });
        }
        for (const it of filtered) {
            const itemId = cfg.getId(it);
            const icon = cfg.getIcon ? cfg.getIcon(it) : undefined;
            const sub  = cfg.getSublabel ? cfg.getSublabel(it) : undefined;
            const label = aeIconPfx(icon) + cfg.getLabel(it) + (sub ? '  \u00b7  ' + sub : '');
            const isSel = cfg.selectedId !== undefined && itemId === cfg.selectedId;
            parts.push(itemButton(label, isSel, (function(captured) { return function() { return cfg.onSelect(captured); }; })(it)));
        }
        if (filtered.length === 0) {
            parts.push({ type: 'text', text: cfg.emptyText || 'No matches.', style: { opacity: '0.5', fontSize: '11px', padding: '8px', textAlign: 'center' } });
        }
        return parts;
    }

    async function render() {
        const content = buildContent();
        try {
            if (handle && !handle.isClosed()) { await handle.update({ content: content }); return; }
        } catch (e) { /* handle stale — fall through and (re)open */ }
        handle = await openEngineModal({ id: 'ae-unified-picker', title: cfg.title, size: pickerSize, content: content });
    }

    await render();
}

async function broadcastToTM(event: string, data?: Record<string, any>): Promise<void> {
    // Preserved verbatim from AI engine.
    data = data || {};
    try {
        await api.v1.messaging.broadcast(
            { type: 'MESSAGE', sid: api.v1.script.id, payload: Object.assign({ event: event }, data) },
            'hypebot'
        );
    } catch (e) {
        api.v1.log('[AE:bridge] broadcastToTM failed:', e);
    }
}

// ── Character Data Broadcast ──────────────────────────────────────────────────

async function buildCharacterDataPayload(): Promise<CharacterVisualRecord[]> {
    // Reads all active characters and packages their visual + persona fields into
    // CharacterVisualRecord[]. Also updates cachedCharVisuals in-memory so
    // getCharacterData() stays current without a round-trip on the next call.
    try {
        const chars = await loadAllCharacters();
        const result: CharacterVisualRecord[] = chars
            .filter(function(c) { return c.active !== false; })
            .map(function(c): CharacterVisualRecord {
                return {
                    id:                  c.id,
                    name:                c.name,
                    nicknames:           c.nicknames           || [],
                    visuals:             c.visuals             || '',
                    uc:                  c.uc                  || '',
                    sceneVisuals:        c.sceneVisuals        || '',
                    avatarVisuals:       c.avatarVisuals       || '',
                    avatarWidth:         c.avatarWidth         || 832,
                    avatarHeight:        c.avatarHeight        || 1216,
                    avatarSeed:          c.avatarSeed          || 0,
                    species:             c.species             || '',
                    age:                 c.age                 || '',
                    gender:              c.gender              || '',
                    briefDescription:    c.briefDescription    || '',
                    physicalDescription: c.physicalDescription || '',
                    personalityCore:     c.personalityCore     || '',
                    voiceAndMannerisms:  c.voiceAndMannerisms  || '',
                    background:          c.background          || ''
                };
            });
        cachedCharVisuals = result; // keep in-memory cache current
        return result;
    } catch (e) {
        api.v1.log('[AE:bridge] buildCharacterDataPayload error:', e);
        return [];
    }
}

// [v0.9.36] Single choke-point for ALL editor generations. The trace showed a
// second editor.generate() (from an auto-trigger / chain effect) racing the one in
// commitTravel, which NAI rejects with 'editor is currently blocked'. This guard
// allows exactly one in-flight generation; concurrent or lock-held requests are
// suppressed (the loser of the old race produced no output anyway), and a blocked
// error is swallowed rather than surfaced. ae_genInFlight is cleared in onGenerationEnd.
async function aeEditorGenerate(tag: string): Promise<void> {
    if (ae_genInFlight || ae_lock) {
        api.v1.log('[AE:gen] suppressed generate (' + tag + ') inFlight=' + ae_genInFlight + ' lock=' + ae_lock);
        return;
    }
    ae_genInFlight = true;
    try {
        await api.v1.editor.generate();
    } catch (gErr) {
        let gMsg = (gErr && (gErr as any).message) ? String((gErr as any).message) : '';
        if (gMsg.indexOf('blocked') >= 0) { api.v1.log('[AE:gen] editor blocked, suppressed (' + tag + ')'); }
        else { api.v1.log('[AE:gen] generate error (' + tag + '):', gErr); }
        ae_genInFlight = false;   // kickoff failed — release so we never deadlock
    }
}

async function broadcastCharacterData(): Promise<void> {
    if (!isBridgeReady) return;
    try {
        const payload = await buildCharacterDataPayload();
        await broadcastToTM(EVT_CHAR_DATA_SYNC, { characters: payload });
        api.v1.log('[AE:bridge] Character data synced:', payload.length, 'characters.');
    } catch (e) {
        api.v1.log('[AE:bridge] broadcastCharacterData error:', e);
    }
}

function queueCharacterDataBroadcast(): void {
    // [v0.9.36] Serialize + coalesce (same rationale as queueSceneStateBroadcast).
    // commitTravel's scene-presence loop saves several characters in a row, each of
    // which queued a broadcast; this collapses them into one.
    if (!isBridgeReady) return;
    if (ae_cdbInFlight) { ae_cdbPending = true; return; }
    ae_cdbInFlight = true;
    broadcastCharacterData()
        .catch(function(e) { api.v1.log('[AE:bridge] charData broadcast err:', e); })
        .then(function() {
            ae_cdbInFlight = false;
            if (ae_cdbPending) { ae_cdbPending = false; queueCharacterDataBroadcast(); }
        });
}

// ── Scene State Broadcast ─────────────────────────────────────────────────────

// [v0.9.9.2] Summarise one time condition for a calendar marker. Returns null for
// non-time conditions. Equality placement hints only fire for the '==' operator.
function aeTimeCondSummary(rule: any): { summary: string; dayOfWeek?: number; dayOfCycle?: number; absoluteDay?: number; band?: string } | null {
    let a = (rule && rule.args) ? rule.args : {};
    let t = rule ? rule.type : '';
    if (t === 'time_between') return { summary: 'between ' + (Number(a.startHour) || 0) + ':00 and ' + (Number(a.endHour) || 0) + ':00' };
    if (t === 'time_band_is') return { summary: 'during ' + (a.band || '?'), band: a.band ? String(a.band) : undefined };
    if (t === 'day_of_cycle_is') return { summary: 'cycle day ' + String(a.op || '==') + ' ' + (Number(a.day) || 0), dayOfCycle: (String(a.op || '==') === '==' ? (Number(a.day) || 0) : undefined) };
    if (t === 'day_of_week_is') return { summary: 'on weekday ' + (Number(a.dayOfWeek) || 0), dayOfWeek: (Number(a.dayOfWeek) || 0) };
    if (t === 'date_is') return { summary: 'absolute day ' + String(a.op || '==') + ' ' + (Number(a.day) || 0), absoluteDay: (String(a.op || '==') === '==' ? (Number(a.day) || 0) : undefined) };
    return null;
}

// [v0.9.9.2] Scan library templates (cheap, in-memory) for time conditions so the
// calendar can mark actions tied to times. One entry per template; the first time
// condition found provides the placement hint, the summary lists them all.

// [v1.13.3] Extracted from buildSceneStatePayload so the clock is readable without a
// resolved player location/protagonist. buildSceneStatePayload (and therefore
// getSceneState()) returns null on a fresh scenario before any location is set — that's a
// location precondition, not a clock precondition. openCalendarModal was piggybacking on the
// full scene-state payload just to reach `.clock`, which meant the calendar reported "no clock"
// on every brand-new scenario even though loadClock() itself has always been location-independent
// (it seeds from cfg.timeStartHours).

async function buildSceneStatePayload(): Promise<SceneStatePayload | null> {
    // Assembles the full HUD payload. Reads the current camera location, present
    // characters, party resources, and one-hop entity actions. Capped to one hop for
    // performance. Calls evaluateFieldCondition (Section 19) — forward reference, safe
    // at runtime.
    try {

        // 2. Current location entity — the camera. [v2.31.0 ROOT-LOCATION-HUD, per
        // user: "the HUD still shows No scene state available"] FIXES a gap v2.30.0
        // left: loadPlayerLocation() was fixed to return AE_ROOT_LOCATION_ID instead
        // of null when no location exists, but this function still did
        // loadEntity(locId) unconditionally right after — and the root sentinel is
        // DELIBERATELY not a real entity (see its own comment), so that load always
        // returned undefined and this function still bailed to null every time,
        // reproducing the exact same "No scene state available" the v2.30.0 patch was
        // meant to fix. This was the actual gap, not a regression in the sentinel
        // logic itself, which was and is correct — recalculateScenePresence's
        // cRoom===camRoom match already works fine with it.
        // FIX: when locId IS the root sentinel, skip loadEntity entirely and
        // synthesize a minimal stand-in with the fields this function actually reads
        // (name/description/state/parentId) — a location-less world's "scene" is just
        // "wherever everyone's unplaced bodies already are," so this describes that
        // literally rather than pretending a real location exists.
        const locId  = await loadPlayerLocation();
        if (!locId) return null;
        let locEnt: any;
        if (locId === AE_ROOT_LOCATION_ID) {
            locEnt = { id: AE_ROOT_LOCATION_ID, name: 'Unplaced', description: 'No location has been created yet.', stateDescriptions: {}, state: 'default', parentId: null, type: 'location' };
        } else {
            locEnt = await loadEntity(locId);
            if (!locEnt) return null;
        }
        api.v1.log('[AE:TRACE] buildSceneState cameraLoc=' + locEnt.name + '(' + locId + ')');

        // 3. Resolve state-dependent description
        const locDesc = (locEnt.stateDescriptions && locEnt.stateDescriptions[locEnt.state])
            || locEnt.description || '';

        // 4. Present characters → SceneCharacterInfo[]. [CE-STRIP vNEXT] No longer
        // force-includes the protagonist via an isProtagonist OR-clause — presence is
        // now purely "co-located with the camera" (recalculateScenePresence), same rule
        // for everyone, protagonist included.
        const allChars = await loadAllCharacters();
        const presentCharacters: SceneCharacterInfo[] = allChars
            .filter(function(c) { return c.scenePresent; })
            .map(function(c): SceneCharacterInfo {
                return {
                    id:              c.id,
                    name:            c.name,
                    entityId:        c.entityId || '',
                    briefDescription: c.briefDescription || '',
                    socialMask:      (c.midRange && c.midRange.socialMask) || '',
                    compressedLine:  (c.ephemeral && c.ephemeral.compressedLine) || '',
                    isProtagonist:   !!c.isProtagonist
                };
            });

        // [CE-STRIP v2.0.0] Action scope / available actions / available ActionInstances /
        // follow-state annotation removed — Actions system cut. allEntityMeta is still
        // needed below by the (simplified, awareness-only) location graph.
        const allEntityMeta = await loadEntityIndex();

        // 8. Location graph — parent (up), children (down), explicit connections (side)
        // [FIX Bug3] Added currentIcon + parentIcon so bridge can render entity icons on map nodes.
        // [CE-STRIP v2.0.0] Travel-cost annotations (resourceTag/resourceCost/resourceIcon/
        // timeCost/gated/requiresVehicle) removed — this is now awareness/adjacency only.
        const locationGraph = {
            currentName:    locEnt.name,
            currentType:    'location',
            currentIcon:    (locEnt as any).icon || undefined,
            parentId:    locEnt.parentId || null,
            parentName:  '',
            parentType:  '',
            parentIcon:  undefined as string | undefined,
            children:    [] as { id: string; name: string; type: string; hasChildren: boolean; icon?: string; }[],
            connections: [] as { id: string; name: string; label: string; oneWay: boolean; icon?: string; }[],
            siblings:    [] as { id: string; name: string; type: string; icon?: string; }[]
        };

        if (locEnt.parentId) {
            const parentMeta = allEntityMeta.find(function(m) { return m.id === locEnt.parentId; });
            if (parentMeta) { locationGraph.parentName = parentMeta.name; locationGraph.parentType = parentMeta.type; locationGraph.parentIcon = (parentMeta as any).icon || undefined; }
        }
        for (const childMeta of allEntityMeta) {
            if (childMeta.parentId === locId && childMeta.type === 'location') {
                const lgHasGrandchildren = allEntityMeta.some(function(m) { return m.parentId === childMeta.id && m.type === 'location'; });
                locationGraph.children.push({
                    id: childMeta.id, name: childMeta.name, type: childMeta.type,
                    hasChildren: lgHasGrandchildren, icon: childMeta.icon || undefined
                });
            }
        }
        for (const lgConn of (locEnt.connectedEntityIds || [])) {
            const lgConnMeta = allEntityMeta.find(function(m) { return m.id === lgConn.targetId; });
            if (lgConnMeta) {
                locationGraph.connections.push({
                    id: lgConn.targetId, name: lgConnMeta.name,
                    label: (lgConn as any).label || '', oneWay: (lgConn as any).oneWay || false,
                    icon: lgConnMeta.icon || undefined
                });
            }
        }

        // [v0.9.81] Lateral siblings: location-type entities sharing this location's parentId
        // (null parentId = shared world root, so top-level locations are mutually reachable).
        // [CE-STRIP v2.0.0] awareness only — no travel cost.
        for (const sibMeta of allEntityMeta) {
            if (sibMeta.type !== 'location' || sibMeta.id === locId) continue;
            if (sibMeta.parentId !== locEnt.parentId) continue;
            locationGraph.siblings.push({
                id: sibMeta.id, name: sibMeta.name, type: sibMeta.type,
                icon: sibMeta.icon || undefined
            });
        }

        // 8b. Present items — item-type entities whose parent is the current location
        const presentItems = allEntityMeta
            .filter(function(m) { return m.type === 'item' && m.parentId === locId; })
            .map(function(m) { return { id: m.id, name: m.name, icon: (m as any).icon || undefined }; });

        const cfg = await loadConfig();

        return {
            locationId:           locId,
            locationName:         locEnt.name,
            locationState:        locEnt.state || 'default',
            presentCharacters:    presentCharacters,
            locationGraph:        locationGraph,
            presentItems:         presentItems,
            // [CE-STRIP v2.1.x] presentMinorNpcs removed — minor-NPC tier retired, everyone is a normal character now.
            // [CE-STRIP v2.1.6] npcArchetypes/itemArchetypes removed from scene payload — Bestiary + Item Templates cut.
            defaultBgUrl:         (cfg as any).defaultBackgroundUrl || ''
        };
    } catch (e) {
        api.v1.log('[AE:bridge] buildSceneStatePayload error:', e);
        return null;
    }
}

// [v0.9.8.6] Stable entry point for renderers (native HUD modals) to read scene
// state, decoupling them from buildSceneStatePayload's name. Pass-through for now;
// a cache with verb-driven invalidation can be layered here once modals consume it.
async function getSceneState(): Promise<SceneStatePayload | null> {
    return await buildSceneStatePayload();
}

async function broadcastSceneState(): Promise<void> {
    if (!isBridgeReady) return;
    try {
        const payload = await buildSceneStatePayload();
        if (payload) await broadcastToTM(EVT_SCENE_STATE, payload);
    } catch (e) {
        api.v1.log('[AE:bridge] broadcastSceneState error:', e);
    }
}

function queueSceneStateBroadcast(): void {
    // [v0.9.36] Serialize + coalesce. The previous fire-and-forget spawned a fresh
    // broadcastSceneState() on every call; during commitTravel that meant ~5 CONCURRENT
    // payload builds, each calling loadPlayerLocation() at a different instant, so a
    // stale 'old room' payload could land after the fresh one -> visible flicker/flap.
    // Now at most one runs at a time; requests during a run collapse into a single
    // follow-up that reflects the final settled state.
    if (!isBridgeReady) return;
    if (ae_sbcInFlight) { ae_sbcPending = true; return; }
    ae_sbcInFlight = true;
    broadcastSceneState()
        .catch(function(e) { api.v1.log('[AE:bridge] sceneState broadcast err:', e); })
        .then(function() {
            ae_sbcInFlight = false;
            if (ae_sbcPending) { ae_sbcPending = false; queueSceneStateBroadcast(); }
        });
}

// ── Messaging Init ────────────────────────────────────────────────────────────

async function initMessaging(): Promise<void> {
    // [v0.9.29 HSK1] onMessage registration is awaited so the handler is in place
    // before onScriptsLoaded continues (fast ACKs won't be missed).
    // The handshake itself is then retried in a detached loop so story init is not
    // blocked if the bridge proxy installed after our worker was constructed.
    try {
        await api.v1.messaging.onMessage(handleBridgeMessage);
    } catch (e) {
        api.v1.log('[AE:bridge] initMessaging onMessage error:', e);
        return;
    }

    // Fire-and-forget retry loop. Sends the full handshake sequence (IN + OUT + REQ)
    // every 1.5 s until the bridge ACKs (isBridgeReady) or 20 attempts are exhausted.
    // Using an anonymous IIFE avoids the named-async-in-sync-body NAI sandbox constraint.
    (async function() {
        let _hsAttempts = 0;
        while (!isBridgeReady && _hsAttempts < 20) {
            try {
                await api.v1.messaging.broadcast(
                    { type: 'HANDSHAKE', sid: api.v1.script.id, payload: { handshake: 'NAI_SCRIPT:IN' } }
                );
                await api.v1.messaging.broadcast(
                    { type: 'HANDSHAKE', sid: api.v1.script.id, payload: { handshake: 'NAI_SCRIPT:OUT' } }
                );
                await broadcastToTM(EVT_HANDSHAKE_REQ, { scriptId: api.v1.script.id });
            } catch (e2) {
                api.v1.log('[AE:bridge] handshake attempt', _hsAttempts, 'error:', e2);
            }
            _hsAttempts++;
            if (isBridgeReady) break;
            api.v1.log('[AE:bridge] Handshake attempt', _hsAttempts, '— waiting for ACK…');
            await api.v1.timers.sleep(1500);
        }
        if (isBridgeReady) {
            api.v1.log('[AE:bridge] Bridge connected after', _hsAttempts, 'attempt(s).');
        } else {
            api.v1.log('[AE:bridge] Bridge did not ACK after', _hsAttempts, 'attempts. Running engine-only.');
        }
    })().catch(function(e3) { api.v1.log('[AE:bridge] initMessaging loop error:', e3); });
}

async function buildEntityDetailPayload(fId: string, char: any, ent: any): Promise<any> {
    const detailPayload: any = {
        id: fId,
        name: char ? char.name : (ent ? ent.name : 'Unknown'),
        type: char ? 'character' : (ent ? ent.type : 'location'),
        compiledThought: char && char.ephemeral ? char.ephemeral.compressedLine : '',
        hooks: char ? (char.hooks || []).filter((h: any) => !h.resolved) : [],
        isEquipped: ent ? !!ent.isEquipped : false,
        equippedToCharId: ent ? ent.equippedToCharId : undefined,
        isProtagonist: !!(char && char.isProtagonist)
    };

    // [v0.9.88] For item entities, resolve the character record ID whose entity body
    // is the item's parent. AE_EQUIP_ITEM requires a character record ID (not an entity ID),
    // so we expose it as ownerCharId. equippedToCharId covers the "currently equipped to"
    // case; ownerCharId covers "which character owns / carries this item" (same as unequip).
    if (ent && ent.type === 'item' && ent.parentId) {
        const _itemAllChars = await loadAllCharacters();
        const _itemOwner = _itemAllChars.find(function(c: any) { return c.entityId === ent.parentId; });
        detailPayload.ownerCharId = _itemOwner ? _itemOwner.id : undefined;
        detailPayload.parentId = ent.parentId; // expose raw entity parentId too for reference
    }

    const targetParentId = char ? char.entityId : (ent ? ent.id : null);
    const entIdx = await loadEntityIndex();
    // [v0.9.32 FOLLOW3] Compute isFollowing: char entity parented under protagonist body.
    if (char && char.entityId && ent) {
        const _fdAllChars = await loadAllCharacters();
        const _fdProtag = _fdAllChars.find(function(c) { return !!c.isProtagonist; });
        detailPayload.isFollowing = !!(ent && _fdProtag && _fdProtag.entityId && ent.parentId === _fdProtag.entityId);
    }
    const children = [];
    if (targetParentId) {
        // [v0.9.9.7] Narrative children carry storyState/isTracked/questTargetName/
        // eventDayTarget so any list that renders a character's or location's
        // narrative children (inventory, quests) can show real state instead of
        // always-locked/never-tracked placeholders. Fetched once, not per-child.
        const _cdTrackedId = await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string;
        const childMetas = entIdx.filter(m => m.parentId === targetParentId);
        // [BUGFIX v2.18.1] childOut.id below is cEnt.id -- the child's ENTITY/body id.
        // For a character-type child that's NOT the same id cachedCharVisuals/
        // AE_FETCH_CHAR_PROFILE/AE_OPEN_CHAR_EDIT key on (the character's own storage
        // id, char.id) -- those two ids are deliberately different (see
        // spawnSceneNpc: rec.entityId = body.id, rec.id is separate). A caller that
        // used childOut.id to focus/profile a present character was silently
        // operating on the wrong record. Resolved once, only when there's a
        // character-type child to resolve, reused for all of them below.
        const _hasCharChild = childMetas.some(m => m.type === 'character');
        const _childAllChars = _hasCharChild ? await loadAllCharacters() : [];
        for (const cm of childMetas) {
            const cEnt = await loadEntity(cm.id);
            if (cEnt) {
                const childOut: any = {
                    id: cEnt.id,
                    name: cEnt.name,
                    type: cEnt.type,
                    icon: cEnt.icon || undefined,
                    description: cEnt.description || '',
                    state: cEnt.state || 'default',
                    isEquipped: !!cEnt.isEquipped,
                    equippedToCharId: (cEnt as any).equippedToCharId,
                };
                if (cEnt.type === 'character') {
                    // [BUGFIX v2.18.1] The character's own storage id -- use THIS, not
                    // childOut.id, to focus/profile/edit a present-character child.
                    const _cMatch = _childAllChars.find(function(c: any) { return c.entityId === cEnt.id; });
                    childOut.charId = _cMatch ? _cMatch.id : undefined;
                }
                if (cEnt.type === 'narrative') {
                    childOut.storyState = (cEnt as any).storyState || 'locked';
                    childOut.isTracked = (_cdTrackedId === cEnt.id);
                    childOut.questTarget = (cEnt as any).questTarget || '';
                    childOut.eventDayTarget = (cEnt as any).eventDayTarget;
                    if ((cEnt as any).questTarget) {
                        const _cdQt = entIdx.find(m => m.id === (cEnt as any).questTarget);
                        childOut.questTargetName = _cdQt ? _cdQt.name : '';
                    }
                }
                children.push(childOut);
            }
        }
    }
    detailPayload.children = children;

    // [v0.9.20] Per-character resources (charResourceDefs + charResourceValues)
    if (char) {
        const crdefs: any[] = char.charResourceDefs || [];
        if (crdefs.length > 0) {
            detailPayload.charResources = crdefs.map(function(def: any) {
                const val = (char.charResourceValues || {})[def.id] || 0;
                return { id: def.id, tag: def.tag, name: def.name, type: def.type, value: val,
                    hasBounds: !!def.hasBounds, min: def.min, max: def.max, states: def.states || [] };
            });
        }
    }

    // [v2.15.0 BRIDGE-CONDITIONS] Expose entityId (the bridge needs this as the
    // parent id for character-scoped item creation, see AE_HUD_SPAWN_ENTITY /
    // spawnItem's explicitParentId), plus the Conditions definitions + this
    // character's active state (CE-STRIP v2.6.0 PASS 10 shipped these engine-side
    // with no bridge exposure at the time — this is that catch-up). Definitions
    // are global (cfg.conditions), not character-specific, but only worth the
    // loadConfig() call when there's actually a character to report state for.
    if (char) {
        detailPayload.entityId = char.entityId;
        const bcCfg = await loadConfig();
        detailPayload.conditionDefs = bcCfg.conditions || [];
        detailPayload.activeConditions = char.activeConditions || [];
    }

    // [v2.18.0 BRIDGE-DRAMA] Same catch-up pattern as BRIDGE-CONDITIONS above:
    // ephemeral/midRange/primaryRelationship have lived on CharacterRecord since
    // day one (generateEphemeralUpdate / generateMidRange / relationship
    // generators write them) but were never serialized to the bridge — nothing
    // exposed them for the new flat Drama tab (hooks + these three) to read.
    // Passed through as-is; the bridge renders them read-only, no reshaping needed.
    if (char) {
        detailPayload.ephemeral = char.ephemeral || null;
        detailPayload.midRange = char.midRange || null;
        detailPayload.primaryRelationship = char.primaryRelationship || null;
    }

    // [CE-STRIP v2.1.5] detailPayload.actions/actionInstances removed — dead Actions remnants, always empty.

    if (ent && ent.type === 'narrative') {
        const isTracked = (await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string) === ent.id;
        let questTargetName = '';
        // [CE-STRIP v2.0.0] pathNames (findTravelPath) removed with Travel.
        if (ent.questTarget) {
            const qtTgt = entIdx.find(m => m.id === ent.questTarget);
            if (qtTgt) questTargetName = qtTgt.name;
        }
        detailPayload.narrative = {
            isTracked,
            questTarget: ent.questTarget || '',
            questTargetName,
            pathNames: [] as string[],
            storyState: ent.storyState || 'locked',
            description: ent.description || ''
        };
    }

    return detailPayload;
}

// [CE-STRIP v2.0.0] performTravelRequest removed — Travel cut.


// [CE-STRIP v2.0.0] toggleCharFollow removed — travel/follow cut.


// [v0.9.9.7] Shared hook resolution. Extracted from AE_RESOLVE_HOOK so the native
// character inspection view can resolve a hook without a message round-trip.
async function resolveCharHook(charId: string, hookId?: string, hookIndex?: number): Promise<void> {
    try {
        if (!charId) return;
        const fresh = await loadCharacter(charId);
        if (!fresh) return;
        if (!fresh.hooks) fresh.hooks = [];

        let idx = -1;
        if (hookId) {
            idx = fresh.hooks.findIndex((h: any) => h.id === hookId);
        } else if (typeof hookIndex === 'number') {
            idx = hookIndex;
        }

        if (idx >= 0 && idx < fresh.hooks.length) {
            const hkFresh = fresh;
            const hkDesc = hkFresh.hooks[idx].description.substring(0, 50);
            hkFresh.hooks.splice(idx, 1);
            await saveCharacter(hkFresh);
            api.v1.ui.toast('✓ Resolved: ' + hkDesc, { type: 'success', autoClose: 3000 });
            await broadcastCharacterData();
            await broadcastSceneState();

            let ent = null;
            if (hkFresh.entityId) ent = await loadEntity(hkFresh.entityId);
            const detailPayload = await buildEntityDetailPayload(charId, hkFresh, ent);
            await broadcastToTM('AE_ENTITY_DETAIL_RESPONSE', detailPayload);
        }
    } catch (e) { api.v1.log('[AE:bridge] resolveCharHook error:', e); }
}

// [CE-STRIP v2.0.0] toggleNarrativeTracking removed — quest-tracker cut.


// [v0.9.9.7] Shared equip/unequip. Extracted from AE_EQUIP_ITEM / AE_UNEQUIP_ITEM
// (merged via the equip flag) so native item rows can toggle equip state without a
// message round-trip. Rule preserved exactly: the toggle only ever targets the
// item's own owner/parent character id passed in as charId -- callers resolve which
// character that is (owner for equip, equippedToCharId for unequip); there is no
// character picker.
async function setItemEquip(charId: string, itemId: string, equip: boolean): Promise<void> {
    try {
        if (!charId || !itemId) return;
        const char = await loadCharacter(charId);
        const item = await loadEntity(itemId);
        if (!char || !item) return;
        await aeSetEquip(item, char, equip);
        api.v1.ui.toast(equip ? ('🎒 Equipped: ' + item.name) : ('🎒 Unequipped: ' + item.name), { type: equip ? 'success' : 'info', autoClose: 2000 });
        await broadcastCharacterData();
        await broadcastSceneState();

        let ent = null;
        if (char.entityId) ent = await loadEntity(char.entityId);
        const detailPayload = await buildEntityDetailPayload(charId, char, ent);
        await broadcastToTM('AE_ENTITY_DETAIL_RESPONSE', detailPayload);
    } catch (e) { api.v1.log('[AE:bridge] setItemEquip error:', e); }
}

// ── Inbound Message Router ────────────────────────────────────────────────────

// [v0.9.101 ENTITIES] Normalize a kind's entities (memory sections / species / factions)
// into a uniform shape for the HUD. Reads the SAME cfg stores the engine wizard writes.
async function buildWizardEntitiesPayload(kind: string): Promise<any> {
    let ecfg = await loadConfig();
    let items: any[] = [];
    if (kind === 'memory') {
        items = (ecfg.wizardSections || []).map(function(sx: WizardMemorySection) {
            return { id: sx.id, name: sx.label, content: sx.content || '', enabled: sx.enabled !== false, target: sx.target || 'memory', instructions: sx.instructions || '' };
        });
    } else if (kind === 'species') {
        items = (ecfg.species || []).map(function(x: any) { return { id: x.id, name: x.name, content: x.description || '' }; });
    } else if (kind === 'factions') {
        items = (ecfg.factions || []).map(function(x: any) { return { id: x.id, name: x.name, content: x.description || '', relationshipStates: x.relationshipStates || [] }; });
    }
    return { kind: kind, items: items };
}

// [v0.9.97 WIZHUD] Build the wizard snapshot for the HUD: topic registry, chat list
// (lightweight), and the active chat in full (messages + context selection).
async function buildWizardStatePayload(): Promise<any> {
    let wcfg = await loadConfig();
    let topicsSrc = ((wcfg as any).wizardTopics && (wcfg as any).wizardTopics.length) ? (wcfg as any).wizardTopics : DEFAULT_WIZARD_TOPICS;
    let topics = topicsSrc.map(function(t: WizardTopic) { return { id: t.id, label: t.label, commitKind: t.commitKind }; });
    let chats = await loadWizardChats();
    let list = chats.map(function(c: WizardChat) {
        return { id: c.id, topicId: c.topicId, title: c.title, updatedAt: c.updatedAt, msgCount: (c.messages || []).length };
    }).sort(function(a: any, b: any) { return b.updatedAt - a.updatedAt; });
    let activeId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_ACTIVE_CHAT, '') as string;
    let active = null;
    if (activeId) {
        let ac = await loadWizardChat(activeId);
        if (ac) {
            active = {
                id: ac.id, topicId: ac.topicId, title: ac.title,
                messages: ac.messages || [],
                contextChatIds: ac.contextChatIds || [],
                lorebookEntryIds: ac.lorebookEntryIds || [],
                includeStory: !!ac.includeStory
            };
        } else { activeId = ''; }
    }
    return { topics: topics, chats: list, activeChatId: activeId, activeChat: active, project: { name: wcfg.projectName || '', genre: wcfg.projectGenre || '', concept: wcfg.projectConcept || '' } };
}

// [v0.9.97 WIZHUD] List selectable context sources for a chat: other wizard chats,
// lorebook entries, and characters (each flagged whether it already has a lore entry,
// so the picker can show 'will create on add'). Mirrors buildWizardContext's sources.
async function buildWizardSourcesPayload(chatId: string): Promise<any> {
    let chats = await loadWizardChats();
    let otherChats = chats.filter(function(c: WizardChat) { return c.id !== chatId; })
        .map(function(c: WizardChat) { return { id: c.id, title: c.title, topicId: c.topicId }; });
    let lbEntries: any[] = [];
    try {
        let entries = await api.v1.lorebook.entries();
        lbEntries = (entries || []).map(function(e: any) {
            let label = e.displayName || (e.keys && e.keys.length ? e.keys[0] : 'Untitled');
            let preview = (e.text || '').slice(0, 80);
            return { id: e.id, label: label, preview: preview };
        });
    } catch (eWlb) { lbEntries = []; }
    let chars = await loadAllCharacters();
    let charSources = chars.map(function(ch: CharacterRecord) {
        return { id: ch.id, name: ch.name, hasLoreEntry: !!ch.lorebookEntryId, lorebookEntryId: ch.lorebookEntryId || '' };
    });
    let active = chatId ? await loadWizardChat(chatId) : null;
    return {
        chatId: chatId,
        chats: otherChats,
        lorebookEntries: lbEntries,
        characters: charSources,
        selected: active ? {
            contextChatIds: active.contextChatIds || [],
            lorebookEntryIds: active.lorebookEntryIds || [],
            characterIds: active.characterIds || [],
            includeStory: !!active.includeStory
        } : { contextChatIds: [], lorebookEntryIds: [], characterIds: [], includeStory: false }
    };
}

// [v0.9.93 PROFILE] Narrative fields regenerable per-field from the concept dump alone
// (seed-and-go). These map 1:1 to generateCharacterFields' labelled output, so a per-field
// regen runs that generator and applies only the requested key.
var REGENERABLE_CHAR_FIELDS: string[] = [
    'species', 'age', 'gender', 'occupationRole', 'briefDescription',
    'physicalDescription', 'personalityCore', 'voiceAndMannerisms', 'background', 'coreValues'
];

// [v0.9.93 PROFILE] Build the full editable character profile for the HUD. Reads the SAME
// CharacterRecord the native editor reads — single source of truth, no divergence.
async function buildCharProfilePayload(char: CharacterRecord, cfg: GlobalConfig): Promise<any> {
    // Sheet categories (the Four Fs live in cat_attr). sheetValues are dot-keyed
    // (cat.id + '.' + field.id) with legacy underscore / bare-id fallbacks.
    let sheetOut: any[] = [];
    for (let pCat of (cfg.sheetCategories || [])) {
        let pFields: any[] = [];
        for (let pF of (pCat.fields || [])) {
            let pDot = pCat.id + '.' + pF.id;
            let pUnd = pCat.id + '_' + pF.id;
            let pVal = char.sheetValues ? char.sheetValues[pDot] : undefined;
            if (pVal === undefined && char.sheetValues) pVal = char.sheetValues[pUnd];
            if (pVal === undefined && char.sheetValues) pVal = char.sheetValues[pF.id];
            if (pVal === undefined) pVal = '';
            pFields.push({ id: pF.id, key: 'sheet.' + pDot, name: pF.name, value: pVal });
        }
        sheetOut.push({ id: pCat.id, name: pCat.name, fieldType: pCat.fieldType, enumValues: pCat.enumValues || [], fields: pFields });
    }

    // Custom static fields: pair each def with its current value.
    let pCustom: any[] = [];
    for (let pCf of (cfg.customStaticFields || [])) {
        pCustom.push({ id: pCf.id, key: 'custom.' + pCf.id, label: pCf.label, instructions: pCf.instructions || '', value: (char.customFieldValues || {})[pCf.id] || '' });
    }

    // Faction relationships paired with display names.
    let pFactionRels: any[] = [];
    let pCfr = char.charFactionRelationships || {};
    for (let pFid of Object.keys(pCfr)) {
        let pFdef = (cfg.factions || []).find(function(x: any) { return x.id === pFid; });
        pFactionRels.push({ id: pFid, name: pFdef ? pFdef.name : pFid, value: pCfr[pFid] });
    }

    let pPr = char.primaryRelationship || ({} as PrimaryRelationship);

    return {
        id: char.id,
        name: char.name,
        isProtagonist: !!char.isProtagonist,
        hasLoreEntry: !!char.lorebookEntryId,
        conceptDump: char.conceptDump || '',
        nicknames: char.nicknames || [],
        species: char.species || '',
        age: char.age || '',
        gender: char.gender || '',
        occupationRole: char.occupationRole || '',
        briefDescription: char.briefDescription || '',
        physicalDescription: char.physicalDescription || '',
        personalityCore: char.personalityCore || '',
        voiceAndMannerisms: char.voiceAndMannerisms || '',
        background: char.background || '',
        coreValues: char.coreValues || [],
        customFields: pCustom,
        sheet: sheetOut,
        primaryRelationship: {
            enabled: pPr.enabled !== false,
            targetName: pPr.targetName || '',
            archetype: pPr.archetype || '',
            stageIndex: pPr.stageIndex || 0,
            howItStarted: pPr.howItStarted || '',
            currentStatus: pPr.currentStatus || '',
            trajectory: pPr.trajectory || '',
            summary: pPr.summary || '',
            threads: pPr.threads || []
        },
        factionRelationships: pFactionRels,
        hooks: (char.hooks || []).filter(function(h: any) { return !h.resolved; }),
        charResources: (char.charResourceDefs || []).map(function(def: any) {
            return { id: def.id, tag: def.tag, name: def.name, type: def.type,
                value: (char.charResourceValues || {})[def.id] || 0,
                hasBounds: !!def.hasBounds, min: def.min, max: def.max, states: def.states || [] };
        }),
        flags: {
            charContextEnabled: !!char.charContextEnabled,
            autoUpdateEnabled: !!char.autoUpdateEnabled,
            autoThoughtsEnabled: !!char.autoThoughtsEnabled,
            hooksEnabled: !!char.hooksEnabled
        },
        regenerableFields: REGENERABLE_CHAR_FIELDS
    };
}

async function handleBridgeMessage(msg: any): Promise<void> {
    try {
        const payload: any = (msg.data && msg.data.payload) ? msg.data.payload : (msg.data || {});
        const event: string = payload.event;

        switch (event) {

            case EVT_HANDSHAKE_ACK:
                // [CHANGE] On ACK: push char data first (bridge needs it for image gen lookups),
                //          then scene state (needs char data for compressedLine/socialMask),
                //          then AE_IMG_FIELDS_SYNC (bridge needs the field library + defaults
                //          for the Image Studio widget and avatar generation quality).
                isBridgeReady = true;
                api.v1.log('[AE:bridge] Bridge handshake confirmed.');
                api.v1.ui.toast('🔗 Bridge connected!', { type: 'success', autoClose: 2000 });
                await broadcastCharacterData();
                await broadcastSceneState();
                try {
                    await broadcastToTM('AE_IMG_FIELDS_SYNC', {
                        fields: imagePromptFields,
                        defaults: { width: globalSettings.defaultWidth, height: globalSettings.defaultHeight, scale: globalSettings.defaultScale, steps: globalSettings.defaultSteps }
                    });
                } catch (_) {}
                try { await broadcastJournal(); } catch (_) {}   // [v1.7.0 JOURNAL] populate HUD journal on connect
                // [CE-STRIP v2.0.x] broadcastHolding() removed — Holding cut.
                break;

            case EVT_PING:
                await broadcastToTM(EVT_PONG, {});
                api.v1.log('[AE:bridge] Bridge PING → PONG.');
                break;

            case EVT_CHAR_SYNC_PUSH:
                // Legacy path: bridge pushes character configs (e.g., on reconnect from old bridge version).
                // In the merged system the engine is source of truth, but we accept the push to update
                // the cache in case bridge has newer emotion-portrait data we don't have.
                if (Array.isArray(payload.configs)) {
                    // Merge bridge configs into cachedCharVisuals without overwriting engine fields.
                    // Only update fields that the bridge is authoritative for: none in the merged system.
                    // This case is essentially a no-op for new bridges; kept for backward compatibility.
                    api.v1.log('[AE:bridge] EVT_CHAR_SYNC_PUSH received (', payload.configs.length, 'entries) — legacy path, no-op in merged system.');
                }
                // Still reply with story ID so bridge can key chat history correctly.
                try {
                    const syncStoryId = await api.v1.story.id();
                    await broadcastToTM(EVT_STORY_ID_SYNC, { storyId: syncStoryId });
                } catch (_) {}
                break;

            // [CE-STRIP v2.0.0] EVT_RUN_ACTION_INSTANCE / RUN_QUICK_INSTANCE removed —
            // both always hit "not found" now that actionInstances/actionTemplates are gone.

            // [CE-STRIP v2.0.x] AE_SET_SILENT removed — Silent Mode cut with Action Modal.
            case EVT_AUTOSNAP: {
                // [WP-img] Bridge ⚙️ "Auto-Snap" button → story-driven scene image.
                try { await executeAutoSnap(); } catch (e) { api.v1.log('[AE:bridge] EVT_AUTOSNAP error:', e); }
                break;
            }
            case EVT_AUTOSNAP_PROMPT: {
                // [v0.9.8.0] Image Studio auto-snap: architect pass over the recent story,
                // result returned to the bridge to fill the composer. payload: { paragraphs }
                try {
                    let asPara = (payload && typeof payload.paragraphs === 'number' && payload.paragraphs > 0) ? Math.floor(payload.paragraphs) : (globalSettings.contextSize || DEFAULT_CTX);
                    if (asPara !== globalSettings.contextSize) { globalSettings.contextSize = asPara; await saveImageSettings(); }
                    let asBuilt = await buildArchitectPromptFromStory(asPara);
                    if (asBuilt) {
                        await broadcastToTM('AUTO_SNAP_PROMPT_RESULT', { prompt: asBuilt.prompt, charNames: asBuilt.matchedChars.map(function(c) { return c.name; }) });
                    } else {
                        await broadcastToTM('AUTO_SNAP_PROMPT_RESULT', { error: 'Could not build a prompt from the recent story.' });
                    }
                } catch (e) { api.v1.log('[AE:bridge] EVT_AUTOSNAP_PROMPT error:', e); await broadcastToTM('AUTO_SNAP_PROMPT_RESULT', { error: 'Auto-snap failed.' }); }
                break;
            }
            case EVT_DIRECTOR_SUBMIT: {
                // [NEW] Bridge submitted a Director's Cut image.
                // payload: { prompt, uc, chars: [{ name, visuals }], enhance?: boolean }
                // If payload.enhance === true: run architect pass and respond with EVT_DIRECTOR_ENHANCE_RESULT.
                // Otherwise: generate and broadcast EVT_GENERATE_IMAGE via submitDirectorPhoto.
                try {
                    if (payload.enhance) {
                        const enhanced = await enhanceDirectorPrompt(payload.prompt || '', payload.chars || []);
                        if (enhanced) {
                            await broadcastToTM('DIRECTOR_ENHANCE_RESULT', {
                                enhancedPrompt: enhanced.enhancedPrompt,
                                charVisuals:    enhanced.charVisuals
                            });
                        } else {
                            await broadcastToTM('DIRECTOR_ENHANCE_RESULT', { error: 'Enhancement failed.' });
                        }
                    } else {
                        await submitDirectorPhoto(payload.prompt || '', payload.uc || '', payload.chars || []);
                    }
                } catch (e) { api.v1.log('[AE:bridge] EVT_DIRECTOR_SUBMIT error:', e); }
                break;
            }

            case EVT_REQ_SCENE_STATE:
                // [NEW] Bridge requests an immediate scene state push (e.g., on reconnect or HUD open).
                await broadcastSceneState();
                break;

            case EVT_REQ_CHAR_DATA:
                // [NEW] Bridge requests an immediate character data push (e.g., on reconnect).
                await broadcastCharacterData();
                break;

            case 'AE_GEN_SNAPSHOT_TEXT': {
                // [v027] Generate the GLM appearance snapshot for a character and
                // store it under STORAGE_CHAR_SNAP_PFX. Result broadcast to bridge.
                try {
                    let stCharId = payload.charId;
                    let stChar = stCharId ? await loadCharacter(stCharId) : null;
                    if (!stChar) { api.v1.log('[AE:bridge] AE_GEN_SNAPSHOT_TEXT: char not found'); break; }
                    let stEntId = (stChar as any).entityId || null;
                    let stEnt = stEntId ? await loadEntity(stEntId) : null;
                    if (!stEnt) { api.v1.ui.toast('No scene context for snapshot.', { type: 'warning' }); break; }
                    let stCfg = await loadConfig();
                    let stText = await generateCharacterSnapshot(stChar, stEnt, stCfg);
                    if (stText) {
                        await api.v1.storyStorage.set(STORAGE_CHAR_SNAP_PFX + stCharId, stText);
                        await broadcastToTM('SNAPSHOT_TEXT_RESULT', { charId: stCharId, text: stText });
                    } else {
                        await broadcastToTM('SNAPSHOT_TEXT_RESULT', { charId: stCharId, error: 'Snapshot generation failed.' });
                    }
                } catch (snapTxtErr) { api.v1.log('[AE:bridge] AE_GEN_SNAPSHOT_TEXT error:', snapTxtErr); }
                break;
            }

            case 'AE_GEN_SNAPSHOT_IMAGE': {
                // [v027] Build an image from the stored snapshot text + character
                // visuals (+ optional location visuals) and broadcast EVT_GENERATE_IMAGE.
                try {
                    let siCharId = payload.charId;
                    if (!siCharId) { api.v1.log('[AE:bridge] AE_GEN_SNAPSHOT_IMAGE: no charId'); break; }
                    await assembleSnapshotImage(siCharId);
                } catch (snapImgErr) { api.v1.log('[AE:bridge] AE_GEN_SNAPSHOT_IMAGE error:', snapImgErr); }
                break;
            }

            case 'AE_OPEN_CHAR_EDIT': {
                // [NEW] Bridge requests Smart Modal for character edit.
                // Phase 2: will use openSmartModal(). For now opens NAI sidebar char edit.
                try {
                    const ceCharId = payload.charId;
                    if (ceCharId) {
                        const ceChar = await loadCharacter(ceCharId);
                        if (ceChar) await openCharEditModal(ceCharId);
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_OPEN_CHAR_EDIT error:', e); }
                break;
            }

            case 'AE_OPEN_ENTITY_EDIT': {
                try {
                    const oeId = payload.entityId;
                    if (oeId) await openEntityEditModal(oeId);
                } catch (e) { api.v1.log('[AE:bridge] AE_OPEN_ENTITY_EDIT error:', e); }
                break;
            }

            case 'AE_OPEN_WIZARD': {
                // [v2.6.0] Bridge header Wizard button (chat-bubble icon) requests the
                // native World-Build Wizard modal, since the bridge has no api.v1.ui access.
                try { await openWizardModal(); }
                catch (e) { api.v1.log('[AE:bridge] AE_OPEN_WIZARD error:', e); }
                break;
            }

            // [CE-STRIP v2.0.x] AE_OPEN_CALENDAR removed — Clock/Calendar cut.

            case 'AE_ADJUST_CHAR_RESOURCE': {
                // Bridge steppers in character focus view adjust a per-character resource.
                try {
                    const acCharId = payload.charId;
                    const acTag    = payload.tag;
                    const acDelta  = payload.delta;
                    if (acCharId && acTag && typeof acDelta === 'number') {
                        await adjustCharResource(acCharId, acTag, acDelta);
                        const acFresh = await loadCharacter(acCharId);
                        let acEnt = null;
                        if (acFresh && acFresh.entityId) acEnt = await loadEntity(acFresh.entityId);
                        const acDp = await buildEntityDetailPayload(acCharId, acFresh, acEnt);
                        await broadcastToTM('AE_ENTITY_DETAIL_RESPONSE', acDp);
                        await broadcastSceneState();
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_ADJUST_CHAR_RESOURCE error:', e); }
                break;
            }

            case 'AE_FETCH_ENTITY_DETAIL': {
                try {
                    const fId = payload.entityId || payload.charId;
                    if (fId) {
                        let char = await loadCharacter(fId);
                        let ent = null;
                        if (char) {
                            if (char.entityId) ent = await loadEntity(char.entityId);
                        } else {
                            ent = await loadEntity(fId);
                            if (ent && ent.type === 'character') {
                                const idx = await loadIndex();
                                const match = idx.find(m => m.entityId === ent.id);
                                if (match) char = await loadCharacter(match.id);
                            }
                        }

                        if (char || ent) {
                            const detailPayload = await buildEntityDetailPayload(fId, char, ent);
                            await broadcastToTM('AE_ENTITY_DETAIL_RESPONSE', detailPayload);
                        } else {
                            await broadcastToTM('AE_ENTITY_DETAIL_RESPONSE', { id: fId, error: 'Not found' });
                        }
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_FETCH_ENTITY_DETAIL error:', e); }
                break;
            }

            case 'AE_RESOLVE_HOOK': {
                // [v0.9.9.7] Delegated to resolveCharHook() (shared with native char inspect).
                await resolveCharHook(payload.charId, payload.hookId, payload.hookIndex);
                break;
            }

            case 'AE_EQUIP_ITEM': {
                // [v0.9.9.7] Delegated to setItemEquip() (shared with native item rows).
                await setItemEquip(payload.charId, payload.itemId, true);
                break;
            }

            case 'AE_UNEQUIP_ITEM': {
                // [v0.9.9.7] Delegated to setItemEquip() (shared with native item rows).
                await setItemEquip(payload.charId, payload.itemId, false);
                break;
            }

            case 'AE_CHAR_CONDITION_ACTION': {
                // [v2.15.0 BRIDGE-CONDITIONS] Bridge Drama tray add/change conditions.
                // Same activeConditions mutation as buildConditionsRows (the native
                // Character Edit modal's Conditions section, now on the Overview tab,
                // CE-STRIP v2.6.0 PASS 10 / v2.17.0 CHAREDIT-TABS):
                // toggle adds/removes the whole entry (unchecking clears rather than
                // resetting to stage 0); setStage only applies to defs with stages and
                // is clamped to their bounds.
                try {
                    const ccCharId = payload.charId;
                    const ccDefId  = payload.defId;
                    const ccOp     = payload.op;
                    if (ccCharId && ccDefId && ccOp) {
                        const ccChar = await loadCharacter(ccCharId);
                        if (ccChar) {
                            if (!ccChar.activeConditions) ccChar.activeConditions = [];
                            if (ccOp === 'toggle') {
                                const ccExists = ccChar.activeConditions.some((s: any) => s.defId === ccDefId);
                                if (ccExists) {
                                    ccChar.activeConditions = ccChar.activeConditions.filter((s: any) => s.defId !== ccDefId);
                                } else {
                                    ccChar.activeConditions.push({ defId: ccDefId, stageIndex: 0 });
                                }
                            } else if (ccOp === 'setStage' && typeof payload.stageIndex === 'number') {
                                const ccCfg = await loadConfig();
                                const ccDef = (ccCfg.conditions || []).find((d: any) => d.id === ccDefId);
                                const ccState = ccChar.activeConditions.find((s: any) => s.defId === ccDefId);
                                if (ccState && ccDef) {
                                    const ccMaxIdx = Math.max(0, (ccDef.stages || []).length - 1);
                                    ccState.stageIndex = Math.max(0, Math.min(ccMaxIdx, payload.stageIndex));
                                }
                            }
                            await saveCharacter(ccChar);
                            let ccEnt = null;
                            if (ccChar.entityId) ccEnt = await loadEntity(ccChar.entityId);
                            const ccDp = await buildEntityDetailPayload(ccCharId, ccChar, ccEnt);
                            await broadcastToTM('AE_ENTITY_DETAIL_RESPONSE', ccDp);
                        }
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_CHAR_CONDITION_ACTION error:', e); }
                break;
            }

            // [CE-STRIP vNEXT] AE_PROMOTE_MINOR_NPC handler removed — promoteMinorNpc()
            // no longer exists (minor-NPC tier retired, nothing left to promote to).
            // Bridge still emits this message from its minor-NPC bubble's "Promote to
            // Major" button (Section 6b / _makeEntityBubbleMinor) — now a silent no-op
            // here until the bridge pass removes that button too.

            case 'AE_SET_CHAR_PRESENT': {
                try { if (payload && payload.charId) await aeSetCharScenePresent(payload.charId, !!payload.present); }
                catch (eEx) { api.v1.log('[AE:bridge] AE_SET_CHAR_PRESENT error:', eEx); }
                break;
            }

            case 'AE_MOVE_CHAR_TO_SCENE': {
                try { if (payload && payload.charId) await aeMoveCharToScene(payload.charId); }
                catch (eMv) { api.v1.log('[AE:bridge] AE_MOVE_CHAR_TO_SCENE error:', eMv); }
                break;
            }

            case 'AE_REFRESH_PRESENCE': {
                try { await aeRefreshPresence(); }
                catch (eRf) { api.v1.log('[AE:bridge] AE_REFRESH_PRESENCE error:', eRf); }
                break;
            }

            case 'AE_HUD_GEN_ENTITY': {
                // [v1.15.0] Bridge "Add NPC/Item" popup: generate a scene-fitting draft
                // (name + brief/desc) WITHOUT spawning; echo it back to prefill the popup.
                // [CE-STRIP v2.1.6] archetype/template lookup removed — Bestiary/Item
                // Templates cut. Always generates freeform now.
                try {
                    const geKind = (payload && payload.kind === 'item') ? 'item' : 'npc';
                    if (geKind === 'item') {
                        const geRes = await generateSceneItem();
                        await broadcastToTM('AE_HUD_GEN_RESULT', { kind: 'item', ok: !!geRes, name: geRes ? geRes.name : '', brief: geRes ? geRes.desc : '' });
                    } else {
                        const geRes = await generateSceneNpc();
                        await broadcastToTM('AE_HUD_GEN_RESULT', { kind: 'npc', ok: !!geRes, name: geRes ? geRes.name : '', brief: geRes ? geRes.brief : '' });
                    }
                } catch (eGe) {
                    api.v1.log('[AE:bridge] AE_HUD_GEN_ENTITY error:', eGe);
                    try { await broadcastToTM('AE_HUD_GEN_RESULT', { kind: (payload && payload.kind) || 'npc', ok: false, name: '', brief: '' }); } catch (eGe2) {}
                }
                break;
            }

            case 'AE_HUD_SPAWN_ENTITY': {
                // [v1.15.0] Bridge "Add NPC/Item" Create: spawn from typed fields at the
                // inspected location. spawn* queues a fresh scene broadcast, so every open
                // HUD refreshes on its own.
                // [CE-STRIP v2.1.6] archetype/template lookup removed — Bestiary/Item
                // Templates cut. Always spawns freeform now.
                try {
                    const seKind = (payload && payload.kind === 'item') ? 'item' : 'npc';
                    const seName = (payload && payload.name) ? String(payload.name).trim() : '';
                    const seBrief = (payload && payload.brief) ? String(payload.brief).trim() : '';
                    const seLoc = (payload && payload.locId) ? String(payload.locId) : null;
                    if (seKind === 'item') {
                        if (seName) await spawnItem(seName, seBrief, false, seLoc || '__room__');
                    } else {
                        if (seName) await spawnSceneNpc(seName, seBrief, seLoc, false);
                    }
                } catch (eSe) {
                    api.v1.log('[AE:bridge] AE_HUD_SPAWN_ENTITY error:', eSe);
                }
                break;
            }

            case 'AE_HUD_GEN_LOCATION': {
                // [v1.18.0 LOCGEN] Bridge Map-tab "New Location" popup: generate a
                // scene-fitting draft (name + desc + lore) WITHOUT creating anything;
                // echo it back to prefill the popup.
                //
                // >>> PAIRED with AE_HUD_GEN_ENTITY directly above: same round-trip shape,
                // >>> genuinely different payload (relation + suggestion in, 3 fields out,
                // >>> no archetype). Touch one, look at the other.
                try {
                    let glRelIn = (payload && payload.relation === 'child') ? 'child' : 'sibling';
                    let glRefIn = (payload && payload.refLocId) ? String(payload.refLocId) : null;
                    let glSugIn = (payload && payload.suggestion) ? String(payload.suggestion) : '';
                    let glResOut = await generateSceneLocation(glRelIn, glRefIn, glSugIn);
                    await broadcastToTM('AE_HUD_GEN_LOCATION_RESULT', {
                        ok: !!glResOut,
                        relation: glRelIn,
                        name: glResOut ? glResOut.name : '',
                        description: glResOut ? glResOut.description : '',
                        lore: glResOut ? glResOut.lore : ''
                    });
                } catch (eGl) {
                    api.v1.log('[AE:bridge] AE_HUD_GEN_LOCATION error:', eGl);
                    try { await broadcastToTM('AE_HUD_GEN_LOCATION_RESULT', { ok: false, relation: (payload && payload.relation === 'child') ? 'child' : 'sibling', name: '', description: '', lore: '' }); } catch (eGl2) {}
                }
                break;
            }

            case 'AE_HUD_SPAWN_LOCATION': {
                // [v1.18.0 LOCGEN] Bridge Map-tab "New Location" Create. spawnLocation
                // queues a fresh scene broadcast, so every open HUD map repaints itself
                // and the new sibling/child node appears without an explicit refresh.
                // >>> PAIRED with AE_HUD_SPAWN_ENTITY directly above.
                try {
                    let slNameIn = (payload && payload.name) ? String(payload.name).trim() : '';
                    let slDescIn = (payload && payload.description) ? String(payload.description).trim() : '';
                    let slLoreIn = (payload && payload.lore) ? String(payload.lore).trim() : '';
                    let slRelIn = (payload && payload.relation === 'child') ? 'child' : 'sibling';
                    let slRefIn = (payload && payload.refLocId) ? String(payload.refLocId) : null;
                    if (slNameIn) await spawnLocation(slNameIn, slDescIn, slLoreIn, slRelIn, slRefIn, false);
                } catch (eSl) {
                    api.v1.log('[AE:bridge] AE_HUD_SPAWN_LOCATION error:', eSl);
                }
                break;
            }

            // [CE-STRIP v2.0.0] AE_TRACK_NARRATIVE removed — quest-tracker cut.

            case 'AE_SET_DEFAULT_BG_URL': {
                // [v0.9.40] Bridge Theme Forge sets module-level scene default background.
                // Saves to GlobalConfig so it persists with the story and flows back
                // through the next buildSceneStatePayload broadcast to all open bridges.
                try {
                    let bgCfg = await loadConfig();
                    (bgCfg as any).defaultBackgroundUrl = (payload.url || '').trim();
                    await saveConfig(bgCfg);
                    await broadcastSceneState();
                    api.v1.ui.toast(
                        (bgCfg as any).defaultBackgroundUrl
                            ? '✓ Scene background URL saved.'
                            : '✓ Scene background cleared.',
                        { type: 'success', autoClose: 2000 }
                    );
                } catch (e) { api.v1.error('[AE] AE_SET_DEFAULT_BG_URL error:', e); }
                break;
            }

            case EVT_IMPORT_WORLD: {
                // [v0.9.39] Bridge-delivered adventure module (Try-the-Demo button).
                // Same importPayload() funnel as file import, then seed/refresh exactly
                // like the new-story prompt callbacks.
                try {
                    let iwModule = payload.module || payload.data || null;
                    if (!iwModule) { api.v1.ui.toast('Demo payload was empty.', { type: 'warning', autoClose: 2500 }); break; }
                    let iwResult = await importPayload(iwModule);
                    let iwParts: string[] = [];
                    if (iwResult.charCount > 0)   iwParts.push(iwResult.charCount + ' character' + (iwResult.charCount !== 1 ? 's' : ''));
                    if (iwResult.entityCount > 0) iwParts.push(iwResult.entityCount + ' node' + (iwResult.entityCount !== 1 ? 's' : ''));
                    await ensureProtagonistExists();
                    await refreshSidebar();
                    queueSceneStateBroadcast();
                    api.v1.ui.toast('Demo loaded: ' + (iwParts.length ? iwParts.join(', ') : 'world') + '.', { type: 'success', autoClose: 3000 });
                } catch (e) {
                    api.v1.error('[AE:bridge] AE_IMPORT_WORLD error:', e);
                    api.v1.ui.toast('Demo import failed.', { type: 'error', autoClose: 2500 });
                }
                break;
            }

            case EVT_DEMO_FAILED: {
                // Bridge could not fetch the module (offline / URL down). Seed a fresh
                // story so the player is never stranded on an empty fresh story.
                try {
                    await ensureProtagonistExists();
                    await refreshSidebar();
                    queueSceneStateBroadcast();
                } catch (e) { api.v1.error('[AE:bridge] AE_DEMO_FAILED fallback error:', e); }
                api.v1.ui.toast('Demo unavailable — started a fresh story instead.', { type: 'warning', autoClose: 3500 });
                break;
            }

            // [CE-STRIP v2.0.0] AE_TOGGLE_FOLLOW / AE_TRAVEL_REQUEST / AE_VEHICLE_TRAVEL_REQUEST
            // removed — Travel cut. AE_SILENT_TELEPORT (below) is the remaining way to
            // reposition the player — direct, no path-finding, no cost.

            case 'REQUEST_NODE_GRAPH': {
                // Bridge map Inspect button — returns the adjacency graph of any entity.
                // [CE-STRIP v2.0.0] awareness/adjacency only — no travel-cost annotations.
                try {
                    const ngId  = payload.entityId;
                    if (!ngId) break;
                    const ngEnt = await loadEntity(ngId);
                    if (!ngEnt) break;
                    const ngAll = await loadEntityIndex();

                    const ngChildren: any[] = [];
                    for (const ngCM of ngAll.filter(function(m) { return m.parentId === ngId && m.type === 'location'; })) {
                        const ngHasGC = ngAll.some(function(m) { return m.parentId === ngCM.id && m.type === 'location'; });
                        ngChildren.push({
                            id: ngCM.id, name: ngCM.name, type: ngCM.type, icon: ngCM.icon || undefined,
                            hasChildren: ngHasGC
                        });
                    }

                    const ngConns: any[] = [];
                    for (const ngC of (ngEnt.connectedEntityIds || [])) {
                        const ngCM2 = ngAll.find(function(m) { return m.id === ngC.targetId; });
                        ngConns.push({
                            id: ngC.targetId,
                            name:   ngCM2 ? ngCM2.name : ngC.targetId,
                            label:  (ngC as any).label   || '',
                            oneWay: (ngC as any).oneWay  || false,
                            icon:   ngCM2 ? ngCM2.icon || undefined : undefined
                        });
                    }

                    // [v0.9.89] Lateral siblings for Orbital HUD
                    const ngSiblings: any[] = [];
                    for (const sibMeta of ngAll) {
                        if (sibMeta.type !== 'location' || sibMeta.id === ngId) continue;
                        if (sibMeta.parentId !== ngEnt.parentId) continue;
                        ngSiblings.push({
                            id: sibMeta.id, name: sibMeta.name, type: sibMeta.type,
                            icon: sibMeta.icon || undefined
                        });
                    }

                    // [FIX Bug3] Added currentIcon + parentIcon to node graph response.
                    const ngGraph: any = {
                        currentName:      ngEnt.name,
                        currentType:      ngEnt.type,
                        currentIcon:      (ngEnt as any).icon      || undefined,
                        parentId: ngEnt.parentId || null, parentName: '', parentType: '', parentIcon: undefined,
                        children: ngChildren, connections: ngConns, siblings: ngSiblings
                    };
                    if (ngEnt.parentId) {
                        const ngPm = ngAll.find(function(m) { return m.id === ngEnt.parentId; });
                        if (ngPm) { ngGraph.parentName = ngPm.name; ngGraph.parentType = ngPm.type; ngGraph.parentIcon = ngPm.icon || undefined; }
                    }
                    await broadcastToTM('AE_NODE_GRAPH_RESPONSE', { entityId: ngId, graph: ngGraph });
                } catch (e) { api.v1.log('[AE:bridge] REQUEST_NODE_GRAPH error:', e); }
                break;
            }

            case 'AE_SILENT_TELEPORT': {
                // Bridge 📍 Teleport button — same action as the native Map's Teleport
                // button. [CE-STRIP vNEXT] Delegates to commitTravel(id, true) instead of
                // duplicating camera/body-move/presence logic inline — that duplication
                // was also protagonist-gated (silently did nothing without one); one fix
                // in commitTravel now covers both entry points.
                try {
                    const tpTargetId = payload.targetId;
                    if (!tpTargetId) break;
                    const tpTgtEnt = await loadEntity(tpTargetId);
                    if (!tpTgtEnt) break;
                    await commitTravel(tpTargetId, true);
                    api.v1.ui.toast('📍 Teleported to ' + tpTgtEnt.name, { type: 'info', autoClose: 2000 });
                } catch (e) { api.v1.log('[AE:bridge] AE_SILENT_TELEPORT error:', e); }
                break;
            }

            case 'AE_DELETE_CHAR': {
                // [v1.9.1] Bridge "Kill Character" — routes through the SAME confirm+delete
                // path the native character cards and the character edit modal use
                // (confirmDeleteChar -> deleteCharacter), so it scrubs the entity body and
                // fires the portrait cascade instead of leaving an orphaned body behind.
                // The confirm modal is shown engine-side; nothing is deleted until the
                // author confirms. Falls back to the old index-only removal only if the
                // character record can't be loaded (true orphan with no name).
                try {
                    const dcId = payload.charId;
                    if (!dcId) break;
                    const dcChar = await loadCharacter(dcId);
                    if (dcChar) {
                        await confirmDeleteChar(dcId, dcChar.name || 'this character');
                    } else {
                        const dcIdx = await loadIndex();
                        await saveIndex(dcIdx.filter(function(m) { return m.id !== dcId; }));
                        await api.v1.storyStorage.remove(STORAGE_CHAR_PFX + dcId);
                        api.v1.ui.toast('Orphan character removed from index.', { type: 'info', autoClose: 2000 });
                        await broadcastCharacterData();
                        await broadcastSceneState();
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_DELETE_CHAR error:', e); }
                break;
            }

            case 'AE_SAVE_CHAR_VISUALS': {
                // Bridge gallery saved visual overrides for a character. Merges into CharacterRecord.
                try {
                    const scvId = payload.charId; if (!scvId) break;
                    const scvChar = await loadCharacter(scvId); if (!scvChar) break;
                    if (payload.visuals       !== undefined) scvChar.visuals       = payload.visuals;
                    if (payload.uc            !== undefined) scvChar.uc            = payload.uc;
                    if (payload.avatarVisuals !== undefined) scvChar.avatarVisuals = payload.avatarVisuals;
                    if (payload.avatarWidth   !== undefined) scvChar.avatarWidth   = payload.avatarWidth;
                    if (payload.avatarHeight  !== undefined) scvChar.avatarHeight  = payload.avatarHeight;
                    if (payload.avatarSeed    !== undefined) scvChar.avatarSeed    = payload.avatarSeed;
                    await saveCharacter(scvChar);
                    api.v1.ui.toast('\u2713 Visuals saved \u2014 ' + scvChar.name, { type: 'success', autoClose: 1500 });
                } catch (e) { api.v1.log('[AE:bridge] AE_SAVE_CHAR_VISUALS error:', e); }
                break;
            }

            case 'AE_FETCH_CHAR_PROFILE': {
                // Bridge opened a character's combined HUD profile. Build and push the
                // full editable record (same CharacterRecord the native editor reads).
                try {
                    const fcpId = payload.charId; if (!fcpId) break;
                    const fcpChar = await loadCharacter(fcpId);
                    if (!fcpChar) { await broadcastToTM(EVT_CHAR_PROFILE, { id: fcpId, error: 'Not found' }); break; }
                    const fcpCfg = await loadConfig();
                    const fcpOut = await buildCharProfilePayload(fcpChar, fcpCfg);
                    await broadcastToTM(EVT_CHAR_PROFILE, fcpOut);
                } catch (e) { api.v1.log('[AE:bridge] AE_FETCH_CHAR_PROFILE error:', e); }
                break;
            }

            case 'AE_SAVE_CHAR_FIELD': {
                // Bridge wrote one field in the HUD profile. Merge into the record, keep the
                // linked lorebook entry in sync, then push a fresh profile + coalesced roster
                // refresh so every surface reflects the change. fieldKey routing:
                //   direct string fields | coreValues | nicknames | custom.<id> | sheet.<cat>.<fld> | flag.<name>
                try {
                    const scfId = payload.charId;
                    const scfKey: string = payload.fieldKey || '';
                    if (!scfId || !scfKey) break;
                    let scfChar = await loadCharacter(scfId); if (!scfChar) break;
                    const scfVal = payload.value;
                    const SCF_DIRECT: string[] = ['name','conceptDump','species','age','gender','occupationRole','briefDescription','physicalDescription','personalityCore','voiceAndMannerisms','background'];
                    let scfHandled = true;
                    if (SCF_DIRECT.indexOf(scfKey) >= 0) {
                        (scfChar as any)[scfKey] = String(scfVal === undefined || scfVal === null ? '' : scfVal);
                    } else if (scfKey === 'coreValues') {
                        if (Array.isArray(scfVal)) scfChar.coreValues = scfVal.map(function(x: any) { return String(x).trim(); }).filter(Boolean);
                        else scfChar.coreValues = String(scfVal || '').split(';').map(function(x) { return x.trim(); }).filter(Boolean);
                    } else if (scfKey === 'nicknames') {
                        if (Array.isArray(scfVal)) scfChar.nicknames = scfVal.map(function(x: any) { return String(x).trim(); }).filter(Boolean);
                        else scfChar.nicknames = String(scfVal || '').split(',').map(function(x) { return x.trim(); }).filter(Boolean);
                    } else if (scfKey.indexOf('custom.') === 0) {
                        let scfCfId = scfKey.slice(7);
                        if (!scfChar.customFieldValues) scfChar.customFieldValues = {};
                        scfChar.customFieldValues[scfCfId] = String(scfVal === undefined ? '' : scfVal);
                    } else if (scfKey.indexOf('sheet.') === 0) {
                        let scfRef = scfKey.slice(6);
                        let scfParts = scfRef.split('.');
                        if (scfParts.length === 2) {
                            let scfDot = scfParts[0] + '.' + scfParts[1];
                            let scfUnd = scfParts[0] + '_' + scfParts[1];
                            if (!scfChar.sheetValues) scfChar.sheetValues = {};
                            scfChar.sheetValues[scfDot] = String(scfVal === undefined ? '' : scfVal);
                            scfChar.sheetValues[scfUnd] = scfChar.sheetValues[scfDot];
                        } else { scfHandled = false; }
                    } else if (scfKey.indexOf('flag.') === 0) {
                        let scfFlag = scfKey.slice(5);
                        let scfBool = !!scfVal;
                        if (scfFlag === 'charContextEnabled') scfChar.charContextEnabled = scfBool;
                        else if (scfFlag === 'autoUpdateEnabled') scfChar.autoUpdateEnabled = scfBool;
                        else if (scfFlag === 'autoThoughtsEnabled') scfChar.autoThoughtsEnabled = scfBool;
                        else if (scfFlag === 'hooksEnabled') scfChar.hooksEnabled = scfBool;
                        else scfHandled = false;
                    } else {
                        scfHandled = false;
                    }
                    if (!scfHandled) { api.v1.log('[AE:bridge] AE_SAVE_CHAR_FIELD unknown key: ' + scfKey); break; }
                    await saveCharacter(scfChar);
                    try { await syncLorebookEntry(scfChar.id, true); } catch (eScfLb) { /* non-fatal: lore sync best-effort */ }
                    const scfCfg = await loadConfig();
                    const scfOut = await buildCharProfilePayload(scfChar, scfCfg);
                    await broadcastToTM(EVT_CHAR_PROFILE, scfOut);
                    queueCharacterDataBroadcast();
                } catch (e) { api.v1.log('[AE:bridge] AE_SAVE_CHAR_FIELD error:', e); }
                break;
            }

            case 'AE_REGEN_CHAR_FIELD': {
                // Regenerate ONE narrative field from the concept dump (seed-and-go). Reuses
                // generateCharacterFields, applies only the requested key, pushes refreshed profile.
                try {
                    const rcfId = payload.charId;
                    const rcfKey: string = payload.fieldKey || '';
                    if (!rcfId || !rcfKey) break;
                    if (REGENERABLE_CHAR_FIELDS.indexOf(rcfKey) < 0) { api.v1.log('[AE:bridge] AE_REGEN_CHAR_FIELD non-regenerable key: ' + rcfKey); break; }
                    let rcfChar = await loadCharacter(rcfId); if (!rcfChar) break;
                    if (!(rcfChar.conceptDump || '').trim()) {
                        api.v1.ui.toast('No concept profile to regenerate from \u2014 add a concept dump first.', { type: 'warning', autoClose: 2500 });
                        break;
                    }
                    api.v1.ui.toast('Regenerating ' + rcfKey + ' for ' + rcfChar.name + '\u2026', { type: 'info', autoClose: 1500 });
                    // [v0.9.100] Per-field generation with optional hint for the four narrative
                    // fields (matches the native editor's auto-generate buttons via generateFieldContent).
                    // Other fields fall back to dump-only generateCharacterFields.
                    let rcfHint: string = (payload.hint || '').toString();
                    let rcfDef = STATIC_FIELD_DEFS.find(function(d: any) { return d.key === rcfKey; });
                    if (rcfDef) {
                        let rcfCfg = await loadConfig();
                        let rcfLabel = (rcfCfg.fieldLabels && rcfCfg.fieldLabels[rcfKey]) || rcfDef.label;
                        let rcfInst  = (rcfCfg.fieldInstructions && rcfCfg.fieldInstructions[rcfKey]) || rcfDef.defaultInstructions;
                        let rcfBudget = (rcfCfg.fieldBudgets && rcfCfg.fieldBudgets[rcfKey]) || rcfDef.defaultBudget;
                        let rcfVal = await generateFieldContent(rcfChar, rcfLabel, rcfInst, rcfCfg.generalStyle || '', rcfHint, rcfBudget);
                        if (rcfVal === null) { api.v1.ui.toast('Regeneration failed.', { type: 'error' }); break; }
                        (rcfChar as any)[rcfKey] = rcfVal;
                    } else {
                        let rcfFields = await generateCharacterFields(rcfChar.name, rcfChar.conceptDump || '');
                        if (!rcfFields) { api.v1.ui.toast('Regeneration failed.', { type: 'error' }); break; }
                        if (rcfKey === 'coreValues') rcfChar.coreValues = (rcfFields as any).coreValues || [];
                        else (rcfChar as any)[rcfKey] = (rcfFields as any)[rcfKey] || '';
                    }
                    await saveCharacter(rcfChar);
                    try { await syncLorebookEntry(rcfChar.id, true); } catch (eRcfLb) { /* non-fatal: lore sync best-effort */ }
                    const rcfCfg = await loadConfig();
                    const rcfOut = await buildCharProfilePayload(rcfChar, rcfCfg);
                    await broadcastToTM(EVT_CHAR_PROFILE, rcfOut);
                    queueCharacterDataBroadcast();
                } catch (e) { api.v1.log('[AE:bridge] AE_REGEN_CHAR_FIELD error:', e); }
                break;
            }

            case 'AE_WIZ_FETCH_STATE': {
                try { await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload()); }
                catch (e) { api.v1.log('[AE:bridge] AE_WIZ_FETCH_STATE error:', e); }
                break;
            }

            case 'AE_WIZ_MODE': {
                // [v1.2.0 WIZMODE] Bridge reports the wizard tab/modal opening or closing.
                try { await aeSetWizardMode(!!(payload && payload.on)); }
                catch (e) { api.v1.log('[AE:bridge] AE_WIZ_MODE error:', e); }
                break;
            }

            case 'AE_WIZLIVE_START': {
                // [v2.4.0 WIZLIVE] Open an in-document wizard chat. payload: { topicId? }
                try { await startLiveWizardChat(payload && payload.topicId ? String(payload.topicId) : ''); }
                catch (e) { api.v1.log('[AE:bridge] AE_WIZLIVE_START error:', e); }
                break;
            }

            case 'AE_WIZLIVE_END': {
                // [v2.4.0 WIZLIVE] Close it. payload: { action: 'save'|'discard' } ([v2.5.0] save -> CE Chats lorebook)
                try { await endLiveWizardChat(payload && payload.action ? String(payload.action) : 'save'); }
                catch (e) { api.v1.log('[AE:bridge] AE_WIZLIVE_END error:', e); }
                break;
            }

            case 'AE_WIZLIVE_FETCH': {
                // [v2.4.0 WIZLIVE] Bridge tab opened — echo current live-chat state.
                try { await broadcastWizLiveState(); }
                catch (e) { api.v1.log('[AE:bridge] AE_WIZLIVE_FETCH error:', e); }
                break;
            }

            // [v2.21.0 CHARCHAT] Engine-ready / bridge-pending: the bridge does not send
            // any of these yet (its HUD panel is P6). They exist now so the engine side is
            // complete and testable, and so P6 is a bridge-only patch. The native Chat
            // toolbar button is the working entry point in the meantime.
            case 'AE_CHARCHAT_START': {
                // payload: { contactId, povId? }
                try { await startCharChat(payload && payload.contactId ? String(payload.contactId) : '', payload && payload.povId ? String(payload.povId) : ''); }
                catch (e) { api.v1.log('[AE:bridge] AE_CHARCHAT_START error:', e); }
                break;
            }

            case 'AE_CHARCHAT_END': {
                // payload: { action: 'discard' } — 'save' is P4 and currently warns instead.
                try { await endCharChat(payload && payload.action ? String(payload.action) : 'discard'); }
                catch (e) { api.v1.log('[AE:bridge] AE_CHARCHAT_END error:', e); }
                break;
            }

            case 'AE_CHARCHAT_FETCH': {
                try { await broadcastCharChatState(); }
                catch (e) { api.v1.log('[AE:bridge] AE_CHARCHAT_FETCH error:', e); }
                break;
            }

            case 'AE_SET_PROJECT': {
                // [v0.9.7.0 SETUP] HUD Setup tab writes project name/genre/concept; echo fresh state.
                try {
                    await mutConfig(function(c) {
                        if (payload.name !== undefined)    c.projectName = String(payload.name);
                        if (payload.genre !== undefined)   c.projectGenre = String(payload.genre);
                        if (payload.concept !== undefined) c.projectConcept = String(payload.concept);
                    });
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_SET_PROJECT error:', e); }
                break;
            }

            case 'AE_WIZ_NEW_CHAT': {
                try {
                    const wncTopic = payload.topicId || (DEFAULT_WIZARD_TOPICS[0] ? DEFAULT_WIZARD_TOPICS[0].id : 'topic_concept');
                    const wncChat = await createWizardChat(wncTopic, payload.title || 'New Chat');
                    await api.v1.tempStorage.set(STORAGE_WIZ_ACTIVE_CHAT, wncChat.id);
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_NEW_CHAT error:', e); }
                break;
            }

            case 'AE_WIZ_SELECT_CHAT': {
                try {
                    if (payload.chatId) await api.v1.tempStorage.set(STORAGE_WIZ_ACTIVE_CHAT, payload.chatId);
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_SELECT_CHAT error:', e); }
                break;
            }

            case 'AE_WIZ_DELETE_CHAT': {
                try {
                    if (payload.chatId) {
                        await deleteWizardChat(payload.chatId);
                        delete _wizFrozenCtx[payload.chatId]; // [v1.2.0 WIZMODE] drop any frozen context for the deleted chat
                        let wdActive = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_ACTIVE_CHAT, '') as string;
                        if (wdActive === payload.chatId) await api.v1.tempStorage.set(STORAGE_WIZ_ACTIVE_CHAT, '');
                    }
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_DELETE_CHAT error:', e); }
                break;
            }

            case 'AE_WIZ_RENAME_CHAT': {
                try {
                    if (payload.chatId && payload.title !== undefined) {
                        let wrChat = await loadWizardChat(payload.chatId);
                        if (wrChat) { wrChat.title = String(payload.title).slice(0, 80) || 'Untitled'; await saveWizardChat(wrChat); }
                    }
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_RENAME_CHAT error:', e); }
                break;
            }

            case 'AE_WIZ_SEND': {
                // Run one wizard chat turn (yoink generation, no budget cost). The turn
                // function persists both messages; we then push reply signal + fresh state.
                try {
                    const wsId = payload.chatId;
                    const wsText: string = payload.text || '';
                    if (!wsId) break;
                    let wsReply = await runWizardChatTurn(wsId, wsText);
                    await broadcastToTM(EVT_WIZ_REPLY, { chatId: wsId, ok: wsReply !== null, error: wsReply === null ? 'Generation failed' : '' });
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) {
                    api.v1.log('[AE:bridge] AE_WIZ_SEND error:', e);
                    try { await broadcastToTM(EVT_WIZ_REPLY, { chatId: payload.chatId, ok: false, error: 'Turn failed' }); } catch (eWs2) {}
                }
                break;
            }

            case 'AE_WIZ_LIST_CONTEXT_SOURCES': {
                try { await broadcastToTM(EVT_WIZ_CONTEXT_SOURCES, await buildWizardSourcesPayload(payload.chatId || '')); }
                catch (e) { api.v1.log('[AE:bridge] AE_WIZ_LIST_CONTEXT_SOURCES error:', e); }
                break;
            }

            case 'AE_WIZ_SET_CHAT_CONTEXT': {
                // Persist a chat's context selection. characterIds resolve to their linked
                // lorebook entries (created lazily if missing), then merged into lorebookEntryIds
                // so buildWizardContext picks them up with no new context source.
                try {
                    const wscId = payload.chatId;
                    if (!wscId) break;
                    let wscChat = await loadWizardChat(wscId);
                    if (!wscChat) break;
                    wscChat.contextChatIds = Array.isArray(payload.contextChatIds) ? payload.contextChatIds : [];
                    wscChat.includeStory = !!payload.includeStory;
                    wscChat.lorebookEntryIds = Array.isArray(payload.lorebookEntryIds) ? payload.lorebookEntryIds : [];
                    wscChat.characterIds = Array.isArray(payload.characterIds) ? payload.characterIds : [];
                    await saveWizardChat(wscChat);
                    delete _wizFrozenCtx[wscId]; // [v1.2.0 WIZMODE] source selection changed — force a fresh context build next turn
                    await broadcastToTM(EVT_WIZ_CONTEXT_SOURCES, await buildWizardSourcesPayload(wscId));
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_SET_CHAT_CONTEXT error:', e); }
                break;
            }

            case 'AE_WIZ_EDIT_MSG': {
                try {
                    let wemChat = await loadWizardChat(payload.chatId);
                    let wemIdx = payload.index;
                    if (wemChat && wemChat.messages && wemIdx >= 0 && wemIdx < wemChat.messages.length && payload.content !== undefined) {
                        wemChat.messages[wemIdx].content = String(payload.content);
                        // [v1.23.0] notesCache keys on message COUNT, which an in-place edit
                        // does not change. Drop it so the next generation re-distills.
                        wemChat.notesCache = undefined;
                        await saveWizardChat(wemChat);
                    }
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_EDIT_MSG error:', e); }
                break;
            }

            case 'AE_WIZ_DELETE_MSG': {
                try {
                    let wdmChat = await loadWizardChat(payload.chatId);
                    let wdmIdx = payload.index;
                    if (wdmChat && wdmChat.messages && wdmIdx >= 0 && wdmIdx < wdmChat.messages.length) {
                        wdmChat.messages.splice(wdmIdx, 1);
                        await saveWizardChat(wdmChat);
                    }
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_DELETE_MSG error:', e); }
                break;
            }

            case 'AE_WIZ_GENERATE': {
                // Unified review/commit dispatcher. Routes a kind to its existing batch
                // function (no recreation), then pushes a result + the relevant refresh.
                try {
                    const wgKind: string = payload.kind || '';
                    const wgCount: number = Math.max(1, Math.min(10, payload.count || 1));
                    const wgSrc: string[] = Array.isArray(payload.sourceChatIds) ? payload.sourceChatIds : [];
                    let wgMade = 0; let wgOk = true;
                    api.v1.ui.toast('Generating ' + wgKind + '\u2026', { type: 'info', autoClose: 1500 });
                    if (wgKind === 'species')        wgMade = await runWizardSpeciesBatch(wgCount, wgSrc);
                    else if (wgKind === 'factions')  wgMade = await runWizardFactionsBatch(wgCount, wgSrc);
                    // [CE-STRIP v2.1.6] 'archetypes'/'items' kinds removed — Bestiary + Item Templates cut.
                    else if (wgKind === 'locations') wgMade = await runWizardLocationsBatch(wgCount, payload.parentId || null, wgSrc);
                    else if (wgKind === 'characters') wgMade = await runWizardCharactersBatch(wgCount, wgSrc);
                    else if (wgKind === 'web')       wgMade = await runWizardWebBatch(wgCount, wgSrc);
                    else if (wgKind === 'narratives') wgMade = await runWizardNarrativesBatch(wgCount, wgSrc);
                    else if (wgKind === 'hooks')     wgMade = await runWizardHooksBatch(Array.isArray(payload.charIds) ? payload.charIds : [], wgSrc);
                    // [v1.6.3 INTRO-STAGE] 'intro' now stages an editable draft (no story write);
                    // commit happens separately (native wizard Commit button / commitIntroDraft).
                    else if (wgKind === 'intro')     { wgOk = await generateIntroDraft(payload.locationId || '', wgSrc); wgMade = wgOk ? 1 : 0; }
                    else { api.v1.log('[AE:bridge] AE_WIZ_GENERATE unknown kind: ' + wgKind); wgOk = false; }
                    if (wgKind === 'characters' || wgKind === 'hooks' || wgKind === 'web') queueCharacterDataBroadcast();
                    await broadcastToTM(EVT_WIZ_GEN_RESULT, { kind: wgKind, count: wgMade, ok: wgOk });
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) {
                    api.v1.log('[AE:bridge] AE_WIZ_GENERATE error:', e);
                    try { await broadcastToTM(EVT_WIZ_GEN_RESULT, { kind: payload.kind, count: 0, ok: false }); } catch (eWg2) {}
                }
                break;
            }

            case 'AE_WIZ_COMMIT_MEMORY': {
                try {
                    api.v1.ui.toast('Building memory\u2026', { type: 'info', autoClose: 1500 });
                    let wcmCount = await runWizardMemoryFanout(payload.chatId || '');
                    let wcmCfg = await loadConfig();
                    let wcmOk = await commitWizardMemory(wcmCfg);
                    await broadcastToTM(EVT_WIZ_GEN_RESULT, { kind: 'memory', count: wcmCount, ok: wcmOk });
                } catch (e) {
                    api.v1.log('[AE:bridge] AE_WIZ_COMMIT_MEMORY error:', e);
                    try { await broadcastToTM(EVT_WIZ_GEN_RESULT, { kind: 'memory', count: 0, ok: false }); } catch (eWcm2) {}
                }
                break;
            }

            case 'AE_SYNC_LOREBOOK': {
                // [v0.9.7.6] Tab-level "Sync to Lorebook": create-or-update every entry
                // of one kind (species|factions|characters|locations). Reuses the engine's
                // existing per-item create/sync fns (silent), with one summary toast.
                try {
                    const slKind: string = payload.kind || '';
                    let slCreated = 0; let slSynced = 0; let slFailed = 0; let slSkipped = 0;
                    if (slKind === 'species') {
                        const slCfgSp = await loadConfig();
                        for (const sp of ((slCfgSp.species || []) as any[])) {
                            try {
                                if (sp.lorebookEntryId) { await syncSpeciesLorebookEntry(sp.id, true); slSynced++; }
                                else { await createLinkedSpeciesLorebookEntry(sp.id, true); slCreated++; }
                            } catch (eSp) { slFailed++; }
                        }
                    } else if (slKind === 'factions') {
                        const slCfgFa = await loadConfig();
                        for (const fa of ((slCfgFa.factions || []) as any[])) {
                            try {
                                if (fa.lorebookEntryId) { await syncFactionLorebookEntry(fa.id, true); slSynced++; }
                                else { await createLinkedFactionLorebookEntry(fa.id, true); slCreated++; }
                            } catch (eFa) { slFailed++; }
                        }
                    } else if (slKind === 'characters') {
                        const slIdx = await loadIndex();
                        for (const slCm of slIdx) {
                            try {
                                const slCh = await loadCharacter(slCm.id);
                                if (!slCh) { slSkipped++; continue; }
                                if (slCh.lorebookEntryId) { await syncLorebookEntry(slCm.id, true); slSynced++; }
                                else { await createLinkedLorebookEntry(slCm.id, true); slCreated++; }
                            } catch (eCh) { slFailed++; }
                        }
                    } else if (slKind === 'locations') {
                        const slEnts = await loadEntityIndex();
                        for (const slLm of slEnts) {
                            if ((slLm as any).type !== 'location') continue;
                            try {
                                const slLoc = await loadEntity(slLm.id);
                                if (!slLoc) { slSkipped++; continue; }
                                if ((slLoc as any).lorebookEntryId) { await syncEntityLorebookEntry(slLm.id, true); slSynced++; }
                                else if (((slLoc as any).lorebookText || '').trim()) { await createLinkedEntityLorebookEntry(slLm.id, true); slCreated++; }
                                else { slSkipped++; }
                            } catch (eLc) { slFailed++; }
                        }
                    } else {
                        api.v1.ui.toast('Unknown lorebook sync kind.', { type: 'error', autoClose: 2500 });
                        break;
                    }
                    let slMsg = 'Lorebook: ' + slCreated + ' created, ' + slSynced + ' updated';
                    if (slSkipped) slMsg += ', ' + slSkipped + ' skipped';
                    if (slFailed)  slMsg += ', ' + slFailed + ' failed';
                    slMsg += '.';
                    api.v1.ui.toast(slMsg, { type: slFailed ? 'warning' : 'success', autoClose: 3500 });
                    try { await broadcastToTM('AE_SYNC_LOREBOOK_RESULT', { kind: slKind, text: slMsg, ok: !slFailed }); } catch (eSLb) { api.v1.log('[AE:bridge] sync result broadcast failed'); }
                } catch (eSL) {
                    api.v1.log('[AE:bridge] AE_SYNC_LOREBOOK error:', eSL);
                    api.v1.ui.toast('Lorebook sync failed.', { type: 'error', autoClose: 3000 });
                }
                break;
            }

            case 'AE_WIZ_LIST_ENTITIES': {
                try { await broadcastToTM(EVT_WIZ_ENTITIES, await buildWizardEntitiesPayload(payload.kind || '')); }
                catch (e) { api.v1.log('[AE:bridge] AE_WIZ_LIST_ENTITIES error:', e); }
                break;
            }

            case 'AE_WIZ_CREATE_ENTITY': {
                // Create a blank named entity so its fields can then be generated.
                try {
                    const wceKind: string = payload.kind || '';
                    const wceName: string = (payload.name || '').toString().trim();
                    if (wceKind === 'memory') {
                        await mutConfig(function(c) {
                            if (!c.wizardSections) c.wizardSections = [];
                            c.wizardSections.push({ id: 'wsec_' + generateId(), label: wceName || 'New Section', enabled: true, content: '', instructions: '', target: 'memory' });
                        });
                    } else if (wceKind === 'species' || wceKind === 'factions') {
                        let wceEk = (wceKind === 'factions') ? 'faction' : 'species';
                        let wceId = await addBlankWizardEntity(wceEk);
                        if (wceName) {
                            await mutConfig(function(c) {
                                let arr: any[] = (wceEk === 'faction') ? (c.factions || []) : (c.species || []);
                                let t = arr.find(function(x) { return x.id === wceId; });
                                if (t) t.name = wceName;
                            });
                            if (wceEk === 'faction') await syncFactionLorebookEntry(wceId).catch(function() {});
                            else await syncSpeciesLorebookEntry(wceId).catch(function() {});
                        }
                    }
                    await broadcastToTM(EVT_WIZ_ENTITIES, await buildWizardEntitiesPayload(wceKind));
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_CREATE_ENTITY error:', e); }
                break;
            }

            case 'AE_WIZ_SAVE_ENTITY': {
                try {
                    const wseKind: string = payload.kind || '';
                    const wseId: string = payload.id || '';
                    if (!wseId) break;
                    if (wseKind === 'memory') {
                        await mutConfig(function(c) {
                            let sec = (c.wizardSections || []).find(function(s) { return s.id === wseId; });
                            if (!sec) return;
                            if (payload.name !== undefined) sec.label = String(payload.name);
                            if (payload.content !== undefined) sec.content = String(payload.content);
                            if (payload.enabled !== undefined) sec.enabled = !!payload.enabled;
                            if (payload.target !== undefined && (payload.target === 'memory' || payload.target === 'an')) sec.target = payload.target;
                            if (payload.instructions !== undefined) sec.instructions = String(payload.instructions);
                        });
                    } else if (wseKind === 'species' || wseKind === 'factions') {
                        let wseEk = (wseKind === 'factions') ? 'faction' : 'species';
                        await mutConfig(function(c) {
                            let arr: any[] = (wseEk === 'faction') ? (c.factions || []) : (c.species || []);
                            let t = arr.find(function(x) { return x.id === wseId; });
                            if (!t) return;
                            if (payload.name !== undefined) t.name = String(payload.name);
                            if (payload.content !== undefined) t.description = String(payload.content);
                            if (wseEk === 'faction' && Array.isArray(payload.relationshipStates)) {
                                t.relationshipStates = payload.relationshipStates.map(function(rs: any) { return String(rs); }).filter(function(rs: string) { return rs.trim().length > 0; });
                            }
                        });
                        if (wseEk === 'faction') await syncFactionLorebookEntry(wseId).catch(function() {});
                        else await syncSpeciesLorebookEntry(wseId).catch(function() {});
                    }
                    await broadcastToTM(EVT_WIZ_ENTITIES, await buildWizardEntitiesPayload(wseKind));
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_SAVE_ENTITY error:', e); }
                break;
            }

            case 'AE_WIZ_REGEN_ENTITY': {
                try {
                    const wreKind: string = payload.kind || '';
                    const wreId: string = payload.id || '';
                    const wreHint: string = (payload.hint || '').toString();
                    const wreSrc: string[] = Array.isArray(payload.sourceChatIds) ? payload.sourceChatIds : [];
                    if (!wreId) break;
                    api.v1.ui.toast('Regenerating\u2026', { type: 'info', autoClose: 1200 });
                    let wreOk = false;
                    if (wreKind === 'memory') { let r = await regenerateWizardSection(wreId, wreSrc, wreHint); wreOk = r !== null; }
                    else if (wreKind === 'species') { let r = await regenerateWizardEntity('species', wreId, wreSrc, wreHint); wreOk = r !== null; }
                    else if (wreKind === 'factions') { let r = await regenerateWizardEntity('faction', wreId, wreSrc, wreHint); wreOk = r !== null; }
                    if (!wreOk) api.v1.ui.toast('Regeneration failed.', { type: 'error', autoClose: 2000 });
                    await broadcastToTM(EVT_WIZ_ENTITIES, await buildWizardEntitiesPayload(wreKind));
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_REGEN_ENTITY error:', e); }
                break;
            }

            case 'AE_WIZ_DELETE_ENTITY': {
                try {
                    const wdeKind: string = payload.kind || '';
                    const wdeId: string = payload.id || '';
                    if (!wdeId) break;
                    if (wdeKind === 'memory') {
                        await mutConfig(function(c) { c.wizardSections = (c.wizardSections || []).filter(function(s) { return s.id !== wdeId; }); });
                    } else if (wdeKind === 'species' || wdeKind === 'factions') {
                        await mutConfig(function(c) {
                            if (wdeKind === 'factions') c.factions = (c.factions || []).filter(function(x: any) { return x.id !== wdeId; });
                            else c.species = (c.species || []).filter(function(x: any) { return x.id !== wdeId; });
                        });
                    }
                    await broadcastToTM(EVT_WIZ_ENTITIES, await buildWizardEntitiesPayload(wdeKind));
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_DELETE_ENTITY error:', e); }
                break;
            }

            case 'AE_FETCH_GALLERY_LOCATIONS': {
                // [v0.9.94 LOCHIER] Enhanced payload: adds parentId, childCount, lorebookText,
                // icon so the bridge can build a true hierarchy navigator.
                try {
                    const listMeta = await loadEntityIndex();
                    const locations = [];
                    for (const m of listMeta) {
                        if (m.type === 'location') {
                            const rec = await loadEntity(m.id);
                            if (rec) {
                                locations.push({
                                    id: rec.id,
                                    name: rec.name,
                                    parentId: rec.parentId,
                                    description: rec.description || '',
                                    atmosphere: rec.atmosphere || '',
                                    locationVisuals: (rec as any).locationVisuals || '',
                                    lorebookText: rec.lorebookText || '',
                                    lorebookEntryId: rec.lorebookEntryId || '',
                                    icon: rec.icon || '',
                                    childCount: m.childCount || 0
                                });
                            }
                        }
                    }
                    await broadcastToTM('AE_GALLERY_LOCATIONS_RESPONSE', { locations: locations });
                } catch (e) { api.v1.log('[AE:bridge] AE_FETCH_GALLERY_LOCATIONS error:', e); }
                break;
            }

            case 'AE_SAVE_LOCATION_VISUALS': {
                // [v0.9.94 LOCHIER] Now accepts description + lorebookText from the HUD
                // location profile in addition to the existing visuals field.
                try {
                    const vlId = payload.locationId;
                    if (vlId) {
                        const vlRec = await loadEntity(vlId);
                        if (vlRec) {
                            if (payload.visuals     !== undefined) (vlRec as any).locationVisuals = payload.visuals;
                            if (payload.description !== undefined) vlRec.description = payload.description;
                            if (payload.lorebookText !== undefined) vlRec.lorebookText = payload.lorebookText;
                            await saveEntity(vlRec);
                            try {
                                // Re-sync the linked lorebook entry if one exists
                                if (vlRec.lorebookEntryId) {
                                    const vlEntry = await api.v1.lorebook.entry(vlRec.lorebookEntryId);
                                    if (vlEntry) {
                                        let vlText = vlRec.description || '';
                                        if (vlRec.lorebookText) vlText += '\n\n' + vlRec.lorebookText;
                                        vlEntry.text = vlText.trim();
                                        await api.v1.lorebook.updateEntry(vlRec.lorebookEntryId, vlEntry);
                                    }
                                }
                            } catch (eLocLb) { /* non-fatal: lorebook re-sync best-effort */ }
                            api.v1.ui.toast('\u2713 Location saved', { type: 'success', autoClose: 1500 });
                        }
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_SAVE_LOCATION_VISUALS error:', e); }
                break;
            }

            case 'AE_ASK_RESPONSE': {
                // [v0.9.23 X2] Bridge resolved an __ask__ picker; unblock the waiting Promise.
                try {
                    let askRes = _pendingBridgeResolves[payload.promptId];
                    if (askRes) { delete _pendingBridgeResolves[payload.promptId]; askRes(payload.value !== undefined ? payload.value : null); }
                } catch (e) { api.v1.log('[AE] AE_ASK_RESPONSE error:', e); }
                break;
            }

            case 'AE_TARGET_SELECTED': {
                // [v0.9.23 X1] Bridge resolved a target pick; unblock the waiting Promise.
                try {
                    let tgtRes = _pendingBridgeResolves[payload.promptId];
                    if (tgtRes) { delete _pendingBridgeResolves[payload.promptId]; tgtRes(payload.targetId || null); }
                } catch (e) { api.v1.log('[AE] AE_TARGET_SELECTED error:', e); }
                break;
            }

            case 'AE_SET_PLAYER_FLAVOR': {
                // [v0.9.22 E5] Bridge sends player flavor before firing an action.
                // Empty string clears any pending flavor.
                try {
                    let flavorTxt = String(payload.text || '').trim();
                    if (flavorTxt) {
                        await api.v1.tempStorage.set(STORAGE_PENDING_FLAVOR, flavorTxt).catch(function(_e: any) {});
                    } else {
                        await api.v1.tempStorage.remove(STORAGE_PENDING_FLAVOR).catch(function(_e: any) {});
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_SET_PLAYER_FLAVOR error:', e); }
                break;
            }

            case 'AE_SET_PLAYER_EMOTION': {
                try {
                    const activeEmo = payload.emotion || 'neutral';
                    await api.v1.tempStorage.set('ae_player_emotion', activeEmo);
                    api.v1.log('[AE:engine] Active player emotion tracked: ' + activeEmo);
                } catch (e) { api.v1.log('[AE:bridge] AE_SET_PLAYER_EMOTION error:', e); }
                break;
            }

            case 'AE_IMG_FIELD_ACTION': {
                // [v2.13.0 IMGFIELDS] Replaces AE_SAVE_PRESET / AE_SET_ACTIVE_PRESET.
                // Single op-based dispatcher for the click-to-add field library, mirroring
                // the journal's AE_*_ACTION convention. saveImageSettings() persists +
                // rebroadcasts AE_IMG_FIELDS_SYNC on every branch.
                try {
                    const ifaOp = String(payload.op || '');
                    if (ifaOp === 'add') {
                        imagePromptFields.push({
                            id: generateId(),
                            name: String(payload.name || 'New Field'),
                            basePrompt: String(payload.basePrompt || ''),
                            uc: String(payload.uc || ''),
                            weight: 1,
                            active: false
                        });
                    } else if (ifaOp === 'update') {
                        const f = imagePromptFields.find(function(x) { return x.id === payload.id; });
                        if (f) {
                            if (payload.name       !== undefined) f.name       = String(payload.name);
                            if (payload.basePrompt  !== undefined) f.basePrompt = String(payload.basePrompt);
                            if (payload.uc          !== undefined) f.uc         = String(payload.uc);
                            if (payload.weight      !== undefined) f.weight     = Math.max(0.1, Math.min(10, Number(payload.weight) || 1));
                        }
                    } else if (ifaOp === 'toggle') {
                        const f = imagePromptFields.find(function(x) { return x.id === payload.id; });
                        if (f) f.active = !f.active;
                    } else if (ifaOp === 'delete') {
                        imagePromptFields = imagePromptFields.filter(function(x) { return x.id !== payload.id; });
                    } else if (ifaOp === 'reorder' && Array.isArray(payload.orderedIds)) {
                        const byId: { [k: string]: ImagePromptField } = {};
                        imagePromptFields.forEach(function(f) { byId[f.id] = f; });
                        imagePromptFields = payload.orderedIds.map(function(oid: string) { return byId[oid]; }).filter(Boolean);
                    } else if (ifaOp === 'setDefaults') {
                        if (payload.width  !== undefined) globalSettings.defaultWidth  = Number(payload.width)  || globalSettings.defaultWidth;
                        if (payload.height !== undefined) globalSettings.defaultHeight = Number(payload.height) || globalSettings.defaultHeight;
                        if (payload.scale  !== undefined) globalSettings.defaultScale  = Number(payload.scale)  || globalSettings.defaultScale;
                        if (payload.steps  !== undefined) globalSettings.defaultSteps  = Number(payload.steps)  || globalSettings.defaultSteps;
                    } else {
                        api.v1.log('[AE:bridge] AE_IMG_FIELD_ACTION unknown op:', ifaOp);
                    }
                    await saveImageSettings();
                } catch (e) { api.v1.log('[AE:bridge] AE_IMG_FIELD_ACTION error:', e); }
                break;
            }

            case 'AE_INSPECT_LOCATION': {
                // Bridge requests description/atmosphere for a location node.
                try {
                    const ilId: string = payload.locationId;
                    if (!ilId) break;
                    let ilEnt: EntityRecord | null = null;
                    try { ilEnt = await loadEntity(ilId); } catch(_e2) {}
                    await broadcastToTM('AE_INSPECT_RESPONSE', {
                        locationId: ilId,
                        name:        ilEnt ? ilEnt.name : ilId,
                        description: (ilEnt as any)?.description  || '',
                        atmosphere:  (ilEnt as any)?.atmosphere   || '',
                        travelCost:  (ilEnt as any)?.travelCost   || null,
                        locked:      (ilEnt as any)?.isLocked     || false
                    });
                } catch (e) { api.v1.log('[AE:map] AE_INSPECT_LOCATION error:', e); }
                break;
            }

            case 'AE_PACK_TO_LOREBOOK': {
                // [v0.9.7.10] Pack full world config to a hidden lorebook entry for
                // scenario sharing. Also callable from the Worldbuilding menu buttons.
                try { await packConfigToLorebook(); }
                catch (ePkMsg) { api.v1.log('[AE:bridge] AE_PACK_TO_LOREBOOK error:', ePkMsg); }
                break;
            }

            // [CE-STRIP v2.0.x] AE_TIME_ADVANCE / AE_TIME_SET removed — Clock/Calendar cut.

            case 'AE_SET_NARRATIVE_DATE': {
                // [v0.9.9.2] Set/clear a narrative's absolute day target (drives the AN
                // countdown when that narrative is the tracked one). Null/empty clears it.
                try {
                    let sndId = payload.narrativeId || payload.entityId || '';
                    if (sndId) {
                        let sndEnt = await loadEntity(sndId);
                        if (sndEnt) {
                            if (payload.day === null || payload.day === undefined || payload.day === '') {
                                sndEnt.eventDayTarget = undefined;
                            } else {
                                sndEnt.eventDayTarget = Math.max(0, Math.floor(Number(payload.day) || 0));
                            }
                            await saveEntity(sndEnt);
                            await refreshSidebar();
                            await broadcastSceneState();
                            api.v1.ui.toast('Event date updated.', { type: 'success', autoClose: 1800 });
                        }
                    }
                } catch (e) { api.v1.error('[AE:bridge] AE_SET_NARRATIVE_DATE error:', e); }
                break;
            }

            // [v1.7.0 JOURNAL] Bridge → engine journal control. State mutations run the
            // same Section 10b verbs the native HUD uses, then rebroadcast AE_JOURNAL_STATE.
            case 'AE_JOURNAL_REQ': {
                await broadcastJournal();
                break;
            }

            case 'AE_JOURNAL_ACTION': {
                try {
                    const jOp = String(payload.op || '');
                    if (jOp === 'add')            await journalAddBubble(String(payload.text || ''));
                    else if (jOp === 'update')    await journalUpdateBubble(String(payload.id || ''), String(payload.text || ''));
                    else if (jOp === 'delete')    await journalDeleteBubble(String(payload.id || ''));
                    else if (jOp === 'archive')   await journalSetArchived(String(payload.id || ''), true);
                    else if (jOp === 'unarchive') await journalSetArchived(String(payload.id || ''), false);
                    else if (jOp === 'merge')     await journalMergeDown();
                    else api.v1.log('[AE:bridge] AE_JOURNAL_ACTION unknown op:', jOp);
                } catch (e) { api.v1.error('[AE:bridge] AE_JOURNAL_ACTION error:', e); }
                await broadcastJournal();
                break;
            }

            case 'AE_JOURNAL_GEN': {
                // Rewrite/compress a passage. Returns text only — the HUD reviews and then
                // commits via AE_JOURNAL_ACTION 'update' (mirrors the native review flow).
                const gOp = String(payload.op || '');
                const gId = String(payload.id || '');
                try {
                    const gSrc = String(payload.text || '');
                    let gOut: string | null = null;
                    if (gOp === 'rewrite')       gOut = await journalGenerateRewrite(gSrc);
                    else if (gOp === 'compress') gOut = await journalGenerateCompress(gSrc);
                    await broadcastToTM('AE_JOURNAL_GEN_RESULT', { id: gId, op: gOp, text: gOut || '', ok: !!gOut });
                } catch (e) {
                    api.v1.error('[AE:bridge] AE_JOURNAL_GEN error:', e);
                    try { await broadcastToTM('AE_JOURNAL_GEN_RESULT', { id: gId, op: gOp, text: '', ok: false }); } catch (e2) {}
                }
                break;
            }

            // [v2.12.0 CHARJOURNAL] Bridge -> engine per-character journal control. Same
            // three-message shape as AE_JOURNAL_* above (REQ/ACTION/GEN), every payload
            // additionally carries charId. State mutations run the Section 10c verbs, then
            // rebroadcast AE_CHAR_JOURNAL_STATE for that charId.
            case 'AE_CHAR_JOURNAL_REQ': {
                const cjrCharId = String(payload.charId || '');
                if (!cjrCharId) break;
                await broadcastCharJournal(cjrCharId);
                break;
            }

            case 'AE_CHAR_JOURNAL_ACTION': {
                const cjaCharId = String(payload.charId || '');
                if (!cjaCharId) break;
                try {
                    const cjaOp = String(payload.op || '');
                    if (cjaOp === 'add')            await charJournalAddBubble(cjaCharId, String(payload.text || ''));
                    else if (cjaOp === 'update')    await charJournalUpdateBubble(cjaCharId, String(payload.id || ''), String(payload.text || ''));
                    else if (cjaOp === 'delete')    await charJournalDeleteBubble(cjaCharId, String(payload.id || ''));
                    else if (cjaOp === 'archive')   await charJournalSetArchived(cjaCharId, String(payload.id || ''), true);
                    else if (cjaOp === 'unarchive') await charJournalSetArchived(cjaCharId, String(payload.id || ''), false);
                    else if (cjaOp === 'merge')     await charJournalMergeDown(cjaCharId);
                    else api.v1.log('[AE:bridge] AE_CHAR_JOURNAL_ACTION unknown op:', cjaOp);
                } catch (e) { api.v1.error('[AE:bridge] AE_CHAR_JOURNAL_ACTION error:', e); }
                await broadcastCharJournal(cjaCharId);
                break;
            }

            case 'AE_CHAR_JOURNAL_GEN': {
                // Rewrite/compress reuse the SAME generation functions the main journal
                // uses — pure text transforms, no per-journal identity, nothing to duplicate.
                const cjgCharId = String(payload.charId || '');
                const cjgOp = String(payload.op || '');
                const cjgId = String(payload.id || '');
                try {
                    const cjgSrc = String(payload.text || '');
                    let cjgOut: string | null = null;
                    if (cjgOp === 'rewrite')       cjgOut = await journalGenerateRewrite(cjgSrc);
                    else if (cjgOp === 'compress') cjgOut = await journalGenerateCompress(cjgSrc);
                    await broadcastToTM('AE_CHAR_JOURNAL_GEN_RESULT', { charId: cjgCharId, id: cjgId, op: cjgOp, text: cjgOut || '', ok: !!cjgOut });
                } catch (e) {
                    api.v1.error('[AE:bridge] AE_CHAR_JOURNAL_GEN error:', e);
                    try { await broadcastToTM('AE_CHAR_JOURNAL_GEN_RESULT', { charId: cjgCharId, id: cjgId, op: cjgOp, text: '', ok: false }); } catch (e2) {}
                }
                break;
            }

            // [CE-STRIP v2.0.x] AE_HOLDING_REQ / AE_HOLDING_ACTION removed — Holding cut.

            default:
                api.v1.log('[AE:bridge] Unhandled bridge message, event:', event, payload);
        }
    } catch (e) {
        api.v1.log('[AE:bridge] handleBridgeMessage error:', e);
    }
}


// ============================================================================
// SECTION 18b — LOREBOOK WORLD-PACK  [v0.9.7.9]
// packConfigToLorebook(): serialises the full AE world into a single hidden,
// disabled lorebook entry (AE_LOREBOOK_PACK_NAME). The entry travels with the
// story's .scenario export, so any user who imports the scenario gets the
// world pre-configured. The entry is NEVER injected into context (enabled:false,
// no keys, forceActivation:false). It can be re-packed at any time; the engine
// finds the existing entry by displayName and updates it in place.
//
// loadConfigFromLorebook(): called from onScriptsLoaded. If the sentinel entry
// exists AND storyStorage has no config yet (fresh story from scenario), imports
// the full world automatically and logs a summary. Non-destructive — existing
// stories are never overwritten.
// ============================================================================

// ============================================================================
// [v0.98] PLAIN-JSON IMPORT / EXPORT
// Uses api.v1.file.save() and api.v1.file.prompt() — no bridge required.
// Produces a human-readable, tool-friendly JSON file using the importPayload()
// schema, fully compatible with the existing smart importer.
// ============================================================================

async function exportAll(): Promise<void> {
    try {
        const xaCfg    = await loadConfig();
        const xaChars  = await loadAllCharacters();
        const xaEntIdx = await loadEntityIndex();
        const xaEnts: EntityRecord[] = [];
        for (const xaM of xaEntIdx.filter(Boolean)) {
            const xaE = await loadEntity(xaM.id);
            if (xaE) xaEnts.push(xaE);
        }
        const xaNpcWeb    = typeof loadNpcWeb    === 'function' ? await (loadNpcWeb as any)().catch(function() { return []; })    : [];

        const xaData = {
            _ae:        true,
            aeVersion:  '0.9.9.2',
            exportedAt: new Date().toISOString(),
            config:     xaCfg,
            characters: xaChars,
            entities:   xaEnts,
            npcWeb:     xaNpcWeb
        };

        const xaSafeName = ((xaCfg as any).projectName || 'ae_world').replace(/[^a-z0-9]/gi, '_').toLowerCase();
        await api.v1.file.save(xaSafeName + '_export.json', JSON.stringify(xaData, null, 2));
        api.v1.ui.toast('Exported: ' + xaChars.length + ' characters, ' + xaEnts.length + ' nodes.', { type: 'success', autoClose: 3000 });
    } catch (e) {
        api.v1.error('[AE] exportAll failed:', e);
        api.v1.ui.toast('Export failed — see engine log.', { type: 'error' });
    }
}

async function importData(): Promise<void> {
    try {
        const raw = await api.v1.file.prompt({ accept: '.json,application/json,text/plain,*/*', readAs: 'text' });
        if (!raw || typeof raw !== 'string') return;

        const data = JSON.parse(raw);
        const result = await importPayload(data);

        const parts: string[] = [];
        if (result.configImported) {
            const cc = sumMergeCounts(result.configCategoryCounts);
            parts.push((cc.added + cc.updated) > 0 ? `settings (${cc.added} added, ${cc.updated} updated)` : 'settings');
        }
        if (result.charCount > 0)      parts.push(result.charCount + ' character' + (result.charCount !== 1 ? 's' : ''));
        if (result.entityCount > 0)    parts.push(result.entityCount + ' node' + (result.entityCount !== 1 ? 's' : ''));
        if (result.npcWebImported) {
            const wc = result.npcWebCounts || { added: 0, updated: 0 };
            parts.push((wc.added + wc.updated) > 0 ? `NPC web (${wc.added} added, ${wc.updated} updated)` : 'NPC web');
        }
        if (result.partyStateImported) parts.push('party state');

        if (!parts.length) {
            api.v1.ui.toast('File loaded but no recognisable AE data found.', { type: 'warning', autoClose: 3500 });
            return;
        }
        api.v1.ui.toast('Imported: ' + parts.join(', ') + '.', { type: 'success', autoClose: 3500 });
        await refreshSidebar();
        queueSceneStateBroadcast();
    } catch (e) {
        api.v1.error('[AE] importData failed:', e);
        api.v1.ui.toast('Import failed — check that the file is valid JSON.', { type: 'error' });
    }
}

async function packConfigToLorebook(): Promise<void> {
    api.v1.log('[AE:pack] Packing world config to lorebook...');
    try {
        // -- Gather storyStorage data -----------------------------------------
        const pkCfg   = await api.v1.storyStorage.get(STORAGE_CONFIG);
        const pkIdx   = await api.v1.storyStorage.getOrDefault(STORAGE_INDEX, []) as CharacterMeta[];
        const pkEntIdx = await api.v1.storyStorage.getOrDefault(STORAGE_ENTITY_INDEX, []) as EntityMeta[];
        const pkParty  = await api.v1.storyStorage.getOrDefault(STORAGE_PARTY, null);
        const pkWebRaw = await api.v1.storyStorage.get(STORAGE_NPC_WEB) as string | undefined;
        const pkQI     = await api.v1.storyStorage.getOrDefault('ae_quick_instances', []);
        const pkWizRaw = await api.v1.storyStorage.getOrDefault(STORAGE_WIZ_CHATS, '[]') as string;

        // -- Characters (sequential load) -------------------------------------
        let pkCharRecs: Record<string, any> = {};
        for (const pkCm of pkIdx) {
            try {
                const pkCh = await api.v1.storyStorage.get(STORAGE_CHAR_PFX + pkCm.id);
                if (pkCh) pkCharRecs[pkCm.id] = pkCh;
            } catch (eChPk) { api.v1.log('[AE:pack] char load skip:', pkCm.id, eChPk); }
        }

        // -- Entities (sequential load) ---------------------------------------
        let pkEntRecs: Record<string, any> = {};
        for (const pkEm of pkEntIdx) {
            try {
                const pkEnt = await api.v1.storyStorage.getOrDefault(STORAGE_ENTITY_PFX + pkEm.id, null);
                if (pkEnt) pkEntRecs[pkEm.id] = pkEnt;
            } catch (eEntPk) { api.v1.log('[AE:pack] entity load skip:', pkEm.id, eEntPk); }
        }

        // -- Image settings (in-memory, from global api.v1.storage) ----------
        // imagePromptFields/globalSettings are module-level; re-read to be safe.
        const pkImgFields = await api.v1.storage.get(STORAGE_KEY_PROMPT_FIELDS);
        const pkImgGlob   = await api.v1.storage.get(STORAGE_KEY_GLOBAL);

        // -- Assemble package -------------------------------------------------
        const pkPayload = JSON.stringify({
            v:            1,
            aeVersion:    '0.9.7.9',
            packedAt:     Date.now(),
            config:       pkCfg     || null,
            charIndex:    pkIdx,
            charRecords:  pkCharRecs,
            entIndex:     pkEntIdx,
            entRecords:   pkEntRecs,
            party:        pkParty   || null,
            npcWeb:       pkWebRaw  || null,
            quickInstances: pkQI,
            wizChats:     pkWizRaw,
            imageFields:  pkImgFields || null,
            imageGlobal:  pkImgGlob   || null
        });

        const pkBytes = pkPayload.length; // character count; JSON is mostly ASCII so ~= bytes
        api.v1.log('[AE:pack] Payload size:', pkBytes, 'bytes;', pkIdx.length, 'chars,', pkEntIdx.length, 'entities.');

        // -- Find existing sentinel entry or create new -----------------------
        let pkExisting: any = null;
        try {
            const pkAllEntries = await api.v1.lorebook.entries();
            pkExisting = pkAllEntries.find(function(pkE: any) { return pkE.displayName === AE_LOREBOOK_PACK_NAME; });
        } catch (eEntries) { api.v1.log('[AE:pack] entries() error:', eEntries); }

        if (pkExisting) {
            await api.v1.lorebook.updateEntry(pkExisting.id, { text: pkPayload });
            api.v1.log('[AE:pack] Updated existing lorebook entry id:', pkExisting.id);
        } else {
            const pkNewId = api.v1.uuid();
            await api.v1.lorebook.createEntry({
                id:              pkNewId,
                displayName:     AE_LOREBOOK_PACK_NAME,
                text:            pkPayload,
                keys:            [],
                enabled:         false,
                hidden:          true,
                forceActivation: false
            });
            api.v1.log('[AE:pack] Created new lorebook entry id:', pkNewId);
        }
        api.v1.ui.toast('World packed to lorebook (' + Math.round(pkBytes / 1024) + ' KB). Export scenario to share.', { type: 'success', autoClose: 4000 });
    } catch (ePack) {
        api.v1.error('[AE:pack] packConfigToLorebook error:', ePack);
        api.v1.ui.toast('Pack failed - see engine log.', { type: 'error', autoClose: 3000 });
    }
}

// Returns true if config was imported, false if skipped (entry missing or
// config already present). Called from onScriptsLoaded.
// Pass forced=true to import even when storyStorage already has a config.
async function loadConfigFromLorebook(forced?: boolean): Promise<boolean> {
    try {
        // -- Find sentinel entry ----------------------------------------------
        let lcEntry: any = null;
        try {
            const lcAll = await api.v1.lorebook.entries();
            lcEntry = lcAll.find(function(lcE: any) { return lcE.displayName === AE_LOREBOOK_PACK_NAME; });
        } catch (eLcList) { api.v1.log('[AE:pack] loadConfigFromLorebook entries() error:', eLcList); return false; }
        if (!lcEntry || !lcEntry.text) return false;

        // -- Only import if storyStorage has no config yet (fresh scenario) ---
        const lcExistingCfg = await api.v1.storyStorage.get(STORAGE_CONFIG);
        if (!forced && lcExistingCfg !== null && lcExistingCfg !== undefined) {
            api.v1.log('[AE:pack] Lorebook pack found but storyStorage already has config; skipping auto-import.');
            return false;
        }

        // -- Parse ------------------------------------------------------------
        let lcData: any;
        try { lcData = JSON.parse(lcEntry.text); }
        catch (eLcParse) { api.v1.error('[AE:pack] loadConfigFromLorebook: JSON parse failed:', eLcParse); return false; }

        api.v1.log('[AE:pack] Importing from lorebook pack v' + (lcData.v || '?') + ' packed at', lcData.packedAt, 'aeVersion', lcData.aeVersion);

        // -- Restore storyStorage: config -------------------------------------
        if (lcData.config) await api.v1.storyStorage.set(STORAGE_CONFIG, lcData.config);

        // -- Restore storyStorage: character index + records ------------------
        if (Array.isArray(lcData.charIndex) && lcData.charIndex.length > 0) {
            await api.v1.storyStorage.set(STORAGE_INDEX, lcData.charIndex);
            let lcCharCount = 0;
            const lcCharRecs = lcData.charRecords || {};
            for (const lcCharId in lcCharRecs) {
                try { await api.v1.storyStorage.set(STORAGE_CHAR_PFX + lcCharId, lcCharRecs[lcCharId]); lcCharCount++; }
                catch (eLcChar) { api.v1.log('[AE:pack] char restore skip:', lcCharId, eLcChar); }
            }
            api.v1.log('[AE:pack] Restored', lcCharCount, 'character records.');
        }

        // -- Restore storyStorage: entity index + records ---------------------
        if (Array.isArray(lcData.entIndex) && lcData.entIndex.length > 0) {
            await api.v1.storyStorage.set(STORAGE_ENTITY_INDEX, lcData.entIndex);
            let lcEntCount = 0;
            const lcEntRecs = lcData.entRecords || {};
            for (const lcEntId in lcEntRecs) {
                try { await api.v1.storyStorage.set(STORAGE_ENTITY_PFX + lcEntId, lcEntRecs[lcEntId]); lcEntCount++; }
                catch (eLcEnt) { api.v1.log('[AE:pack] entity restore skip:', lcEntId, eLcEnt); }
            }
            api.v1.log('[AE:pack] Restored', lcEntCount, 'entity records.');
        }

        // -- Restore storyStorage: ancillary data -----------------------------
        if (lcData.party)          await api.v1.storyStorage.set(STORAGE_PARTY,         lcData.party);
        if (lcData.npcWeb)         await api.v1.storyStorage.set(STORAGE_NPC_WEB,        lcData.npcWeb);
        if (lcData.quickInstances) await api.v1.storyStorage.set('ae_quick_instances',   lcData.quickInstances);
        if (lcData.wizChats)       await api.v1.storyStorage.set(STORAGE_WIZ_CHATS,      lcData.wizChats);

        // -- Restore global api.v1.storage: image settings -------------------
        if (lcData.imageFields) await api.v1.storage.set(STORAGE_KEY_PROMPT_FIELDS, lcData.imageFields);
        if (lcData.imageGlobal) await api.v1.storage.set(STORAGE_KEY_GLOBAL,        lcData.imageGlobal);

        const lcCharLen  = Object.keys(lcData.charRecords || {}).length;
        const lcEntLen   = Object.keys(lcData.entRecords  || {}).length;
        api.v1.log('[AE:pack] Import complete:', lcCharLen, 'chars,', lcEntLen, 'entities.');
        api.v1.ui.toast('World imported from lorebook pack (' + lcCharLen + ' chars, ' + lcEntLen + ' locations). Reload to activate.', { type: 'success', autoClose: 5000 });
        return true;
    } catch (eLcMain) {
        api.v1.error('[AE:pack] loadConfigFromLorebook error:', eLcMain);
        return false;
    }
}

// Takes already-parsed lorebook pack data (packConfigToLorebook format: charIndex/
// charRecords/entIndex/entRecords) and restores the full world into storyStorage
// and api.v1.storage. 
// Distinct from importPayload(), which handles the plain-JSON export format.
async function importFromLorebookPack(data: any): Promise<void> {
    if (data.config) await api.v1.storyStorage.set(STORAGE_CONFIG, data.config);

    if (Array.isArray(data.charIndex) && data.charIndex.length > 0) {
        await api.v1.storyStorage.set(STORAGE_INDEX, data.charIndex);
        let ifpCharRecs = data.charRecords || {};
        for (let ifpCId in ifpCharRecs) {
            try { await api.v1.storyStorage.set(STORAGE_CHAR_PFX + ifpCId, ifpCharRecs[ifpCId]); } catch (eIfpC) {}
        }
    }

    if (Array.isArray(data.entIndex) && data.entIndex.length > 0) {
        await api.v1.storyStorage.set(STORAGE_ENTITY_INDEX, data.entIndex);
        let ifpEntRecs = data.entRecords || {};
        for (let ifpEId in ifpEntRecs) {
            try { await api.v1.storyStorage.set(STORAGE_ENTITY_PFX + ifpEId, ifpEntRecs[ifpEId]); } catch (eIfpE) {}
        }
    }

    if (data.party)          await api.v1.storyStorage.set(STORAGE_PARTY,         data.party);
    if (data.npcWeb)         await api.v1.storyStorage.set(STORAGE_NPC_WEB,        data.npcWeb);
    if (data.quickInstances) await api.v1.storyStorage.set('ae_quick_instances',   data.quickInstances);
    if (data.wizChats)       await api.v1.storyStorage.set(STORAGE_WIZ_CHATS,      data.wizChats);

    if (data.imageFields) await api.v1.storage.set(STORAGE_KEY_PROMPT_FIELDS, data.imageFields);
    if (data.imageGlobal) await api.v1.storage.set(STORAGE_KEY_GLOBAL,        data.imageGlobal);
}

// Scans all lorebook entries for AE world packs (any entry whose text parses to
// JSON containing an aeVersion field), presents a modal picker, and calls
// importFromLorebookPack on the selected entry. Entry-point for the Import button
// in Settings → Adventure Module Management and the Characters tab header.
async function pickAndImportFromLorebook(): Promise<void> {
    let pklPacks: { entry: any; data: any }[] = [];
    try {
        let pklAll = await api.v1.lorebook.entries();
        for (let pklE of pklAll) {
            if (!pklE.text) continue;
            try {
                let pklD = JSON.parse(pklE.text);
                if (pklD && pklD.aeVersion) pklPacks.push({ entry: pklE, data: pklD });
            } catch (ePklParse) {}
        }
    } catch (ePklScan) {
        api.v1.ui.toast('Failed to scan lorebook entries.', { type: 'error' });
        return;
    }

    if (pklPacks.length === 0) {
        api.v1.ui.toast('No AE world packs found in the lorebook. Use "Pack to Lorebook" first.', { type: 'warning', autoClose: 4000 });
        return;
    }

    let pklContent: any[] = [
        { type: 'text', text: 'Select a world pack to import. This will overwrite the current world data.', style: { marginBottom: '14px', fontSize: '12px', lineHeight: '1.5' } }
    ];
    let pklModal: any;

    for (let pklI = 0; pklI < pklPacks.length; pklI++) {
        (function(pklEnt: any, pklDat: any) {
            let pklCC  = Object.keys(pklDat.charRecords || {}).length;
            let pklEC  = Object.keys(pklDat.entRecords  || {}).length;
            let pklLbl = (pklEnt.displayName || '[AE World]') + ' — ' + pklCC + ' chars, ' + pklEC + ' locations';
            pklContent.push({
                type: 'button',
                text: '📥 Import: ' + pklLbl,
                style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.15)', border: '1px solid rgba(136,204,255,0.4)', color: '#88ccff', fontWeight: 'bold' },
                disabledWhileCallbackRunning: true,
                callback: async function() {
                    try {
                        await importFromLorebookPack(pklDat);
                        if (pklModal) pklModal.close();
                        api.v1.ui.toast('World imported. Reload the sidebar to activate.', { type: 'success', autoClose: 4000 });
                        await refreshSidebar();
                        queueSceneStateBroadcast();
                    } catch (ePklImp) {
                        api.v1.error('[AE] pickAndImportFromLorebook import failed:', ePklImp);
                        api.v1.ui.toast('Import failed — see engine log.', { type: 'error' });
                    }
                }
            });
        })(pklPacks[pklI].entry, pklPacks[pklI].data);
    }

    pklContent.push({ type: 'button', text: 'Cancel', style: { width: '100%', marginTop: '8px' }, callback: function() { if (pklModal) pklModal.close(); } });
    pklModal = await openEngineModal({ id: 'ae-pick-import', title: '📥 Import from Lorebook', size: 'small', content: pklContent });
}

// ============================================================================
// ============================================================================
// SECTION 19 — SCENE PRESENCE, LOCATION & EQUIP HELPERS
// [CE-STRIP v2.0.0] Was ACTION EXECUTION ENGINE. The AERule/ActionInstance effects
// engine (aeApplyEffects/aeCheckConditions/runActionInstance/runQuickInstance/
// aeRollResolution/aePickTarget/aeBindStakeDef/evaluateFieldCondition/etc — ~40
// functions, the AERule/ActionInstance/AEScope/AEResolution/ActionBranch/
// AEOutcomeBand/AEResOutcome interfaces, and the Travel executors executeTravelTo/
// findTravelPath/findVehicleAncestor/executeVehicleTravel/executeDestinationTravel)
// is fully removed — every remaining external call site was traced and fixed or
// confirmed unreachable (grep "CE-STRIP v2.0.0" across the file for each one).
// What's left is genuinely still needed: scene presence, location resolution,
// item equip, the equip/faction-resource read-write helpers still used from Holding,
// Schedule's NPC positioning, and commitTravel (still used for World-Build Wizard
// intro placement and the native Map's Teleport button — NOT reachable from any
// player-facing travel/action UI any more).
// ============================================================================

function resolveEntityTokens(text: string, ent: EntityRecord, targetEnt?: EntityRecord | null): string {
    // Replaces __self__ and __target__ tokens in action outcome notes with entity names.
    // Preserved verbatim from AE source.
    if (!text || !ent) return text || '';
    let result = text.replace(/__self__/g, ent.name);
    if (targetEnt) result = result.replace(/__target__/g, targetEnt.name);
    return result;
}

function aeSubstituteTokens(text: string, scope: AEScope): string {
    if (!text) return '';
    let out = text;
    const actorName = scope.protag ? scope.protag.name : (scope.sourceEnt ? scope.sourceEnt.name : 'You');
    const targetName = scope.target ? scope.target.name : (scope.sourceEnt ? scope.sourceEnt.name : '');
    out = out.replace(/\{Actor\}/g, actorName);
    out = out.replace(/\{Target\}/g, targetName);
    // also honour the legacy __self__ / __target__ tokens via the existing resolver
    out = resolveEntityTokens(out, scope.sourceEnt, scope.target);
    return out;
}

function composeActionPrompt(base: string, flavor: string): string {
    let b = base.trim();
    let f = flavor.trim();
    if (!f) return b;
    if (!b) { return f.charAt(0).toUpperCase() + f.slice(1); }
    let flavorComplete = /[.!?]$/.test(f);
    if (flavorComplete) { return b + ' ' + f; }
    let stripped = b.replace(/[.!?]\s*$/, '');
    return stripped + ', ' + f + '.';
}

async function aeSetEquip(itemEnt: EntityRecord | null, charRec: CharacterRecord | null, equip: boolean): Promise<void> {
    if (!itemEnt) return;
    let freshItem = await loadEntity(itemEnt.id);
    if (!freshItem) return;
    freshItem.isEquipped = equip;
    freshItem.equippedToCharId = (equip && charRec) ? charRec.id : undefined;
    await saveEntity(freshItem);
    if (charRec) {
        let freshChar = await loadCharacter(charRec.id);
        if (freshChar) {
            if (!freshChar.equippedItemIds) freshChar.equippedItemIds = [];
            if (equip) { if (freshChar.equippedItemIds.indexOf(freshItem.id) < 0) freshChar.equippedItemIds.push(freshItem.id); }
            else { freshChar.equippedItemIds = freshChar.equippedItemIds.filter(function(id) { return id !== freshItem.id; }); }
            await saveCharacter(freshChar);
            // [v0.9.8.5] No lorebook re-sync — equipment now rides an ephemeral temp entry.
        }
    }
}

function aeResolveResourceCompareValue(raw: any, states: string[] | undefined): number {
    let s = String(raw === undefined || raw === null ? '' : raw).trim();
    if (s === '') return NaN;
    let asNum = Number(s);
    if (!isNaN(asNum)) return asNum;
    if (states && states.length) {
        let idx = states.findIndex(function(st) { return String(st).toLowerCase() === s.toLowerCase(); });
        if (idx >= 0) return idx;
    }
    return NaN;
}

// [CE-STRIP v2.0.x] aeFactionResDefaultValue / aeSetFactionResource /
// aeSetFactionResourceClamped removed — their only callers were the dead-by-
// starvation Faction Resources display in buildFactionsWorkspace (factionResourceDefs
// no longer exists on GlobalConfig; the block could never render anything real).
// loadFactionResourceValues/saveFactionResourceValues/effectiveFactionResourceSections
// were already missing before this patch (likely lost in the same earlier deletion
// that took aeRenderIndexedStatesEditor's definition) — this finishes that removal
// properly instead of restoring a subsystem whose data model is already gone.

// [FEATURE v2.30.0 ROOT-LOCATION, per user] Sentinel id for "the top of the entity
// graph" — every character's body starts here (parentId: null, see
// createWizardCharacter/spawnSceneNpc) and stays here until something moves it to a
// real location. Ungrouped and grouped-by-nothing used to mean the same thing as
// "unresolvable" (null), which is why a story with characters but NO location
// entities ever computed scene presence at all (loadPlayerLocation had nothing to
// fall back to but null, and recalculateScenePresence bails out entirely on a null
// camera room — see both below). Treating root as a real, comparable id instead of a
// dead end fixes that: a world with no locations now has exactly one implicit place,
// and every unplaced character is correctly co-located there together. Deliberately
// NOT a real entity — nothing should ever loadEntity() this id, which is also why it
// is namespaced away from api.v1.uuid()'s format rather than risking a collision.
var AE_ROOT_LOCATION_ID = '__ce_root__';

async function loadPlayerLocation(): Promise<string | null> {
    // [CE-STRIP vNEXT] The "camera" — what the HUD/context treats as the current
    // scene — is now independent of any character. STORAGE_PLAYER_LOC (declared long
    // ago but never actually written until now) is the single source of truth, set by
    // commitTravel/AE_SILENT_TELEPORT (the Map's Teleport action = "select a location").
    // Falls back to a protagonist's physical room if one exists and no camera has been
    // set yet (back-compat for worlds still using a protagonist), then to the first
    // location in the world so a fresh/no-protagonist world isn't permanently stuck on
    // "No scene state available." Each fallback persists into STORAGE_PLAYER_LOC so it
    // stays stable once resolved, rather than re-deriving every call.
    // [v2.30.0 ROOT-LOCATION] FINAL fallback below no longer returns null when there is
    // no location entity anywhere in the world — it returns AE_ROOT_LOCATION_ID, also
    // persisted, so this function can no longer return null at all. commitTravel still
    // overwrites STORAGE_PLAYER_LOC unconditionally the moment a real location exists
    // and gets selected, so this is a one-time bootstrap, not a permanent ceiling.
    const camLoc = await api.v1.storyStorage.getOrDefault(STORAGE_PLAYER_LOC, null) as string | null;
    if (camLoc === AE_ROOT_LOCATION_ID) return AE_ROOT_LOCATION_ID;
    if (camLoc) {
        const camEnt = await loadEntity(camLoc);
        if (camEnt) return camLoc;
        // Stale pointer (location was deleted) — fall through and re-resolve.
    }

    const idx = await loadIndex();
    const pMeta = idx.find(function(m) { return !!m.isProtagonist; });
    if (pMeta) {
        const protag = await loadCharacter(pMeta.id);
        if (protag && protag.entityId) {
            const protagBody = await loadEntity(protag.entityId);
            if (protagBody && protagBody.parentId) {
                await api.v1.storyStorage.set(STORAGE_PLAYER_LOC, protagBody.parentId);
                return protagBody.parentId;
            }
        }
    }

    const allNodes = await loadEntityIndex();
    const firstLoc = allNodes.find(function(n) { return n.type === 'location'; });
    if (firstLoc) {
        await api.v1.storyStorage.set(STORAGE_PLAYER_LOC, firstLoc.id);
        return firstLoc.id;
    }
    await api.v1.storyStorage.set(STORAGE_PLAYER_LOC, AE_ROOT_LOCATION_ID);
    return AE_ROOT_LOCATION_ID;
}

function getEffectiveRoomId(entityId: string, allNodes: EntityMeta[]): string | null {
    // Walks up the entity tree until a 'location' node is found.
    // Preserved verbatim from AE source, EXCEPT the final line — [v2.30.0 ROOT-LOCATION]
    // walking all the way to the top (parentId chain ends in null) with no 'location'
    // ancestor used to return null here, indistinguishable from "entityId doesn't exist
    // at all." Now returns AE_ROOT_LOCATION_ID instead, a real comparable id meaning
    // "this body sits at the top of the graph, ungrouped" — see that constant's own
    // comment for why this matters (recalculateScenePresence's camRoom comparison).
    // A genuinely missing node (!node) still returns null — that is a real error case
    // (a deleted/dangling entityId), not "unplaced," and stays distinguishable from it.
    if (!entityId) return null;
    let currentId: string | null = entityId;
    let sanity = 0;
    while (currentId && sanity < 10) {
        const node = allNodes.find(function(n) { return n.id === currentId; });
        if (!node) return null;
        if (node.type === 'location') return node.id;
        currentId = node.parentId || null;
        sanity++;
    }
    return currentId === null ? AE_ROOT_LOCATION_ID : currentId;
}

async function aeGetPlayerRoomId(): Promise<string | null> {
    // [CE-STRIP vNEXT] Delegates to loadPlayerLocation() — the camera already resolves
    // to a location-type node (walking up from a protagonist's body if needed), so a
    // separate walk here is redundant now that "current room" means "camera location"
    // rather than "wherever the protagonist's body specifically sits."
    try {
        return await loadPlayerLocation();
    } catch (e) { api.v1.log('[AE] aeGetPlayerRoomId:', e); return null; }
}

async function aeSetCharScenePresent(charId: string, present: boolean): Promise<void> {
    try {
        const c = await loadCharacter(charId);
        if (!c) return;
        c.scenePresent = !!present;
        await saveCharacter(c);
        queueSceneStateBroadcast();
    } catch (e) { api.v1.log('[AE] aeSetCharScenePresent:', e); }
}

async function aeMoveCharToScene(charId: string): Promise<void> {
    try {
        const c = await loadCharacter(charId);
        if (!c || !c.entityId) return;
        const room = await aeGetPlayerRoomId();   // co-locate in the player's actual room
        const body = await loadEntity(c.entityId);
        if (body) { body.parentId = room; await saveEntity(body); }
        await saveCharacter(c);
        await recalculateScenePresence();
        queueSceneStateBroadcast();
    } catch (e) { api.v1.log('[AE] aeMoveCharToScene:', e); }
}

async function aeRefreshPresence(): Promise<void> {
    try {
        await recalculateScenePresence();
        queueSceneStateBroadcast();
    } catch (e) { api.v1.log('[AE] aeRefreshPresence:', e); }
}

async function recalculateScenePresence(): Promise<void> {
    // [CE-STRIP vNEXT] Updates scenePresent for all active characters based on
    // co-location with the CAMERA location (loadPlayerLocation()) instead of the
    // protagonist's body. Previously this returned immediately if no protagonist
    // existed, so presence was never computed at all without one — root cause of
    // "No scene state available." A protagonist, if one exists, is now just another
    // character for presence purposes: present if co-located, absent otherwise, no
    // longer the anchor everyone else is measured against.
    try {
        // [v2.30.0 ROOT-LOCATION] loadPlayerLocation can no longer return null (its
        // final fallback is now AE_ROOT_LOCATION_ID, not null — see both of their own
        // comments), so this guard is believed unreachable now. Left in place as
        // defense-in-depth rather than removed — a null here would mean something
        // deeper broke, and silently proceeding with a null camRoom would make every
        // cRoom === camRoom comparison below false in a way that would look identical
        // to "nobody's present," not "something's wrong."
        const camRoom = await loadPlayerLocation();
        if (!camRoom) return;

        const allChars = await loadAllCharacters();
        const freshEntIdx = await loadEntityIndex();
        for (const c of allChars) {
            if (!c.active) continue;
            if (!c.entityId) {
                // No body in the world graph — cannot be co-located with anyone.
                if (c.scenePresent) { c.scenePresent = false; await saveCharacter(c); }
                continue;
            }
            const cRoom = getEffectiveRoomId(c.entityId, freshEntIdx);
            const shouldBePresent = (cRoom !== null) && (cRoom === camRoom);
            if (c.scenePresent !== shouldBePresent) {
                c.scenePresent = shouldBePresent;
                await saveCharacter(c);
            }
        }
    } catch (e) {
        api.v1.log('[AE] recalculateScenePresence error:', e);
    }
}


async function commitTravel(targetId: string, isSilent: boolean): Promise<void> {
    try {
        const ctTarget = await loadEntity(targetId);
        if (!ctTarget) return;
        api.v1.log('[AE:TRACE] commitTravel ENTER target=' + ctTarget.name + '(' + targetId + ') isSilent=' + isSilent + ' ae_lock=' + ae_lock);
        const ctIsSpatial = ctTarget.type === 'location';
        await api.v1.tempStorage.set(STORAGE_LAST_TRAVEL, Date.now());

        // [CE-STRIP vNEXT] Camera: set unconditionally, no protagonist required — this
        // IS the "select a location from the Map" action. Previously the whole function
        // bailed out here if no protagonist existed.
        if (ctIsSpatial) { await api.v1.storyStorage.set(STORAGE_PLAYER_LOC, targetId); }

        const ctChars  = await loadAllCharacters();
        const ctProtag = ctChars.find(function(c) { return c.isProtagonist; });
        if (ctProtag && ctProtag.entityId) {
            // Move body
            if (ctIsSpatial) {
                const ctBody = await loadEntity(ctProtag.entityId);
                if (ctBody && ctBody.id !== targetId) { api.v1.log('[AE:TRACE] commitTravel body move ' + ctBody.parentId + ' -> ' + targetId); ctBody.parentId = targetId; await saveEntity(ctBody); }
                else { api.v1.log('[AE:TRACE] commitTravel body NOT moved (ctBody=' + (ctBody ? ctBody.id : 'null') + ' target=' + targetId + ')'); }
            }

            // Legacy per-character camera field — kept in sync for any code still
            // reading it, but STORAGE_PLAYER_LOC above is the actual source of truth now.
            const ctFreshProtag = await loadCharacter(ctProtag.id);
            if (ctFreshProtag) { ctFreshProtag.currentLocationId = targetId; await saveCharacter(ctFreshProtag); }
        }

        // Pre-generation auto-triggers
        if (ctIsSpatial) { await runAutoTriggers(); }

        // [v0.9.9.2] Position offstage NPCs per their hourly schedule for the current
        // hour before computing who is scene-present at the destination.
        // [CE-STRIP v2.0.x] resolveSchedules() call removed — Schedule cut.

        // Scene presence — camera-anchored (recalculateScenePresence), no longer a
        // protagonist-room loop duplicated inline here.
        if (ctIsSpatial) { await recalculateScenePresence(); }

        // History
        const ctHist = await loadEntityHistory();
        ctHist.unshift(targetId);
        await saveEntityHistory(ctHist);

        // Quest arrival check
        if (ctIsSpatial) {
            try {
                const ctNarrId = await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string;
                if (ctNarrId) {
                    const ctNarr = await loadEntity(ctNarrId);
                    if (ctNarr && ctNarr.questTarget) {
                        const ctQIdx = await loadEntityIndex();
                        const ctQTgt = ctQIdx.find(function(m) { return m.id === ctNarr.questTarget; });
                        if (ctQTgt) {
                            const ctNavId = ctQTgt.type === 'location' ? ctQTgt.id : (ctQTgt.parentId || '');
                            if (ctNavId && targetId === ctNavId) {
                                await api.v1.storyStorage.set(STORAGE_TRACKED_NARRATIVE, '');
                                api.v1.ui.toast('🎯 Reached: ' + ctQTgt.name + ' — quest tracking cleared.', { type: 'success', autoClose: 3000 });
                            }
                        }
                    }
                }
            } catch (_) {}
        }

        // [v0.9.25 E4] Encounter roll removed from commitTravel

        await refreshSidebar();
        queueSceneStateBroadcast();

        if (!isSilent) {
            // [v0.9.37 DEFER1] Do NOT generate inline. move_player_to_self can sit in the
            // MIDDLE of an effects list (e.g. before inject_narrative); generating here
            // blocks the editor so any later inject_narrative/inject_message throws
            // 'editor is currently blocked' and the narrative never lands. Set a pending
            // flag; the top-level handler generates ONCE after every effect completes.
            api.v1.log('[AE:TRACE] commitTravel DEFER generate (target=' + targetId + ')');
            ae_pendingGenerate = true;
        } else {
            api.v1.log('[AE:TRACE] commitTravel SILENT SKIP generate (target=' + targetId + ')');
        }
    } catch (e) {
        api.v1.log('[AE] commitTravel error:', e);
    }
}

// SECTION 20 — SIDEBAR
// refreshSidebar, buildSidebar, buildCharCard, killCharacter,
// openCharEditModal and all character sub-section builders.
//
// [CHANGE] renderSceneHUD() -> queueSceneStateBroadcast() throughout.
// [CHANGE] typeof renderSceneHUD guards removed — call directly.
// [CHANGE] refreshSidebar no longer calls renderSceneHUD:
//          queueSceneStateBroadcast() is called instead.
// ============================================================================

async function refreshSidebar(): Promise<void> {
    // [CHANGE] renderSceneHUD() removed — bridge owns the HUD now.
    //          queueSceneStateBroadcast() fires so bridge HUD stays in sync.
    await api.v1.ui.update([{ type: 'sidebarPanel', id: 'ce-panel', name: 'Adventure', iconId: 'compass', content: await buildSidebar() } as any]);
    queueSceneStateBroadcast();
    try { await refreshWorkspace(); } catch (e) {}
}

async function buildSidebar(): Promise<UIPart[]> {
    // [v1.10.0] Landing hub. The old four-tab bar is replaced by a launcher of
    // full-screen workspaces (see openWorkspace / WORKSPACE_DEFS). Roster, Drama,
    // Locations & Entities and Action Studio render inside the shared full-screen
    // workspace modal; Wizard, World & Engine Settings and Bestiary keep their
    // existing modals for now (Phase B folds them into the shell).
    const parts: UIPart[] = [];
    let cfg: GlobalConfig;
    try { cfg = await loadConfig(); } catch (e) { cfg = {} as GlobalConfig; }

    // 1. PROJECT SETUP \u2014 hoisted from the Wizard Setup tab.
    parts.push({ type: 'text', text: 'Name your project and jot the initial concept. These seed world generation and every Wizard chat.', style: { fontSize: '12px', opacity: '0.7', lineHeight: '1.5', marginBottom: '8px' } });
    parts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '8px' }, content: [
        { type: 'textInput', label: 'Project Name', initialValue: (cfg as any).projectName || '', placeholder: 'Untitled Project', style: { flex: '1 1 0', margin: 0 }, onChange: async function(v: string) { await mutConfig(function(c) { (c as any).projectName = v; }); } },
        { type: 'textInput', label: 'Genre', initialValue: (cfg as any).projectGenre || '', placeholder: 'e.g. dark fantasy, cyberpunk noir\u2026', style: { flex: '1 1 0', margin: 0 }, onChange: async function(v: string) { await mutConfig(function(c) { (c as any).projectGenre = v; }); } }
    ] });
    parts.push({ type: 'multilineTextInput', label: 'Initial Concept', initialValue: (cfg as any).projectConcept || '', placeholder: 'The working idea your world starts from\u2026', style: { minHeight: '70px', marginBottom: '12px' }, onChange: async function(v: string) { await mutConfig(function(c) { (c as any).projectConcept = v; }); } } as UIPart);

    // 2. LAUNCHER \u2014 two-column grid of the seven workspaces.
    parts.push({ type: 'text', text: 'OPEN A WORKSPACE', style: { fontSize: '10px', fontWeight: 'bold', opacity: '0.5', letterSpacing: '0.5px', marginBottom: '6px' } });
    parts.push({ type: 'row', wrap: true, style: { gap: '6px', marginBottom: '12px' }, content: WORKSPACE_DEFS.map(function(d) {
        return { type: 'button', text: d.label, iconId: d.iconId as any, style: { flex: '1 1 46%', margin: 0, fontSize: '12px', textAlign: 'left', padding: '8px', border: '1px solid rgba(255,255,255,0.12)' }, callback: async function() { await launchWorkspace(d.id); } } as UIPart;
    }) });

    // 2b. WORLD MAINTENANCE — whole-world actions that belong to the project, not to any
    // one workspace. [v1.22.3] "Sync All Lorebooks" moved here from the Wizard's Memory
    // tab, where it sat below an unrelated commit button and was routinely missed.
    // [v1.24.0 CLEANUP] Adventure Module Management (lorebook pack + JSON import/export)
    // moved here from World Settings — same "whole-world action" rationale as Sync All.
    parts.push({ type: 'collapsibleSection', title: 'World maintenance', iconId: 'book-open', initialCollapsed: true, storageKey: 'temp:ae_landing_maint', content: [
        { type: 'text', text: 'Create any missing lorebook entries and refresh existing ones for every character, location, species, and faction. Safe to run at any time; it also repairs entries deleted in NovelAI.', style: { fontSize: '11px', opacity: '0.7', lineHeight: '1.5', marginBottom: '6px' } },
        { type: 'button', text: '\ud83d\udcda Sync All Lorebooks', iconId: 'book-open' as any, style: { width: '100%', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.10)' }, disabledWhileCallbackRunning: true, callback: async function() {
            api.v1.ui.toast('Syncing all lorebooks\u2026', { id: 'ae-lore-all', autoClose: false, type: 'info' });
            try {
                let t = await syncAllLorebooks();
                let totCreated = t.characters.created + t.locations.created + t.species.created + t.factions.created;
                let totSynced  = t.characters.synced  + t.locations.synced  + t.species.synced  + t.factions.synced;
                api.v1.ui.toast(totCreated + ' created, ' + totSynced + ' synced (chars ' + t.characters.created + '+' + t.characters.synced + ', locs ' + t.locations.created + '+' + t.locations.synced + ', species ' + t.species.created + '+' + t.species.synced + ', factions ' + t.factions.created + '+' + t.factions.synced + ').', { id: 'ae-lore-all', type: 'success', autoClose: 4000 });
            } catch (eSyncAll) {
                api.v1.error('[AE:lore] Sync All button:', eSyncAll);
                api.v1.ui.toast('Sync All failed.', { id: 'ae-lore-all', type: 'error', autoClose: 2500 });
            }
        } },
        { type: 'box', style: { borderTop: '1px solid rgba(255,255,255,0.1)', marginTop: '12px', paddingTop: '12px' }, content: [
            { type: 'text', text: '📦 Adventure Module Management', style: { fontSize: '12px', fontWeight: 'bold', marginBottom: '6px', color: '#7ec8a0' } },
            { type: 'text', text: 'Pack the full world into a hidden lorebook entry that travels with your .scenario export. Use the picker to import any AE pack found in the lorebook.', style: { fontSize: '11px', opacity: '0.7', marginBottom: '8px' } },
            { type: 'row', style: { gap: '8px', marginBottom: '10px' }, content: [
                { type: 'button', text: '📦 Pack to Lorebook', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(126,200,160,0.12)', border: '1px solid rgba(126,200,160,0.35)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {
                    await packConfigToLorebook();
                } },
                { type: 'button', text: '📥 Import from Lorebook', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(136,204,255,0.12)', border: '1px solid rgba(136,204,255,0.35)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                    await pickAndImportFromLorebook();
                } }
            ] },
            { type: 'text', text: 'Export to a plain JSON file for backups or external tools. Import a previously exported JSON file.', style: { fontSize: '11px', opacity: '0.7', marginBottom: '8px' } },
            { type: 'row', style: { gap: '8px' }, content: [
                { type: 'button', text: '⬇ Export JSON', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(232,168,124,0.12)', border: '1px solid rgba(232,168,124,0.35)', color: '#e8a87c' }, disabledWhileCallbackRunning: true, callback: async function() {
                    await exportAll();
                } },
                { type: 'button', text: '⬆ Import JSON', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(232,168,124,0.12)', border: '1px solid rgba(232,168,124,0.35)', color: '#e8a87c' }, disabledWhileCallbackRunning: true, callback: async function() {
                    await importData();
                } }
            ] }
        ] } as UIPart
    ] } as UIPart);

    // 3. DISPLAY MODE \u2014 HUD routing (was top chrome; demoted to a collapsed strip).
    var _hudMode = (cfg as any).interfaceMode || 'native';
    function hudModeBtn(mode: string, label: string, icon: any): UIPart {
        var on = _hudMode === mode;
        return { type: 'button', text: label, iconId: icon, style: { flex: '1 1 0', margin: 0, fontSize: '11px', fontWeight: on ? 'bold' : 'normal', backgroundColor: on ? 'rgba(126,200,160,0.18)' : 'transparent', color: on ? '#7ec8a0' : undefined, border: on ? '1px solid #7ec8a0' : '1px solid rgba(255,255,255,0.12)', opacity: on ? '1' : '0.7' }, callback: async function() { await setInterfaceMode(mode); } } as UIPart;
    }
    parts.push({ type: 'collapsibleSection', title: 'Display mode', iconId: 'monitor', initialCollapsed: true, storageKey: 'temp:ae_display_mode', content: [
        { type: 'text', text: 'Where the game interface renders. Native uses NovelAI\u2019s own UI; Bridge uses the HUD userscript; Both runs them together.', style: { fontSize: '11px', opacity: '0.7', marginBottom: '6px' } },
        { type: 'row', style: { gap: '6px' }, content: [ hudModeBtn('native', 'Native', 'cloud-off'), hudModeBtn('bridge', 'Bridge', 'cloud'), hudModeBtn('both', 'Both', 'layers') ] }
    ] } as UIPart);

    // 4. HOW THIS PANEL WORKS \u2014 default collapsed.
    parts.push({ type: 'collapsibleSection', title: 'How this panel works', iconId: 'help-circle', initialCollapsed: true, storageKey: 'temp:ae_landing_intro', content: [
        { type: 'text', markdown: true, text: 'This landing is your project home. Fill in the setup fields above, then open a **workspace** for focused work. Every workspace has a **Navigate** header to jump anywhere in two taps, plus its own **Help** button explaining its controls.', style: { fontSize: '11px', opacity: '0.85', lineHeight: '1.5' } }
    ] } as UIPart);

    return parts.filter(Boolean) as UIPart[];
}

async function buildRosterWorkspace(): Promise<UIPart[]> {
    const parts: UIPart[] = [];
    try {
const index = await loadIndex(); 
            const cfg = await loadConfig();
            const entIdx = await loadEntityIndex();
            const searchQuery = await api.v1.tempStorage.getOrDefault('temp:ae_char_search', '') as string;
            
            // 1. TOP ROW: ADD & IMPORT & HELP
            parts.push({ type: 'row', style: { gap: '8px', marginBottom: '8px' }, content: [
                { type: 'button', text: 'Character', iconId: 'plus', style: { flex: '1 1 0', margin: 0 }, disabledWhileCallbackRunning: true, callback: async function() {
                    try {
                        let addCfg = await loadConfig();
                        let addEnt = makeDefaultEntity('New Character');
                        addEnt.type = 'character';
                        addEnt.parentId = null;
                        await saveEntity(addEnt);
                        let addChar = makeDefaultCharacter('New Character', addCfg);
                        addChar.entityId = addEnt.id;
                        await saveCharacter(addChar);
                        try { await createLinkedLorebookEntry(addChar.id); } catch (lbErr) {}
                        if (typeof openCharEditModal === 'function') await openCharEditModal(addChar.id);
                        await refreshSidebar();
                    } catch (e) {
                        api.v1.error('[AE] Create character failed:', e);
                        api.v1.ui.toast('Failed to create character.', { type: 'error' });
                    }
                } },
                { type: 'button', text: 'Import', iconId: 'download', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(136,204,255,0.15)', border: '1px solid rgba(136,204,255,0.3)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() { 
                    await pickAndImportFromLorebook(); 
                } },
            ] });

            // 2. SEARCH BAR
            parts.push({
                type: 'textInput', 
                placeholder: 'Search characters\u2026', 
                initialValue: searchQuery,
                style: { marginBottom: '12px' }, 
                onChange: async function(v: string) {
                    await api.v1.tempStorage.set('temp:ae_char_search', v);
                    await refreshSidebar();
                }
            });
            
            if (index.length === 0) {
                parts.push({ type: 'text', text: 'No characters yet.', style: { fontSize: '12px', opacity: '0.6', marginBottom: '8px' } });
            }
            
            // 3. FILTER & SORT LOGIC
            let displayIndex = index.filter(Boolean);
            
            if (searchQuery) {
                const sq = searchQuery.toLowerCase();
                displayIndex = displayIndex.filter(m => (m.name || '').toLowerCase().includes(sq));
            }

            displayIndex.sort(function(a, b) {
                // Tier 0 Sort: Protagonist always at the absolute top
                if (a.isProtagonist !== b.isProtagonist) return a.isProtagonist ? -1 : 1;

                // Tier 1 Sort: Pinned
                const aPinned = !!(a as any).pinned;
                const bPinned = !!(b as any).pinned;
                if (aPinned !== bPinned) return aPinned ? -1 : 1;
                
                // Tier 2 Sort: Scene Present
                const aScene = !!a.scenePresent;
                const bScene = !!b.scenePresent;
                if (aScene !== bScene) return aScene ? -1 : 1;
                
                // Tier 3 Sort: Fallback to underlying array order (retains natural order)
                return 0; 
            });

            // 4. RENDER CARDS
            for (let i = 0; i < displayIndex.length; i++) {
                const meta = displayIndex[i];
                if (meta) {
                    // Extract global position so Up/Down manual-sort buttons know true array bounds
                    const globalPos = index.findIndex(m => m.id === meta.id);
                    parts.push(buildCharCard(meta, cfg, entIdx, globalPos, index.length)); 
                }
            }

    } catch (e) {
        api.v1.error('[AE] Roster render error:', e);
        parts.push({ type: 'box', style: { backgroundColor: 'rgba(255,107,107,0.1)', padding: '12px', borderRadius: '6px', margin: '8px 0' }, content: [
            { type: 'text', text: 'Roster failed to load', style: { fontWeight: 'bold', fontSize: '12px', color: '#ff6b6b', marginBottom: '4px' } },
            { type: 'text', text: String(e), style: { fontSize: '10px', fontFamily: 'monospace', opacity: '0.8', whiteSpace: 'pre-wrap', color: '#ff6b6b' } }
        ] });
    }
    return parts.filter(Boolean) as UIPart[];
}

// ============================================================================
// SECTION 20b \u2014 WORKSPACE SHELL  [v1.10.0]
// One full-screen modal hosts the "workspace" surfaces, swapped in place via
// handle.update() (api.v1.ui.modal.open). buildWorkspaceNav() gives every
// workspace a persistent collapsible cross-nav so any destination is two taps
// away. refreshSidebar() (Section 20) also calls refreshWorkspace() so the open
// workspace re-renders on any state change \u2014 existing refreshSidebar() call
// sites therefore update both surfaces with no change. Roster / Drama /
// Locations & Entities / Action Studio render through the shell; Wizard /
// Settings / Bestiary still open their own modals (Phase B folds them in).
// ============================================================================

var WORKSPACE_DEFS: { id: string; label: string; iconId: string; shell: boolean }[] = [
    { id: 'wizard',   label: 'World-Build Wizard',       iconId: 'message-square', shell: false },
    { id: 'settings', label: 'Settings',                 iconId: 'settings',       shell: true  },
    { id: 'roster',   label: 'Character Roster',         iconId: 'users',          shell: true  },
    { id: 'drama',    label: 'Drama Manager',            iconId: 'frown',            shell: true  },
    { id: 'entities', label: 'Locations & Entities',     iconId: 'globe',          shell: true  }
    // [CE-STRIP v2.11.0] 'factions' entry removed — folded into the Settings workspace
    // as a section (buildSettingsWorkspace calls buildFactionsWorkspace internally now).
    // [CE-STRIP v2.1.6] 'bestiary' (NPC & Item Templates) entry removed — Bestiary + Item Templates cut.
    // [CE-STRIP v2.0.0] 'actions' (Action Studio) entry removed — no longer navigable.
    // The modal code itself (SECTION "3") is still physically present pending a full
    // deletion pass; this just takes it out of reach so it's no longer "visually there."
];

var _aeWorkspaceHandle: any = null;
var _aeWorkspaceId: string = '';

function _aeWorkspaceOpen(): boolean {
    return !!(_aeWorkspaceHandle && (typeof _aeWorkspaceHandle.isClosed !== 'function' || !_aeWorkspaceHandle.isClosed()));
}

async function _aeCloseWorkspace(): Promise<void> {
    try { if (_aeWorkspaceOpen() && typeof _aeWorkspaceHandle.close === 'function') { await _aeWorkspaceHandle.close(); } } catch (e) {}
    _aeWorkspaceHandle = null;
    _aeWorkspaceId = '';
}

async function workspaceBody(id: string): Promise<UIPart[]> {
    if (id === 'settings') return await buildSettingsWorkspace();
    if (id === 'roster')   return await buildRosterWorkspace();
    if (id === 'drama')    return await buildDramaTabContent();
    if (id === 'entities') return await buildEntitiesTab();
    // [CE-STRIP v2.11.0] 'factions' routing removed — buildFactionsWorkspace is now
    // called internally by buildSettingsWorkspace instead of being its own shell page.
    // [CE-STRIP v2.0.0] 'actions' routing removed — Action Studio cut.
    return [{ type: 'text', text: 'This workspace has no shell renderer.' } as UIPart];
}

function buildWorkspaceNav(currentId: string): UIPart {
    var cells: UIPart[] = WORKSPACE_DEFS.map(function(d) {
        var on = d.id === currentId;
        return { type: 'button', text: d.label, iconId: d.iconId as any, disabled: on, style: { flex: '1 1 46%', margin: 0, fontSize: '11px', padding: '6px 8px', textAlign: 'left', fontWeight: on ? 'bold' : 'normal', backgroundColor: on ? 'rgba(126,200,160,0.15)' : 'transparent', border: on ? '1px solid #7ec8a0' : '1px solid rgba(255,255,255,0.12)', borderRadius: '4px', opacity: on ? '1' : '0.8' }, callback: async function() { await launchWorkspace(d.id); } } as UIPart;
    });
    cells.push({ type: 'button', text: 'Help', iconId: 'help-circle', style: { flex: '1 1 46%', margin: 0, fontSize: '11px', padding: '6px 8px', textAlign: 'left', backgroundColor: 'transparent', border: '1px solid rgba(255,255,255,0.12)', borderRadius: '4px', opacity: '0.8' }, callback: async function() { await openWorkspaceHelp(currentId); } } as UIPart);
    return { type: 'row', wrap: true, style: { gap: '6px', marginBottom: '12px', paddingBottom: '10px', borderBottom: '1px solid rgba(255,255,255,0.1)' }, content: cells } as UIPart;
}

async function renderWorkspace(id: string): Promise<void> {
    _aeWorkspaceId = id;
    var def = WORKSPACE_DEFS.filter(function(d) { return d.id === id; })[0];
    var title = def ? def.label : 'Workspace';
    var body: UIPart[];
    try { body = await workspaceBody(id); }
    catch (e) {
        api.v1.error('[AE] workspace render error:', e);
        body = [{ type: 'box', style: { backgroundColor: 'rgba(255,107,107,0.1)', padding: '12px', borderRadius: '6px' }, content: [
            { type: 'text', text: 'Workspace failed to load', style: { fontWeight: 'bold', color: '#ff6b6b', marginBottom: '4px' } },
            { type: 'text', text: String(e), style: { fontSize: '10px', fontFamily: 'monospace', opacity: '0.8', whiteSpace: 'pre-wrap', color: '#ff6b6b' } }
        ] } as UIPart];
    }
    var content: UIPart[] = [buildWorkspaceNav(id)].concat(body);
    if (_aeWorkspaceOpen() && typeof _aeWorkspaceHandle.update === 'function') {
        try { await _aeWorkspaceHandle.update({ title: title, content: content }); return; }
        catch (e) { _aeWorkspaceHandle = null; }
    }
    try {
        _aeWorkspaceHandle = await openEngineModal({ id: 'ae-workspace', title: title, size: 'full', content: content });
        if (_aeWorkspaceHandle && _aeWorkspaceHandle.closed && typeof _aeWorkspaceHandle.closed.then === 'function') {
            _aeWorkspaceHandle.closed.then(function() { _aeWorkspaceHandle = null; _aeWorkspaceId = ''; });
        }
    } catch (openErr) {
        _aeWorkspaceHandle = null; _aeWorkspaceId = '';
        api.v1.error('[AE] workspace modal open failed:', openErr);
        try { api.v1.ui.toast('Could not open ' + title + '. ' + String(openErr), { type: 'error' }); } catch (e2) {}
    }
}

async function openWorkspace(id: string): Promise<void> {
    await renderWorkspace(id);
}

async function refreshWorkspace(): Promise<void> {
    if (_aeWorkspaceOpen() && _aeWorkspaceId) { await renderWorkspace(_aeWorkspaceId); }
}

async function launchWorkspace(id: string): Promise<void> {
    var def = WORKSPACE_DEFS.filter(function(d) { return d.id === id; })[0];
    if (def && def.shell) { await openWorkspace(id); return; }
    await _aeCloseWorkspace();
    try {
        if (id === 'wizard')   { await openWizardModal(); return; }
        // [CE-STRIP v2.11.0] 'settings' special-case removed — settings is shell:true
        // now (see WORKSPACE_DEFS) and routes through the generic path above via
        // buildSettingsWorkspace, which merges the old World Settings + System
        // Settings + Factions Manager into one workspace.
        // [CE-STRIP v2.1.6] 'bestiary' route dispatch removed — Bestiary + Item Templates cut.
    } catch (e) { api.v1.error('[AE] launchWorkspace legacy:', e); }
}

function _wsHelpLine(label: string, body: string): UIPart[] {
    return [
        { type: 'text', text: label, style: { fontWeight: 'bold', fontSize: '12px' } } as UIPart,
        { type: 'text', text: body, style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } } as UIPart
    ];
}

// [v1.19.1 WSHELP] Expanded every workspace's Help modal from a one-liner into a
// short walkthrough (still no code/mechanics detail) matching what that workspace
// actually contains today, and added the 'factions' entry that was missing entirely
// (Factions Manager's Help button previously fell through to the "no help yet" toast).
var WORKSPACE_HELP: { [k: string]: { title: string; parts: UIPart[] } } = {
    roster: { title: 'Character Roster Help', parts: ([
        { type: 'text', text: 'The master list of every character in your world. Use + Add Character for a full dossier \u2014 identity, narrative profile, attributes, resources, relationship. Roster order is manual (Up/Down), with the protagonist and pinned characters always sorted first.', style: { marginBottom: '8px' } } as UIPart
    ] as UIPart[])
        .concat(_wsHelpLine('Active', 'Removes the character from all context injections entirely, as if they do not exist.'))
        .concat(_wsHelpLine('Scene', 'Manually overrides scene presence. Resets automatically when you change locations.'))
        .concat(_wsHelpLine('Dynamic', 'Toggles all background AI updates for this character (thoughts, goals, hooks).'))
        .concat(_wsHelpLine('Location', 'Changes where the character body sits in the world graph.'))
        .concat(_wsHelpLine('Kill', 'Sets the character Inactive, drops inventory at their last location, and moves the body to a Graveyard location. Restore by moving them out and setting Active again.')) },
    drama: { title: 'Drama Manager Help', parts: ([
        { type: 'text', text: 'Author the pressure in your story: character hooks, narrative arcs, and the relationship web that links your cast together. Three collapsible sections:', style: { fontSize: '12px', lineHeight: '1.5', marginBottom: '8px' } } as UIPart
    ] as UIPart[])
        .concat(_wsHelpLine('Hook Queue', 'Active dramatic tensions on a character. Pressure 85+ (Critical) injects directly into the Author\u2019s Note alongside that character\u2019s thoughts. Below 85%, hooks are tracked here but not currently injected into context. Resolve a hook once the story pays it off.'))
        .concat(_wsHelpLine('NPC Web', 'Bilateral dynamics between two characters \u2014 rivalries, alliances, unspoken history. High-priority (70+) links between two present characters still inject via the Imperative splice; lower-priority links are tracked here but not currently injected.'))
        .concat(_wsHelpLine('Narrative Threads', 'The quest tree: nested story threads shown \ud83d\udd12 Locked, \ud83d\udd25 Active, or \u2705 Completed. Tracking/state only \u2014 thread descriptions are not currently injected into context.')) },
    entities: { title: 'Locations & Entities Help', parts: ([
        { type: 'text', text: 'The world graph: locations, items, and narrative objects, nested tree-style \u2014 a region holds settlements, a settlement holds buildings, a building holds rooms. Travel and adjacency are computed from this structure automatically.', style: { fontSize: '12px', lineHeight: '1.5', marginBottom: '8px' } } as UIPart
    ] as UIPart[])
        .concat(_wsHelpLine('Create Entity', 'Adds a blank entity anywhere in the tree \u2014 for items, narrative objects, or a location you want full manual control over.'))
        .concat(_wsHelpLine('Map', 'A room-centered visual view for authoring locations. + New Location spawns a sibling (same tier, no extra adjacency) or a child (nested inside), generated from context or written by hand.'))
        .concat(_wsHelpLine('Description vs. Lorebook', 'Description is what a camera senses on arrival \u2014 shown only while the player is there. The Lorebook Entry is deeper hidden history that fires whenever the place is named, even from afar. Keep the two from repeating each other.')) },
    // [BUGFIX v2.26.0] The 'actions' entry (Action Studio Help — Stakes/Action Library/
    // Four Fs/2d6+Modifier) is REMOVED. It was already flagged as unreachable (no button
    // routes to an 'actions' workspace since [CE-STRIP v2.0.0] — see the note near the
    // workspace tab list) and its content was already flagged as stale (describing the
    // long-removed Action Studio in detail). Deleting rather than relocating: whether any
    // 2d6+F skill-check mechanic still runs anywhere in current Character Engine is itself
    // unclear post-CE-STRIP (actionTemplates/stakeDefs no longer exist on GlobalConfig),
    // so relocating this content risks documenting a mechanic that no longer executes.
    // NOT touched, flagging rather than guessing: the 'help' tab's Icon Library panel
    // still points here ("See Action Studio → Help") — that dead-end needs the same
    // "does 2d6+F still run anywhere" answer before it can be fixed correctly.
    wizard: { title: 'World-Build Wizard Help', parts: [
        { type: 'text', text: 'Chat-driven world generation. Set your project name and concept on the landing page, then work through Topics here \u2014 each chat feeds a matching generator: Species, Factions, Locations, Characters, Drama, Intro.', style: { fontSize: '12px', lineHeight: '1.5', marginBottom: '8px' } } as UIPart,
        { type: 'text', text: 'Every batch is a draft \u2014 review, edit, or discard each result in the gallery before anything commits to your world or lorebook.', style: { fontSize: '12px', lineHeight: '1.5' } } as UIPart
    ] },
    settings: { title: 'Settings Help', parts: ([
        { type: 'text', text: 'World-authoring, Factions, and System settings live together here now. World: Species, Relationship Archetypes, Conditions, Lorebook Additions, and any custom sheet fields you\u2019ve defined. Factions: name, description, an ordered relationship ladder (cold \u2192 warm), and an optional lorebook entry per faction \u2014 each character\u2019s own standing with a faction is set from their Edit Profile screen, not here. System: generation timing intervals, the general style prompt, static field instructions/budgets, and the default scene background.', style: { fontSize: '12px', lineHeight: '1.5' } } as UIPart
    ] as UIPart[]) },
    // [CE-STRIP v2.11.0] 'factions' WORKSPACE_HELP entry removed — Factions Manager is
    // no longer its own workspace, folded into 'settings' above. (It was already stale:
    // described a Holding Document that CE-STRIP v2.0.x removed long before this pass.)
};

// [BUGFIX v2.26.0] openWorkspaceHelp was CALLED by every workspace's Help button
// (buildWorkspaceShell's action row, `callback: async function() { await
// openWorkspaceHelp(currentId); }`) but never DEFINED anywhere in the file — flagged
// as a real bug in an earlier pass (see the note above this pass's own additions) but
// left alone pending "what should the Help button chain actually do now" — answered:
// nothing special: a straight WORKSPACE_HELP[id] lookup into a modal is all any current
// workspace needs, now that 'actions' (the one entry that wanted special-case behavior,
// openActionStudioHelp — also never defined, also never called from anywhere but this
// same dead comment) is gone. Tapping Help previously threw a ReferenceError, surfaced
// by NAI as "Error in user script ... in UI callback ... unwrapResult".
async function openWorkspaceHelp(id: string): Promise<void> {
    const entry = WORKSPACE_HELP[id];
    if (!entry) { api.v1.ui.toast('No help available for this section.', { type: 'info', autoClose: 2500 }); return; }
    await openEngineModal({ id: 'ae-workspace-help', title: entry.title, size: 'medium', content: entry.parts });
}

// [CE-STRIP v2.0.0] Action Studio (buildActionTab, buildStakeTrackItems,
// stakeTrackDisplayLabel, buildCharResWidget, the whole UIRuleManifest condition/
// effect catalog and its arg-rendering helpers, openActionBuilderModal, and the
// Action Studio Help modal) fully removed. The workspace nav entry was already
// removed earlier in this pass, so this was unreachable; now it's gone outright.
// Every external caller (Entry Action / Travel Action buttons, EVT_RUN_ACTION_
// INSTANCE, RUN_QUICK_INSTANCE, the native Available-Actions/Quick-Action-Composer
// buttons) was traced and fixed or confirmed already-unreachable earlier in this pass.

async function moveChar(id: string, direction: number) {
    const idx = await loadIndex();
    const pos = idx.findIndex(m => m.id === id);
    if (pos < 0) return;
    const newPos = pos + direction;
    if (newPos < 0 || newPos >= idx.length) return;
    
    const temp = idx[pos];
    idx[pos] = idx[newPos];
    idx[newPos] = temp;
    
    await saveIndex(idx);
    await refreshSidebar();
}

// ── Characters Tab: Card & Kill ──────────────────────────────────────────────

function buildCharCard(meta: any, cfg: GlobalConfig, entIdx: any[], idxPos: number, idxLength: number): UIPart {
    const isScene = meta.scenePresent;
    const isPinned = !!meta.pinned;
    const isStatic = !!meta.isStatic;
    const isProtag = !!meta.isProtagonist;
    let avatarCol: UIPart | null = null;
    
    // Left edge highlight for scene presence (Major/Minor logic removed)
    const cardBorderLeft = isScene ? '4px solid #7ec8a0' : '4px solid rgba(255,255,255,0.05)';

    // ── RIGHT COLUMN ──────────────────────────────────────────────────
    // Row 1: Name + Dynamic/Static + Pin
    const hasCritHookMeta = !!meta.hasCriticalHook;
    const protagPrefix = isProtag ? '👑 ' : '';
    const nameRow: UIPart = { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
        { type: 'text', text: protagPrefix + (hasCritHookMeta ? '🔥 ' : '') + (meta.name || 'Unnamed'), style: { fontSize: '13px', fontWeight: 'bold', flex: '1 1 0', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis', color: isProtag ? '#ffb432' : undefined } },
        { type: 'button', text: isStatic ? '▫️Static' : '⚡️Dynamic', style: { margin: 0, padding: '2px 4px', fontSize: '9px', backgroundColor: isStatic ? 'rgba(255,255,255,0.05)' : 'rgba(136,204,255,0.15)', color: isStatic ? '#888' : '#88ccff', border: 'none' }, callback: async function() {
            const f = await loadCharacter(meta.id); if (!f) return;
            f.isStatic = !f.isStatic;
            // Master gate: flip all dynamic flags in sync with card toggle
            const nowDynamic = !f.isStatic;
            f.charContextEnabled = nowDynamic;
            f.autoUpdateEnabled = nowDynamic;
            f.autoThoughtsEnabled = nowDynamic;
            f.hooksEnabled = nowDynamic;
            await saveCharacter(f);
            
            // Sync to index for immediate UI refresh
            const idx = await loadIndex();
            const mMatch = idx.find(function(m) { return m.id === meta.id; });
            if (mMatch) { (mMatch as any).isStatic = f.isStatic; await saveIndex(idx); }
            await refreshSidebar();
        } },
        // [vNEXT] Dynamic-priority rank. Hidden for the protagonist (never dynamic).
        // Shows the current rank or a neutral marker when unranked; tapping opens the
        // swap-enforced rank picker.
        (isProtag) ? { type: 'text', text: '', style: { width: '0px' } } : { type: 'button', text: (typeof meta.dynamicPriorityRank === 'number' && meta.dynamicPriorityRank > 0) ? ('#' + meta.dynamicPriorityRank) : '#–', style: { margin: 0, padding: '2px 4px', fontSize: '9px', backgroundColor: (typeof meta.dynamicPriorityRank === 'number' && meta.dynamicPriorityRank > 0) ? 'rgba(232,168,124,0.15)' : 'rgba(255,255,255,0.05)', color: (typeof meta.dynamicPriorityRank === 'number' && meta.dynamicPriorityRank > 0) ? '#e8a87c' : '#888', border: 'none' }, callback: async function() {
            await openDynamicRankPicker(meta.id, async function() { await refreshSidebar(); });
        } },
        { type: 'button', text: (isPinned || isProtag) ? '📌' : '📌', style: { margin: 0, padding: '2px 4px', fontSize: '10px', backgroundColor: 'transparent', opacity: (isPinned || isProtag) ? '1' : '0.3', border: 'none' }, disabled: isProtag, callback: async function() {
            const f = await loadCharacter(meta.id); if (!f) return;
            f.pinned = !f.pinned; await saveCharacter(f);
            
            const idx = await loadIndex();
            const mMatch = idx.find(function(m) { return m.id === meta.id; });
            if (mMatch) { (mMatch as any).pinned = f.pinned; await saveIndex(idx); }
            await refreshSidebar();
        } }
    ] };

    // Row 2: Species, Age, Gender, Role
    let detailsArr: string[] = [];
    if (meta.species) detailsArr.push(meta.species);
    if (meta.age) detailsArr.push(meta.age);
    if (meta.gender) detailsArr.push(meta.gender);
    if (meta.occupationRole) detailsArr.push(meta.occupationRole);
    const detailsStr = detailsArr.length > 0 ? detailsArr.join(' · ') : 'No details';
    
    const descRow: UIPart = { type: 'text', text: detailsStr, style: { fontSize: '10px', opacity: '0.6', marginBottom: '4px', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } };

    // Row 3: Equipped items (if any)
    const equipped = (meta.equippedItemNames || []).filter(Boolean);
    const equipRow: UIPart | null = equipped.length > 0 ? {
        type: 'text', text: `🎒 ${equipped.join(', ')}`, style: { fontSize: '10px', opacity: '0.6', marginBottom: '4px', fontStyle: 'italic', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }
    } : null;

    // Row 4: Action Row (Scene Toggle + Location + Kill + Sort + Edit)
    const locName = meta.currentLocationId
        ? ((entIdx || []).find(function(l: any) { return l.id === meta.currentLocationId; })?.name || 'Unknown')
        : 'No Location';

    const sceneBtn: UIPart = {
        type: 'button',
        text: isScene ? '🟢 Scene' : '⚫ Away',
        style: { margin: 0, padding: '4px 6px', fontSize: '10px', backgroundColor: isScene ? 'rgba(126,200,160,0.15)' : 'rgba(255,255,255,0.05)', color: isScene ? '#7ec8a0' : '#888', border: 'none' },
        callback: async function() {
            const f = await loadCharacter(meta.id); if (!f) return;
            f.scenePresent = !f.scenePresent; await saveCharacter(f); await refreshSidebar();
        }
    };

    const locationBtn: UIPart = { type: 'button', text: `📍 ${locName}`, style: { flex: '1 1 0', margin: 0, padding: '4px 6px', fontSize: '10px', textAlign: 'left', opacity: '0.8', borderRadius: '4px', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }, callback: async function() {
        const freshEntIdx = await loadEntityIndex();
        // [BUGFIX v2.26.0] Same fix as the character edit modal's Set Location picker —
        // was `n.type !== 'character'`, which let items and narrative threads show up
        // as location options. Only type==='location' entities are valid spatial parents.
        const spatialNodes = freshEntIdx.filter(function(n: any) { return n.type === 'location'; });
        const pm = await openEngineModal({ title: 'Set Location', size: 'medium', content: [
            { type: 'button', text: '✕ No Location', style: { width: '100%', marginBottom: '8px' }, callback: async function() {
                const f = await loadCharacter(meta.id); if (!f) { pm.close(); return; }
                if (f.entityId) { let locEnt = await loadEntity(f.entityId); if (locEnt) { locEnt.parentId = null; await saveEntity(locEnt); } }
                await saveCharacter(f); await recalculateScenePresence(); pm.close(); await refreshSidebar();
            } },
            ...spatialNodes.filter(Boolean).map(function(l: any) {
                return { type: 'button', text: `📍 ${l.name}`, style: { width: '100%', marginBottom: '2px', textAlign: 'left', backgroundColor: meta.currentLocationId === l.id ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() {
                    const f = await loadCharacter(meta.id); if (!f) { pm.close(); return; }
                    if (f.entityId) { let locEnt2 = await loadEntity(f.entityId); if (locEnt2) { locEnt2.parentId = l.id; await saveEntity(locEnt2); } }
                    await saveCharacter(f); await recalculateScenePresence(); pm.close(); await refreshSidebar();
                } } as UIPart;
            })
        ]});
    } };

    const actionRowContent: UIPart[] = [ sceneBtn, locationBtn ];
    if (!isProtag) {
        actionRowContent.push({
            type: 'button', text: '💀', style: { margin: 0, padding: '4px 6px', fontSize: '11px', backgroundColor: 'transparent', color: '#ff6b6b', border: '1px solid rgba(255,107,107,0.2)' },
            callback: async function() { await killCharacter(meta.id); await refreshSidebar(); }
        } as UIPart);
    }
    actionRowContent.push(
        { type: 'button', iconId: 'arrow-up', style: { margin: 0, padding: '4px', backgroundColor: 'transparent', opacity: idxPos > 0 ? '1' : '0.2' }, disabled: idxPos === 0, callback: async function() { await moveChar(meta.id, -1); } },
        { type: 'button', iconId: 'arrow-down', style: { margin: 0, padding: '4px', backgroundColor: 'transparent', opacity: idxPos < idxLength - 1 ? '1' : '0.2' }, disabled: idxPos >= idxLength - 1, callback: async function() { await moveChar(meta.id, 1); } },
        { type: 'button', iconId: 'edit-2', style: { margin: 0, padding: '4px', backgroundColor: 'transparent' }, callback: async function() { await openCharEditModal(meta.id); } }
    );

    const actionRow: UIPart = { type: 'row', alignment: 'center', style: { gap: '4px', marginTop: '4px' }, content: actionRowContent };

    const rightCol: UIPart = { type: 'column', style: { flex: '1 1 0', gap: '0', overflow: 'hidden' }, content: [
        nameRow, descRow,
        ...(equipRow ? [equipRow] : []),
        actionRow
    ] };

    return {
        type: 'box',
        style: { marginBottom: '8px', padding: '8px', borderRadius: '8px', backgroundColor: 'rgba(255,255,255,0.02)', border: '1px solid rgba(255,255,255,0.05)', borderLeft: cardBorderLeft, opacity: meta.active ? '1' : '0.45' },
        content: [{ type: 'row', style: { gap: '10px' }, content: avatarCol ? [avatarCol, rightCol] : [rightCol] }]
    };
}

// ============================================================================
// [vNEXT] FREEFORM SCENE NPC SPAWNING
// [CE-STRIP vNEXT] Minor-NPC tier retired — the "+ Add Character Here" flow now
// creates an ordinary CharacterRecord with normal defaults (dynamic, full
// lorebook/dossier fallback via buildSceneLorebookActivation's standard
// per-character path, same as a character made any other way). No more
// starved-record/promote lifecycle — there is nothing to promote FROM anymore.
// ============================================================================

// [vNEXT] Expand {a|b|c} alternation groups in a template string, picking one
// option per group via the seeded RNG. Runs ONCE at spawn time and the result is
// baked into the record — deliberately kept out of the live |macro| evaluator,
// which re-evaluates every generation and would re-roll the choice each turn.
function aeExpandAlternations(txt: string): string {
    let outAlt = String(txt || '');
    let guardAlt = 0;
    while (guardAlt < 24) {
        let mAlt = outAlt.match(/\{([^{}|]*(?:\|[^{}|]*)+)\}/);
        if (!mAlt) break;
        let optsAlt = mAlt[1].split('|');
        let idxAlt = 0;
        try { idxAlt = api.v1.random.roll('1d' + optsAlt.length).total - 1; } catch (eAlt) { idxAlt = 0; }
        if (idxAlt < 0 || idxAlt >= optsAlt.length) idxAlt = 0;
        let posAlt = (typeof mAlt.index === 'number') ? mAlt.index : 0;
        outAlt = outAlt.substring(0, posAlt) + optsAlt[idxAlt].trim() + outAlt.substring(posAlt + mAlt[0].length);
        guardAlt++;
    }
    return outAlt;
}

async function spawnSceneNpc(name: string, brief: string, locId: string | null, quiet?: boolean): Promise<{ id: string; name: string } | null> {
    try {
        const cfg = await loadConfig();
        if (!locId) { locId = await aeGetPlayerRoomId(); }   // [vNEXT] default to the player's actual room
        let baseName = aeExpandAlternations(name || 'Someone').trim();
        if (!baseName) baseName = 'Someone';
        let finalBrief = aeExpandAlternations(brief || '').trim();

        // Numbered suffix on collision with any active character (Skeleton, Skeleton 2...).
        const nsIdx = await loadIndex();
        let finalName = baseName;
        let nsN = 2;
        while (nsIdx.some(function(m) { return !!m && m.active && (m.name || '') === finalName; }) && nsN < 50) {
            finalName = baseName + ' ' + nsN;
            nsN++;
        }

        const body = makeDefaultEntity(finalName);
        body.type = 'character';
        body.parentId = locId ? locId : null;
        body.description = finalBrief;
        await saveEntity(body);

        const rec = makeDefaultCharacter(finalName, cfg);
        rec.entityId = body.id;
        rec.briefDescription = finalBrief;
        rec.active = true;
        rec.scenePresent = true;
        await saveCharacter(rec);

        await recalculateScenePresence();
        queueSceneStateBroadcast();
        if (!quiet) api.v1.ui.toast('Character "' + finalName + '" added.', { type: 'success', autoClose: 2000 });
        return { id: rec.id, name: finalName };
    } catch (e) {
        api.v1.error('[AE] spawnSceneNpc:', e);
        api.v1.ui.toast('Failed to add character.', { type: 'error' });
        return null;
    }
}

// [vNEXT] Scene-grounded NPC generator. Uses generateWithStory in 'background' mode
// (same path as generateCharacterSnapshot) so the model sees the live story +
// location and invents someone who fits the moment. Returns a {name, brief} for
// review/spawn; does NOT create anything itself.
async function generateSceneNpc(): Promise<{ name: string; brief: string } | null> {
    try {
        let gsLocName = 'the current location';
        let gsLocDesc = '';
        let gsLocId = await api.v1.storyStorage.getOrDefault(STORAGE_PLAYER_LOC, null) as string | null;
        if (gsLocId) {
            let gsLocEnt = await loadEntity(gsLocId);
            if (gsLocEnt) { gsLocName = gsLocEnt.name || gsLocName; gsLocDesc = gsLocEnt.description || ''; }
        }
        let gsCfg = await loadConfig();
        let gsSys: string[] = [
            gsCfg.generalStyle || '',
            '',
            'You invent ONE background character who would plausibly be present in the current scene.',
            'Base them on what is actually happening in the story right now and on the location.',
            'Output EXACTLY two lines and nothing else, no preamble:',
            'NAME: <a short name or label, e.g. Gate Guard, Mara, Hooded Vendor>',
            'DOING: <one present-tense sentence describing what they are doing here and why>'
        ];
        let gsUsr: string[] = [
            'Location: ' + gsLocName,
            gsLocDesc ? 'Setting: ' + gsLocDesc.slice(0, 160) : '',
            'Invent a fitting NPC now. Two lines only.'
        ].filter(Boolean);

        let gsResp = await api.v1.generateWithStory(
            [{ role: 'system', content: gsSys.join('\n') }, { role: 'user', content: gsUsr.join('\n') }],
            { model: 'glm-4-6', max_tokens: 120 },
            { suppressScriptHooks: 'self', contextLimitReduction: 450 },
            undefined,
            'background'
        );
        let gsTxt = (gsResp && gsResp.choices && gsResp.choices.length > 0) ? String(gsResp.choices[0].text || '') : '';
        if (!gsTxt.trim()) return null;

        let gsName = '';
        let gsBrief = '';
        gsTxt.split('\n').forEach(function(ln) {
            let t = ln.trim();
            let up = t.toUpperCase();
            if (up.indexOf('NAME:') === 0) gsName = t.substring(5).trim();
            else if (up.indexOf('DOING:') === 0) gsBrief = t.substring(6).trim();
        });
        if (!gsName || !gsBrief) {
            let gsLines = gsTxt.split('\n').map(function(s) { return s.trim(); }).filter(Boolean);
            if (!gsName && gsLines.length > 0) gsName = gsLines[0].replace(/^NAME:\s*/i, '');
            if (!gsBrief && gsLines.length > 1) gsBrief = gsLines.slice(1).join(' ').replace(/^DOING:\s*/i, '');
        }
        gsName = gsName.replace(/^["'\s\-]+/, '').replace(/["'\s]+$/, '').slice(0, 60);
        gsBrief = gsBrief.replace(/^["'\s\-]+/, '').slice(0, 240);
        if (!gsName) return null;
        return { name: gsName, brief: gsBrief };
    } catch (e) {
        api.v1.error('[AE] generateSceneNpc:', e);
        api.v1.ui.toast('Scene generation failed.', { type: 'error' });
        return null;
    }
}

// [CE-STRIP v2.1.6] NPC Archetype editor (aeMutateArchetype/buildArchetypeEditContent/refreshArchetypeEditModal/openArchetypeEditModal), Bestiary modal (buildBestiaryContent/refreshBestiaryModal/openBestiaryModal), and Item Template mutator (aeMutateItemArchetype) all removed — Bestiary + Item Templates cut.

// Spawn one item from a template. Target defaults to the player's inventory (parented
// to the protagonist's body); a template may instead choose the current room, where the
// loose item becomes pick-up-able via the library Pick Up action. {a|b|c} alternations
// in name/description are rolled once, here, and baked into the copy.
async function spawnItem(name: string, desc: string, quiet?: boolean, explicitParentId?: string | null): Promise<{ id: string; name: string } | null> {
    try {
        // Target resolution: an explicit entity id (e.g. the inspected room) wins; the
        // sentinels '__room__' / '__inventory__' force a mode; default is inventory (the
        // protagonist's body).
        // [FIX v1.19.0] spTarget used to be declared inside the `else` below, so the
        // explicit-parent-id branch (the exact path AE_HUD_SPAWN_ENTITY takes) skipped
        // its declaration entirely -- saveEntity succeeded but the toast line threw a
        // ReferenceError, surfacing as "Failed to add item." on a spawn that actually
        // worked. Hoisted to outer scope; explicit parent counts as 'room' (a place in
        // the world, not the protagonist's body).
        let target: string | null = null;
        let spTarget: string;
        if (explicitParentId && explicitParentId !== '__inventory__' && explicitParentId !== '__room__') {
            target = explicitParentId;
            spTarget = 'room';
        } else {
            if (explicitParentId === '__room__') spTarget = 'room';
            else spTarget = 'inventory';
            if (spTarget === 'room') {
                target = await aeGetPlayerRoomId();
            } else {
                const spChars = await loadAllCharacters();
                const spProtag = spChars.find(function(c) { return c.isProtagonist; });
                target = (spProtag && spProtag.entityId) ? spProtag.entityId : await aeGetPlayerRoomId();
            }
        }

        let baseName = aeExpandAlternations(name || 'Item').trim();
        if (!baseName) baseName = 'Item';
        let finalDesc = aeExpandAlternations(desc || '').trim();

        // Numbered suffix on collision with any item already in the same container.
        const siIdx = await loadEntityIndex();
        let finalName = baseName;
        let siN = 2;
        while (siIdx.some(function(m) { return !!m && m.type === 'item' && m.parentId === target && (m.name || '') === finalName; }) && siN < 50) {
            finalName = baseName + ' ' + siN;
            siN++;
        }

        const body = makeDefaultEntity(finalName);
        body.type = 'item';
        body.parentId = target ? target : null;
        body.description = finalDesc;
        await saveEntity(body);

        queueSceneStateBroadcast();
        if (!quiet) api.v1.ui.toast('Item \u201c' + finalName + '\u201d added' + (spTarget === 'room' ? ' to the room.' : ' to inventory.'), { type: 'success', autoClose: 2000 });
        return { id: body.id, name: finalName };
    } catch (e) {
        api.v1.error('[AE] spawnItem:', e);
        api.v1.ui.toast('Failed to add item.', { type: 'error' });
        return null;
    }
}

// Scene-grounded item generator. Same background path as generateSceneNpc: reads the
// live location, invents an item that fits the moment, returns {name, desc} for
// review/spawn. Creates nothing itself.
async function generateSceneItem(): Promise<{ name: string; desc: string } | null> {
    try {
        let giLocName = 'the current location';
        let giLocDesc = '';
        let giLocId = await api.v1.storyStorage.getOrDefault(STORAGE_PLAYER_LOC, null) as string | null;
        if (giLocId) {
            let giLocEnt = await loadEntity(giLocId);
            if (giLocEnt) { giLocName = giLocEnt.name || giLocName; giLocDesc = giLocEnt.description || ''; }
        }
        let giCfg = await loadConfig();
        let giSys: string[] = [
            giCfg.generalStyle || '',
            '',
            'You invent ONE item that would plausibly be found in the current scene.',
            'Base it on what is actually happening in the story right now and on the location.',
            'Output EXACTLY two lines and nothing else, no preamble:',
            'NAME: <a short item name, e.g. Rusted Key, Silk Scarf, Hunting Knife>',
            'DESC: <one sentence describing what it is and its notable qualities>'
        ];
        let giUsr: string[] = [
            'Location: ' + giLocName,
            giLocDesc ? 'Setting: ' + giLocDesc.slice(0, 160) : '',
            'Invent a fitting item now. Two lines only.'
        ].filter(Boolean);

        let giResp = await api.v1.generateWithStory(
            [{ role: 'system', content: giSys.join('\n') }, { role: 'user', content: giUsr.join('\n') }],
            { model: 'glm-4-6', max_tokens: 120 },
            { suppressScriptHooks: 'self', contextLimitReduction: 450 },
            undefined,
            'background'
        );
        let giTxt = (giResp && giResp.choices && giResp.choices.length > 0) ? String(giResp.choices[0].text || '') : '';
        if (!giTxt.trim()) return null;

        let giName = '';
        let giDesc = '';
        giTxt.split('\n').forEach(function(ln) {
            let t = ln.trim();
            let up = t.toUpperCase();
            if (up.indexOf('NAME:') === 0) giName = t.substring(5).trim();
            else if (up.indexOf('DESC:') === 0) giDesc = t.substring(5).trim();
        });
        if (!giName || !giDesc) {
            let giLines = giTxt.split('\n').map(function(s2) { return s2.trim(); }).filter(Boolean);
            if (!giName && giLines.length > 0) giName = giLines[0].replace(/^NAME:\s*/i, '');
            if (!giDesc && giLines.length > 1) giDesc = giLines.slice(1).join(' ').replace(/^DESC:\s*/i, '');
        }
        giName = giName.replace(/^["'\s\-]+/, '').replace(/["'\s]+$/, '').slice(0, 60);
        giDesc = giDesc.replace(/^["'\s\-]+/, '').slice(0, 240);
        if (!giName) return null;
        return { name: giName, desc: giDesc };
    } catch (e) {
        api.v1.error('[AE] generateSceneItem:', e);
        api.v1.ui.toast('Scene generation failed.', { type: 'error' });
        return null;
    }
}

// ============================================================================
// [v1.18.0 LOCGEN] IN-PLAY LOCATION AUTHORING
// The spatial sibling of spawnItem / generateSceneItem, directly above. Same two-step
// shape: generate a draft from live story context, hand it back for review, then create.
//
// RELATION is the whole model. There is no third case:
//   'sibling'  same tier, adjacent      -> parentId = reference location's parentId
//   'child'    contained within here    -> parentId = reference location's id
// Sibling adjacency is implicit (shared parentId); no connectedEntityIds edge is written.
//
// >>> PAIRED CODE, three ways. Change one, check the others:
// >>>   generateLocationBatch()  — the wizard's chat-context twin of the prompt below.
// >>>   createLocationEntity()   — the shared entity+lorebook birth helper both use.
// >>>   spawnItem/spawnNpc       — the popup/round-trip pattern this mirrors, and the
// >>>                              AE_HUD_GEN_ENTITY / AE_HUD_SPAWN_ENTITY message pair
// >>>                              that AE_HUD_GEN_LOCATION / AE_HUD_SPAWN_LOCATION copy.
// ============================================================================

// Scene-grounded location generator. Background generation (NOT executeYoinkGeneration —
// that hijacks the foreground editor call, which is right for an interactive wizard chat
// and wrong for a HUD button). Reads the reference location and an optional author
// suggestion; returns {name, description, lore} for review. Creates nothing itself.
async function generateSceneLocation(relation: string, refLocId?: string | null, suggestion?: string): Promise<{ name: string; description: string; lore: string } | null> {
    try {
        let glRel = (relation === 'child') ? 'child' : 'sibling';
        let glRefId = refLocId ? refLocId : (await api.v1.storyStorage.getOrDefault(STORAGE_PLAYER_LOC, null) as string | null);
        let glRefEnt = glRefId ? await loadEntity(glRefId) : null;
        let glRefName = (glRefEnt && glRefEnt.name) ? glRefEnt.name : 'the current location';
        let glRefDesc = (glRefEnt && glRefEnt.description) ? glRefEnt.description : '';
        let glParentId = (glRel === 'child') ? (glRefId || null) : (glRefEnt ? (glRefEnt.parentId || null) : null);
        let glParentEnt = (glRel === 'sibling' && glParentId) ? await loadEntity(glParentId) : null;

        let glIdx = await loadEntityIndex();
        let glExisting = glIdx
            .filter(function(m) { return m.type === 'location' && m.parentId === (glParentId || null); })
            .map(function(m) { return m.name; })
            .filter(Boolean);

        let glCfg = await loadConfig();
        let glScope = (glRel === 'child')
            ? 'a NEW place contained INSIDE \u201c' + glRefName + '\u201d \u2014 one scale-step smaller than it (a room within a house, a district within a city, a glade within a forest).'
            : 'a NEW place standing ALONGSIDE \u201c' + glRefName + '\u201d at the SAME scale' + (glParentEnt ? ', both contained within \u201c' + glParentEnt.name + '\u201d' : ', both at the top level of the world') + '.';

        let glSys: string[] = [
            glCfg.generalStyle || '',
            '',
            'You invent exactly ONE new location for a story world: ' + glScope,
            'Ground it in what is actually happening in the story right now, and in the reference location below.',
            'CRITICAL RULE: DO NOT use any markdown. DO NOT bold headers or names. Output plain text only.',
            'FORMAT: output exactly these three labelled blocks and nothing else, no preamble:',
            'NAME: <short place name>',
            'DESC: <1-2 sentences capturing ONLY what a camera physically senses on arrival (light, texture, scale). No history.>',
            'LORE: <a full, comprehensive entry (roughly 5-8 sentences) covering history, significance, culture, and tensions. Never restate the DESC line.>'
        ];
        if (glExisting.length) {
            glSys.push('');
            glSys.push('These places ALREADY EXIST at that same level \u2014 do NOT recreate or duplicate them:\n' + glExisting.map(function(gn) { return '- ' + gn; }).join('\n'));
        }

        let glUsr: string[] = [
            'Reference location: ' + glRefName,
            glRefDesc ? 'Setting: ' + glRefDesc.slice(0, 240) : '',
            (glParentEnt && (glParentEnt.description || '').trim()) ? 'Containing place \u2014 ' + glParentEnt.name + ': ' + glParentEnt.description.trim().slice(0, 240) : '',
            (suggestion || '').trim() ? 'The author asks specifically for: ' + String(suggestion).trim().slice(0, 400) : '',
            'Invent the location now. Three labelled blocks only.'
        ].filter(Boolean);

        let glResp = await api.v1.generateWithStory(
            [{ role: 'system', content: glSys.join('\n') }, { role: 'user', content: glUsr.join('\n\n') }],
            { model: 'glm-4-6', max_tokens: 420 },
            { suppressScriptHooks: 'self', contextLimitReduction: 700 },
            undefined,
            'background'
        );
        let glTxt = (glResp && glResp.choices && glResp.choices.length > 0) ? String(glResp.choices[0].text || '') : '';
        if (!glTxt.trim()) return null;

        // Same three regexes generateLocationBatch uses per chunk (see PAIRED PROMPT note there).
        let glNmM = glTxt.match(/NAME:\s*(.+)/i);
        let glDeM = glTxt.match(/DESC:\s*([\s\S]+?)(?:\nLORE:|$)/i);
        let glLoM = glTxt.match(/LORE:\s*([\s\S]+)/i);
        if (!glNmM) return null;
        let glName = glNmM[1].trim().replace(/^["'\s\-]+/, '').replace(/["'\s]+$/, '').slice(0, 60);
        let glDesc = glDeM ? glDeM[1].replace(/\nLORE:[\s\S]*$/i, '').replace(/\nNAME:[\s\S]*$/i, '').trim() : '';
        let glLore = glLoM ? glLoM[1].replace(/\n-{3,}[\s\S]*$/, '').replace(/\nNAME:[\s\S]*$/i, '').trim() : '';
        if (!glName) return null;
        return { name: glName, description: glDesc, lore: glLore };
    } catch (e) {
        api.v1.error('[AE] generateSceneLocation:', e);
        api.v1.ui.toast('Location generation failed.', { type: 'error' });
        return null;
    }
}

// Create one location relative to a reference location (default: the player's current
// one). Depth decides the tier travel template, exactly as the wizard batch path does.
// {a|b|c} alternations in the name/description are rolled once, here.
async function spawnLocation(name: string, description: string, lore: string, relation: string, refLocId?: string | null, quiet?: boolean): Promise<{ id: string; name: string } | null> {
    try {
        let slRel = (relation === 'child') ? 'child' : 'sibling';
        let slRefId = refLocId ? refLocId : (await api.v1.storyStorage.getOrDefault(STORAGE_PLAYER_LOC, null) as string | null);
        if (!slRefId) {
            if (!quiet) api.v1.ui.toast('No current location to anchor a new one to.', { type: 'error' });
            return null;
        }
        let slRefEnt = await loadEntity(slRefId);
        if (!slRefEnt) {
            if (!quiet) api.v1.ui.toast('Reference location not found.', { type: 'error' });
            return null;
        }

        let slParentId = (slRel === 'child') ? slRefId : (slRefEnt.parentId || null);

        let slBase = aeExpandAlternations(name || '').trim();
        if (!slBase) slBase = 'New Location';

        // Numbered suffix on collision with any location already sharing the new parent.
        let slIdx = await loadEntityIndex();
        let slFinal = slBase;
        let slN = 2;
        while (slIdx.some(function(m) { return !!m && m.type === 'location' && m.parentId === (slParentId || null) && (m.name || '') === slFinal; }) && slN < 50) {
            slFinal = slBase + ' ' + slN;
            slN++;
        }

        let slDesc = aeExpandAlternations(description || '').trim();
        let slId = await createLocationEntity(slFinal, slDesc, (lore || '').trim(), slParentId);

        queueSceneStateBroadcast();
        if (!quiet) {
            let slWhere = (slRel === 'child')
                ? 'inside ' + (slRefEnt.name || 'here')
                : 'beside ' + (slRefEnt.name || 'here');
            api.v1.ui.toast('Location \u201c' + slFinal + '\u201d created ' + slWhere + '.', { type: 'success', autoClose: 2600 });
        }
        return { id: slId, name: slFinal };
    } catch (e) {
        api.v1.error('[AE] spawnLocation:', e);
        api.v1.ui.toast('Failed to create location.', { type: 'error' });
        return null;
    }
}

// [CE-STRIP v2.1.6] Item Template editor (buildItemArchetypeEditContent/refreshItemArchetypeEditModal/openItemArchetypeEditModal/buildItemTemplateRows) removed — Item Templates cut along with Bestiary.


// ── [vNEXT] Add-NPC modal (freeform, scene-grounded) ──────────────────────────
// [v1.19.0 LOCGEN] >>> PAIRED with openAddLocationModal() (near killCharacter, below):
// >>> same three-part shape (module state / build.../ open...), spatial instead of
// >>> populational. Its bridge-side twin is _showAddLocationPopup (Map tab).
var _aeAddNpcHandle: any = null;
var _aeAddNpcName = '';
var _aeAddNpcBrief = '';
var _aeAddNpcLoc: string | null = null;
var _aeAddNpcRefresh: (() => Promise<void>) | null = null;

async function buildAddNpcContent(): Promise<UIPart[]> {
    let amParts: UIPart[] = [];
    amParts.push({ type: 'text', text: 'A quick drop-in character at the current location. Name plus what they are doing here — an ordinary character like any other, just fast to create.', style: { fontSize: '11px', opacity: '0.7', marginBottom: '8px' } } as UIPart);
    amParts.push({ type: 'textInput', label: 'Name', placeholder: 'e.g. Skeleton, Gate Guard, Fruit Vendor', initialValue: _aeAddNpcName, onChange: function(v: string) { _aeAddNpcName = v; } } as UIPart);
    amParts.push({ type: 'multilineTextInput', label: 'What are they doing here?', placeholder: 'e.g. A brittle skeleton lurching forward to attack.', initialValue: _aeAddNpcBrief, style: { minHeight: '50px' }, onChange: function(v: string) { _aeAddNpcBrief = v; } } as UIPart);
    amParts.push({ type: 'button', text: '✨ Generate from Scene', style: { width: '100%', marginTop: '6px', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.12)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
        api.v1.ui.toast('Generating an NPC that fits the scene…', { id: 'ae-gen-am', autoClose: false });
        let amGen = await generateSceneNpc();
        if (amGen) {
            _aeAddNpcName = amGen.name;
            _aeAddNpcBrief = amGen.brief;
            api.v1.ui.toast('Filled in — tweak and Create, or generate again.', { id: 'ae-gen-am', type: 'success', autoClose: 2500 });
            await refreshAddNpcModal();
        } else {
            api.v1.ui.toast('Could not generate — type it in or try again.', { id: 'ae-gen-am', type: 'warning', autoClose: 3000 });
        }
    } } as UIPart);
    amParts.push({ type: 'button', text: 'Create Character', iconId: 'user-plus', style: { width: '100%', marginTop: '6px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {
        if (!_aeAddNpcName.trim()) { api.v1.ui.toast('Name required.', { type: 'warning' }); return; }
        await spawnSceneNpc(_aeAddNpcName.trim(), _aeAddNpcBrief.trim(), _aeAddNpcLoc, false);
        try { if (_aeAddNpcHandle && !_aeAddNpcHandle.isClosed()) await _aeAddNpcHandle.close(); } catch (eAc) {}
        if (_aeAddNpcRefresh) await _aeAddNpcRefresh();
    } } as UIPart);
    return amParts;
}

async function refreshAddNpcModal(): Promise<void> {
    if (_aeAddNpcHandle && typeof _aeAddNpcHandle.isClosed === 'function' && !_aeAddNpcHandle.isClosed()) {
        let ramContent = await buildAddNpcContent();
        await _aeAddNpcHandle.update({ content: ramContent });
    }
}

async function openAddNpcModal(locId: string | null, refreshFn: () => Promise<void>): Promise<void> {
    _aeAddNpcName = '';
    _aeAddNpcBrief = '';
    _aeAddNpcLoc = locId;
    _aeAddNpcRefresh = refreshFn;
    let oamContent = await buildAddNpcContent();
    _aeAddNpcHandle = await openEngineModal({ id: 'ae-add-minor', title: 'Add Character', size: 'small', content: oamContent });
}

// ── [v1.15.0] Add-Item modal (blank or from item template) \u2014 native HUD twin of
// the Add-NPC modal. Spawns a loose item into the inspected location so the
// existing Pick Up action can grab it, mirroring "+ Add NPC Here".
var _aeAddItemHandle: any = null;
var _aeAddItemName = '';
var _aeAddItemDesc = '';
var _aeAddItemLoc: string | null = null;
var _aeAddItemRefresh: (() => Promise<void>) | null = null;

async function buildAddItemContent(): Promise<UIPart[]> {
    // [CE-STRIP v2.1.6] Item template picker removed — Item Templates cut. Freeform
    // name + description only now, same as before minus the template shortcut.
    let aiParts: UIPart[] = [];
    // [v2.17.0 CHAREDIT-TABS] This modal is now also opened from a character's
    // Equipment section ("+ Add Item Here", explicitParentId = char.entityId) —
    // the original copy assumed a location target ("lands loose here; Pick Up
    // moves it to inventory"), which reads wrong for a character. Check the
    // actual target entity's type and phrase accordingly.
    let aiTargetEnt = _aeAddItemLoc ? await loadEntity(_aeAddItemLoc) : null;
    let aiIntroText = (aiTargetEnt && aiTargetEnt.type === 'character')
        ? 'A quick item, parented directly to this character\u2019s inventory. Name plus what it is.'
        : 'A quick drop-in item at the current location. Name plus what it is. It lands loose here; Pick Up moves it to inventory.';
    aiParts.push({ type: 'text', text: aiIntroText, style: { fontSize: '11px', opacity: '0.7', marginBottom: '8px' } } as UIPart);
    aiParts.push({ type: 'textInput', label: 'Name', placeholder: 'e.g. Rusted Key, Silk Scarf, Hunting Knife', initialValue: _aeAddItemName, onChange: function(v: string) { _aeAddItemName = v; } } as UIPart);
    aiParts.push({ type: 'multilineTextInput', label: 'What is it?', placeholder: 'e.g. A tarnished brass key with a worn ribbon.', initialValue: _aeAddItemDesc, style: { minHeight: '50px' }, onChange: function(v: string) { _aeAddItemDesc = v; } } as UIPart);
    aiParts.push({ type: 'button', text: '✨ Generate from Scene', style: { width: '100%', marginTop: '6px', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.12)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
        api.v1.ui.toast('Generating an item that fits the scene…', { id: 'ae-gen-ai', autoClose: false });
        let aiGen = await generateSceneItem();
        if (aiGen) {
            _aeAddItemName = aiGen.name;
            _aeAddItemDesc = aiGen.desc;
            api.v1.ui.toast('Filled in — tweak and Create, or generate again.', { id: 'ae-gen-ai', type: 'success', autoClose: 2500 });
            await refreshAddItemModal();
        } else {
            api.v1.ui.toast('Could not generate — type it in or try again.', { id: 'ae-gen-ai', type: 'warning', autoClose: 3000 });
        }
    } } as UIPart);
    aiParts.push({ type: 'button', text: 'Create Item', iconId: 'plus', style: { width: '100%', marginTop: '6px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {
        if (!_aeAddItemName.trim()) { api.v1.ui.toast('Name required.', { type: 'warning' }); return; }
        await spawnItem(_aeAddItemName.trim(), _aeAddItemDesc.trim(), false, _aeAddItemLoc || '__room__');
        try { if (_aeAddItemHandle && !_aeAddItemHandle.isClosed()) await _aeAddItemHandle.close(); } catch (eAi) {}
        if (_aeAddItemRefresh) await _aeAddItemRefresh();
    } } as UIPart);
    return aiParts;
}

async function refreshAddItemModal(): Promise<void> {
    if (_aeAddItemHandle && typeof _aeAddItemHandle.isClosed === 'function' && !_aeAddItemHandle.isClosed()) {
        let raiContent = await buildAddItemContent();
        await _aeAddItemHandle.update({ content: raiContent });
    }
}

async function openAddItemModal(locId: string | null, refreshFn: () => Promise<void>): Promise<void> {
    _aeAddItemName = '';
    _aeAddItemDesc = '';
    _aeAddItemLoc = locId;
    _aeAddItemRefresh = refreshFn;
    let oaiContent = await buildAddItemContent();
    _aeAddItemHandle = await openEngineModal({ id: 'ae-add-item', title: 'Add Item', size: 'small', content: oaiContent });
}

// ── [v1.19.0 LOCGEN] Add-Location modal \u2014 native HUD twin of the bridge Map tab's
// _showAddLocationPopup. Opened from renderMap()'s "+ New Location" button, next to the
// Travel header, so it's anchored to the same reference location the Travel list uses.
//
// >>> PAIRED, three ways \u2014 touch one, check the others:
// >>>   _showAddLocationPopup()  bridge Section 12 \u2014 same relation model, same fields.
// >>>   generateSceneLocation()  the generator this calls (Items block).
// >>>   spawnLocation()          the creator this calls (Items block).
var _aeAddLocHandle: any = null;
var _aeAddLocName = '';
var _aeAddLocDesc = '';
var _aeAddLocLore = '';
var _aeAddLocSuggestion = '';
var _aeAddLocRelation: string = 'sibling';   // 'sibling' | 'child' \u2014 see spawnLocation
var _aeAddLocRefId: string | null = null;
var _aeAddLocRefresh: (() => Promise<void>) | null = null;

async function buildAddLocationContent(): Promise<UIPart[]> {
    let alParts: UIPart[] = [];
    let alRefEnt = _aeAddLocRefId ? await loadEntity(_aeAddLocRefId) : null;
    let alRefName = alRefEnt ? alRefEnt.name : 'here';
    let alState: any = await getSceneState();
    let alParentName = (alState && alState.locationGraph && alState.locationGraph.parentName) ? alState.locationGraph.parentName : '';

    alParts.push({ type: 'text', text: 'A new place relative to ' + alRefName + '. Gets a name, a scene description, and a lorebook entry. Gating and travel cost are left default \u2014 set those in the entity editor after.', style: { fontSize: '11px', opacity: '0.7', marginBottom: '8px' } } as UIPart);

    alParts.push({ type: 'text', text: 'Where does it sit?', style: { fontSize: '11px', opacity: '0.7', marginBottom: '4px' } } as UIPart);
    alParts.push(_aeHudRow([
        { type: 'button', text: 'Beside \u2014 same tier', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: _aeAddLocRelation === 'sibling' ? 'rgba(136,204,255,0.15)' : undefined, border: _aeAddLocRelation === 'sibling' ? '1px solid rgba(136,204,255,0.4)' : undefined }, callback: async function() { _aeAddLocRelation = 'sibling'; await refreshAddLocationModal(); } } as UIPart,
        { type: 'button', text: 'Inside \u2014 contained here', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: _aeAddLocRelation === 'child' ? 'rgba(136,204,255,0.15)' : undefined, border: _aeAddLocRelation === 'child' ? '1px solid rgba(136,204,255,0.4)' : undefined }, callback: async function() { _aeAddLocRelation = 'child'; await refreshAddLocationModal(); } } as UIPart
    ]));
    let alHint = (_aeAddLocRelation === 'sibling')
        ? ('Same tier as ' + alRefName + (alParentName ? ', also inside ' + alParentName : ', at the top level of the world') + '. Reachable from here without going up first.')
        : ('One tier down, contained within ' + alRefName + '. Entered from here.');
    alParts.push({ type: 'text', text: alHint, style: { fontSize: '10px', opacity: '0.55', lineHeight: '1.4', marginBottom: '8px' } } as UIPart);

    alParts.push({ type: 'textInput', label: 'Steer the generator (optional)', placeholder: 'e.g. a flooded undercroft', initialValue: _aeAddLocSuggestion, onChange: function(v: string) { _aeAddLocSuggestion = v; } } as UIPart);
    alParts.push({ type: 'button', text: '\u2728 Generate from Story', style: { width: '100%', marginTop: '6px', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.12)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
        api.v1.ui.toast('Generating a location that fits the story\u2026', { id: 'ae-gen-al', autoClose: false });
        let alGen = await generateSceneLocation(_aeAddLocRelation, _aeAddLocRefId, _aeAddLocSuggestion);
        if (alGen) {
            _aeAddLocName = alGen.name;
            _aeAddLocDesc = alGen.description;
            _aeAddLocLore = alGen.lore;
            api.v1.ui.toast('Filled in \u2014 tweak and Create, or generate again.', { id: 'ae-gen-al', type: 'success', autoClose: 2500 });
            await refreshAddLocationModal();
        } else {
            api.v1.ui.toast('Could not generate \u2014 type it in or try again.', { id: 'ae-gen-al', type: 'warning', autoClose: 3000 });
        }
    } } as UIPart);

    alParts.push({ type: 'textInput', label: 'Name', placeholder: 'e.g. The Drowned Undercroft', initialValue: _aeAddLocName, onChange: function(v: string) { _aeAddLocName = v; } } as UIPart);
    alParts.push({ type: 'multilineTextInput', label: 'Description \u2014 what a camera senses on arrival', placeholder: 'No history here, just the immediate scene.', initialValue: _aeAddLocDesc, style: { minHeight: '50px' }, onChange: function(v: string) { _aeAddLocDesc = v; } } as UIPart);
    alParts.push({ type: 'multilineTextInput', label: 'Lorebook entry (blank = no entry)', placeholder: 'History, significance, culture, tensions.', initialValue: _aeAddLocLore, style: { minHeight: '70px' }, onChange: function(v: string) { _aeAddLocLore = v; } } as UIPart);

    alParts.push({ type: 'button', text: 'Create Location', iconId: 'map-pin', style: { width: '100%', marginTop: '6px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {
        if (!_aeAddLocName.trim()) { api.v1.ui.toast('Name required.', { type: 'warning' }); return; }
        await spawnLocation(_aeAddLocName.trim(), _aeAddLocDesc.trim(), _aeAddLocLore.trim(), _aeAddLocRelation, _aeAddLocRefId, false);
        try { if (_aeAddLocHandle && !_aeAddLocHandle.isClosed()) await _aeAddLocHandle.close(); } catch (eAl) {}
        if (_aeAddLocRefresh) await _aeAddLocRefresh();
    } } as UIPart);
    return alParts;
}

async function refreshAddLocationModal(): Promise<void> {
    if (_aeAddLocHandle && typeof _aeAddLocHandle.isClosed === 'function' && !_aeAddLocHandle.isClosed()) {
        let ralContent = await buildAddLocationContent();
        await _aeAddLocHandle.update({ content: ralContent });
    }
}

async function openAddLocationModal(refLocId: string | null, refreshFn: () => Promise<void>): Promise<void> {
    _aeAddLocName = '';
    _aeAddLocDesc = '';
    _aeAddLocLore = '';
    _aeAddLocSuggestion = '';
    _aeAddLocRelation = 'sibling';
    _aeAddLocRefId = refLocId;
    _aeAddLocRefresh = refreshFn;
    let oalContent = await buildAddLocationContent();
    _aeAddLocHandle = await openEngineModal({ id: 'ae-add-location', title: 'New Location', size: 'small', content: oalContent });
}

async function killCharacter(charId: string): Promise<void> {
    try {
        let char = await loadCharacter(charId);
        if (!char) return;

        char.active = false;
        char.scenePresent = false;

        // --- INVENTORY DROP LOGIC ---
        if (char.entityId) {
            let allEnts = await loadEntityIndex();
            let charBody = await loadEntity(char.entityId);
            
            if (charBody) {
                // Determine where to drop the loot: the room they died in.
                // If they are in the void (null), fallback to the player's room.
                let dropRoomId = charBody.parentId; 
                if (!dropRoomId) {
                    dropRoomId = await loadPlayerLocation(); 
                }

                if (dropRoomId) {
                    // Find all items/entities currently attached to the dying character
                    let lootItems = allEnts.filter(function(e) { return e.parentId === char.entityId; });
                    for (let lootMeta of lootItems) {
                        let itemEnt = await loadEntity(lootMeta.id);
                        if (itemEnt) {
                            itemEnt.parentId = dropRoomId;
                            await saveEntity(itemEnt);
                        }
                    }
                }
                
                // Clear equipped items so they aren't still "wielding" things from the grave
                char.equippedItemIds = [];
            }
        }

        await saveCharacter(char);

        // Send entity body to Graveyard
        if (char.entityId) {
            let allEnts = await loadEntityIndex();
            let gyMeta = allEnts.find(function(e) { return e.name === 'Graveyard' && e.type === 'location'; });
            if (!gyMeta) {
                let gyEnt = makeDefaultEntity('Graveyard');
                gyEnt.type = 'location';
                gyEnt.parentId = null;
                await saveEntity(gyEnt);
                gyMeta = { id: gyEnt.id, name: 'Graveyard', type: 'location', parentId: null, childCount: 0, presentCharacterCount: 0, state: 'default' };
            }
            let gyBody = await loadEntity(char.entityId);
            if (gyBody) { gyBody.parentId = gyMeta.id; await saveEntity(gyBody); }
        }

        // Move to bottom of character index
        let idx = await loadIndex();
        let pos = idx.findIndex(function(m) { return m.id === charId; });
        if (pos >= 0 && pos < idx.length - 1) {
            let item = idx.splice(pos, 1)[0];
            idx.push(item);
            await saveIndex(idx);
        }

        api.v1.ui.toast('💀 ' + char.name + ' — deceased.', { type: 'warning' });
    } catch (e) { 
        api.v1.error('[AE] killCharacter:', e); 
    }
}


// ── Character Edit Modal ─────────────────────────────────────────────────────

async function openCharEditModal(charId: string): Promise<void> {
    if (charEditModalHandle && !charEditModalHandle.isClosed()) charEditModalHandle.close();
    editingCharId = charId;
    // [v2.17.0 CHAREDIT-TABS] title now shows the character's own name — the tab
    // bar replaced the old always-visible header, so this is the one place
    // identity stays visible regardless of which tab is open.
    const openChar = await loadCharacter(charId);
    charEditModalHandle = await openEngineModal({ id: 'ce-char-edit', size: 'full', fillWidth: true, title: (openChar && openChar.name) ? openChar.name : 'Edit Character', content: await buildCharEditContent(charId) });
}

async function refreshCharEditModal(): Promise<void> { 
    if (!charEditModalHandle || charEditModalHandle.isClosed() || !editingCharId) return; 
    const freshChar = await loadCharacter(editingCharId);
    await charEditModalHandle.update({ title: (freshChar && freshChar.name) ? freshChar.name : 'Edit Character', content: await buildCharEditContent(editingCharId) }); 
}


// ============================================================================
// CHARACTER EDIT MODAL — TABBED LAYOUT  [v2.17.0 CHAREDIT-TABS]
// Replaces the old flat list-of-collapsing-headers with four button-tabs
// (Overview / Static Profile / Dynamic Profile / Visuals), mirroring the
// World-Build Wizard's own tabBar()/redraw() pattern (Section 23) so content
// isn't squished inside a collapsibleSection wrapper on top of its own
// nesting. Active tab is per-character tempStorage (`ce_tab_${charId}`);
// switching tabs calls refreshCharEditModal() same as any other mutation.
// ============================================================================

var CHAR_EDIT_TABS: { id: string; label: string; iconId: string }[] = [
    { id: 'overview', label: 'Overview',        iconId: 'user'   },
    { id: 'static',   label: 'Static Profile',  iconId: 'edit-3' },
    { id: 'dynamic',  label: 'Dynamic Profile', iconId: 'zap'    },
    { id: 'visuals',  label: 'Visuals',         iconId: 'eye'    }
];

function charEditTabBar(charId: string, activeTab: string): UIPart {
    return { type: 'row', wrap: true, style: { gap: '4px', marginBottom: '10px', paddingBottom: '8px', borderBottom: '1px solid rgba(255,255,255,0.1)' }, content: CHAR_EDIT_TABS.map(function(t) {
        const on = t.id === activeTab;
        return { type: 'button', text: t.label, iconId: t.iconId as any, disabled: on, style: { flex: '1 1 auto', minWidth: '90px', margin: 0, padding: '6px 4px', fontSize: '11px', fontWeight: on ? 'bold' : 'normal', borderBottom: on ? '2px solid #88ccff' : '2px solid transparent', borderRadius: '4px 4px 0 0', backgroundColor: on ? 'rgba(136,204,255,0.12)' : 'transparent', opacity: on ? '1' : '0.65' }, callback: async function() { await api.v1.tempStorage.set(`ce_tab_${charId}`, t.id); await refreshCharEditModal(); } } as UIPart;
    }) } as UIPart;
}

// Plain, non-collapsing section label — used on Overview for Equipment/
// Conditions/Factions (always expanded per request, not buried in a
// collapsibleSection) and as sub-headers within the Dynamic Profile tab.
function sectionHeader(label: string): UIPart {
    return { type: 'text', text: label, style: { fontSize: '13px', fontWeight: 'bold', marginTop: '18px', marginBottom: '8px', paddingBottom: '4px', borderBottom: '1px solid rgba(255,255,255,0.08)' } } as UIPart;
}

// A control button paired with an inline caption explaining what it does —
// replaces the old header row's single "❓ Help" popup modal.
function controlRow(btn: UIPart, caption: string): UIPart {
    return { type: 'row', alignment: 'center', style: { gap: '10px', marginBottom: '8px' }, content: [
        btn,
        { type: 'text', text: caption, style: { flex: '1 1 0', fontSize: '10px', opacity: '0.55', lineHeight: '1.3' } }
    ] } as UIPart;
}

function _ceToggleBtn(label: string, on: boolean, onToggle: () => Promise<void>): UIPart {
    return { type: 'button', text: label, style: { flex: '1 1 0', minWidth: '80px', margin: 0, fontSize: '11px', padding: '6px 4px', fontWeight: on ? 'bold' : 'normal', backgroundColor: on ? 'rgba(126,200,160,0.18)' : 'rgba(255,255,255,0.04)', color: on ? '#7ec8a0' : '#888', border: on ? '1px solid rgba(126,200,160,0.4)' : '1px solid rgba(255,255,255,0.1)' }, callback: onToggle } as UIPart;
}

// [v2.17.0] A generatable static field, rendered as: label (left) + a
// zap-icon button (right) that pops a small "optional hint" modal before
// confirming generation, then a click-to-expand preview/edit button below
// (opens a `size:'large'` modal with one big multilineTextInput — text is
// never squished into a small bubble, edited or not). Shared by the four
// STATIC_FIELD_DEFS fields, Core Values, and custom fields — all of which
// previously duplicated the same hint-textInput-plus-zap-row pattern.
function buildGeneratableFieldBlock(
    char: CharacterRecord, cfg: GlobalConfig, charId: string,
    label: string, currentValue: string, genInstructions: string, genBudget: number,
    applyResult: (v: string) => Promise<void>
): UIPart[] {
    return [
        { type: 'row', alignment: 'center', style: { justifyContent: 'space-between', marginTop: '14px', marginBottom: '4px' }, content: [
            { type: 'text', text: label, style: { fontSize: '12px', fontWeight: 'bold' } },
            { type: 'button', iconId: 'zap', style: { margin: 0, padding: '4px 8px', backgroundColor: 'rgba(255,180,50,0.15)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() {
                let hintVal = '';
                const hintContent: UIPart[] = [
                    { type: 'text', text: 'Optional hint to steer the generation.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },
                    { type: 'textInput', placeholder: 'e.g. emphasize a scar from the war', initialValue: '', onChange: function(v: string) { hintVal = v; } },
                    { type: 'button', text: 'Generate', iconId: 'zap', style: { width: '100%', marginTop: '8px', backgroundColor: 'rgba(255,180,50,0.15)', color: '#ffb432' }, disabledWhileCallbackRunning: true, callback: async function() {
                        try { if (hp && !hp.isClosed()) hp.close(); } catch (eHp) {}
                        api.v1.ui.toast('Generating ' + label + '…', { id: 'ce-genf', autoClose: false, type: 'info' });
                        const result = await generateFieldContent(char, label, genInstructions, cfg.generalStyle, hintVal, genBudget);
                        if (result) { await applyResult(result); api.v1.ui.toast('Generated.', { id: 'ce-genf', type: 'success', autoClose: 1500 }); await refreshCharEditModal(); }
                        else { api.v1.ui.toast('Failed.', { id: 'ce-genf', type: 'error', autoClose: 2000 }); }
                    } }
                ];
                const hp = await openEngineModal({ title: 'Generate: ' + label, size: 'small', content: hintContent });
            } }
        ] } as UIPart,
        { type: 'button', text: currentValue || '(Tap to write, or generate above)', style: { width: '100%', margin: 0, textAlign: 'left', whiteSpace: 'pre-wrap', minHeight: '44px', fontSize: '12px', backgroundColor: 'rgba(255,255,255,0.03)', border: '1px solid rgba(255,255,255,0.08)', color: currentValue ? undefined : '#666' }, callback: async function() {
            const editContent: UIPart[] = [
                { type: 'multilineTextInput', label: label, initialValue: currentValue, style: { minHeight: '220px' }, onChange: async function(v: string) { await applyResult(v); } },
                { type: 'button', text: 'Done', style: { width: '100%', marginTop: '8px' }, callback: async function() { try { if (fp && !fp.isClosed()) fp.close(); } catch (eFp) {} await refreshCharEditModal(); } }
            ];
            const fp = await openEngineModal({ title: label, size: 'large', content: editContent });
        } } as UIPart
    ];
}

// ── Equipment (Overview tab) ─────────────────────────────────────────────
// [v2.17.0] Gained "+ Add Item Here" — the native inspect modal's own
// openAddItemModal()/spawnItem(), just called with this character's
// entityId as the explicit parent instead of a location id. spawnItem
// already treats any non-sentinel explicitParentId as a direct parent, so
// this parents the new item straight into the character's hierarchy, same
// as the bridge's existing character-scoped item button (v2.15.0
// BRIDGE-CONDITIONS). Also carries over the per-item edit shortcut that
// the orphaned buildInventorySection had the right idea about.
async function buildEquipmentRows(char: CharacterRecord): Promise<UIPart[]> {
    if (!char.entityId) {
        return [{ type: 'text', text: 'Character has no body entity — use Generate Missing Physical Body above before adding items.', style: { fontSize: '11px', opacity: '0.5' } }];
    }
    const rows: UIPart[] = [];
    const entIdx = await loadEntityIndex();
    const invItems = entIdx.filter(function(e) { return e.type === 'item' && e.parentId === char.entityId; });
    rows.push({ type: 'button', text: '+ Add Item Here', iconId: 'plus', style: { width: '100%', fontSize: '11px', marginBottom: '8px' }, callback: async function() { await openAddItemModal(char.entityId || null, refreshCharEditModal); } } as UIPart);
    if (invItems.length === 0) {
        rows.push({ type: 'text', text: 'No items carried.', style: { fontSize: '11px', opacity: '0.5' } });
    } else {
        for (const item of invItems) {
            const isEquipped = (char.equippedItemIds || []).includes(item.id);
            rows.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                { type: 'text', text: item.name, style: { flex: '1 1 0', fontSize: '12px', color: isEquipped ? '#7ec8a0' : undefined } },
                { type: 'button', text: isEquipped ? '\u2713 Equipped' : 'Equip', style: { margin: 0, fontSize: '11px', backgroundColor: isEquipped ? 'rgba(126,200,160,0.15)' : 'rgba(255,255,255,0.05)', color: isEquipped ? '#7ec8a0' : undefined }, callback: async function() {
                    const f = await loadCharacter(char.id); if (!f) return;
                    if (!f.equippedItemIds) f.equippedItemIds = [];
                    if (isEquipped) { f.equippedItemIds = f.equippedItemIds.filter(function(id) { return id !== item.id; }); }
                    else { f.equippedItemIds.push(item.id); }
                    await saveCharacter(f); await refreshCharEditModal();  // [v0.9.8.5] equipment rides ephemeral temp entry; no lorebook sync
                } },
                { type: 'button', iconId: 'edit', style: { margin: 0 }, callback: async function() { await openEntityEditModal(item.id); } }
            ] } as UIPart);
        }
    }
    return rows;
}

// ── Faction Relationships (Overview tab) ─────────────────────────────────
function buildFactionRelationshipRows(char: CharacterRecord, cfg: GlobalConfig, charId: string): UIPart[] {
    if (!cfg.factions || cfg.factions.length === 0) {
        return [{ type: 'text', text: 'No factions defined yet — add some in Settings.', style: { fontSize: '11px', opacity: '0.5' } }];
    }
    const trackedFactions = cfg.factions.filter(function(f) { return char.charFactionRelationships && char.charFactionRelationships[f.id] !== undefined; });
    const untrackedFactions = cfg.factions.filter(function(f) { return !char.charFactionRelationships || char.charFactionRelationships[f.id] === undefined; });
    const rows: UIPart[] = [];
    rows.push({ type: 'text', text: 'Track faction relationships for this character independently of the player\'s standing.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });

    for (let fi = 0; fi < trackedFactions.length; fi++) {
        let fac = trackedFactions[fi];
        let captFacId = fac.id;
        let relIdx = char.charFactionRelationships[fac.id] || 0;
        let relState = (fac.relationshipStates || [])[relIdx] || 'Unknown';
        rows.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
            { type: 'text', text: fac.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold' } },
            { type: 'button', text: relState, style: { margin: 0, fontSize: '11px', minWidth: '90px', backgroundColor: 'rgba(255,255,255,0.05)' }, callback: async function() {
                let states = fac.relationshipStates || [];
                let pm = await openEngineModal({ title: fac.name + ' — Relationship', size: 'small', content: states.map(function(s, idx) {
                    return { type: 'button', text: s, style: { width: '100%', marginBottom: '4px', backgroundColor: relIdx === idx ? 'rgba(126,200,160,0.2)' : undefined, color: relIdx === idx ? '#7ec8a0' : undefined }, callback: async function() {
                        const f2 = await loadCharacter(charId); if (!f2) return;
                        if (!f2.charFactionRelationships) f2.charFactionRelationships = {};
                        f2.charFactionRelationships[captFacId] = idx; await saveCharacter(f2); pm.close(); await refreshCharEditModal();
                    } } as UIPart;
                })});
            } },
            { type: 'button', text: '✕', style: { margin: 0, fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent' }, callback: async function() {
                const f2 = await loadCharacter(charId); if (!f2) return;
                delete f2.charFactionRelationships[captFacId]; await saveCharacter(f2); await refreshCharEditModal();
            } }
        ] });
    }

    if (untrackedFactions.length > 0) {
        rows.push({ type: 'button', text: '+ Track Faction', style: { fontSize: '11px', width: '100%', backgroundColor: 'rgba(255,255,255,0.04)' }, callback: async function() {
            let pm = await openEngineModal({ title: 'Track Faction Relationship', size: 'small', content: untrackedFactions.map(function(f) {
                return { type: 'button', text: f.name, style: { width: '100%', marginBottom: '4px', textAlign: 'left' }, callback: async function() {
                    const f2 = await loadCharacter(charId); if (!f2) return;
                    if (!f2.charFactionRelationships) f2.charFactionRelationships = {};
                    f2.charFactionRelationships[f.id] = 0; await saveCharacter(f2); pm.close(); await refreshCharEditModal();
                } } as UIPart;
            })});
        } });
    }

    if (trackedFactions.length === 0) rows.push({ type: 'text', text: 'No factions tracked. Use "+ Track Faction" to add.', style: { fontSize: '11px', opacity: '0.4' } });
    return rows;
}

// ── Conditions (Overview tab) ────────────────────────────────────────────
// [v2.17.0] Same computation as before (v2.7.0 CONDITIONS), just returning
// bare rows instead of a wrapping collapsibleSection — Overview shows it
// under a plain sectionHeader() instead.
function buildConditionsRows(char: CharacterRecord, cfg: GlobalConfig): UIPart[] {
    const defs = cfg.conditions || [];
    const active = char.activeConditions || [];

    const rows: UIPart[] = defs.map(function(def) {
        const stateIdx = active.findIndex(function(s) { return s.defId === def.id; });
        const isActive = stateIdx >= 0;
        const curStageIdx = isActive ? (active[stateIdx].stageIndex || 0) : 0;
        const hasStages = !!(def.stages && def.stages.length);
        const stageLabel = hasStages ? (def.stages[Math.max(0, Math.min(def.stages.length - 1, curStageIdx))] || '') : '';

        const rowContent: UIPart[] = [
            { type: 'row', alignment: 'center', style: { gap: '8px' }, content: [
                { type: 'checkboxInput', initialValue: isActive, onChange: async function(v: boolean) {
                    const f = await loadCharacter(char.id); if (!f) return;
                    if (!f.activeConditions) f.activeConditions = [];
                    if (v) {
                        if (!f.activeConditions.some(function(s) { return s.defId === def.id; })) {
                            f.activeConditions.push({ defId: def.id, stageIndex: 0 });
                        }
                    } else {
                        f.activeConditions = f.activeConditions.filter(function(s) { return s.defId !== def.id; });
                    }
                    await saveCharacter(f); await refreshCharEditModal();
                } },
                { type: 'text', text: def.name, style: { fontSize: '12px', fontWeight: 'bold', color: isActive ? '#e8a87c' : undefined, flex: '1 1 0' } }
            ] } as UIPart
        ];

        if (isActive && hasStages) {
            rowContent.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginTop: '2px', marginLeft: '24px' }, content: [
                { type: 'button', text: '◀', style: { margin: 0, width: '28px' }, disabled: curStageIdx === 0, callback: async function() {
                    const f = await loadCharacter(char.id); if (!f) return;
                    const s = (f.activeConditions || []).find(function(x) { return x.defId === def.id; });
                    if (s) { s.stageIndex = Math.max(0, curStageIdx - 1); await saveCharacter(f); await refreshCharEditModal(); }
                } },
                { type: 'text', text: (curStageIdx + 1) + '/' + def.stages.length + ' \u2014 ' + (stageLabel || ''), style: { flex: '1', fontSize: '11px', textAlign: 'center', color: '#7ec8a0' } },
                { type: 'button', text: '\u25b6', style: { margin: 0, width: '28px' }, disabled: curStageIdx >= def.stages.length - 1, callback: async function() {
                    const f = await loadCharacter(char.id); if (!f) return;
                    const s = (f.activeConditions || []).find(function(x) { return x.defId === def.id; });
                    if (s) { s.stageIndex = Math.min(def.stages.length - 1, curStageIdx + 1); await saveCharacter(f); await refreshCharEditModal(); }
                } }
            ] } as UIPart);
        }

        return { type: 'box', style: { padding: '6px 8px', marginBottom: '4px', backgroundColor: 'rgba(255,255,255,0.02)', borderRadius: '4px' }, content: rowContent } as UIPart;
    });

    if (defs.length === 0) {
        rows.push({ type: 'text', text: 'No conditions defined yet \u2014 add some in Settings.', style: { fontSize: '11px', opacity: '0.5', textAlign: 'center', marginBottom: '4px' } } as UIPart);
    }

    const previewLines: string[] = active.map(function(s) {
        const def = defs.find(function(d) { return d.id === s.defId; });
        if (!def) return '';
        return buildConditionLine(char, def, s.stageIndex, cfg);
    }).filter(Boolean);

    return [
        { type: 'text', text: 'Multiple can be active at once. Defined in Settings. Injects into a temporary lorebook entry while active, not the Author\u2019s Note.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } } as UIPart,
        ...rows,
        (previewLines.length > 0 ? { type: 'box', style: { padding: '6px 8px', marginTop: '8px', backgroundColor: 'rgba(0,0,0,0.25)', borderRadius: '4px', borderLeft: '3px solid #7ec8a0' }, content: [
            { type: 'text', text: 'Lorebook preview:', style: { fontSize: '10px', opacity: '0.5', marginBottom: '2px' } },
            ...previewLines.map(function(l) { return { type: 'text', text: l, style: { fontSize: '11px', fontStyle: 'italic', opacity: '0.85' } } as UIPart; })
        ] } as UIPart : null)
    ].filter(Boolean) as UIPart[];
}

// ── Hooks (Dynamic Profile tab, rendered first) ──────────────────────────
// [v2.17.0] Slim empty state (one line + Add/Scan) instead of a padded
// collapsibleSection nobody opens when there's nothing in it; full editable
// list once hooks exist. BUNDLED FIX found while rebuilding this: the old
// "✓ Resolve Hook" button was singular-labeled but wiped char.hooks = []
// entirely — ALL hooks, not just one — with zero confirmation. Renamed to
// "Resolve Oldest" and changed to f.hooks.slice(1), matching what the label
// always claimed to do.
function buildHooksSection(char: CharacterRecord, cfg: GlobalConfig): UIPart[] {
    if (char.hooks.length === 0) {
        return [{ type: 'row', alignment: 'center', style: { gap: '8px' }, content: [
            { type: 'text', text: 'No active hooks.', style: { fontSize: '11px', opacity: '0.5', flex: '1 1 0' } },
            { type: 'button', text: '+ Add Hook', style: { margin: 0, fontSize: '11px' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.hooks.push({ id: api.v1.uuid(), targetName: '', description: '', pressureLevel: 30, developmentNotes: [], resolved: false }); await saveCharacter(f); await refreshCharEditModal(); } } },
            { type: 'button', text: 'Scan', iconId: 'refresh-cw', style: { margin: 0, fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() {
                const f = await loadCharacter(char.id); if (!f) return;
                const cfg2 = await loadConfig(); const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;
                api.v1.ui.toast('Scanning…', { id: 'ce-hk', autoClose: false, type: 'info' });
                const ok = await generateHookUpdates(f, cfg2, tc);
                api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-hk', type: ok ? 'success' : 'error', autoClose: 2000 });
                if (ok) await refreshCharEditModal();
            } }
        ] } as UIPart];
    }

    const hookItems: UIPart[] = char.hooks.filter(Boolean).map(function(hk, i) {
        // [BUGFIX v2.28.0, per user's crash report] Was `npcPressureLabel`, which is
        // not and never was defined anywhere in this file (a ReferenceError only once
        // a character actually had a hook, which is why it surfaced as "can't open
        // Dynamics" rather than at load time). The real function is `_aePressureLabel`
        // (SECTION "SHARED INSPECT / ITEM / NARRATIVE HELPERS"), already used correctly
        // by the sidebar's hooks list a few hundred lines down.
        const hi = i; const imperative = _aePressureLabel(hk.pressureLevel);
        let hkDisplayTarget = hk.targetName === '__player__' ? '👑 Player' : (hk.targetName || 'Unknown');
        return { type: 'collapsibleSection', title: (hk.pressureLevel >= 85 ? '🔥 ' : '') + hkDisplayTarget + ' — ' + imperative + ' (' + hk.pressureLevel + ')', initialCollapsed: true, storageKey: `temp:ce_hk_${char.id}_${hk.id}`, content: [
            { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px' }, content: [
                { type: 'text', text: 'Target:', style: { fontSize: '11px', width: '50px', opacity: '0.7' } },
                { type: 'button', text: hk.targetName === '__player__' ? '👑 Player' : (hk.targetName || '(Select Target)'), style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left', backgroundColor: 'rgba(255,255,255,0.05)' }, callback: async function() {
                    await api.v1.tempStorage.set('ce_hk_target_search', '');
                    async function drawSearchablePicker() {
                        const term = await api.v1.tempStorage.getOrDefault('ce_hk_target_search', '') as string;
                        const chars = typeof loadIndex === 'function' ? await loadIndex() : [];
                        const pickable = chars.filter(function(m) {
                            return m.id !== char.id && m.name.toLowerCase().includes(term.toLowerCase());
                        });
                        const contentParts: UIPart[] = [];
                        contentParts.push({ type: 'textInput', placeholder: '🔍 Search characters...', initialValue: term, onChange: async function(v: string) { await api.v1.tempStorage.set('ce_hk_target_search', v); await drawSearchablePicker(); } });
                        contentParts.push({ type: 'button', text: '✕ Clear Target', style: { width: '100%', marginBottom: '4px', marginTop: '8px', color: '#ff6b6b' }, callback: async function() {
                            const f = await loadCharacter(char.id);
                            if (f) { f.hooks[hi].targetName = ''; await saveCharacter(f); pm.close(); await refreshCharEditModal(); }
                        } });
                        contentParts.push({ type: 'button', text: '👑 Player Character (protagonist)', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(255,180,50,0.1)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.2)' }, callback: async function() {
                            const f = await loadCharacter(char.id);
                            if (f) { f.hooks[hi].targetName = '__player__'; await saveCharacter(f); pm.close(); await refreshCharEditModal(); }
                        } });
                        pickable.forEach(function(m) {
                            contentParts.push({ type: 'button', text: `👤 ${m.name}`, style: { width: '100%', marginBottom: '2px', textAlign: 'left', backgroundColor: hk.targetName === m.name ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() {
                                const f = await loadCharacter(char.id);
                                if (f) { f.hooks[hi].targetName = m.name; await saveCharacter(f); pm.close(); await refreshCharEditModal(); }
                            } } as UIPart);
                        });
                        if (pm && typeof pm.isClosed === 'function' && !pm.isClosed()) {
                            await pm.update({ content: contentParts });
                        } else {
                            pm = await openEngineModal({ id: 'ce-hk-target-picker', title: 'Select Hook Target', size: 'medium', content: contentParts });
                        }
                    }
                    let pm: any;
                    await drawSearchablePicker();
                }}
            ]},
            { type: 'multilineTextInput', label: 'Hook Description (the core tension)', initialValue: hk.description, style: { minHeight: '50px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.hooks[hi].description = v; await saveCharacter(f); } } },
            { type: 'sliderInput', label: `Pressure Level — ${imperative}`, min: 0, max: 100, step: 5, initialValue: hk.pressureLevel, onChange: async function(v: number) { const f = await loadCharacter(char.id); if (f) { f.hooks[hi].pressureLevel = v; await saveCharacter(f); } } },
            { type: 'text', text: 'Pressure 85+: injects directly into the Author\u2019s Note alongside this character\u2019s thoughts. Below 85: tracked here but not currently injected into context.', style: { fontSize: '10px', opacity: '0.45', marginBottom: '6px' } },
            hk.developmentNotes.filter(Boolean).length > 0 ? { type: 'box', style: { backgroundColor: 'bg1', padding: '6px', borderRadius: '4px', marginBottom: '4px' }, content: hk.developmentNotes.filter(Boolean).map(function(n) { return { type: 'text', text: `• ${n}`, style: { fontSize: '10px', opacity: '0.6' } } as UIPart; }) } as UIPart : null,
            { type: 'checkboxInput', label: 'Resolved', initialValue: hk.resolved, onChange: async function(v: boolean) { const f = await loadCharacter(char.id); if (f) { f.hooks[hi].resolved = v; await saveCharacter(f); await refreshCharEditModal(); } } },
            { type: 'button', text: '🗑 Remove Hook', style: { fontSize: '11px', marginTop: '6px', color: '#ff6b6b' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.hooks.splice(hi, 1); await saveCharacter(f); await refreshCharEditModal(); } } }
        ].filter(Boolean) as UIPart[] } as UIPart;
    });

    return [
        { type: 'text', text: 'Dramatic tensions between this character and another. Tracked by pressure level; 85+ injects into the Author\u2019s Note.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } } as UIPart,
        ...hookItems,
        { type: 'row', style: { gap: '4px', marginTop: '8px' }, content: [
            { type: 'button', text: '+ Add Blank Hook', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.hooks.push({ id: api.v1.uuid(), targetName: '', description: '', pressureLevel: 30, developmentNotes: [], resolved: false }); await saveCharacter(f); await refreshCharEditModal(); } } },
            { type: 'button', text: 'Scan Hooks', iconId: 'refresh-cw', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() {
                const f = await loadCharacter(char.id); if (!f) return;
                const cfg2 = await loadConfig(); const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;
                api.v1.ui.toast('Scanning…', { id: 'ce-hk', autoClose: false, type: 'info' });
                const ok = await generateHookUpdates(f, cfg2, tc);
                api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-hk', type: ok ? 'success' : 'error', autoClose: 2000 });
                if (ok) await refreshCharEditModal();
            } },
            { type: 'button', text: 'Resolve Oldest', style: { margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.08)', color: '#7ec8a0', border: '1px solid rgba(126,200,160,0.3)' }, disabled: char.hooks.length === 0, callback: async function() {
                const f = await loadCharacter(char.id); if (!f || f.hooks.length === 0) return;
                const hDesc = f.hooks[0].description.substring(0, 50);
                f.hooks = f.hooks.slice(1); await saveCharacter(f);
                api.v1.ui.toast('Hook resolved: ' + hDesc, { type: 'success', autoClose: 3000 });
                await refreshCharEditModal();
            } }
        ] }
    ];
}

// ── Ephemeral Thoughts / Mid-range State (Dynamic Profile tab) ──────────
function buildEphemeralRows(char: CharacterRecord, cfg: GlobalConfig): UIPart[] {
    const eph = char.ephemeral;
    const rows: UIPart[] = [];
    if (eph) {
        rows.push(
            { type: 'box', style: { backgroundColor: 'bg1', padding: '8px', borderRadius: '4px', marginBottom: '8px' }, content: [
                { type: 'text', text: `Event: "${eph.eventAnchor}"`, style: { fontSize: '11px', marginBottom: '2px' } },
                { type: 'text', text: `Feeling: "${eph.emotionalResponse}"`, style: { fontSize: '11px', marginBottom: '2px' } },
                { type: 'text', text: `Drive: "${eph.immediateDesire}"`, style: { fontSize: '11px', marginBottom: '6px' } },
                { type: 'text', text: 'Override thought (replaces AI fallback line):', style: { fontSize: '9px', opacity: '0.55', marginTop: '6px', marginBottom: '2px' } },
                { type: 'multilineTextInput', label: 'Override', placeholder: 'Leave blank to use AI-generated line. Type here to manually set.', initialValue: eph.compressedLine, style: { fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.ephemeral) { f.ephemeral.compressedLine = v; await saveCharacter(f); } } }
            ] },
            { type: 'row', style: { gap: '4px' }, content: [
                { type: 'button', text: 'Regenerate', iconId: 'refresh-cw', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-eph', autoClose: false, type: 'info' }); const ok = await generateEphemeral(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-eph', type: ok ? 'success' : 'error', autoClose: 2000 }); if (ok) await refreshCharEditModal(); } },
                { type: 'button', text: 'Clear', style: { margin: 0, fontSize: '11px' }, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; f.ephemeral = null; f.ephemeralHistory = []; f.lastEphemeralGen = 0; await saveCharacter(f); await refreshCharEditModal(); } }
            ] }
        );
        if (char.ephemeralHistory.filter(Boolean).length > 0) {
            rows.push({ type: 'text', text: 'History:', style: { fontSize: '10px', opacity: '0.5', marginTop: '8px' } });
            for (const h of char.ephemeralHistory.filter(Boolean)) { rows.push({ type: 'text', text: `  ${h.compressedLine}`, style: { fontSize: '10px', opacity: '0.4' } }); }
        }
    } else {
        rows.push({ type: 'text', text: 'No snapshot yet. Generates automatically on generation end.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '6px' } });
        rows.push({ type: 'button', text: 'Force Generate', iconId: 'zap', style: { fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-eph', autoClose: false, type: 'info' }); const ok = await generateEphemeral(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-eph', type: ok ? 'success' : 'error', autoClose: ok ? 2000 : 3000 }); if (ok) await refreshCharEditModal(); } });
    }
    return rows;
}

function buildMidRangeRows(char: CharacterRecord, cfg: GlobalConfig): UIPart[] {
    const mid = char.midRange;
    const rows: UIPart[] = [];
    if (mid) {
        rows.push(
            { type: 'multilineTextInput', label: 'Current Goal', initialValue: mid.currentDesire, style: { fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.midRange) { f.midRange.currentDesire = v; await saveCharacter(f); } } },
            { type: 'multilineTextInput', label: 'Social Mask (performing vs. interior)', initialValue: mid.socialMask, style: { fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.midRange) { f.midRange.socialMask = v; await saveCharacter(f); } } },
            { type: 'multilineTextInput', label: 'Shifted View (belief now — diffed from baseline)', initialValue: mid.shiftedView, style: { fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.midRange) { f.midRange.shiftedView = v; await saveCharacter(f); } } },
            { type: 'multilineTextInput', label: 'Baseline View (frozen — belief entering the story)', initialValue: (mid as any).baselineView || '', style: { fontSize: '11px', minHeight: '40px', opacity: '0.85' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.midRange) { (f.midRange as any).baselineView = v; await saveCharacter(f); } } },
            { type: 'button', text: 'Regenerate', iconId: 'refresh-cw', style: { fontSize: '11px', marginTop: '4px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-mid', autoClose: false, type: 'info' }); const ok = await generateMidRange(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-mid', type: ok ? 'success' : 'error', autoClose: 2000 }); if (ok) await refreshCharEditModal(); } }
        );
        const _mh = (char.midRangeHistory || []).filter(Boolean);
        if (_mh.length > 0) {
            rows.push({ type: 'text', text: 'History (logged only on change):', style: { fontSize: '10px', opacity: '0.5', marginTop: '6px' } });
            for (const _h of _mh) { rows.push({ type: 'text', text: `  (gen ${_h.atGen}) wants ${_h.currentDesire || '\u2014'}; believes ${_h.shiftedView || '\u2014'}`, style: { fontSize: '10px', opacity: '0.4' } }); }
        }
    } else {
        rows.push({ type: 'text', text: 'No mid-range state yet.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '6px' } });
        rows.push({ type: 'button', text: 'Force Generate', iconId: 'zap', style: { fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-mid', autoClose: false, type: 'info' }); const ok = await generateMidRange(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-mid', type: ok ? 'success' : 'error', autoClose: ok ? 2000 : 3000 }); if (ok) await refreshCharEditModal(); } });
    }
    return rows;
}

// ── Primary Relationship (Dynamic Profile tab) ───────────────────────────
// [v2.17.0] "Enable in AI Context" checkbox removed — that's now the top
// toggle bar's "Relationship" button (char.primaryRelationship.enabled is
// the same field, just controlled from one place instead of two).
function buildRelationshipSection(char: CharacterRecord, cfg: GlobalConfig): UIPart[] {
    const rel = char.primaryRelationship;
    const threadItems: UIPart[] = rel.threads.filter(Boolean).map(function(thread, i) {
        const ti = i; return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
            { type: 'textInput', initialValue: thread, style: { flex: '1 1 0', fontSize: '12px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.threads[ti] = v; await saveCharacter(f); } } },
            { type: 'button', iconId: 'x', style: { margin: 0 }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.threads.splice(ti, 1); await saveCharacter(f); await refreshCharEditModal(); } } }
        ] } as UIPart;
    });
    const tkTh = `ce_tmp_rth_${char.id}`;

    return [
        { type: 'button', text: rel.targetName === '__player__' ? '👑 Player Character' : (rel.targetName ? `👤 ${rel.targetName}` : 'Select Character...'), style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: 'rgba(255,255,255,0.05)' }, callback: async function() {
            const others = await loadCharacterListForPicker(char.id);
            const pm = await openEngineModal({ title: 'Relationship Target', size: 'small', content: [
                { type: 'button', text: '✕ Clear', style: { width: '100%', marginBottom: '8px', color: '#ff6b6b' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.targetName = ''; await saveCharacter(f); } pm.close(); await refreshCharEditModal(); } },
                { type: 'button', text: '👑 Player Character (protagonist)', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(255,180,50,0.1)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.2)' }, callback: async function() {
                    const f = await loadCharacter(char.id); if (!f) return;
                    f.primaryRelationship.targetName = '__player__';
                    if (!f.primaryRelationship.enabled) f.primaryRelationship.enabled = true;
                    await saveCharacter(f); pm.close(); await refreshCharEditModal();
                } },
                ...others.map(function(m) {
                    return { type: 'button', text: m.name, style: { width: '100%', marginBottom: '4px', backgroundColor: rel.targetName === m.name ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() {
                        const f = await loadCharacter(char.id); if (!f) return;
                        f.primaryRelationship.targetName = m.name; await saveCharacter(f); pm.close(); await refreshCharEditModal();
                    } } as UIPart;
                })
            ]});
        } } as UIPart,
        { type: 'column', style: { gap: '2px', marginTop: '8px', marginBottom: '8px' }, content: (function() {
            let archDef = findArchetypeDef(cfg, rel);
            let stageName = resolveArchetypeStage(cfg, rel);
            let hasStages = !!(archDef && archDef.stages && archDef.stages.length);
            let curStageIdx = (typeof rel.stageIndex === 'number') ? rel.stageIndex : 0;
            let archCol: UIPart[] = [
                { type: 'text', text: 'Archetype', style: { fontSize: '11px', opacity: '0.6' } },
                { type: 'button', text: rel.archetype || '(Select Archetype)', style: { margin: 0, textAlign: 'left', fontSize: '12px' }, callback: async function() {
                    let items: PickItem[] = (cfg.relationshipArchetypes || []).map(function(d) { return { id: d.id, label: d.name + (d.stages && d.stages.length ? '  (' + d.stages.length + ' stages)' : ''), selected: rel.archetypeId === d.id || rel.archetype === d.name }; });
                    await openSearchPicker('Archetype', items, async function(id) {
                        const f = await loadCharacter(char.id); if (!f) return;
                        let picked = (cfg.relationshipArchetypes || []).find(function(d) { return d.id === id; });
                        if (picked) { f.primaryRelationship.archetypeId = picked.id; f.primaryRelationship.archetype = picked.name; f.primaryRelationship.stageIndex = 0; await saveCharacter(f); }
                        await refreshCharEditModal();
                    });
                } }
            ];
            if (hasStages) {
                archCol.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginTop: '4px' }, content: [
                    { type: 'text', text: 'Stage:', style: { fontSize: '11px', width: '44px', opacity: '0.7' } },
                    { type: 'button', text: '\u25c0', style: { margin: 0, width: '32px' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { let m = Math.max(0, Math.min((archDef!.stages.length - 1), curStageIdx - 1)); f.primaryRelationship.stageIndex = m; await saveCharacter(f); await refreshCharEditModal(); } } },
                    { type: 'text', text: (curStageIdx + 1) + '/' + archDef!.stages.length + ' \u2014 ' + (stageName || ''), style: { flex: '1', fontSize: '11px', textAlign: 'center', color: '#7ec8a0' } },
                    { type: 'button', text: '\u25b6', style: { margin: 0, width: '32px' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { let m = Math.max(0, Math.min((archDef!.stages.length - 1), curStageIdx + 1)); f.primaryRelationship.stageIndex = m; await saveCharacter(f); await refreshCharEditModal(); } } }
                ] } as UIPart);
            }
            return archCol;
        })() } as UIPart,
        { type: 'textInput', label: 'How It Started', initialValue: rel.howItStarted, placeholder: 'Origin of the dynamic...', onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.howItStarted = v; await saveCharacter(f); } } } as UIPart,
        { type: 'text', text: 'Threads', style: { fontSize: '11px', opacity: '0.6', marginTop: '8px', marginBottom: '2px' } } as UIPart,
        ...threadItems,
        { type: 'row', style: { gap: '4px', marginBottom: '8px' }, content: [
            { type: 'textInput', placeholder: 'Add thread...', storageKey: `temp:${tkTh}`, style: { flex: '1 1 0' } },
            { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(tkTh) as string || ''; if (!v.trim()) return; const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.threads.push(v.trim()); await saveCharacter(f); await api.v1.tempStorage.remove(tkTh); await refreshCharEditModal(); } } }
        ] } as UIPart,
        { type: 'multilineTextInput', label: 'Current Status', initialValue: rel.currentStatus, placeholder: 'Observable surface behavior — how do they act toward each other right now?', style: { minHeight: '50px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.currentStatus = v; await saveCharacter(f); } } } as UIPart,
        { type: 'multilineTextInput', label: 'Trajectory', initialValue: rel.trajectory, placeholder: 'The force pushing it — what event or tension is driving change?', style: { minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.trajectory = v; await saveCharacter(f); } } } as UIPart,
        { type: 'multilineTextInput', label: 'Summary', initialValue: rel.summary, placeholder: 'The core knot — what do they each need that the other cannot give?', style: { minHeight: '60px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.summary = v; await saveCharacter(f); } } } as UIPart,
        { type: 'button', text: 'Regenerate Relationship', iconId: 'refresh-cw', style: { width: '100%', marginTop: '8px', fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-rel', autoClose: false, type: 'info' }); const ok = await generateRelationshipUpdate(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-rel', type: ok ? 'success' : 'error', autoClose: 2000 }); if (ok) await refreshCharEditModal(); } } as UIPart
    ];
}

// ── TAB: Overview ─────────────────────────────────────────────────────────
async function buildCharOverviewTab(char: CharacterRecord, cfg: GlobalConfig, charId: string, mut: (fn: (c: CharacterRecord) => void) => Promise<void>): Promise<UIPart[]> {
    const parts: UIPart[] = [];
    const idx = await loadIndex();
    const myMeta = idx.find(function(m) { return m.id === charId; });
    const currentLocationId = myMeta ? myMeta.currentLocationId : undefined;
    const entIdx = await loadEntityIndex();
    const locName = currentLocationId ? (entIdx.find(function(m) { return m.id === currentLocationId; })?.name || 'Unknown') : 'No Location';

    parts.push({ type: 'textInput', placeholder: 'Character Name', initialValue: char.name, style: { fontSize: '16px', fontWeight: 'bold', marginBottom: '12px' }, onChange: async function(v: string) {
        await mut(function(c) { c.name = v; });
        const fresh = await loadCharacter(charId);
        if (fresh && fresh.entityId) { let nameEnt = await loadEntity(fresh.entityId); if (nameEnt) { nameEnt.name = v; await saveEntity(nameEnt); } }
    } } as UIPart);

    parts.push(sectionHeader('Status'));
    parts.push(controlRow(
        { type: 'button', text: char.active ? 'Active' : 'Inactive', style: { minWidth: '100px', margin: 0, fontSize: '11px', backgroundColor: char.active ? 'rgba(126,200,160,0.2)' : 'rgba(255,107,107,0.2)', color: char.active ? '#7ec8a0' : '#ff6b6b' }, callback: async function() { await mut(function(c) { c.active = !c.active; }); await refreshCharEditModal(); } } as UIPart,
        'Included in context injection at all. Off = as if this character doesn\u2019t exist.'
    ));
    parts.push(controlRow(
        { type: 'button', text: char.scenePresent ? 'In Scene' : 'Away', style: { minWidth: '100px', margin: 0, fontSize: '11px', backgroundColor: char.scenePresent ? 'rgba(126,200,160,0.15)' : 'rgba(255,255,255,0.05)', color: char.scenePresent ? '#7ec8a0' : '#888' }, callback: async function() { await mut(function(c) { c.scenePresent = !c.scenePresent; }); await refreshCharEditModal(); } } as UIPart,
        'Manual override for scene presence. Resets automatically on location change.'
    ));
    parts.push(controlRow(
        { type: 'button', text: (char as any).isStatic ? 'Static' : 'Dynamic', style: { minWidth: '100px', margin: 0, fontSize: '11px', backgroundColor: (char as any).isStatic ? 'rgba(255,255,255,0.05)' : 'rgba(136,204,255,0.15)', color: (char as any).isStatic ? '#888' : '#88ccff' }, callback: async function() {
            await mut(function(c) {
                (c as any).isStatic = !(c as any).isStatic;
                const nowDyn = !(c as any).isStatic;
                c.charContextEnabled = nowDyn;
                c.autoUpdateEnabled = nowDyn;
                c.autoThoughtsEnabled = nowDyn;
                c.hooksEnabled = nowDyn;
                if (c.primaryRelationship) c.primaryRelationship.enabled = nowDyn;
            });
            await refreshCharEditModal();
        } } as UIPart,
        'Master switch for all background AI updates and their injection. Individual controls live on the Dynamic Profile tab.'
    ));
    parts.push(
        ((char as any).isProtagonist) ? { type: 'text', text: '', style: { height: '0px' } } as UIPart : { type: 'column', style: { gap: '2px', marginBottom: '10px' }, content: [
            { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [
                { type: 'text', text: 'Dynamic priority', style: { fontSize: '10px', opacity: '0.7', flexShrink: '0' } },
                { type: 'button', text: (typeof (char as any).dynamicPriorityRank === 'number' && (char as any).dynamicPriorityRank > 0) ? ('Rank #' + (char as any).dynamicPriorityRank) : 'Unranked', style: { flex: '1 1 0', margin: 0, fontSize: '10px', textAlign: 'left', backgroundColor: (typeof (char as any).dynamicPriorityRank === 'number' && (char as any).dynamicPriorityRank > 0) ? 'rgba(232,168,124,0.15)' : 'rgba(255,255,255,0.05)', color: (typeof (char as any).dynamicPriorityRank === 'number' && (char as any).dynamicPriorityRank > 0) ? '#e8a87c' : '#888' }, callback: async function() {
                    await openDynamicRankPicker(charId, async function() { await refreshCharEditModal(); await refreshSidebar(); });
                } }
            ] },
            // [v2.26.0, per user] Helper text explaining maxDynamicCharacters lives here
            // now — it previously had no in-context explanation at all.
            { type: 'text', text: 'Only the top-ranked characters, up to the max set in Settings \u2192 Dynamic Updates Timing, actually run in the background each turn \u2014 everyone else waits. Recommend limiting how many dynamic characters are present at once, or setting a max there, to avoid context bloat.', style: { fontSize: '10px', opacity: '0.55', lineHeight: '1.3' } }
        ] }
    );

    parts.push(sectionHeader('Location & Journal'));
    parts.push({ type: 'button', text: locName, iconId: 'map-pin', style: { width: '100%', margin: 0, marginBottom: '6px', fontSize: '11px', textAlign: 'left' }, callback: async function() {
        const freshEntIdx = await loadEntityIndex();
        // [BUGFIX v2.26.0, per user] Was `n.type !== 'character'` — excluded characters
        // but let items and narrative threads show up as location options too. parentId
        // (what this picker sets) is purely spatial nesting, so only type==='location'
        // entities are ever valid targets.
        const spatialNodes = freshEntIdx.filter(function(n: any) { return n.type === 'location'; });
        const pickerContent = [
            { type: 'button', text: '✕ No Location', style: { width: '100%', marginBottom: '8px' }, callback: async function() {
                const f = await loadCharacter(char.id); if (!f) { pm.close(); return; }
                if (f.entityId) { let locEnt = await loadEntity(f.entityId); if (locEnt) { locEnt.parentId = null; await saveEntity(locEnt); } }
                await saveCharacter(f); await recalculateScenePresence(); pm.close(); await refreshCharEditModal();
            } }
        ];
        spatialNodes.filter(Boolean).forEach(function(l: any) {
            pickerContent.push({ type: 'button', text: l.name, style: { width: '100%', marginBottom: '2px', textAlign: 'left', backgroundColor: currentLocationId === l.id ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() {
                const f = await loadCharacter(char.id); if (!f) { pm.close(); return; }
                if (f.entityId) { let locEnt2 = await loadEntity(f.entityId); if (locEnt2) { locEnt2.parentId = l.id; await saveEntity(locEnt2); } }
                await saveCharacter(f); await recalculateScenePresence(); pm.close(); await refreshCharEditModal();
            } } as UIPart);
        });
        const pm = await openEngineModal({ title: 'Set Location', size: 'medium', content: pickerContent });
    } } as UIPart);
    parts.push({ type: 'button', text: 'Open Journal', iconId: 'book-open', style: { width: '100%', margin: 0, marginBottom: '6px', fontSize: '11px', backgroundColor: 'rgba(232,168,124,0.12)', color: '#e8a87c' }, callback: async function() { try { await openCharJournalModal(charId); } catch (e) {} } } as UIPart);

    parts.push(sectionHeader('System'));
    let charBodyIsMissing = true;
    if (char.entityId) { let checkEnt = await loadEntity(char.entityId); if (checkEnt) charBodyIsMissing = false; }
    if (charBodyIsMissing) {
        parts.push({ type: 'button', text: 'Generate Missing Physical Body', iconId: 'tool', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(255,180,50,0.1)', border: '1px solid rgba(255,180,50,0.3)', color: '#ffb432' }, callback: async function() {
            if (typeof makeDefaultEntity === 'function') {
                let repairEnt = makeDefaultEntity(char.name);
                repairEnt.type = 'character';
                repairEnt.parentId = null;
                await saveEntity(repairEnt);
                const f = await loadCharacter(char.id);
                if (f) { f.entityId = repairEnt.id; await saveCharacter(f); await refreshCharEditModal(); if (typeof refreshSidebar === 'function') await refreshSidebar(); }
            }
        } } as UIPart);
    }
    // BUNDLED FIX [v2.17.0]: this button previously called confirmDeleteChar
    // (a PERMANENT, irreversible deleteCharacter()) even though its own Help
    // text — and the identical Roster card button — describe the reversible
    // killCharacter() (Inactive + drop items + move to Graveyard, restorable).
    // Now correctly calls killCharacter, matching the roster's own Kill button
    // and the caption below.
    parts.push(controlRow(
        { type: 'button', text: 'Kill', iconId: 'archive', style: { minWidth: '100px', margin: 0, fontSize: '11px', backgroundColor: 'rgba(255,180,50,0.08)', border: '1px solid rgba(255,180,50,0.25)', color: '#ffb432' }, callback: async function() { await killCharacter(char.id); await refreshCharEditModal(); await refreshSidebar(); } } as UIPart,
        'Sets Inactive, drops carried items at their last location, moves the body to a Graveyard location. Reversible \u2014 move them out and reactivate to restore.'
    ));
    parts.push(controlRow(
        { type: 'button', text: 'Delete Character', iconId: 'trash-2', style: { minWidth: '100px', margin: 0, fontSize: '11px', color: '#ff6b6b', backgroundColor: 'rgba(255,107,107,0.1)', border: '1px solid rgba(255,107,107,0.3)' }, callback: async function() { if (typeof confirmDeleteChar === 'function') await confirmDeleteChar(char.id, char.name); } } as UIPart,
        'Permanently deletes the character record. Cannot be undone.'
    ));

    parts.push(sectionHeader('Equipment'));
    parts.push(...(await buildEquipmentRows(char)));

    parts.push(sectionHeader('Conditions'));
    parts.push(...buildConditionsRows(char, cfg));

    parts.push(sectionHeader('Factions'));
    parts.push(...buildFactionRelationshipRows(char, cfg, charId));

    return parts;
}

// ── TAB: Static Profile ────────────────────────────────────────────────────
async function buildCharStaticTab(char: CharacterRecord, cfg: GlobalConfig, charId: string, mut: (fn: (c: CharacterRecord) => void) => Promise<void>): Promise<UIPart[]> {
    function getBiographicalPreviews(c: CharacterRecord) {
        const idLeader = [(c.species || '').trim(), (c.gender || '').trim()].filter(Boolean).join(' ');
        const idMid = [idLeader, (c.age || '').trim(), (c.occupationRole || '').trim()].filter(Boolean).join(', ');
        let loreLine = (c.name || 'Unnamed').trim();
        if (idMid) loreLine += ' \u2014 ' + idMid;
        return { anLine: loreLine };
    }
    async function updateBiographicalPreviews() {
        const fresh = await loadCharacter(charId);
        if (!fresh) return;
        const previews = getBiographicalPreviews(fresh);
        await api.v1.ui.updateParts([{ id: 'ae-an-preview', text: 'Lorebook: ' + previews.anLine }]).catch(function() {});
    }
    const initialPreviews = getBiographicalPreviews(char);

    const staticContent: UIPart[] = [];

    staticContent.push({
        type: 'multilineTextInput', label: 'Concept Dump (Raw Notes)',
        placeholder: 'Dump ideas, profiles, references — informs all static field generations. Not injected into live context.',
        initialValue: char.conceptDump || '', style: { minHeight: '80px', marginBottom: '8px' },
        onChange: async function(v: string) { await mut(function(c) { c.conceptDump = v; }); }
    } as UIPart);

    staticContent.push({ type: 'row', style: { gap: '6px', marginBottom: '12px' }, content: [
        { type: 'button', text: 'Generate All From Concept Dump', iconId: 'zap', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(255,180,50,0.15)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() {
            const f0 = await loadCharacter(charId); if (!f0) return;
            if (!(f0.conceptDump || '').trim()) { api.v1.ui.toast('Add notes to Concept Dump first.', { type: 'warning' }); return; }
            api.v1.ui.toast('Generating all fields…', { id: 'ce-genall', autoClose: false, type: 'info' });
            const fields = await generateCharacterFields(f0.name, f0.conceptDump);
            // [v2.20.0 GENDIAG] A single transient error (e.g. AbortError) no longer fails
            // this outright — executeYoinkGeneration now retries once internally. If it
            // STILL comes back null, point at the diagnostics viewer instead of a bare
            // "Failed." with no next step.
            if (!fields) { api.v1.ui.toast('Failed \u2014 tap \ud83e\ude7a Diagnostics for details.', { id: 'ce-genall', type: 'error', autoClose: 4000 }); return; }
            await mut(function(c) {
                if (fields.species) c.species = fields.species;
                if (fields.age) c.age = fields.age;
                if (fields.gender) c.gender = fields.gender;
                if (fields.occupationRole) c.occupationRole = fields.occupationRole;
                if (fields.briefDescription) c.briefDescription = fields.briefDescription;
                if (fields.physicalDescription) c.physicalDescription = fields.physicalDescription;
                if (fields.personalityCore) c.personalityCore = fields.personalityCore;
                if (fields.voiceAndMannerisms) c.voiceAndMannerisms = fields.voiceAndMannerisms;
                if (fields.background) c.background = fields.background;
                if (fields.coreValues && fields.coreValues.length) c.coreValues = fields.coreValues;
            });
            api.v1.ui.toast('Generated.', { id: 'ce-genall', type: 'success', autoClose: 1500 });
            await refreshCharEditModal();
        } },
        { type: 'button', text: '\ud83e\ude7a', style: { margin: 0, flex: '0 0 auto', minWidth: '36px' }, callback: async function() { await openGenDiagModal(); } }
    ] } as UIPart);

    staticContent.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
        { type: 'textInput', placeholder: 'Age', initialValue: char.age || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mut(function(c){ c.age = v; }); await updateBiographicalPreviews(); } },
        { type: 'textInput', placeholder: 'Gender', initialValue: char.gender || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mut(function(c){ c.gender = v; }); await updateBiographicalPreviews(); } },
        (cfg.species && cfg.species.length > 0) ? { type: 'button', text: char.species?.trim() || 'Species', style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left', backgroundColor: char.species?.trim() ? 'rgba(136,204,255,0.1)' : 'rgba(255,255,255,0.03)', border: '1px solid rgba(255,255,255,0.12)', color: char.species?.trim() ? '#88ccff' : '#666' }, callback: async function() {
            const pm = await openEngineModal({ title: 'Set Species', size: 'small', content: [
                { type: 'button', text: '✕ Clear', style: { width: '100%', marginBottom: '8px', color: '#ff6b6b' }, callback: async function() { await mut(function(c) { c.species = ''; }); pm.close(); await refreshCharEditModal(); } },
                ...(cfg.species || []).map(function(sp) {
                    const isCur = char.species === sp.name;
                    return { type: 'button', text: sp.name, style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: isCur ? 'rgba(136,204,255,0.15)' : undefined, color: isCur ? '#88ccff' : undefined }, callback: async function() { await mut(function(c) { c.species = sp.name; }); pm.close(); await refreshCharEditModal(); } } as UIPart;
                })
            ]});
        } } as UIPart : { type: 'textInput', placeholder: 'Species', initialValue: char.species || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mut(function(c) { c.species = v; }); await updateBiographicalPreviews(); } } as UIPart,
        { type: 'textInput', placeholder: 'Role / occupation', initialValue: char.occupationRole || '', style: { flex: '2 1 0' }, onChange: async function(v: string) { await mut(function(c){ c.occupationRole = v; }); await updateBiographicalPreviews(); } }
    ] } as UIPart);
    staticContent.push({ type: 'multilineTextInput', label: 'Brief Description', placeholder: 'One vivid sentence the generators must not contradict. Authoring anchor — not injected into context.', initialValue: char.briefDescription || '', style: { minHeight: '40px' }, onChange: async function(v: string) { await mut(function(c){ c.briefDescription = v; }); await updateBiographicalPreviews(); } } as UIPart);
    staticContent.push({ type: 'text', text: 'Authoring anchor for field/intro generation. Not injected into context — static identity rides the lorebook entry.', style: { fontSize: '10px', opacity: '0.45', marginTop: '4px', marginBottom: '8px' } } as UIPart);
    staticContent.push({ type: 'box', style: { backgroundColor: 'rgba(255,255,255,0.03)', border: '1px dashed rgba(255,255,255,0.1)', padding: '8px', borderRadius: '6px', marginBottom: '12px' }, content: [
        { type: 'text', text: 'Live Context Injection Preview', style: { fontSize: '10px', fontWeight: 'bold', color: 'var(--ae-accent)', marginBottom: '4px', textTransform: 'uppercase' } },
        { id: 'ae-an-preview', type: 'text', text: 'Lorebook: ' + initialPreviews.anLine, style: { fontSize: '11px', opacity: '0.9', marginBottom: '2px', fontFamily: 'monospace' } }
    ] } as UIPart);

    for (const fd of STATIC_FIELD_DEFS) {
        const label = cfg.fieldLabels[fd.key] || fd.label;
        const capturedFd = fd;
        const capBudget = cfg.fieldBudgets[fd.key] || fd.defaultBudget;
        const capInst = cfg.fieldInstructions[fd.key] || fd.defaultInstructions;
        const rawVal = (char as any)[capturedFd.key];
        const strVal = (rawVal !== null && rawVal !== undefined && !Array.isArray(rawVal)) ? String(rawVal) : '';
        staticContent.push(...buildGeneratableFieldBlock(char, cfg, charId, label, strVal, capInst, capBudget, async function(v: string) {
            await mut(function(c) { (c as any)[capturedFd.key] = v; });
        }));
    }

    const cvInitial = (char.coreValues || []).filter(Boolean).join('; ');
    staticContent.push(...buildGeneratableFieldBlock(char, cfg, charId, 'Core Values', cvInitial,
        'List 3–5 deeply held values that drive this character\'s decisions. Return them as a semicolon-separated list only.', 80,
        async function(v: string) { await mut(function(c) { c.coreValues = v.split(';').map(function(s) { return s.trim(); }).filter(Boolean); }); }
    ));

    for (const cf of cfg.customStaticFields.filter(Boolean)) {
        const capturedCf = cf;
        staticContent.push(...buildGeneratableFieldBlock(char, cfg, charId, capturedCf.label, char.customFieldValues[capturedCf.id] || '',
            capturedCf.instructions, cfg.fieldBudgets[capturedCf.id] || 150,
            async function(v: string) { await mut(function(c) { c.customFieldValues[capturedCf.id] = v; }); }
        ));
    }

    const tmpNickKey = `ce_tmp_nick_${char.id}`;
    const nickItems: UIPart[] = (char.nicknames || []).filter(Boolean).map(function(nick, i) { return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [{ type: 'text', text: nick, style: { flex: '1 1 0', fontSize: '12px' } }, { type: 'button', iconId: 'x', style: { margin: 0, fontSize: '10px' }, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; f.nicknames.splice(i, 1); await saveCharacter(f); await refreshCharEditModal(); } }] } as UIPart; });

    staticContent.push({ type: 'box', style: { borderTop: '1px solid rgba(255,255,255,0.1)', marginTop: '12px', paddingTop: '12px' }, content: (function() {
        const lbContent: UIPart[] = [];
        if (char.lorebookEntryId) {
            lbContent.push(
                { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [{ type: 'text', text: '✓ Lorebook entry linked', style: { fontSize: '12px', color: '#7ec8a0', flex: '1 1 0' } }] },
                { type: 'text', text: `Keys: ${getLorebookKeys(char).join(', ')}`, style: { fontSize: '11px', opacity: '0.55', marginBottom: '8px' } },
                { type: 'row', style: { gap: '6px' }, content: [
                    { type: 'button', text: 'Sync Static Core', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.1)', border: '1px solid rgba(126,200,160,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await syncLorebookEntry(char.id); } },
                    { type: 'button', text: 'Unlink', style: { margin: 0, fontSize: '11px' }, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; f.lorebookEntryId = undefined; await saveCharacter(f); await refreshCharEditModal(); } }
                ] }
            );
        } else {
            lbContent.push(
                { type: 'text', text: "No lorebook entry. Creating one lets NAI natively inject this character's static profile when their name appears.", style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },
                { type: 'button', text: '+ Create & Link Lorebook Entry', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.1)', border: '1px solid rgba(136,204,255,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { if (typeof createLinkedLorebookEntry === 'function') { await createLinkedLorebookEntry(char.id); await refreshCharEditModal(); } } }
            );
        }
        lbContent.push({ type: 'text', text: 'Nicknames / Aliases (added as lorebook keys):', style: { fontSize: '11px', opacity: '0.6', marginTop: '12px', marginBottom: '4px' } });
        nickItems.forEach(function(item) { lbContent.push(item); });
        lbContent.push({ type: 'row', style: { gap: '4px' }, content: [
            { type: 'textInput', placeholder: 'Add nickname or alias...', storageKey: `temp:${tmpNickKey}`, style: { flex: '1 1 0' } },
            { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(tmpNickKey) as string || ''; if (!v.trim()) return; const f = await loadCharacter(char.id); if (!f) return; if (!f.nicknames.includes(v.trim())) f.nicknames.push(v.trim()); await saveCharacter(f); await api.v1.tempStorage.remove(tmpNickKey); await refreshCharEditModal(); } }
        ] });
        return lbContent;
    })()} as UIPart);

    return staticContent;
}

// ── TAB: Dynamic Profile ───────────────────────────────────────────────────
// [v2.17.0] Unified "Enabled" toggle bar replaces four scattered checkboxes.
// Ephemeral was already independent (autoThoughtsEnabled). Midrange,
// Relationship, and Hooks used to all share ONE flag (autoUpdateEnabled) —
// see the runDynamicEngine dispatch fix in the same patch: Relationship now
// runs on primaryRelationship.enabled alone, and hooksEnabled (present on
// every CharacterRecord since day one, serialized to the bridge, but NEVER
// actually read by any dispatch condition) now genuinely gates Hooks. Hooks
// moved to the top per request; stale "(engine reference)" labeling on
// Mid-range corrected — LOREFOLD (v2.9.0) already folds it into the
// lorebook, it just never updated this copy to say so.
function buildCharDynamicTab(char: CharacterRecord, cfg: GlobalConfig, charId: string): UIPart[] {
    const parts: UIPart[] = [];
    const rel = char.primaryRelationship;

    parts.push({ type: 'text', text: 'Enabled', style: { fontSize: '11px', fontWeight: 'bold', opacity: '0.6', marginBottom: '4px', textTransform: 'uppercase' } });
    parts.push({ type: 'row', style: { gap: '6px', marginBottom: '6px', flexWrap: 'wrap' }, content: [
        _ceToggleBtn('Ephemeral', !!char.autoThoughtsEnabled, async function() { const f = await loadCharacter(charId); if (!f) return; f.autoThoughtsEnabled = !f.autoThoughtsEnabled; await saveCharacter(f); await refreshCharEditModal(); }),
        _ceToggleBtn('Midrange', !!char.autoUpdateEnabled, async function() { const f = await loadCharacter(charId); if (!f) return; f.autoUpdateEnabled = !f.autoUpdateEnabled; await saveCharacter(f); await refreshCharEditModal(); }),
        _ceToggleBtn('Relationship', !!(rel && rel.enabled), async function() { const f = await loadCharacter(charId); if (!f || !f.primaryRelationship) return; f.primaryRelationship.enabled = !f.primaryRelationship.enabled; await saveCharacter(f); await refreshCharEditModal(); }),
        _ceToggleBtn('Hooks', !!char.hooksEnabled, async function() { const f = await loadCharacter(charId); if (!f) return; f.hooksEnabled = !f.hooksEnabled; await saveCharacter(f); await refreshCharEditModal(); })
    ] });
    parts.push({ type: 'text', text: 'Each controls whether that field keeps updating in the background. Ephemeral injects into the Author\u2019s Note; Midrange, Relationship, and high-pressure Hooks fold into this character\u2019s lorebook entry. Turning one off freezes its current content in place rather than clearing it.', style: { fontSize: '10px', opacity: '0.5', lineHeight: '1.4', marginBottom: '10px' } });

    parts.push(sectionHeader('Hooks'));
    parts.push(...buildHooksSection(char, cfg));

    parts.push(sectionHeader('Ephemeral Thoughts (injects into the Author\u2019s Note)'));
    parts.push(...buildEphemeralRows(char, cfg));

    parts.push(sectionHeader('Mid-range State (folds into this character\u2019s lorebook entry)'));
    parts.push(...buildMidRangeRows(char, cfg));

    parts.push(sectionHeader('Primary Relationship'));
    parts.push(...buildRelationshipSection(char, cfg));

    parts.push(sectionHeader('Texting Persona (Character Chat)'));
    parts.push(...buildChatPersonaSection(char, cfg, charId));

    return parts;
}

// ── [v2.24.0 CHARCHAT-PERSONA] Texting persona editor ───────────────────
// Three enum rows and a notes box. Deliberately has NO generate button, unlike every
// other field on this tab — per user, this compiles into the next-message instruction,
// so it needs to stay one short line. A zap button here would produce a paragraph that
// is worse at the job and costs tokens on every single turn to be worse at it.
// Lives on Dynamic Profile rather than Static because it is a behaviour switch, not
// authored prose about who they are.
function _ccPersonaRow(char: CharacterRecord, charId: string, label: string, opts: CharChatOpt[], current: string, apply: (c: CharacterRecord, v: string) => void): UIPart {
    const cur = _charchatOpt(opts, current || 'auto');
    return { type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '6px' }, content: [
        { type: 'text', text: label, style: { width: '72px', fontSize: '11px', opacity: '0.6' } },
        { type: 'button', text: cur.label, style: { flex: '1 1 0', margin: 0, textAlign: 'left', fontSize: '12px' }, callback: async function() {
            const pk = await openEngineModal({ title: label, size: 'small', content: opts.map(function(o) {
                return { type: 'button', text: o.label, style: { width: '100%', margin: '2px 0', textAlign: 'left', fontSize: '12px', backgroundColor: o.id === cur.id ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() {
                    const f = await loadCharacter(charId); if (f) { if (!f.chatPersona) f.chatPersona = {}; apply(f, o.id); await saveCharacter(f); }
                    try { if (pk && !pk.isClosed()) pk.close(); } catch (ePk) {}
                    await refreshCharEditModal();
                } } as UIPart;
            }) });
        } }
    ] } as UIPart;
}

function buildChatPersonaSection(char: CharacterRecord, cfg: GlobalConfig, charId: string): UIPart[] {
    const cp = char.chatPersona || {};
    const on = cp.enabled !== false && !!char.chatPersona;
    const parts: UIPart[] = [];

    parts.push({ type: 'row', style: { gap: '6px', marginBottom: '6px' }, content: [
        _ceToggleBtn(on ? 'Persona On' : 'Persona Off', on, async function() {
            const f = await loadCharacter(charId); if (!f) return;
            if (!f.chatPersona) f.chatPersona = { enabled: true, style: 'auto', verbosity: 'auto', emoji: 'auto' };
            else f.chatPersona.enabled = (f.chatPersona.enabled === false);
            await saveCharacter(f); await refreshCharEditModal();
        })
    ] } as UIPart);
    parts.push({ type: 'text', text: 'How this character texts, compiled into one line on the chat\u2019s next-message instruction. Off (or every axis on Auto) means the model derives a style from their profile on its own \u2014 which is usually the right answer, so only override what you actively disagree with. Verbosity also sets the reply token cap.', style: { fontSize: '10px', opacity: '0.5', lineHeight: '1.4', marginBottom: '10px' } } as UIPart);

    if (!on) return parts;

    parts.push(_ccPersonaRow(char, charId, 'Style',     CHARCHAT_STYLE_OPTS,     cp.style || 'auto',     function(c, v) { if (c.chatPersona) c.chatPersona.style = v; }));
    parts.push(_ccPersonaRow(char, charId, 'Length',    CHARCHAT_VERBOSITY_OPTS, cp.verbosity || 'auto', function(c, v) { if (c.chatPersona) c.chatPersona.verbosity = v; }));
    parts.push(_ccPersonaRow(char, charId, 'Emoji',     CHARCHAT_EMOJI_OPTS,     cp.emoji || 'auto',     function(c, v) { if (c.chatPersona) c.chatPersona.emoji = v; }));
    parts.push({ type: 'multilineTextInput', label: 'Extra notes (optional)', placeholder: 'never uses full stops; always signs off with a nickname\u2026', initialValue: cp.notes || '', style: { minHeight: '44px', marginTop: '6px' }, onChange: async function(v: string) {
        const f = await loadCharacter(charId); if (!f) return; if (!f.chatPersona) f.chatPersona = {}; f.chatPersona.notes = v; await saveCharacter(f);
    } } as UIPart);

    // Live preview of the exact string that reaches the model — the same function the
    // context builder calls, not a re-description of it.
    const preview = buildCharChatPersonaClause(char);
    parts.push({ type: 'text', text: preview ? ('Sent as: ' + preview) : 'Sent as: (nothing \u2014 every axis is on Auto, so the global rubric applies)', style: { fontSize: '10px', opacity: '0.45', marginTop: '8px', fontStyle: 'italic', whiteSpace: 'pre-wrap' } } as UIPart);
    parts.push({ type: 'text', text: 'Reply cap: ' + charChatMaxTokensFor(char, cfg) + ' tokens.', style: { fontSize: '10px', opacity: '0.45', marginTop: '2px' } } as UIPart);
    return parts;
}

// ── TAB: Visuals ────────────────────────────────────────────────────────────
// [v2.17.0] Dropped the "Tag Subscriptions" block that used to sit here —
// confirmed dead: it reads cfg.actionTemplates, a field CE-STRIP v2.0.x
// removed from GlobalConfig entirely (same "dead-but-non-crashing" bug
// class already documented and fixed once for the Item Template editor;
// this character-modal copy was missed in that earlier pass). _ctsAllTags
// was permanently empty, so the section never rendered for any character —
// verified zero behavior change from removing it.
function buildCharVisualsTab(char: CharacterRecord, cfg: GlobalConfig, charId: string, mut: (fn: (c: CharacterRecord) => void) => Promise<void>): UIPart[] {
    return [
        { type: 'text', text: 'Used for all character image generations. Tags like: hair color, eye color, clothing.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '6px' } },
        { type: 'multilineTextInput', label: 'Base Character Visuals', placeholder: '1girl, brown hair, blue eyes, red dress...', initialValue: char.visuals || '', style: { minHeight: '55px' }, onChange: async function(v: string) { await mut(function(c) { c.visuals = v; }); } } as UIPart,
        { type: 'text', text: 'Tags to suppress in all this character\'s images.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '6px', marginTop: '10px' } },
        { type: 'multilineTextInput', label: 'Character Unwanted Content', placeholder: 'lowres, bad anatomy, extra limbs...', initialValue: char.uc || '', style: { minHeight: '40px' }, onChange: async function(v: string) { await mut(function(c) { c.uc = v; }); } } as UIPart
    ];
}

async function buildCharEditContent(charId: string): Promise<UIPart[]> {
    const char = await loadCharacter(charId); if (!char) return [{ type: 'text', text: 'Character not found.' }];

    // --- DATA SAFETY PATCH (Fixes "filter of undefined" on new characters) ---
    char.hooks = char.hooks || [];
    char.ephemeralHistory = char.ephemeralHistory || [];
    char.nicknames = char.nicknames || [];
    char.coreValues = char.coreValues || [];
    if (!char.primaryRelationship) {
        char.primaryRelationship = { targetName: '', enabled: false, archetype: '', howItStarted: '', threads: [], currentStatus: '', trajectory: '', summary: '', milestones: [] };
    }
    char.primaryRelationship.threads = char.primaryRelationship.threads || [];
    char.primaryRelationship.milestones = char.primaryRelationship.milestones || [];
    if (!char.customFieldValues) char.customFieldValues = {};
    if (!char.sheetValues) char.sheetValues = {};
    // ------------------------------------------------------------------------

    const cfg = await loadConfig();
    async function mut(fn: (c: CharacterRecord) => void): Promise<void> { const f = await loadCharacter(charId); if (!f) return; fn(f); await saveCharacter(f); await refreshSidebar(); }

    const activeTab = await api.v1.tempStorage.getOrDefault(`ce_tab_${charId}`, 'overview') as string;
    const parts: UIPart[] = [];
    parts.push(charEditTabBar(charId, activeTab));

    if (activeTab === 'static') {
        parts.push(...(await buildCharStaticTab(char, cfg, charId, mut)));
    } else if (activeTab === 'dynamic') {
        parts.push(...buildCharDynamicTab(char, cfg, charId));
    } else if (activeTab === 'visuals') {
        parts.push(...buildCharVisualsTab(char, cfg, charId, mut));
    } else {
        parts.push(...(await buildCharOverviewTab(char, cfg, charId, mut)));
    }

    // Padding for smooth scrolling at the bottom
    parts.push({ type: 'text', text: ' ', style: { marginBottom: '48px' } });
    return parts;
}

// ============================================================================
// CHARACTER EDIT — CHARACTER SHEET SECTION
// ============================================================================

function buildSheetSection(char: CharacterRecord, cfg: GlobalConfig): UIPart {
    if (cfg.sheetCategories.filter(Boolean).length === 0) {
        return { type: 'collapsibleSection', title: '📊 Character Sheet', initialCollapsed: true, storageKey: `temp:ce_sheet_${char.id}`, content: [{ type: 'text', text: 'No categories defined. Add them in ⚙ Settings.', style: { fontSize: '11px', opacity: '0.5' } }] };
    }
    const cats: UIPart[] = cfg.sheetCategories.filter(Boolean).map(function(cat) {
        const fields: UIPart[] = cat.fields.filter(Boolean).map(function(field) {
            const key = `${cat.id}.${field.id}`; const cur = char.sheetValues[key] || '';
            if (cat.fieldType === 'enum' && cat.enumValues.filter(Boolean).length > 0) {
                return { type: 'column', style: { marginBottom: '8px' }, content: [
                    { type: 'text', text: field.name, style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } },
                    { type: 'button', text: cur || '(Select…)', style: { margin: 0, textAlign: 'left', fontSize: '12px' }, callback: async function() {
                        const p = await openEngineModal({ title: field.name, size: 'small', content: cat.enumValues.filter(Boolean).map(function(v) {
                            return { type: 'button', text: v, style: { margin: '2px', width: '100%', backgroundColor: v === cur ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.sheetValues[key] = v; await saveCharacter(f); } p.close(); await refreshCharEditModal(); } } as UIPart;
                        }) });
                    } }
                ] } as UIPart;
            } else if (cat.fieldType === 'number') {
                return { type: 'numberInput', label: field.name, initialValue: Number(cur) || 0, style: { marginBottom: '8px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.sheetValues[key] = v; await saveCharacter(f); } } } as UIPart;
            } else {
                return { type: 'textInput', label: field.name, initialValue: cur, style: { marginBottom: '8px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.sheetValues[key] = v; await saveCharacter(f); } } } as UIPart;
            }
        });
        return { type: 'collapsibleSection', title: cat.name, initialCollapsed: true, storageKey: `temp:ce_sheet_${char.id}_${cat.id}`, content: fields.filter(Boolean) as UIPart[] } as UIPart;
    });
    return { type: 'collapsibleSection', title: '📊 Character Sheet', initialCollapsed: true, storageKey: `temp:ce_sheet_${char.id}`, content: cats };
}

// ============================================================================
// [CE-STRIP v2.6.0 CTX-CUT] TEMPLATE BUILDER UI SYSTEM — PHYSICALLY DELETED.
// MACRO_DICTIONARIES, DUMMY_DATA, _resPreview, copyMacroToClipboard,
// buildMacroButtons, buildTemplateEditor, getGlobalTemplateUIParts all removed
// (verified zero remaining callers of each before removal — the Drama tab's
// "⚙️ Context Templates" section, their only consumer, is gone too). The two
// surviving injections (character thoughts, critical hooks) still run through
// parseMacroTemplate() against cfg.contextTemplates.{npc,criticalHook} — just
// with hardcoded DEFAULT_TEMPLATES values and no UI exposing them for editing.
// ============================================================================

// ============================================================================
// SECTION 21 — SIDEBAR: DRAMA TAB
// buildDramaTabContent: NPC hooks, narrative arcs, web links.
// ============================================================================

async function buildDramaTabContent(): Promise<UIPart[]> {
    const allChars = await loadAllCharacters();
    let parts: UIPart[] = [];

    // [v0.9.17] Resolve the player's display name so __player__ targets show a real name.
    const _dramaCfg = await loadConfig();
    const _dramaProtag = allChars.find(function(c) { return (c as any).isProtagonist; });
    const _playerDisplayName = _dramaProtag ? _dramaProtag.name : ((_dramaCfg as any).protagonistName || 'Player');

    // --- 1. THE HOOK QUEUE (COLLAPSIBLE) ---
    let hookParts: UIPart[] = [
        { type: 'text', text: 'Hooks are active dramatic tensions involving characters. Pressure 85+ (Critical) injects directly into the Author\u2019s Note alongside that character\u2019s thoughts. Below 85%, hooks are tracked here but not currently injected into context.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '12px', lineHeight: '1.4' } }
    ];
    let allHooks: { charId: string, charName: string, hook: UnresolvedHook }[] = [];
    
    for (const c of allChars) {
        if (!c.active || !c.hooks) continue;
        for (const h of c.hooks) {
            // Under the new rules, this will realistically only find 1 active hook per character
            if (!h.resolved) allHooks.push({ charId: c.id, charName: c.name, hook: h });
        }
    }

    allHooks.sort(function(a, b) { return b.hook.pressureLevel - a.hook.pressureLevel; });

    if (allHooks.length === 0) {
        hookParts.push({ type: 'text', text: 'No active hooks. The tea is cold.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic', marginBottom: '8px', textAlign: 'center' } });
    } else {
        for (const item of allHooks) {
            const h = item.hook;
            
            // Color Logic & Glow
            let pColor = '#f1c40f'; // Yellow (< 60)
            let shadow = 'none';
            if (h.pressureLevel >= 85) {
                pColor = '#ff6b6b'; // Red (Critical)
                shadow = '0 0 10px rgba(255, 107, 107, 0.3)';
            } else if (h.pressureLevel >= 60) {
                pColor = '#ffb432'; // Orange (Urgent)
                shadow = '0 0 6px rgba(255, 180, 50, 0.15)';
            }

            hookParts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.3)', padding: '8px', marginBottom: '8px', borderLeft: `3px solid ${pColor}`, borderRadius: '4px', boxShadow: shadow }, content: [
                
                // ROW 1: Title, %, Edit, Delete
                { type: 'row', alignment: 'center', style: { marginBottom: '4px', gap: '4px' }, content: [
                    { type: 'text', text: `${item.charName} ➝ ${h.targetName === '__player__' ? _playerDisplayName : (h.targetName || 'Unknown')}`, style: { fontWeight: 'bold', fontSize: '13px', flex: '1 1 0', color: '#e8a87c', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } },
                    { type: 'text', text: `${h.pressureLevel}%`, style: { fontSize: '11px', color: pColor, fontWeight: 'bold', backgroundColor: 'rgba(0,0,0,0.5)', padding: '2px 6px', borderRadius: '4px' } },
                    { type: 'button', iconId: 'edit-2', style: { margin: 0, padding: '2px 4px', backgroundColor: 'transparent' }, callback: async function() { await openCharEditModal(item.charId); } },
                    { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px 4px', backgroundColor: 'transparent', color: '#ff6b6b' }, callback: async function() {
                        const f = await loadCharacter(item.charId);
                        if (f && f.hooks) {
                            f.hooks = f.hooks.filter(function(x) { return x.id !== h.id; });
                            await saveCharacter(f);
                            await refreshSidebar(); 
                        }
                    }}
                ]},
                
                // ROW 2: Description
                { type: 'text', text: h.description, style: { fontSize: '12px', opacity: '0.85', lineHeight: '1.4', marginBottom: '8px' } },
                
                // ROW 3: Slider & Manual Force-Update Button
                { type: 'row', alignment: 'center', style: { gap: '8px' }, content: [
                    { type: 'sliderInput', min: 0, max: 100, step: 5, initialValue: h.pressureLevel, style: { flex: '1 1 0', margin: 0 }, onChange: async function(v: number) {
                        const f = await loadCharacter(item.charId);
                        if (f && f.hooks) {
                            const targetHook = f.hooks.find(function(x) { return x.id === h.id; });
                            if (targetHook) {
                                targetHook.pressureLevel = v;
                                await saveCharacter(f);
                                // Note: Slider saves backend state silently to avoid UI crash. 
                                // User clicks 🔄 to actually trigger the color/text refresh.
                            }
                        }
                    }},
                    { type: 'button', text: '🔄 Update', style: { margin: 0, padding: '4px 8px', fontSize: '11px', backgroundColor: 'rgba(255,255,255,0.05)', border: '1px solid rgba(255,255,255,0.1)' }, disabledWhileCallbackRunning: true, callback: async function() {
                        const f = await loadCharacter(item.charId);
                        if (!f) return;
                        const cfg = await loadConfig();
                        const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;
                        
                        api.v1.ui.toast(`Scanning scene for ${f.name}...`, { id: 'hk-upd', autoClose: false, type: 'info' });
                        const ok = await generateHookUpdates(f, cfg, tc); // Calls the background engine manually
                        api.v1.ui.toast(ok ? 'Tension Updated.' : 'No changes detected.', { id: 'hk-upd', type: ok ? 'success' : 'warning', autoClose: 2000 });
                        
                        // Redraws the sidebar to apply the new colors/text
                        await refreshSidebar();
                    }}
                ]}
            ]});
        }
    }

    parts.push({ type: 'collapsibleSection', title: `🔥 The Hook Queue (${allHooks.length})`, initialCollapsed: false, storageKey: 'temp:drama_hooks', content: hookParts });

// --- 2. THE NPC WEB (COLLAPSIBLE) ---
    const npcWeb = await loadNpcWeb();
    let webParts: UIPart[] = [
        { type: 'text', text: 'Bilateral dynamics between characters. When both characters are present in the scene, priority 70+ injects as an Imperative (top of context), while lower priorities inject as Background Drama.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '12px', lineHeight: '1.4' } }
    ];

    // Helper to fetch character names for the UI buttons
    function getCharName(id: string) {
        const c = allChars.find(function(x) { return x.id === id; });
        return c ? c.name : 'Select...';
    }

    for (let i = 0; i < npcWeb.length; i++) {
        const link = npcWeb[i];
        
        // NEW: Check if both characters are currently in the scene!
        const cA = allChars.find(function(x) { return x.id === link.charA_id; });
        const cB = allChars.find(function(x) { return x.id === link.charB_id; });
        const bothPresent = !!(cA && cA.scenePresent && cB && cB.scenePresent);
        
        // Green if active in scene, Blue if background
        const webBorderColor = bothPresent ? '#7ec8a0' : '#88ccff'; 
        const webShadow = bothPresent ? '0 0 8px rgba(126,200,160,0.2)' : 'none';

        // Modal helper to select a character
        async function selectChar(isCharA: boolean) {
            const pm = await openEngineModal({
                title: 'Select Character',
                size: 'small',
                content: allChars.map(function(c) {
                    return { type: 'button', text: c.name, style: { margin: '2px', width: '100%', backgroundColor: 'rgba(255,255,255,0.02)' }, callback: async function() {
                        const web = await loadNpcWeb();
                        if (isCharA) web[i].charA_id = c.id;
                        else web[i].charB_id = c.id;
                        await saveNpcWeb(web);
                        pm.close();
                        await refreshSidebar();
                    } } as UIPart;
                })
            });
        }

        webParts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.3)', padding: '8px', marginBottom: '8px', borderLeft: `3px solid ${webBorderColor}`, boxShadow: webShadow, borderRadius: '4px' }, content: [
            
            // ROW 1: Character A ⇄ Character B + Delete
            { type: 'row', alignment: 'center', style: { marginBottom: '6px', gap: '4px' }, content: [
                { type: 'button', text: getCharName(link.charA_id), style: { flex: '1 1 0', margin: 0, fontSize: '11px', padding: '4px', color: (cA && cA.scenePresent) ? '#7ec8a0' : undefined }, callback: async function() { await selectChar(true); } },
                { type: 'text', text: '⇄', style: { fontSize: '14px', opacity: '0.6', margin: '0 2px' } },
                { type: 'button', text: getCharName(link.charB_id), style: { flex: '1 1 0', margin: 0, fontSize: '11px', padding: '4px', color: (cB && cB.scenePresent) ? '#7ec8a0' : undefined }, callback: async function() { await selectChar(false); } },
                { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px 4px', backgroundColor: 'transparent', color: '#ff6b6b' }, callback: async function() {
                    const web = await loadNpcWeb();
                    web.splice(i, 1);
                    await saveNpcWeb(web);
                    await refreshSidebar();
                }}
            ]},
            
            // ROW 2: The Dynamic Input
            { type: 'textInput', placeholder: 'Describe their dynamic (e.g., Bitter rivals...)', initialValue: link.dynamic, style: { fontSize: '12px', marginBottom: '6px' }, onChange: async function(v: string) {
                const web = await loadNpcWeb();
                web[i].dynamic = v;
                await saveNpcWeb(web);
            }},
            
            // ROW 3: The Priority Slider
            { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [
                { type: 'text', text: 'Priority', style: { fontSize: '10px', opacity: '0.6' } },
                { type: 'sliderInput', min: 0, max: 100, step: 10, initialValue: link.priority, showValue: false, style: { flex: '1 1 0', margin: 0 }, onChange: async function(v: number) {
                    const web = await loadNpcWeb();
                    web[i].priority = v;
                    await saveNpcWeb(web);
                }},
                { type: 'text', text: `${link.priority}`, style: { fontSize: '10px', fontWeight: 'bold', width: '24px', textAlign: 'right', color: webBorderColor } }
            ]}
        ]});
    }

    // Add New Link Button
    webParts.push({ type: 'button', text: '+ Add Web Link', iconId: 'plus', style: { width: '100%', fontSize: '11px', marginTop: '4px', backgroundColor: 'rgba(136,204,255,0.1)' }, callback: async function() {
        const web = await loadNpcWeb();
        web.push({ id: api.v1.uuid(), charA_id: '', charB_id: '', dynamic: '', priority: 30 });
        await saveNpcWeb(web);
        await refreshSidebar();
    }});

    parts.push({ type: 'collapsibleSection', title: `🕸️ The NPC Web (${npcWeb.length})`, initialCollapsed: true, storageKey: 'temp:drama_npcweb', content: webParts });
    // --- 3. NARRATIVE THREADS (QUEST TREE) ---
    const entIdx = await loadEntityIndex();
    const narratives = entIdx.filter(function(n) { return n.type === 'narrative'; });
    let storyParts: UIPart[] = [
        { type: 'text', text: 'Active story threads. Their descriptions inject into the Scene Drama block (bottom of context) to remind the AI of ongoing plots when they are active.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '12px', lineHeight: '1.4' } }
    ];

    // Recursive Tree Builder
    async function renderNarrativeTree(narrativeParentId: string | null, depth: number) {
        const children = narratives.filter(function(n) { return (n.narrativeParentId || null) === narrativeParentId; });
        for (const child of children) {
            const hasChildren = narratives.some(function(n) { return n.narrativeParentId === child.id; });
            
            // Emoji logic based on storyState
            let stateEmoji = '🔒';
            let nameColor = '#888';
            if (child.storyState === 'active') { stateEmoji = '🔥'; nameColor = '#ffb432'; }
            else if (child.storyState === 'completed') { stateEmoji = '✅'; nameColor = '#7ec8a0'; }

            storyParts.push({
                type: 'row', alignment: 'center', style: { paddingLeft: `${depth * 14}px`, marginBottom: '4px' }, content: [
                    { type: 'text', text: stateEmoji, style: { marginRight: '6px', fontSize: '12px' } },
                    { type: 'text', text: child.name, style: { flex: '1 1 0', fontSize: '12px', color: nameColor, fontWeight: depth === 0 ? 'bold' : 'normal' } },
                    { type: 'button', iconId: 'edit', style: { margin: 0, padding: '2px', backgroundColor: 'transparent' }, callback: async function() { await openEntityEditModal(child.id); } }
                ]
            });

            if (hasChildren) await renderNarrativeTree(child.id, depth + 1);
        }
    }

    await renderNarrativeTree(null, 0);

    if (narratives.length === 0) {
        storyParts.push({ type: 'text', text: 'No narrative threads created yet.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic', textAlign: 'center', marginBottom: '8px' } });
    }

    storyParts.push({ type: 'button', text: '+ New Narrative Thread', iconId: 'plus', style: { marginTop: '8px', fontSize: '11px', backgroundColor: 'rgba(232, 168, 124, 0.1)' }, callback: async function() {
        const ent = makeDefaultEntity('New Thread');
        ent.type = 'narrative';
        ent.storyState = 'locked';
        await saveEntity(ent);
        await openEntityEditModal(ent.id);
        await refreshSidebar();
    }});

    parts.push({ type: 'collapsibleSection', title: `📜 Narrative Threads (${narratives.length})`, initialCollapsed: false, storageKey: 'temp:drama_narratives', content: storyParts });
    
    // [CE-STRIP v2.6.0 CTX-CUT] "⚙️ Context Templates" section removed — user: "we
    // shouldn't have the Context Template in the drama tab anymore or the injections
    // tied to it." See CE-INDEX PASS 9 for the full cut (location/quest injection
    // gone too, template-editor UI stack physically deleted).

    // [v1.13.1 FACMGR-FIX] Holding Document authoring relocated to Factions Manager
    // (landing page) — it defines the shared Faction Resource schema that faction list
    // lives right next to now, instead of being split across two workspaces.
    parts.push({ type: 'box', style: { padding: '8px 10px', marginBottom: '8px', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '6px' }, content: [
        { type: 'text', text: '\ud83c\udff0 The Holding Document has moved to the Factions Manager workspace (landing page).', style: { fontSize: '11px', opacity: '0.7' } } as UIPart
    ] } as UIPart);

    return parts;
}

// ============================================================================
// SECTION 22 — SIDEBAR: WORLD / ENTITIES TAB
// [CHANGE] renderSceneHUD() -> queueSceneStateBroadcast() in travel callbacks.
// ============================================================================

async function buildEntitiesTab(): Promise<UIPart[]> {
    const parts: UIPart[] = [];
    
    // 1. Fetch the active search query for entities from temporary storage
    const searchQuery = await api.v1.tempStorage.getOrDefault('temp:ae_entity_search', '') as string;
    
    // Top Row: Create Entity Button
    parts.push({ 
        type: 'button', 
        text: 'Create Entity', iconId: 'plus', 
        style: { marginBottom: '8px' }, 
        callback: async function() { 
            const ent = makeDefaultEntity('New Entity');
            await saveEntity(ent);
            await openEntityEditModal(ent.id);
            await refreshSidebar();
        } 
    });

    // 2. Add the Search Bar component
    parts.push({
        type: 'textInput', 
        placeholder: '🔍 Search entities...', 
        initialValue: searchQuery,
        style: { marginBottom: '12px' }, 
        onChange: async function(v: string) {
            // Save the query and re-render the UI
            await api.v1.tempStorage.set('temp:ae_entity_search', v);
            await refreshSidebar();
        }
    });

    // Load the master entity index
    const entIdx = await loadEntityIndex();
    
    // 3. Filter the index based on the search query
    let displayEntIdx = entIdx;
    if (searchQuery) {
        const sq = searchQuery.toLowerCase();
        displayEntIdx = displayEntIdx.filter(m => (m.name || '').toLowerCase().includes(sq));
    }
    
    // Empty state message (Optional but recommended)
    if (displayEntIdx.length === 0) {
        parts.push({ 
            type: 'text', 
            text: searchQuery ? 'No entities match your search.' : 'No entities yet.', 
            style: { fontSize: '12px', opacity: '0.6', marginBottom: '8px' } 
        });
    }
    
    // Helper to swap order in the index array
    async function moveEntity(id: string, direction: -1 | 1) {
        const currentIndex = await loadEntityIndex();
        const childMeta = currentIndex.find(function(m) { return m.id === id; });
        if (!childMeta) return;

        // Get siblings in their current exact order
        const siblings = currentIndex.filter(function(m) { return m.parentId === childMeta.parentId; });
        const sibIdx = siblings.findIndex(function(m) { return m.id === id; });

        if (direction === -1 && sibIdx > 0) {
            // Move Up (Swap with previous sibling)
            const targetId = siblings[sibIdx - 1].id;
            const pos1 = currentIndex.findIndex(function(m) { return m.id === id; });
            const pos2 = currentIndex.findIndex(function(m) { return m.id === targetId; });
            const temp = currentIndex[pos1]; currentIndex[pos1] = currentIndex[pos2]; currentIndex[pos2] = temp;
            await saveEntityIndex(currentIndex);
            await refreshSidebar();
        } else if (direction === 1 && sibIdx < siblings.length - 1) {
            // Move Down (Swap with next sibling)
            const targetId = siblings[sibIdx + 1].id;
            const pos1 = currentIndex.findIndex(function(m) { return m.id === id; });
            const pos2 = currentIndex.findIndex(function(m) { return m.id === targetId; });
            const temp = currentIndex[pos1]; currentIndex[pos1] = currentIndex[pos2]; currentIndex[pos2] = temp;
            await saveEntityIndex(currentIndex);
            await refreshSidebar();
        }
    }

    if (searchQuery) {
        // Render a flat list when searching, since tree hierarchy parents might not match the search
        for (const child of displayEntIdx) {
            const icon = (child as any).icon || ENTITY_TYPE_ICONS[child.type] || '●';
            parts.push({
                type: 'row', alignment: 'center',
                style: { marginBottom: '4px', borderBottom: '1px solid rgba(255,255,255,0.05)', paddingBottom: '4px' },
                content: [
                    { type: 'text', text: icon, style: { marginRight: '6px', fontSize: '14px' } },
                    { type: 'text', text: child.name, style: { flex: '1 1 0', fontSize: '12px', opacity: child.type === 'item' ? '0.7' : '1' } },
                    { type: 'button', iconId: 'edit', style: { margin: 0, padding: '4px', backgroundColor: 'transparent' }, callback: async function() { await openEntityEditModal(child.id); } }
                ]
            });
        }
    } else {
        // Async Recursive Tree Builder with Collapse Memory
        async function renderEntityTree(parentId: string | null, depth: number) {
            const children = entIdx.filter(function(m) { return m.parentId === parentId; });
            
            for (let i = 0; i < children.length; i++) {
                const child = children[i];
                const hasChildren = entIdx.some(function(m) { return m.parentId === child.id; });
                const isCollapsed = await api.v1.tempStorage.getOrDefault(`ce_col_${child.id}`, false);

                const icon = (child as any).icon || ENTITY_TYPE_ICONS[child.type] || '●';
                
                const rowContent: UIPart[] = [];
                
                // 1. The Collapse Toggle Chevron
                if (hasChildren) {
                    rowContent.push({
                        type: 'button', iconId: isCollapsed ? 'chevron-right' : 'chevron-down',
                        style: { margin: '0 4px 0 0', padding: '2px', backgroundColor: 'transparent' },
                        callback: async function() {
                            await api.v1.tempStorage.set(`ce_col_${child.id}`, !isCollapsed);
                            await refreshSidebar();
                        }
                    });
                } else {
                    rowContent.push({ type: 'text', text: '', style: { minWidth: '24px', marginRight: '4px' } });
                }
                
                // 2. The Icon & Name
                rowContent.push({ type: 'text', text: icon, style: { marginRight: '6px', fontSize: '14px' } });
                rowContent.push({ type: 'text', text: child.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: depth === 0 ? 'bold' : 'normal', opacity: child.type === 'item' ? '0.7' : '1' } });
                
                // 3. Sorting Chevrons (Up / Down)
                const isFirst = i === 0;
                const isLast = i === children.length - 1;
                
                rowContent.push({
                    type: 'button', iconId: 'chevron-up', disabled: isFirst,
                    style: { margin: 0, padding: '2px', backgroundColor: 'transparent', opacity: isFirst ? '0.1' : '0.5' },
                    callback: async function() { await moveEntity(child.id, -1); }
                });
                
                rowContent.push({
                    type: 'button', iconId: 'chevron-down', disabled: isLast,
                    style: { margin: '0 4px 0 0', padding: '2px', backgroundColor: 'transparent', opacity: isLast ? '0.1' : '0.5' },
                    callback: async function() { await moveEntity(child.id, 1); }
                });

                // 4. The Edit Button
                rowContent.push({ type: 'button', iconId: 'edit', style: { margin: 0, padding: '4px', backgroundColor: 'transparent' }, callback: async function() { await openEntityEditModal(child.id); } });

                // Push the assembled row
                parts.push({
                    type: 'row', alignment: 'center',
                    style: { paddingLeft: `${depth * 14}px`, marginBottom: '4px', borderBottom: '1px solid rgba(255,255,255,0.05)', paddingBottom: '4px' },
                    content: rowContent
                });
                
                // 5. Recurse!
                if (hasChildren && !isCollapsed) {
                    await renderEntityTree(child.id, depth + 1);
                }
            }
        }
        
        // Kick off the recursion starting at the Root level (null)
        await renderEntityTree(null, 0);
    }

    if (entIdx.length === 0) {
        parts.push({ type: 'text', text: 'No nodes created yet.', style: { fontSize: '12px', opacity: '0.6' } });
    }

    // ── LOST & FOUND: entities with broken parent references ────────────
    let orphanEnts = entIdx.filter(function(m) {
        return m.parentId !== null && !entIdx.find(function(p) { return p.id === m.parentId; });
    });
    if (orphanEnts.length > 0) {
        let lostParts: UIPart[] = [
            { type: 'text', text: 'These entities have a parent that no longer exists. Move to Root or edit to reparent.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } }
        ];
        for (let orphan of orphanEnts) {
            let captOrphanId = orphan.id;
            let oIcon = ENTITY_TYPE_ICONS[orphan.type] || '❓';
            lostParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px', padding: '6px 8px', backgroundColor: 'rgba(255,180,50,0.07)', borderRadius: '4px', border: '1px solid rgba(255,180,50,0.2)' }, content: [
                { type: 'text', text: oIcon, style: { fontSize: '13px', flexShrink: '0' } },
                { type: 'text', text: orphan.name, style: { flex: '1 1 0', fontSize: '12px', color: '#ffb432' } },
                { type: 'button', text: 'Root', style: { margin: 0, fontSize: '10px', padding: '2px 8px', backgroundColor: 'rgba(255,255,255,0.06)' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let fe = await loadEntity(captOrphanId); if (!fe) return;
                    fe.parentId = null; await saveEntity(fe); await refreshSidebar();
                } },
                { type: 'button', iconId: 'edit', style: { margin: 0, padding: '4px', backgroundColor: 'transparent' }, callback: async function() { await openEntityEditModal(captOrphanId); } }
            ] });
        }
        parts.push({ type: 'collapsibleSection', title: '⚠️ Lost Entities (' + orphanEnts.length + ')', initialCollapsed: false, storageKey: 'temp:ce_lost_ents', content: lostParts });
    }

    return parts;
}

// ============================================================================
// ENTITY EDIT MODAL
// ============================================================================

async function openEntityEditModal(id: string): Promise<void> {
    const ent = await loadEntity(id);
    if (!ent) return;

    const allNodes = await loadEntityIndex();
    const cfg = await loadConfig(); 
    let parts: UIPart[] = [];

    // [CE-STRIP v2.1.5] skillOptions builder removed — only consumer (Entity skillBonuses editor) removed above.

    // --- ALWAYS VISIBLE (Top Level) ---
    parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
        { type: 'textInput', label: 'Entity Name', initialValue: ent.name, style: { flex: '1 1 0' }, onChange: async function(val: string) { ent.name = val; await saveEntity(ent); await refreshSidebar(); } },
        { type: 'textInput', label: 'Icon', placeholder: '🌍', initialValue: ent.icon || '', style: { width: '52px', flexShrink: '0', textAlign: 'center' }, onChange: async function(val: string) { ent.icon = val.trim() || undefined; await saveEntity(ent); await refreshSidebar(); queueSceneStateBroadcast(); } },
        { type: 'button', text: '⧉ Copy', style: { margin: 0, fontSize: '11px', flexShrink: '0', backgroundColor: 'rgba(136,204,255,0.1)', border: '1px solid rgba(136,204,255,0.3)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
            await copyEntity(ent.id, false);
        } },
        { type: 'button', text: '⧉+ Deep', style: { margin: 0, fontSize: '11px', flexShrink: '0', backgroundColor: 'rgba(232,168,124,0.1)', border: '1px solid rgba(232,168,124,0.3)', color: '#e8a87c' }, disabledWhileCallbackRunning: true, callback: async function() {
            await copyEntity(ent.id, true);
        } }
    ] });

    const typeOpts = [
        { id: 'location', icon: '🌍', label: 'Location' },
        { id: 'item', icon: '🎒', label: 'Item' },
        { id: 'narrative', icon: '📜', label: 'Narrative' },
        { id: 'character', icon: '👤', label: 'Character' }
    ];
    
    parts.push({ type: 'text', text: 'Entity Type', style: { fontSize: '12px', fontWeight: 'bold', marginBottom: '4px', marginTop: '8px' } });
    parts.push({ type: 'row', style: { gap: '4px', marginBottom: '12px' }, content: typeOpts.map(function(opt) { 
        const isActive = ent.type === opt.id; 
        return { 
            type: 'button', text: `${opt.icon} ${opt.label}`, 
            style: { 
                flex: '1 1 0', margin: 0, fontSize: '11px', 
                backgroundColor: isActive ? 'rgba(126,200,160,0.22)' : 'transparent', 
                border: isActive ? '1px solid rgba(126,200,160,0.55)' : '1px solid rgba(255,255,255,0.1)', 
                fontWeight: isActive ? 'bold' : 'normal' 
            }, 
            callback: async function() { ent.type = opt.id as any; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } 
        } as UIPart; 
    }) });

    // --- NARRATIVE SPECIFIC CONTROLS ---
    if (ent.type === 'narrative') {
        parts.push({ type: 'text', text: 'Story State', style: { fontSize: '12px', fontWeight: 'bold', marginBottom: '4px', marginTop: '8px', color: '#e8a87c' } });
        parts.push({ type: 'row', style: { gap: '4px', marginBottom: '8px' }, content: [
            { type: 'button', text: '🔒 Locked', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: ent.storyState === 'locked' ? 'rgba(136,136,136,0.2)' : 'transparent', border: ent.storyState === 'locked' ? '1px solid #888' : '1px solid rgba(255,255,255,0.1)' }, callback: async function() { ent.storyState = 'locked'; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } },
            { type: 'button', text: '🔥 Active', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: ent.storyState === 'active' ? 'rgba(255,180,50,0.2)' : 'transparent', border: ent.storyState === 'active' ? '1px solid #ffb432' : '1px solid rgba(255,255,255,0.1)' }, callback: async function() { ent.storyState = 'active'; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } },
            { type: 'button', text: '✅ Done', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: ent.storyState === 'completed' ? 'rgba(126,200,160,0.2)' : 'transparent', border: ent.storyState === 'completed' ? '1px solid #7ec8a0' : '1px solid rgba(255,255,255,0.1)' }, callback: async function() { ent.storyState = 'completed'; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } }
        ]});

        const narrativeNodes = allNodes.filter(function(n) { return n.type === 'narrative' && n.id !== ent.id; });
        const narrParentName = ent.narrativeParentId ? (narrativeNodes.find(function(n) { return n.id === ent.narrativeParentId; })?.name || 'Unknown') : 'None (Root Plot)';
        
        parts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '12px', backgroundColor: 'rgba(232, 168, 124, 0.05)', padding: '8px', borderRadius: '4px' }, content: [
            { type: 'text', text: `Plot Parent: ${narrParentName}`, style: { fontSize: '11px', flex: '1 1 0', color: '#e8a87c', fontWeight: 'bold' } },
            { type: 'button', text: 'Set Parent', style: { margin: 0, fontSize: '11px' }, callback: async function() {
                const pm = await openEngineModal({ id: 'ce-nparent-picker', title: 'Nest Under Plotline', size: 'medium', content: [
                    { type: 'button', text: '✕ None (Make Root Plot)', style: { width: '100%', marginBottom: '8px' }, callback: async function() { ent.narrativeParentId = null; await saveEntity(ent); pm.close(); await openEntityEditModal(ent.id); await refreshSidebar(); } },
                    ...narrativeNodes.map(function(m) { return { type: 'button', text: `📜 ${m.name}`, style: { width: '100%', marginBottom: '2px', textAlign: 'left' }, callback: async function() { ent.narrativeParentId = m.id; await saveEntity(ent); pm.close(); await openEntityEditModal(ent.id); await refreshSidebar(); } } as UIPart; })
                ]});
            }}
        ]});

        // --- QUEST TARGET ---
        const allEntForTarget = await loadEntityIndex();
        const qtMeta = ent.questTarget ? allEntForTarget.find(function(m) { return m.id === ent.questTarget; }) : null;
        const qtDisplay = qtMeta ? (ENTITY_TYPE_ICONS[qtMeta.type] || '●') + ' ' + qtMeta.name : 'None set';
        parts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '8px', padding: '8px', backgroundColor: 'rgba(136,204,255,0.05)', borderRadius: '4px', border: '1px solid rgba(136,204,255,0.1)' }, content: [
            { type: 'text', text: '🎯 Quest Target:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
            { type: 'text', text: qtDisplay, style: { flex: '1 1 0', fontSize: '12px', color: qtMeta ? '#88ccff' : '#888' } },
            ...(ent.questTarget ? [{ type: 'button', text: '✕', style: { margin: 0, padding: '2px 8px', fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent' }, callback: async function() {
                const fe = await loadEntity(ent.id); if (!fe) return;
                fe.questTarget = ''; await saveEntity(fe); await openEntityEditModal(ent.id);
            } } as UIPart] : []),
            { type: 'button', text: 'Set', style: { margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.08)', color: '#88ccff' }, callback: async function() {
                await api.v1.tempStorage.set('temp:ce_qt_search', '');
                async function drawQtPicker(pm3: any) {
                    const term3 = ((await api.v1.tempStorage.getOrDefault('temp:ce_qt_search', '')) as string).toLowerCase();
                    const pickable3 = allEntForTarget.filter(function(m) { return m.id !== ent.id && (!term3 || m.name.toLowerCase().includes(term3)); });
                    const content3: UIPart[] = [
                        { type: 'textInput', placeholder: '🔍 Search all entities...', initialValue: term3, onChange: async function(v: string) { await api.v1.tempStorage.set('temp:ce_qt_search', v); await drawQtPicker(pm3); } } as UIPart,
                        ...pickable3.map(function(m) { return { type: 'button', text: (ENTITY_TYPE_ICONS[m.type] || '●') + ' ' + m.name, style: { width: '100%', marginBottom: '2px', textAlign: 'left' }, callback: async function() {
                            pm3.close();
                            const fe3 = await loadEntity(ent.id); if (!fe3) return;
                            fe3.questTarget = m.id; await saveEntity(fe3); await openEntityEditModal(ent.id);
                        } } as UIPart; })
                    ];
                    if (pm3 && !pm3.isClosed()) { await pm3.update({ content: content3 }); }
                    else { pm3 = await openEngineModal({ id: 'ce-qt-picker', title: 'Set Quest Target', size: 'medium', content: content3 }); }
                }
                let pm3: any = null;
                await drawQtPicker(pm3);
            } }
        ] });
    }

    // --- 1. CORE DESCRIPTION ---
    let coreParts: UIPart[] = [];
    const parentName = ent.parentId ? (allNodes.find(function(m){ return m.id === ent.parentId; })?.name || 'Unknown') : 'None (Root Level)';
    
    coreParts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '12px', backgroundColor: 'rgba(255,255,255,0.05)', padding: '8px', borderRadius: '4px' }, content: [
        { type: 'text', text: 'Parent:', style: { fontSize: '12px', fontWeight: 'bold' } },
        { type: 'button', text: '❓', style: { margin: 0, padding: '2px 8px', fontSize: '11px', backgroundColor: 'transparent', border: '1px solid rgba(255,255,255,0.2)', opacity: '0.7' }, callback: async function() {
            await api.v1.ui.modal.open({ 
                title: 'About Parents & Children', size: 'small', 
                content: [ { type: 'text', markdown: true, text: 'The Engine uses a strict parent/child hierarchy.\n\n- **Locations**: If a Room is parented to a Building, entering the Room automatically moves the player down the tree.\n- **Items/Characters**: Assigning a location as a parent places them inside that location.' } ] 
            });
        } },
        { type: 'button', text: parentName, style: { margin: 0, fontSize: '11px', flex: '1 1 0' }, callback: async function() {
            await openPickerModal({
                title: 'Nest Under Entity',
                items: allNodes.filter(function(m) { return m.id !== ent.id; }),
                getId: function(m) { return m.id; },
                getLabel: function(m) { return m.name; },
                getIcon: function(m) { return m.icon || '\ud83d\udccd'; },
                getSublabel: function(m) { return m.type; },
                selectedId: ent.parentId || undefined,
                searchable: true,
                pinnedOptions: [
                    { id: '__none__', label: 'None (Make Root Level)', icon: '\u2715', onSelect: async function() { ent.parentId = null; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } }
                ],
                onSelect: async function(m) { ent.parentId = m.id; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); }
            });
        } }
    ] });

    if (ent.type === 'item') {
        coreParts.push({ 
            type: 'checkboxInput', 
            label: '🎒 Equipped to Parent (Targetable State)', 
            initialValue: !!(ent as any).isEquipped, 
            onChange: async function(val: boolean) { 
                const fe = await loadEntity(ent.id);
                if (!fe) return;
                
                (fe as any).isEquipped = val;
                (fe as any).equippedToCharId = (val && fe.parentId) ? fe.parentId : null;
                await saveEntity(fe); 
                
                // Cross-sync equippedItemIds to the parent
                if (fe.parentId) {
                    let parentChar = await loadCharacter(fe.parentId).catch(() => null);
                    if (parentChar) {
                        if (!parentChar.equippedItemIds) parentChar.equippedItemIds = [];
                        if (val && !parentChar.equippedItemIds.includes(fe.id)) parentChar.equippedItemIds.push(fe.id);
                        if (!val) parentChar.equippedItemIds = parentChar.equippedItemIds.filter(function(i: string) { return i !== fe.id; });
                        await saveCharacter(parentChar);
                    } else {
                        // Fallback in case items are parented to non-character entities
                        let parentEnt = await loadEntity(fe.parentId).catch(() => null);
                        if (parentEnt) {
                            if (!(parentEnt as any).equippedItemIds) (parentEnt as any).equippedItemIds = [];
                            if (val && !(parentEnt as any).equippedItemIds.includes(fe.id)) (parentEnt as any).equippedItemIds.push(fe.id);
                            if (!val) (parentEnt as any).equippedItemIds = (parentEnt as any).equippedItemIds.filter(function(i: string) { return i !== fe.id; });
                            await saveEntity(parentEnt);
                        }
                    }
                }
            } 
        });
    }

    // --- SILENT TOGGLE (top-level, no header) ---
    // [CE-STRIP v2.1.5] Silent Interaction / Vehicle checkboxes removed — isSilent was
    // never read anywhere; isVehicle had no consumer beyond this toggle and the display
    // fields already removed above.

    coreParts.push({ type: 'multilineTextInput', label: 'Description', initialValue: ent.description, style: { minHeight: '80px' }, onChange: async function(val) { ent.description = val; await saveEntity(ent); } });
    if (ent.type === 'location') {
        // [CE-STRIP v2.6.0 CTX-CUT] Old text claimed this description "exists in AN if
        // present" — false now that location injection is gone entirely. Description
        // is lorebook + image-gen only going forward.
        coreParts.push({ type: 'multilineTextInput', label: '🎨 Location Visuals', placeholder: 'Image tags for how this place looks (e.g. "stone tavern interior, fireplace, wooden beams"). Used by image generations specific to this location.', initialValue: (ent as any).locationVisuals || '', style: { minHeight: '50px' }, onChange: async function(val: string) { (ent as any).locationVisuals = val; await saveEntity(ent); } });
    } else if (ent.type === 'item') {
        // [CE-STRIP v2.6.0 CTX-CUT] Corrected — item names were NEVER listed in the AN
        // (that claim was already stale before this pass; buildCharInjection, the only
        // function that ever did that, has been unused-in-pipeline since v0.9.8.4).
        // buildSceneLorebookActivation is the real, current behavior.
        coreParts.push({ type: 'text', text: 'Equipped items fold into the wearer\u2019s own lorebook entry (name + description), rebuilt every generation. Unequipping removes them. Toggle via World Settings \u2192 Lorebook Additions.', style: { fontSize: '10px', opacity: '0.6', marginTop: '2px', marginBottom: '8px' } });
    }

    parts.push({ type: 'collapsibleSection', title: '📝 Core Details', initialCollapsed: false, storageKey: `temp:ce_core_${ent.id}`, content: coreParts });

    // [WP-1] ENTITY LOREBOOK
    if (ent.type !== 'character') {
        const loreParts: UIPart[] = [];
        const loreLinked = !!ent.lorebookEntryId;
        loreParts.push({ type: 'multilineTextInput', label: '📖 Lorebook Entry', placeholder: 'Extended info NOT already in the description — history, secrets, rules, reputation. Injected only when the name or an added key is mentioned (Sync after editing).', initialValue: ent.lorebookText || '', style: { minHeight: '70px' }, onChange: async function(val: string) { ent.lorebookText = val; await saveEntity(ent); } });
        loreParts.push({ type: 'text', text: loreLinked ? '✅ Linked — injects when a key below appears in the story.' : 'Not linked. Create an entry to inject this entity into context when its name (or a key) appears.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '6px' } });
        loreParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
            { type: 'button', text: loreLinked ? '🔄 Sync' : '➕ Create Lorebook', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { if (ent.lorebookEntryId) { await syncEntityLorebookEntry(ent.id); } else { await createLinkedEntityLorebookEntry(ent.id); } await openEntityEditModal(ent.id); } }
        ].concat(loreLinked ? [{ type: 'button', text: '🔗 Unlink', style: { margin: 0, fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent' }, callback: async function() { await unlinkEntityLorebookEntry(ent.id); await openEntityEditModal(ent.id); } } as UIPart] : []) });
        loreParts.push({ type: 'text', text: '🔑 Keys: ' + [ent.name].concat(ent.lorebookTags || []).join(', '), style: { fontSize: '11px', opacity: '0.8', marginBottom: '4px' } });
        (ent.lorebookTags || []).forEach(function(tg, ti) {
            const captTi = ti;
            loreParts.push({ type: 'row', alignment: 'center', style: { gap: '4px' }, content: [
                { type: 'text', text: '• ' + tg, style: { fontSize: '11px', flex: '1 1 0' } },
                { type: 'button', text: '✕', style: { margin: 0, padding: '2px 6px', fontSize: '10px', color: '#ff6b6b', backgroundColor: 'transparent' }, callback: async function() { let fe = await loadEntity(ent.id); if (!fe) return; fe.lorebookTags = (fe.lorebookTags || []).filter(function(_t, i) { return i !== captTi; }); await saveEntity(fe); if (fe.lorebookEntryId) await syncEntityLorebookEntry(fe.id, true); await openEntityEditModal(fe.id); } }
            ] });
        });
        loreParts.push({ type: 'button', text: '+ Add Key', style: { margin: '4px 0 0 0', fontSize: '11px', width: '100%' }, callback: async function() {
            let addModal: any; let pending = '';
            addModal = await openEngineModal({ id: 'ae-lore-key-add', title: 'Add Lorebook Key', size: 'small', content: [
                { type: 'text', text: 'Extra trigger word or phrase. The entity name is always a key.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '6px' } },
                { type: 'textInput', placeholder: 'e.g. the old mill', initialValue: '', onChange: function(v: string) { pending = v; } },
                { type: 'button', text: 'Add', style: { width: '100%', marginTop: '6px' }, callback: async function() { let t = (pending || '').trim(); if (t) { let fe = await loadEntity(ent.id); if (fe) { if (!fe.lorebookTags) fe.lorebookTags = []; if (fe.lorebookTags.indexOf(t) < 0) fe.lorebookTags.push(t); await saveEntity(fe); if (fe.lorebookEntryId) await syncEntityLorebookEntry(fe.id, true); } } await addModal.close(); await openEntityEditModal(ent.id); } }
            ] });
        } });
        parts.push({ type: 'collapsibleSection', title: '📖 Lorebook', initialCollapsed: true, storageKey: `temp:ce_lore_${ent.id}`, content: loreParts });
    }
    
    // --- 4. CONNECTIONS ---
    const implicitRows: UIPart[] = [];
    if (ent.parentId) { 
        const pMeta = allNodes.find(function(m) { return m.id === ent.parentId; }); 
        if (pMeta) implicitRows.push({ type: 'text', text: `↑ Go back to ${pMeta.name} (Parent)`, style: { fontSize: '11px', opacity: '0.6', marginLeft: '8px', marginBottom: '2px' } }); 
    }
    const children = allNodes.filter(function(m) { return m.parentId === ent.id; });
    for (const child of children) {
        const captChild = child;
        const childEntForGate = await loadEntity(child.id);
        // [CE-STRIP v2.1.5] childIsGated lock indicator removed — .gated has no enforcement guard anymore.
        implicitRows.push({ type: 'text', text: '↓ Enter ' + captChild.name + ' (Child)', style: { fontSize: '11px', opacity: '0.7', marginLeft: '8px', marginBottom: '2px' } });
    }
    
    let connParts: UIPart[] = [
        // [CE-STRIP v2.1.5] Self-lock toggle removed — .gated had no enforcement guard
        // left anywhere (the entity_locked guard it refers to no longer exists), so this
        // was a cosmetic lock icon with zero effect.
        // [CE-STRIP v2.0.0] "+ Entry Action" button removed — entryActionId/travel-cost
        // editing cut with Actions + Travel.
        { type: 'box', style: { marginBottom: '12px', padding: '6px', backgroundColor: 'rgba(255,255,255,0.02)', borderRadius: '4px' }, content: [
            { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                { type: 'text', text: 'Implicit Tree Connections:', style: { fontSize: '11px', fontWeight: 'bold' } },
                { type: 'button', text: '❓', style: { margin: 0, padding: '2px 6px', fontSize: '10px', backgroundColor: 'transparent', border: '1px solid rgba(255,255,255,0.2)', opacity: '0.7' }, callback: async function() {
                    await api.v1.ui.modal.open({ title: 'Implicit vs Explicit Connections', size: 'medium', content: [ { type: 'text', markdown: true, text: 'The engine automatically creates **Implicit** "Up" and "Down" connections based on parents and children (e.g., moving from the House down to the Bedroom).\n\n**Explicit** Connections are custom travel routes to entities that aren\'t strictly parents/children (e.g., a teleporter or road).' } ] });
                } }
            ] },
            ...(implicitRows.length > 0 ? implicitRows : [{ type: 'text', text: 'No parent or children.', style: { fontSize: '11px', opacity: '0.4', marginLeft: '8px', marginBottom: '2px' } } as UIPart])
        ]}
    ];

    ent.connectedEntityIds.filter(Boolean).forEach(function(conn, i) {
        const targetMeta = allNodes.find(function(m) { return m.id === conn.targetId; });
        const targetName = targetMeta?.name || `Unknown (${conn.targetId.substring(0, 8)})`; 
        
        connParts.push({ type: 'box', style: { padding: '8px', backgroundColor: 'rgba(255,255,255,0.05)', marginBottom: '4px' }, content: [
            { type: 'textInput', label: `→ ${targetName} Label`, initialValue: conn.label, placeholder: 'e.g. "Head to the market"', onChange: async function(v: string) { ent.connectedEntityIds[i].label = v; await saveEntity(ent); } },

            // [CE-STRIP v2.1.5] Requires Vehicle / Silent Travel checkboxes, the Travel
            // Action button, and the Lock/Open toggle all removed — travel-cost/vehicle/
            // gate mechanics cut, no enforcement guard reads any of them anymore.

            { type: 'button', text: 'Remove', style: { color: '#ff6b6b', marginTop: '4px' }, callback: async function() { ent.connectedEntityIds.splice(i, 1); await saveEntity(ent); await openEntityEditModal(ent.id); } }
        ] });
    });

    const existingTargetIds = new Set(ent.connectedEntityIds.map(function(c) { return c.targetId; }));
    const pickableConns = allNodes.filter(function(m) { return m.id !== ent.id && !existingTargetIds.has(m.id); });
    if (pickableConns.length > 0) {
        connParts.push({ type: 'button', text: '+ Add Explicit Connection', style: { marginTop: '6px', fontSize: '11px' }, callback: async function() {
            const pickerModal = await openEngineModal({ id: 'ce-conn-picker', size: 'medium', title: 'Pick Destination', content: [
                ...pickableConns.map(function(m) { return { type: 'button', text: `📍 ${m.name}`, style: { width: '100%', marginBottom: '4px', textAlign: 'left' }, callback: async function() { pickerModal.close(); ent.connectedEntityIds.push({ targetId: m.id, label: `Go to ${m.name}`, resourceCost: 0 }); await saveEntity(ent); await openEntityEditModal(ent.id); } } as UIPart; })
            ] });
        } });
    }
    parts.push({ type: 'collapsibleSection', title: `🔗 Connections (${ent.connectedEntityIds.length})`, initialCollapsed: true, storageKey: `temp:ce_conn_${ent.id}`, content: connParts });
    
    // [CE-STRIP v2.1.5] Entity-level Skill Bonuses editor removed — dead Actions/skillBonuses remnant.
    // --- 6. ENCOUNTERS --- [v0.9.25 E4] Removed — replaced by action system
    // --- 6. CHARACTERS ---
    const charIdx = await loadIndex();
    const chars = await loadAllCharacters();
    const presentChars = chars.filter(function(c) { return c.currentLocationId === ent.id; });
    let charParts: UIPart[] = [];
    // --- Present characters (read-only, auto-synced) ---
    charParts.push({ type: 'text', text: 'Present (auto-synced from entity tree)', style: { fontWeight: 'bold', fontSize: '11px', opacity: '0.6', marginBottom: '4px' } });
    if (presentChars.length === 0) {
        charParts.push({ type: 'text', text: 'None currently.', style: { fontSize: '11px', opacity: '0.4' } });
    } else {
        presentChars.forEach(function(c) { charParts.push({ type: 'text', text: '• ' + c.name, style: { fontSize: '12px', marginLeft: '8px', marginBottom: '2px' } }); });
    }
    
    // --- 7. EXPORT / DELETE ---
    parts.push({ type: 'row', style: { gap: '8px', marginTop: '16px' }, content: [
        { type: 'button', text: 'Delete Node', style: { flex: '1 1 0', margin: 0, fontSize: '11px', color: '#ff6b6b' }, callback: async function() { if (typeof confirmDeleteEntity === 'function') { await confirmDeleteEntity(ent.id, ent.name); } editingEntityId = null; } }
    ] });

    await openEngineModal({ id: 'entity-edit-modal', title: `Edit: ${ent.name}`, size: 'large', content: parts });
}

// ============================================================================
// ENTITY DELETION & GRAVEYARD PROTECTION
// ============================================================================


async function confirmDeleteEntity(id: string, name: string): Promise<void> {
    const pm = await openEngineModal({
        title: 'Confirm Deletion',
        size: 'small',
        content: [
            { type: 'text', text: `Are you sure you want to remove ${name}?`, style: { marginBottom: '12px' } },
            
            // THE GRAVEYARD SHUNT
            { type: 'button', text: '⚰️ Send to Graveyard (Keep data, hide from play)', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,136,136,0.2)' }, callback: async function() {
                const allEnts = await loadEntityIndex();
                let gyMeta = allEnts.find(function(e) { return e.name === 'Graveyard' && e.type === 'location'; });
                
                // Forge the Graveyard if it doesn't exist
                if (!gyMeta) {
                    const gy = typeof makeDefaultEntity === 'function' ? makeDefaultEntity('Graveyard') : { id: generateId(), name: 'Graveyard' };
                    gy.type = 'location';
                    gy.parentId = null;
                    await saveEntity(gy);
                    gyMeta = { id: gy.id, name: gy.name, type: gy.type, parentId: null };
                }
                
                const ent = await loadEntity(id);
                if (ent) {
                    ent.parentId = gyMeta.id;
                    await saveEntity(ent);
                }
                
                pm.close();
                if (typeof editingEntityId !== 'undefined' && editingEntityId === id) await openEntityEditModal(id);
                await refreshSidebar();
            }},
            
            // THE ORPHAN PROTECTOR
            { type: 'button', text: '🗑️ Permanently Delete', style: { width: '100%', marginBottom: '8px', color: '#ff6b6b', backgroundColor: 'rgba(255,107,107,0.1)' }, callback: async function() {
                const allEnts = await loadEntityIndex();
                const children = allEnts.filter(function(e) { return e.parentId === id; });
                
                // Failsafe: Shunt all internal items/characters back to Root
                for (const childMeta of children) {
                    const child = await loadEntity(childMeta.id);
                    if (child) {
                        child.parentId = null; 
                        await saveEntity(child);
                    }
                }
                
                // Now permanently delete the target node
                if (typeof deleteEntity === 'function') await deleteEntity(id);
                pm.close();
                
                // Close modal if deleting the one we are actively editing
                if (typeof editingEntityId !== 'undefined' && editingEntityId === id) {
                    const em = await openEngineModal({id: 'entity-edit-modal', title: 'Closed', content: []});
                    em.close();
                }
                await refreshSidebar();
            }},
            { type: 'button', text: 'Cancel', style: { width: '100%' }, callback: async function() { pm.close(); } }
        ]
    });
}

// ============================================================================
// SECTION 23 — WORLDBUILDING MODAL (New Setup Hub)
// ============================================================================

var worldbuildingModalHandle: any = null;

async function refreshWorldbuildingModal(): Promise<void> {
    if (worldbuildingModalHandle && !worldbuildingModalHandle.isClosed()) {
        await worldbuildingModalHandle.update({ content: await buildWorldbuildingContent() });
        return;
    }
    // [CE-STRIP v2.11.0] World Settings now renders inside the merged Settings
    // workspace (buildSettingsWorkspace) instead of its own standalone modal —
    // refresh whichever workspace is currently open instead.
    await refreshWorkspace();
}

// ── World-Build Wizard: engine-native interface ──────────────────────────
// [vNEXT] Engine-only interface for the wizard (the bridge HUD will mirror every
// function later). Tabbed so future groups (Characters, Factions, Species, ...)
// slot in without the modal growing unmanageable. Data lives in storyStorage
// (chats) and config (sections/project fields); the modal reloads fresh data on
// every redraw rather than holding a snapshot.
// [v0.9.8.2] iconId replaces emoji labels; tab order: setup, chats, memory,
// species, factions, locations, characters, intro, drama.
var WIZARD_TABS: { id: string; label: string; iconId: string }[] = [
    { id: 'live',       label: 'Chat',       iconId: 'star'            },
    { id: 'memory',     label: 'Memory',     iconId: 'file-text'       },
    { id: 'species',    label: 'Species',    iconId: 'activity'        },
    { id: 'factions',   label: 'Factions',   iconId: 'shield'          },
    // [CE-STRIP v2.1.6] 'bestiary'/'items' wizard tab entries removed — Bestiary + Item Templates cut.
    { id: 'locations',  label: 'Locations',  iconId: 'map-pin'         },
    { id: 'characters', label: 'Characters', iconId: 'user'            },
    { id: 'intro',      label: 'Intro',      iconId: 'film'            },
    { id: 'drama',      label: 'Drama',      iconId: 'zap'             },
    { id: 'help',       label: 'Help',       iconId: 'help'            }
];

// [v1.6.1] All-Schedules modal — every character's daily timetable in one place,
// now read/write. Was read-only (see prior comment below); this reuses the exact
// same row mechanics as each character's own Daily Schedule section (same
// loadCharacter/saveCharacter/openPickerModal calls) so both surfaces stay on one
// source of truth — nothing here is a separate copy of the schedule data.
// One pass over the character index + one location-index load per render; nothing
// here runs unless the user opens it, so it adds zero runtime scan cost.

async function openWizardModal(): Promise<void> {
    let pm: any;

    async function redraw(): Promise<void> {
        if (pm && typeof pm.isClosed === 'function' && pm.isClosed()) return;
        let content = await buildWizardContent();
        if (pm && !pm.isClosed()) { await pm.update({ content: content }); }
    }

    function tabBar(activeTab: string): UIPart {
        return { type: 'row', style: { gap: '3px', flexWrap: 'wrap', marginBottom: '10px', borderBottom: '1px solid rgba(255,255,255,0.08)', paddingBottom: '4px' }, content: WIZARD_TABS.map(function(t) {
            let on = activeTab === t.id;
            // [v0.9.8.2] iconId on each tab button; text provides the accessible label.
        return { type: 'button', iconId: t.iconId as any, text: t.label, style: { flex: '1 1 auto', minWidth: '76px', margin: 0, padding: '4px 3px', fontSize: '10px', fontWeight: on ? 'bold' : 'normal', borderBottom: on ? '2px solid #88ccff' : '2px solid transparent', borderRadius: '4px 4px 0 0', backgroundColor: on ? 'rgba(136,204,255,0.12)' : 'transparent', opacity: on ? '1' : '0.65' }, callback: async function() { await api.v1.tempStorage.set(STORAGE_WIZ_TAB, t.id); await redraw(); } } as UIPart;
        }) };
    }

    async function buildWizardContent(): Promise<UIPart[]> {
        let cfg = await loadConfig();
        let chats = await loadWizardChats();
        let ceEntries = await listWizChatEntries();   // [v2.6.0] CE Chats lorebook entries, offered as extra context sources on every generator tab
        let activeId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_ACTIVE_CHAT, '') as string;
        let active = chats.find(function(c) { return c.id === activeId; }) || null;
        let topics = ((cfg as any).wizardTopics && (cfg as any).wizardTopics.length) ? (cfg as any).wizardTopics : DEFAULT_WIZARD_TOPICS;
        let activeTab = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_TAB, 'live') as string;
        if (activeTab === 'story') { activeTab = 'setup'; } // [v0.9.8.2] legacy redirect
        if (activeTab === 'chats') { activeTab = 'live'; }  // [v2.19.0 WIZARD-2.0] removed Chats tab -> land on Chat
        let parts: UIPart[] = [];
        parts.push(tabBar(activeTab));

        if (activeTab === 'live') {
            // [v2.5.0 CE-CHATS] in-document wizard chat controls; refresh via the modal's
            // own redraw(), and close the modal (pm) before persona-pick / resume.
            let liveParts = await buildLiveChatTab(redraw, async function() { try { if (pm && !pm.isClosed()) await pm.close(); } catch (_eLc) {} });
            for (let __lp = 0; __lp < liveParts.length; __lp++) parts.push(liveParts[__lp]);
        // [v2.19.0 WIZARD-2.0] The classic "Chats" tab (multi-chat authoring) is removed
        // from the wizard UI; the in-document "Chat" tab (buildLiveChatTab) is the sole
        // chat method now. DEAD-PENDING-REMOVAL, kept in place because they still back the
        // bridge-mode generator surface and read existing saves: loadWizardChats /
        // saveWizardChats / createWizardChat / deleteWizardChat / exportWizardChats,
        // runWizardMemoryFanout, and the AE_WIZ_NEW_CHAT / AE_WIZ_DELETE_CHAT /
        // AE_WIZ_COMMIT_MEMORY handlers. Generator context-source checklists still surface
        // any classic chats an existing save carries; new stories simply have none.
        } else if (activeTab === 'memory') {
            // ── MEMORY SECTIONS ──
            // [v2.11.0] Context sources are now a shared, top-level checklist (mirrors
            // Species/Factions below) instead of implicitly using whichever chat happens
            // to be "active". Every section's own Regen button reads this same selection —
            // check/uncheck sources here as you go, then Regen a section to (re)generate
            // it from the current selection.
            let memSrcKey = STORAGE_WIZ_TAB_SRC + 'memory';
            let memStoredSrcRaw = await api.v1.tempStorage.getOrDefault(memSrcKey, '') as string;
            let memStoredSrcIds: string[] = [];
            try { let mj = JSON.parse(memStoredSrcRaw || '[]'); if (Array.isArray(mj)) memStoredSrcIds = mj.filter(Boolean); } catch (eMemSrc) { memStoredSrcIds = []; }
            memStoredSrcIds = memStoredSrcIds.filter(function(id) { return (chats.some(function(c) { return c.id === id; }) || ceEntries.some(function(e) { return e.id === id; })); });
            let memEffSrcIds = memStoredSrcIds.length ? memStoredSrcIds : (active ? [active.id] : []);

            parts.push({ type: 'text', text: 'Enabled sections are assembled into the static Memory block (Style → Author’s Note) on commit. Check one or more context sources below, then Regen a section to generate it from that selection.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });

            parts.push({ type: 'text', text: 'Context sources' + (memStoredSrcIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, using project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });
            if (chats.length === 0) {
                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });
            } else {
                chats.forEach(function(pc) {
                    let onSrc = memStoredSrcIds.indexOf(pc.id) >= 0;
                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {
                        let curRaw = await api.v1.tempStorage.getOrDefault(memSrcKey, '') as string;
                        let curIds: string[] = [];
                        try { let pj = JSON.parse(curRaw || '[]'); if (Array.isArray(pj)) curIds = pj.filter(Boolean); } catch (eMemSet) { curIds = []; }
                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);
                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });
                        await api.v1.tempStorage.set(memSrcKey, JSON.stringify(curIds));
                        await redraw();
                    } } as UIPart);
                });
                parts.push({ type: 'text', text: '(Check one or more. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '8px' } });
            }
            _wizCeSourceCheckboxParts(ceEntries, memStoredSrcIds, memSrcKey, redraw).forEach(function(ccp) { parts.push(ccp); });
            parts.push(wizContextPreviewPart(memEffSrcIds));

            (cfg.wizardSections || []).forEach(function(s: WizardMemorySection, si: number) {
                let hintKey = STORAGE_WIZ_SEC_HINT + s.id;
                parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '6px' }, content: [
                    { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '3px' }, content: [
                        { type: 'checkboxInput', label: '', initialValue: !!s.enabled, onChange: async function(val: boolean) { await mutConfig(function(c) { c.wizardSections[si].enabled = val; }); } } as UIPart,
                        { type: 'textInput', initialValue: s.label, style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { await mutConfig(function(c) { c.wizardSections[si].label = v; }); } },
                        { type: 'text', text: s.target === 'an' ? 'AN' : 'MEM', style: { fontSize: '9px', opacity: '0.5', flexShrink: '0' } },
                        { type: 'button', text: '↑', style: { margin: 0, padding: '2px 5px', fontSize: '11px', opacity: si === 0 ? '0.25' : '0.8' }, callback: async function() { if (si === 0) return; await mutConfig(function(c) { let a = c.wizardSections; let t = a[si - 1]; a[si - 1] = a[si]; a[si] = t; }); await redraw(); } },
                        { type: 'button', text: '↓', style: { margin: 0, padding: '2px 5px', fontSize: '11px', opacity: si >= (cfg.wizardSections || []).length - 1 ? '0.25' : '0.8' }, callback: async function() { let len = (cfg.wizardSections || []).length; if (si >= len - 1) return; await mutConfig(function(c) { let a = c.wizardSections; let t = a[si + 1]; a[si + 1] = a[si]; a[si] = t; }); await redraw(); } },
                        { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() { await mutConfig(function(c) { c.wizardSections.splice(si, 1); }); await redraw(); } }
                    ] },
                    { type: 'multilineTextInput', initialValue: s.content || '', placeholder: '(generated on commit; editable)', style: { minHeight: '40px', marginBottom: '3px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.wizardSections[si].content = v; }); } } as UIPart,
                    { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '3px' }, content: [
                        { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(hintKey, v); } },
                        { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                            let hint = await api.v1.tempStorage.getOrDefault(hintKey, '') as string;
                            api.v1.ui.toast('Regenerating “' + s.label + '”…', { id: 'wiz-regen', autoClose: false, type: 'info' });
                            let r = await regenerateWizardSection(s.id, memEffSrcIds, hint);
                            api.v1.ui.toast(r ? ('Regenerated “' + s.label + '”.') : 'Regeneration failed.', { id: 'wiz-regen', type: r ? 'success' : 'error', autoClose: 2000 });
                            await redraw();
                        } }
                    ] },
                    { type: 'textInput', initialValue: s.instructions || '', placeholder: 'Scope instructions', style: { margin: 0, fontSize: '10px', opacity: '0.8' }, onChange: async function(v: string) { await mutConfig(function(c) { c.wizardSections[si].instructions = v; }); } }
                ] });
            });
            parts.push({ type: 'button', text: '+ Add Section', style: { marginTop: '2px', fontSize: '11px' }, callback: async function() {
                await mutConfig(function(c) { if (!c.wizardSections) c.wizardSections = []; c.wizardSections.push({ id: 'wsec_' + generateId(), label: 'New Section', enabled: false, content: '', instructions: 'Describe ONLY this section’s scope.', target: 'memory' }); });
                await redraw();
            } });
            parts.push({ type: 'button', text: '✅ Commit to Memory + Author’s Note', style: { width: '100%', marginTop: '6px', fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.12)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {
                let fresh = await loadConfig();
                let ok = await commitWizardMemory(fresh);
                api.v1.ui.toast(ok ? 'Committed to Memory and Author’s Note.' : 'Commit failed.', { type: ok ? 'success' : 'error', autoClose: 2000 });
            } });
            // [v1.22.3] "Sync All Lorebooks" moved to the sidebar landing page — it is a
            // whole-world maintenance action, not a Memory-generation step, and users kept
            // missing it at the bottom of an unrelated tab. See buildSidebar section 2b.
        } else if (activeTab === 'species' || activeTab === 'factions') {
            // ── SPECIES / FACTIONS (batch yoink generation + per-item regen) ──
            let kind = (activeTab === 'factions') ? 'faction' : 'species';
            let list: any[] = (kind === 'faction') ? (cfg.factions || []) : (cfg.species || []);
            // [v0.9.81] Per-tab context sources: MULTI-select (checkboxes, mirroring the
            // per-chat context model). Stored as a JSON id array per kind. Empty selection
            // falls back to the active chat; no active chat falls back to project concept only.
            let srcKey = STORAGE_WIZ_TAB_SRC + kind;
            let storedSrcRaw = await api.v1.tempStorage.getOrDefault(srcKey, '') as string;
            let storedSrcIds: string[] = [];
            try { let parsedSrc = JSON.parse(storedSrcRaw || '[]'); if (Array.isArray(parsedSrc)) storedSrcIds = parsedSrc.filter(Boolean); } catch (eSrcParse) { storedSrcIds = []; }
            storedSrcIds = storedSrcIds.filter(function(id) { return (chats.some(function(c) { return c.id === id; }) || ceEntries.some(function(e) { return e.id === id; })); });
            let effSrcIds = storedSrcIds.length ? storedSrcIds : (active ? [active.id] : []);
            let countKey = STORAGE_WIZ_GEN_COUNT + kind;
            let countDraft = await api.v1.tempStorage.getOrDefault(countKey, 3) as number;

            parts.push({ type: 'text', text: 'Generate ' + (kind === 'faction' ? 'factions' : 'species') + ' from the chosen context source plus project context. Existing entries are fed in so new ones won\'t duplicate them. Results are STAGED for review \u2014 nothing is written to your world or the lorebook until you commit.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });

            // Context sources (multi-select checkboxes, mirroring the per-chat context model).
            parts.push({ type: 'text', text: 'Context sources' + (storedSrcIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, using project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });
            if (chats.length === 0) {
                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });
            } else {
                chats.forEach(function(pc) {
                    let onSrc = storedSrcIds.indexOf(pc.id) >= 0;
                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {
                        let curRaw = await api.v1.tempStorage.getOrDefault(srcKey, '') as string;
                        let curIds: string[] = [];
                        try { let pj = JSON.parse(curRaw || '[]'); if (Array.isArray(pj)) curIds = pj.filter(Boolean); } catch (eSrcSet) { curIds = []; }
                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);
                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });
                        await api.v1.tempStorage.set(srcKey, JSON.stringify(curIds));
                        await redraw();
                    } } as UIPart);
                });
                parts.push({ type: 'text', text: '(Check one or more. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '8px' } });
            }
            _wizCeSourceCheckboxParts(ceEntries, storedSrcIds, srcKey, redraw).forEach(function(ccp) { parts.push(ccp); });

            // [v1.22.0 PREVIEW] Show exactly what the generator will receive.
            parts.push(wizContextPreviewPart(effSrcIds));

            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '10px' }, content: [
                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'numberInput', initialValue: countDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(countKey, Math.max(1, Math.min(12, v || 1))); } },
                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let n = await api.v1.tempStorage.getOrDefault(countKey, 3) as number;
                    api.v1.ui.toast('Generating ' + n + ' ' + kind + '(s)…', { id: 'wiz-batch', autoClose: false, type: 'info' });
                    // [v1.22.0 STAGING] Stage for review; commit is a separate, explicit step.
                    let stagedIds = await stageEntityBatch(kind, n, effSrcIds);
                    api.v1.ui.toast(stagedIds.length > 0 ? ('Staged ' + stagedIds.length + ' ' + kind + '(s) \u2014 review below.') : 'Generation failed.', { id: 'wiz-batch', type: stagedIds.length > 0 ? 'success' : 'error', autoClose: 2500 });
                    await redraw();
                } }
            ] });

            // [v1.22.0 STAGING] Staged drafts for this kind, above the committed list.
            let spStageParts = await wizStagingParts(kind, redraw);
            spStageParts.forEach(function(sp) { parts.push(sp); });

            parts.push({ type: 'button', text: '+ Add blank ' + (kind === 'faction' ? 'faction' : 'species'), style: { width: '100%', marginBottom: '10px', fontSize: '11px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() {
                await addBlankWizardEntity(kind);
                await redraw();
            } });

            if (list.length === 0) {
                parts.push({ type: 'text', text: 'None yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '6px' } });
            } else {
                list.forEach(function(item: any, ii: number) {
                    let hintKey = STORAGE_WIZ_ITEM_HINT + item.id;
                    let boxContent: UIPart[] = [
                        { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '3px' }, content: [
                            { type: 'textInput', initialValue: item.name, style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { await mutConfig(function(c) { let arr: any[] = (kind === 'faction') ? c.factions : c.species; if (arr[ii]) arr[ii].name = v; }); } },
                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() {
                                let capId = item.id;
                                if (kind === 'faction') { await unlinkFactionLorebookEntry(capId).catch(function() {}); }
                                else { await unlinkSpeciesLorebookEntry(capId).catch(function() {}); }
                                await mutConfig(function(c) { let arr: any[] = (kind === 'faction') ? c.factions : c.species; let idx = arr.findIndex(function(x: any) { return x.id === capId; }); if (idx >= 0) arr.splice(idx, 1); });
                                await redraw();
                            } }
                        ] },
                        { type: 'multilineTextInput', initialValue: item.description || '', placeholder: '(lore description)', style: { minHeight: '44px', marginBottom: '3px' }, onChange: async function(v: string) { await mutConfig(function(c) { let arr: any[] = (kind === 'faction') ? c.factions : c.species; if (arr[ii]) arr[ii].description = v; }); } } as UIPart,
                        { type: 'textInput', initialValue: (item.lorebookTags || []).join(', '), placeholder: 'Lorebook tags (comma-separated)', style: { margin: '0 0 3px 0', fontSize: '10px' }, onChange: async function(v: string) { await mutConfig(function(c) { let arr: any[] = (kind === 'faction') ? c.factions : c.species; if (arr[ii]) arr[ii].lorebookTags = v.split(',').map(function(s2: string) { return s2.trim(); }).filter(Boolean); }); } },
                        { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
                            { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(hintKey, v); } },
                            { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                                let hint = await api.v1.tempStorage.getOrDefault(hintKey, '') as string;
                                api.v1.ui.toast('Regenerating “' + item.name + '”…', { id: 'wiz-ireg', autoClose: false, type: 'info' });
                                let r = await regenerateWizardEntity(kind, item.id, effSrcIds, hint);
                                api.v1.ui.toast(r ? ('Regenerated “' + item.name + '”.') : 'Regeneration failed.', { id: 'wiz-ireg', type: r ? 'success' : 'error', autoClose: 2000 });
                                await redraw();
                            } },
                            { type: 'button', text: '🔗 Sync Lore', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                                if (kind === 'faction') await syncFactionLorebookEntry(item.id); else await syncSpeciesLorebookEntry(item.id);
                            } }
                        ] }
                    ];
                    if (kind === 'faction') {
                        boxContent.push({ type: 'textInput', initialValue: (item.relationshipStates || []).join(' → '), placeholder: 'Standing track (lowest → highest)', style: { margin: 0, fontSize: '10px', opacity: '0.8' }, onChange: async function(v: string) { await mutConfig(function(c) { if (c.factions[ii]) c.factions[ii].relationshipStates = v.split('→').map(function(s2: string) { return s2.trim(); }).filter(Boolean); }); } });
                        const fNeutral = (typeof (item as any).neutralIndex === 'number') ? (item as any).neutralIndex : factionNeutralIndex(item as any);
                        boxContent.push({ type: 'row', style: { marginTop: '4px', gap: '4px' }, content: [
                            { type: 'text', text: 'Neutral/"unaffiliated" state (filtered from rosters):', style: { flex: '1 1 0', fontSize: '10px', opacity: '0.6', alignSelf: 'center' } } as UIPart,
                            { type: 'numberInput', initialValue: fNeutral, style: { width: '56px', margin: 0 }, onChange: async function(v: number) { await mutConfig(function(c) { if (c.factions[ii]) { const mx = Math.max(0, (c.factions[ii].relationshipStates || []).length - 1); (c.factions[ii] as any).neutralIndex = Math.max(0, Math.min(mx, Number(v) || 0)); } }); } } as UIPart
                        ] });
                    }
                    parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '6px' }, content: boxContent });
                });
            }
        // [CE-STRIP v2.1.6] Wizard 'bestiary' and 'items' tabs removed — Bestiary + Item Templates cut.
        } else if (activeTab === 'locations') {
            // ── LOCATIONS (two-pass tree: scope top-level, then step into any node) ──
            let lkind = 'locations';
            // Context sources (multi-select, same model as species/factions).
            let lSrcKey = STORAGE_WIZ_TAB_SRC + lkind;
            let lStoredRaw = await api.v1.tempStorage.getOrDefault(lSrcKey, '') as string;
            let lStoredIds: string[] = [];
            try { let lpj = JSON.parse(lStoredRaw || '[]'); if (Array.isArray(lpj)) lStoredIds = lpj.filter(Boolean); } catch (eLSrc) { lStoredIds = []; }
            lStoredIds = lStoredIds.filter(function(id) { return (chats.some(function(c) { return c.id === id; }) || ceEntries.some(function(e) { return e.id === id; })); });
            let lEffIds = lStoredIds.length ? lStoredIds : (active ? [active.id] : []);

            // Current parent navigation (Pass 2 step-into).
            let lParentId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_LOC_PARENT, '') as string;
            let lParentEnt = lParentId ? await loadEntity(lParentId) : null;
            if (lParentId && !lParentEnt) { lParentId = ''; await api.v1.tempStorage.set(STORAGE_WIZ_LOC_PARENT, ''); }
            let lChildDepth = lParentId ? ((await computeEntityTier(lParentId)) + 1) : 0;

            // Breadcrumb / step-up.
            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
                { type: 'text', text: lParentEnt ? ('📍 Inside: ' + lParentEnt.name) : '🌍 World root (top-level)', style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold', color: '#88ccff' } }
            ].concat(lParentEnt ? [{ type: 'button', text: '↑ Up', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, callback: async function() {
                let up = (lParentEnt && lParentEnt.parentId) ? lParentEnt.parentId : '';
                await api.v1.tempStorage.set(STORAGE_WIZ_LOC_PARENT, up);
                await redraw();
            } } as UIPart] : []) });
            parts.push({ type: 'text', text: lParentEnt ? ('Generating sub-locations of “' + lParentEnt.name + '”.') : ('Generating top-level locations. Step into any location below to build its sub-locations.'), style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });

            // [CE-STRIP v2.0.0] Tier travel rule editor (cost/time/narrate) removed — dead
            // without Travel. lChildDepth is retained only in case a future awareness-tier
            // concept needs it; currently unused past this point.
            void lChildDepth;

            // Context sources (multi-select checkboxes).
            parts.push({ type: 'text', text: 'Context sources' + (lStoredIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });
            if (chats.length === 0) {
                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });
            } else {
                chats.forEach(function(pc) {
                    let onSrc = lStoredIds.indexOf(pc.id) >= 0;
                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {
                        let curRaw = await api.v1.tempStorage.getOrDefault(lSrcKey, '') as string;
                        let curIds: string[] = [];
                        try { let lpj2 = JSON.parse(curRaw || '[]'); if (Array.isArray(lpj2)) curIds = lpj2.filter(Boolean); } catch (eLSrc2) { curIds = []; }
                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);
                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });
                        await api.v1.tempStorage.set(lSrcKey, JSON.stringify(curIds));
                        await redraw();
                    } } as UIPart);
                });
                parts.push({ type: 'text', text: '(Check one or more. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '8px' } });
            }
            _wizCeSourceCheckboxParts(ceEntries, lStoredIds, lSrcKey, redraw).forEach(function(ccp) { parts.push(ccp); });

            // Generate + add-blank.
            let lCountKey = STORAGE_WIZ_GEN_COUNT + lkind;
            let lCountDraft = await api.v1.tempStorage.getOrDefault(lCountKey, 3) as number;
            // [v1.22.0 PREVIEW] Show exactly what the generator will receive.
            parts.push(wizContextPreviewPart(lEffIds));
            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '8px' }, content: [
                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'numberInput', initialValue: lCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(lCountKey, Math.max(1, Math.min(12, v || 1))); } },
                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let n = await api.v1.tempStorage.getOrDefault(lCountKey, 3) as number;
                    let pId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_LOC_PARENT, '') as string;
                    api.v1.ui.toast('Generating ' + n + ' location(s)…', { id: 'wiz-loc', autoClose: false, type: 'info' });
                    // [v1.22.0 STAGING] Stage for review; the draft carries its parentId, so
                    // committing later still files it under the right branch of the tree.
                    let lStaged = await stageLocationBatch(n, pId || null, lEffIds);
                    api.v1.ui.toast(lStaged.length > 0 ? ('Staged ' + lStaged.length + ' location(s) \u2014 review below.') : 'Generation failed.', { id: 'wiz-loc', type: lStaged.length > 0 ? 'success' : 'error', autoClose: 2500 });
                    await redraw();
                } }
            ] });

            // [v1.22.0 STAGING] Staged location drafts, above the committed children list.
            let lStageParts = await wizStagingParts('location', redraw);
            lStageParts.forEach(function(lsp) { parts.push(lsp); });

            parts.push({ type: 'button', text: '+ Add blank location', style: { width: '100%', marginBottom: '10px', fontSize: '11px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() {
                let pId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_LOC_PARENT, '') as string;
                await addBlankWizardLocation(pId || null);
                await redraw();
            } });

            // Children list (locations under the current parent).
            let lIdx = await loadEntityIndex();
            let lKids = lIdx.filter(function(m) { return m.type === 'location' && m.parentId === (lParentId || null); });
            if (lKids.length === 0) {
                parts.push({ type: 'text', text: 'No locations here yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '6px' } });
            } else {
                for (let lk = 0; lk < lKids.length; lk++) {
                    let kidMeta = lKids[lk];
                    let kidEnt = await loadEntity(kidMeta.id);
                    if (!kidEnt) continue;
                    let kidId = kidMeta.id;
                    let kidName = kidEnt.name;
                    let lHintKey = STORAGE_WIZ_ITEM_HINT + kidId;
                    let grandCount = lIdx.filter(function(m) { return m.type === 'location' && m.parentId === kidId; }).length;
                    parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '6px' }, content: [
                        { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '3px' }, content: [
                            { type: 'textInput', initialValue: kidEnt.name, style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { let fe = await loadEntity(kidId); if (!fe) return; fe.name = v; await saveEntity(fe); } },
                            { type: 'button', text: '↳ Into' + (grandCount ? (' (' + grandCount + ')') : ''), style: { margin: 0, fontSize: '10px', padding: '3px 8px', backgroundColor: 'rgba(136,204,255,0.12)', color: '#88ccff' }, callback: async function() { await api.v1.tempStorage.set(STORAGE_WIZ_LOC_PARENT, kidId); await redraw(); } },
                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() { await deleteEntity(kidId); await redraw(); } }
                        ] },
                        { type: 'multilineTextInput', initialValue: kidEnt.description || '', placeholder: 'Scene description (AN — short, what you sense on arrival)', style: { minHeight: '38px', marginBottom: '3px' }, onChange: async function(v: string) { let fe = await loadEntity(kidId); if (!fe) return; fe.description = v; await saveEntity(fe); } } as UIPart,
                        { type: 'multilineTextInput', initialValue: (kidEnt as any).lorebookText || '', placeholder: '📖 Lorebook (comprehensive — history, significance, secrets)', style: { minHeight: '52px', marginBottom: '3px' }, onChange: async function(v: string) { let fe = await loadEntity(kidId); if (!fe) return; (fe as any).lorebookText = v; await saveEntity(fe); } } as UIPart,
                        { type: 'button', text: (kidEnt as any).lorebookEntryId ? '🔗 Sync lorebook entry' : '+ Create lorebook entry', style: { width: '100%', margin: '0 0 3px 0', fontSize: '10px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() { let fe = await loadEntity(kidId); if (!fe) return; if ((fe as any).lorebookEntryId) await syncEntityLorebookEntry(kidId, false).catch(function() {}); else await createLinkedEntityLorebookEntry(kidId).catch(function() {}); await redraw(); } } as UIPart,
                        { type: 'textInput', initialValue: (kidEnt as any).locationVisuals || '', placeholder: '🎨 Image tags (booru + plain language) — for the image pipeline', style: { margin: '0 0 3px 0', fontSize: '10px' }, onChange: async function(v: string) { let fe = await loadEntity(kidId); if (!fe) return; (fe as any).locationVisuals = v; await saveEntity(fe); } },
                        { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [
                            { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(lHintKey, v); } },
                            { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                                let hint = await api.v1.tempStorage.getOrDefault(lHintKey, '') as string;
                                api.v1.ui.toast('Regenerating “' + kidName + '”…', { id: 'wiz-lreg', autoClose: false, type: 'info' });
                                let r = await regenerateWizardLocation(kidId, lEffIds, hint);
                                api.v1.ui.toast(r ? ('Regenerated “' + kidName + '”.') : 'Regeneration failed.', { id: 'wiz-lreg', type: r ? 'success' : 'error', autoClose: 2000 });
                                await redraw();
                            } }
                        ] }
                    ] });
                }
            }
        } else if (activeTab === 'characters') {
            // ── CHARACTERS (seed-and-go: name + comprehensive dump -> fields -> create) ──
            let ckind = 'characters';
            let cSrcKey = STORAGE_WIZ_TAB_SRC + ckind;
            let cStoredRaw = await api.v1.tempStorage.getOrDefault(cSrcKey, '') as string;
            let cStoredIds: string[] = [];
            try { let cpj = JSON.parse(cStoredRaw || '[]'); if (Array.isArray(cpj)) cStoredIds = cpj.filter(Boolean); } catch (eCSrc) { cStoredIds = []; }
            cStoredIds = cStoredIds.filter(function(id) { return (chats.some(function(c) { return c.id === id; }) || ceEntries.some(function(e) { return e.id === id; })); });
            let cEffIds = cStoredIds.length ? cStoredIds : (active ? [active.id] : []);

            parts.push({ type: 'text', text: 'Generate characters from the selected context. Each gets a comprehensive concept dump organising everything the chat establishes about them; their dramatis-personae and static fields are then derived from that dump. New characters appear in the Characters tab — edit and regenerate individual fields there.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });

            // Context sources (multi-select checkboxes).
            parts.push({ type: 'text', text: 'Context sources' + (cStoredIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });
            if (chats.length === 0) {
                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });
            } else {
                chats.forEach(function(pc) {
                    let onSrc = cStoredIds.indexOf(pc.id) >= 0;
                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {
                        let curRaw = await api.v1.tempStorage.getOrDefault(cSrcKey, '') as string;
                        let curIds: string[] = [];
                        try { let cpj2 = JSON.parse(curRaw || '[]'); if (Array.isArray(cpj2)) curIds = cpj2.filter(Boolean); } catch (eCSrc2) { curIds = []; }
                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);
                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });
                        await api.v1.tempStorage.set(cSrcKey, JSON.stringify(curIds));
                        await redraw();
                    } } as UIPart);
                });
                parts.push({ type: 'text', text: '(Check one or more. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '8px' } });
            }
            _wizCeSourceCheckboxParts(ceEntries, cStoredIds, cSrcKey, redraw).forEach(function(ccp) { parts.push(ccp); });

            // Generate N (each character runs several budget-free passes).
            let cCountKey = STORAGE_WIZ_GEN_COUNT + ckind;
            let cCountDraft = await api.v1.tempStorage.getOrDefault(cCountKey, 2) as number;
            // [v1.22.2 PREVIEW] Show exactly what the generator will receive.
            parts.push(wizContextPreviewPart(cEffIds));
            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '8px' }, content: [
                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'numberInput', initialValue: cCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(cCountKey, Math.max(1, Math.min(8, v || 1))); } },
                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let n = await api.v1.tempStorage.getOrDefault(cCountKey, 2) as number;
                    api.v1.ui.toast('Generating ' + n + ' character(s) \u2014 a few passes each, please wait\u2026', { id: 'wiz-char', autoClose: false, type: 'info' });
                    // [v1.22.2 CHAR-STAGE] Stage name + concept for review; fields are derived on commit.
                    let cStaged = await stageCharacterBatch(n, cEffIds);
                    api.v1.ui.toast(cStaged.length > 0 ? ('Staged ' + cStaged.length + ' character(s) \u2014 review below.') : 'Generation failed.', { id: 'wiz-char', type: cStaged.length > 0 ? 'success' : 'error', autoClose: 2500 });
                    await redraw();
                } }
            ] });

            // [v1.22.2 CHAR-STAGE] Staged character drafts, above the committed roster.
            let cStageParts = await wizStagingParts('character', redraw);
            cStageParts.forEach(function(csp) { parts.push(csp); });

            // Manual add by name (ensures a specific character is generated).
            let cNameKey = 'ae_wiz_char_addname';
            let cNameDraft = await api.v1.tempStorage.getOrDefault(cNameKey, '') as string;
            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '10px' }, content: [
                { type: 'textInput', initialValue: cNameDraft, placeholder: 'Add a specific character by name…', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(cNameKey, v); } },
                { type: 'button', text: '+ Generate', style: { margin: 0, fontSize: '11px', padding: '4px 10px' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let nm = ((await api.v1.tempStorage.getOrDefault(cNameKey, '') as string) || '').trim();
                    if (!nm) { api.v1.ui.toast('Enter a name first.', { type: 'error', autoClose: 2000 }); return; }
                    api.v1.ui.toast('Generating “' + nm + '”…', { id: 'wiz-char1', autoClose: false, type: 'info' });
                    let ok = await runWizardCharacterSingle(nm, cEffIds);
                    api.v1.ui.toast(ok ? ('Created “' + nm + '”.') : 'Generation failed.', { id: 'wiz-char1', type: ok ? 'success' : 'error', autoClose: 2500 });
                    if (ok) await api.v1.tempStorage.set(cNameKey, '');
                    await redraw();
                } }
            ] });

            // Existing character names (dedup visibility; managed in the Characters tab).
            let cCharIdx = await loadIndex();
            if (cCharIdx.length === 0) {
                parts.push({ type: 'text', text: 'No characters yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic' } });
            } else {
                parts.push({ type: 'text', text: 'Characters (' + cCharIdx.length + ') — generation avoids repeating these:', style: { fontSize: '10px', opacity: '0.6', marginBottom: '4px' } });
                cCharIdx.forEach(function(cm) {
                    parts.push({ type: 'text', text: (cm.isProtagonist ? '★ ' : '• ') + cm.name + (cm.occupationRole ? (' — ' + cm.occupationRole) : ''), style: { fontSize: '11px', opacity: '0.85', marginBottom: '2px' } });
                });
            }
        } else if (activeTab === 'drama') {
            // ── DRAMA (seed hooks, NPC web, narrative threads) ──
            // [vNEXT] Seeds the three drama primitives the sidebar Drama tab + dynamic
            // engine maintain. ONE shared context-source select feeds all three generators.
            let dkind = 'drama';
            let dSrcKey = STORAGE_WIZ_TAB_SRC + dkind;
            let dStoredRaw = await api.v1.tempStorage.getOrDefault(dSrcKey, '') as string;
            let dStoredIds: string[] = [];
            try { let dpj = JSON.parse(dStoredRaw || '[]'); if (Array.isArray(dpj)) dStoredIds = dpj.filter(Boolean); } catch (eDSrc) { dStoredIds = []; }
            dStoredIds = dStoredIds.filter(function(id) { return (chats.some(function(c) { return c.id === id; }) || ceEntries.some(function(e) { return e.id === id; })); });
            let dEffIds = dStoredIds.length ? dStoredIds : (active ? [active.id] : []);
            let dramaChars = await loadAllCharacters();

            parts.push({ type: 'text', text: 'Seed the dramatic engine across the cast: directed hooks, bilateral web dynamics, and narrative threads. Generators read the cast plus the chosen context. Full editing of each lives in the sidebar Drama tab — this establishes the opening state.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });

            if (dramaChars.length === 0) {
                parts.push({ type: 'text', text: 'No characters yet — create the cast in the Characters tab before seeding hooks or web dynamics.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic', marginBottom: '8px' } });
            }

            // Shared context sources (multi-select).
            parts.push({ type: 'text', text: 'Context sources' + (dStoredIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });
            if (chats.length === 0) {
                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });
            } else {
                chats.forEach(function(pc) {
                    let onDSrc = dStoredIds.indexOf(pc.id) >= 0;
                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onDSrc, onChange: async function(val: boolean) {
                        let dCurRaw = await api.v1.tempStorage.getOrDefault(dSrcKey, '') as string;
                        let dCurIds: string[] = [];
                        try { let dpj2 = JSON.parse(dCurRaw || '[]'); if (Array.isArray(dpj2)) dCurIds = dpj2.filter(Boolean); } catch (eDSrc2) { dCurIds = []; }
                        if (val && dCurIds.indexOf(pc.id) < 0) dCurIds.push(pc.id);
                        else if (!val) dCurIds = dCurIds.filter(function(x) { return x !== pc.id; });
                        await api.v1.tempStorage.set(dSrcKey, JSON.stringify(dCurIds));
                        await redraw();
                    } } as UIPart);
                });
                parts.push({ type: 'text', text: '(Shared by all three generators below. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '10px' } });
            }
            _wizCeSourceCheckboxParts(ceEntries, dStoredIds, dSrcKey, redraw).forEach(function(ccp) { parts.push(ccp); });

            // ===== 1. HOOKS =====
            parts.push({ type: 'text', text: '🔥 Hooks', style: { fontWeight: 'bold', fontSize: '13px', marginTop: '4px', marginBottom: '3px', color: '#e8a87c' } });
            parts.push({ type: 'text', text: 'One directed opening tension per character (pressure 20–50, matching what the engine spawns mid-play). Check who to seed, then generate.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } });

            let hookSelRaw = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_HOOK_CHARS, '') as string;
            let hookSelIds: string[] = [];
            try { let hsp = JSON.parse(hookSelRaw || '[]'); if (Array.isArray(hsp)) hookSelIds = hsp.filter(Boolean); } catch (eHookSel) { hookSelIds = []; }
            hookSelIds = hookSelIds.filter(function(id) { return dramaChars.some(function(c) { return c.id === id; }); });
            let hookCandidates = dramaChars.filter(function(c) { return c.active; });

            hookCandidates.forEach(function(hc) {
                let curHook = (hc.hooks && hc.hooks.length) ? hc.hooks[0] : null;
                let onHook = hookSelIds.indexOf(hc.id) >= 0;
                let hookSubtitle = curHook ? ('▸ ' + (curHook.targetName === '__player__' ? 'the player' : (curHook.targetName || '?')) + ' · ' + curHook.pressureLevel + '% — ' + curHook.description) : '(no hook yet)';
                let hookBox: UIPart[] = [
                    { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [
                        { type: 'checkboxInput', label: '', initialValue: onHook, onChange: async function(val: boolean) {
                            let hCurRaw = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_HOOK_CHARS, '') as string;
                            let hCurIds: string[] = [];
                            try { let hsp2 = JSON.parse(hCurRaw || '[]'); if (Array.isArray(hsp2)) hCurIds = hsp2.filter(Boolean); } catch (eHookSel2) { hCurIds = []; }
                            if (val && hCurIds.indexOf(hc.id) < 0) hCurIds.push(hc.id);
                            else if (!val) hCurIds = hCurIds.filter(function(x) { return x !== hc.id; });
                            await api.v1.tempStorage.set(STORAGE_WIZ_HOOK_CHARS, JSON.stringify(hCurIds));
                            await redraw();
                        } } as UIPart,
                        { type: 'text', text: (hc.isProtagonist ? '★ ' : '') + hc.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold' } },
                        { type: 'button', text: '⚡ Reseed', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                            api.v1.ui.toast('Seeding hook for ' + hc.name + '…', { id: 'wiz-hook1', autoClose: false, type: 'info' });
                            let hOk = await runWizardHookSingle(hc.id, dEffIds, '');
                            api.v1.ui.toast(hOk ? ('Hook seeded for ' + hc.name + '.') : 'No clean tension found.', { id: 'wiz-hook1', type: hOk ? 'success' : 'warning', autoClose: 2500 });
                            await redraw();
                        } }
                    ] },
                    { type: 'text', text: hookSubtitle, style: { fontSize: '10px', opacity: curHook ? '0.8' : '0.4', fontStyle: curHook ? 'normal' : 'italic', marginTop: '2px', lineHeight: '1.3' } }
                ];
                if (curHook) {
                    hookBox.push({ type: 'button', text: '✕ Clear hook', style: { margin: '3px 0 0 0', fontSize: '9px', padding: '2px 6px', backgroundColor: 'transparent', color: '#ff6b6b', opacity: '0.85' }, callback: async function() {
                        let fh = await loadCharacter(hc.id);
                        if (fh) { fh.hooks = []; await saveCharacter(fh); }
                        await redraw();
                    } });
                }
                parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '5px' }, content: hookBox });
            });

            if (hookCandidates.length > 0) {
                parts.push({ type: 'button', text: '⚡ Seed hooks for checked characters', style: { width: '100%', margin: '2px 0 16px 0', fontSize: '11px', fontWeight: 'bold', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let hbRaw = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_HOOK_CHARS, '') as string;
                    let hbIds: string[] = [];
                    try { let hsp3 = JSON.parse(hbRaw || '[]'); if (Array.isArray(hsp3)) hbIds = hsp3.filter(Boolean); } catch (eHookSel3) { hbIds = []; }
                    if (hbIds.length === 0) { api.v1.ui.toast('Check at least one character first.', { type: 'info', autoClose: 2000 }); return; }
                    api.v1.ui.toast('Seeding ' + hbIds.length + ' hook(s)…', { id: 'wiz-hooks', autoClose: false, type: 'info' });
                    let hbMade = await runWizardHooksBatch(hbIds, dEffIds);
                    api.v1.ui.toast(hbMade > 0 ? ('Seeded ' + hbMade + ' hook(s).') : 'No clean tensions found.', { id: 'wiz-hooks', type: hbMade > 0 ? 'success' : 'warning', autoClose: 2500 });
                    await redraw();
                } });
            }

            // ===== 2. NPC WEB =====
            parts.push({ type: 'text', text: '🕸 NPC Web', style: { fontWeight: 'bold', fontSize: '13px', marginTop: '4px', marginBottom: '3px', color: '#88ccff' } });
            parts.push({ type: 'text', text: 'Bilateral dynamics between cast members. Generated pairs are mapped to real characters; self-pairs and duplicates are skipped.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } });

            let webCountKey = STORAGE_WIZ_GEN_COUNT + 'web';
            let webCountDraft = await api.v1.tempStorage.getOrDefault(webCountKey, 3) as number;
            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '8px' }, content: [
                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'numberInput', initialValue: webCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(webCountKey, Math.max(1, Math.min(12, v || 1))); } },
                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                    if (dramaChars.length < 2) { api.v1.ui.toast('Need at least two characters.', { type: 'error', autoClose: 2000 }); return; }
                    let wn = await api.v1.tempStorage.getOrDefault(webCountKey, 3) as number;
                    api.v1.ui.toast('Generating ' + wn + ' web dynamic(s)…', { id: 'wiz-web', autoClose: false, type: 'info' });
                    let wMade = await runWizardWebBatch(wn, dEffIds);
                    api.v1.ui.toast(wMade > 0 ? ('Added ' + wMade + ' web link(s).') : 'No new links resolved.', { id: 'wiz-web', type: wMade > 0 ? 'success' : 'warning', autoClose: 2500 });
                    await redraw();
                } }
            ] });

            let dramaWeb = await loadNpcWeb();
            if (dramaWeb.length === 0) {
                parts.push({ type: 'text', text: 'No web links yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '14px' } });
            } else {
                dramaWeb.forEach(function(wl) {
                    let wlA = dramaChars.find(function(c) { return c.id === wl.charA_id; });
                    let wlB = dramaChars.find(function(c) { return c.id === wl.charB_id; });
                    let wlHintKey = STORAGE_WIZ_ITEM_HINT + wl.id;
                    parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '5px' }, content: [
                        { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '3px' }, content: [
                            { type: 'text', text: (wlA ? wlA.name : '?') + ' ⇄ ' + (wlB ? wlB.name : '?'), style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold', color: '#88ccff' } },
                            { type: 'text', text: wl.priority + '%', style: { fontSize: '10px', opacity: '0.6' } },
                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() {
                                let wFresh = await loadNpcWeb();
                                let wIdx = wFresh.findIndex(function(x) { return x.id === wl.id; });
                                if (wIdx >= 0) { wFresh.splice(wIdx, 1); await saveNpcWeb(wFresh); }
                                await redraw();
                            } }
                        ] },
                        { type: 'text', text: wl.dynamic || '(no dynamic yet)', style: { fontSize: '11px', opacity: wl.dynamic ? '0.85' : '0.4', fontStyle: wl.dynamic ? 'normal' : 'italic', lineHeight: '1.3', marginBottom: '4px' } },
                        { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [
                            { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(wlHintKey, v); } },
                            { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                                let wHint = await api.v1.tempStorage.getOrDefault(wlHintKey, '') as string;
                                api.v1.ui.toast('Regenerating dynamic…', { id: 'wiz-webreg', autoClose: false, type: 'info' });
                                let wr = await regenerateWebLink(wl.id, dEffIds, wHint);
                                api.v1.ui.toast(wr ? 'Dynamic updated.' : 'Regeneration failed.', { id: 'wiz-webreg', type: wr ? 'success' : 'error', autoClose: 2000 });
                                await redraw();
                            } }
                        ] }
                    ] });
                });
                parts.push({ type: 'box', style: { marginBottom: '14px' }, content: [] });
            }

            // ===== 3. NARRATIVE THREADS =====
            parts.push({ type: 'text', text: '📜 Narrative Threads', style: { fontWeight: 'bold', fontSize: '13px', marginTop: '4px', marginBottom: '3px', color: '#ffb432' } });
            parts.push({ type: 'text', text: 'Opening plot threads (quests, mysteries, obligations). Created at the top level — nest and re-state them in the sidebar Drama tab afterward.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } });

            let narrCountKey = STORAGE_WIZ_GEN_COUNT + 'narrative';
            let narrCountDraft = await api.v1.tempStorage.getOrDefault(narrCountKey, 3) as number;
            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '8px' }, content: [
                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'numberInput', initialValue: narrCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(narrCountKey, Math.max(1, Math.min(12, v || 1))); } },
                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(255,180,50,0.15)', color: '#ffb432' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let nn = await api.v1.tempStorage.getOrDefault(narrCountKey, 3) as number;
                    api.v1.ui.toast('Generating ' + nn + ' thread(s)…', { id: 'wiz-narr', autoClose: false, type: 'info' });
                    let nMade = await runWizardNarrativesBatch(nn, dEffIds);
                    api.v1.ui.toast(nMade > 0 ? ('Created ' + nMade + ' thread(s).') : 'Generation failed.', { id: 'wiz-narr', type: nMade > 0 ? 'success' : 'error', autoClose: 2500 });
                    await redraw();
                } }
            ] });

            parts.push({ type: 'button', text: '+ Add blank thread', style: { width: '100%', marginBottom: '8px', fontSize: '11px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() {
                await addBlankWizardNarrative();
                await redraw();
            } });

            let dramaNarrIdx = await loadEntityIndex();
            let dramaNarratives = dramaNarrIdx.filter(function(n) { return n.type === 'narrative' && (n.narrativeParentId || null) === null; });
            if (dramaNarratives.length === 0) {
                parts.push({ type: 'text', text: 'No top-level threads yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic' } });
            } else {
                dramaNarratives.forEach(function(nm) {
                    let nStateEmoji = nm.storyState === 'active' ? '🔥' : (nm.storyState === 'completed' ? '✅' : '🔒');
                    let nHintKey = STORAGE_WIZ_ITEM_HINT + nm.id;
                    parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '5px' }, content: [
                        { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '3px' }, content: [
                            { type: 'text', text: nStateEmoji, style: { fontSize: '12px' } },
                            { type: 'textInput', initialValue: nm.name, style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { let nf = await loadEntity(nm.id); if (nf) { nf.name = v; await saveEntity(nf); } } },
                            { type: 'button', iconId: 'edit', style: { margin: 0, padding: '2px' }, callback: async function() { await openEntityEditModal(nm.id); } },
                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() {
                                await deleteEntity(nm.id);
                                await redraw();
                            } }
                        ] },
                        { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [
                            { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(nHintKey, v); } },
                            { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                                let nHint = await api.v1.tempStorage.getOrDefault(nHintKey, '') as string;
                                api.v1.ui.toast('Regenerating “' + nm.name + '”…', { id: 'wiz-narrreg', autoClose: false, type: 'info' });
                                let nr = await regenerateNarrativeThread(nm.id, dEffIds, nHint);
                                api.v1.ui.toast(nr ? ('Updated “' + nm.name + '”.') : 'Regeneration failed.', { id: 'wiz-narrreg', type: nr ? 'success' : 'error', autoClose: 2000 });
                                await redraw();
                            } }
                        ] }
                    ] });
                });
            }

        } else if (activeTab === 'intro') {
            // ── INTRO / OPENING (unified location picker, generate & insert) ──
            // [v0.9.86] Cast presence removed — set character locations in their character cards.
            let ikind = 'intro';
            let introLocId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_LOC, '') as string;
            let introLocEnt = introLocId ? await loadEntity(introLocId) : null;
            if (introLocId && !introLocEnt) { introLocId = ''; await api.v1.tempStorage.set(STORAGE_WIZ_INTRO_LOC, ''); }

            parts.push({ type: 'text', text: '🎬 Opening scene', style: { fontWeight: 'bold', fontSize: '13px', marginBottom: '2px' } });
            parts.push({ type: 'text', text: 'Choose the opening location and brainstorming context, then generate a draft opening. Review, edit, or regenerate it below before committing it into the story. Set which characters are present via their character cards.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '10px' } });

            // Location: unified picker button.
            parts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '10px' }, content: [
                { type: 'text', text: '📍 Location:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'button',
                  text: introLocEnt ? introLocEnt.name : 'Pick location…',
                  style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left',
                           backgroundColor: introLocEnt ? 'rgba(136,204,255,0.15)' : 'transparent',
                           color: introLocEnt ? '#88ccff' : 'rgba(255,255,255,0.5)',
                           border: '1px solid ' + (introLocEnt ? '#88ccff' : 'rgba(255,255,255,0.2)') },
                  callback: async function() {
                    let iLocIdx = (await loadEntityIndex()).filter(function(m) { return m.type === 'location'; });
                    let curILocId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_LOC, '') as string;
                    await openPickerModal({
                        title: 'Intro location',
                        items: iLocIdx,
                        getId:       function(m) { return m.id; },
                        getLabel:    function(m) { return m.name; },
                        getIcon:     function(m) { return m.icon || '📍'; },
                        getSublabel: function(m) {
                            if (!m.parentId) return 'top-level';
                            let par = iLocIdx.find(function(x) { return x.id === m.parentId; });
                            return par ? ('in ' + par.name) : '';
                        },
                        selectedId:    curILocId || undefined,
                        emptyText:     'No locations yet — build some in the Locations tab first.',
                        pinnedOptions: curILocId ? [{ id: '__clear__', label: 'Clear selection', icon: '✕', onSelect: async function() { await api.v1.tempStorage.set(STORAGE_WIZ_INTRO_LOC, ''); await redraw(); } }] : [],
                        onSelect: async function(lm) { await api.v1.tempStorage.set(STORAGE_WIZ_INTRO_LOC, lm.id); await redraw(); }
                    });
                  } } as UIPart
            ] });

            // Context sources (multi-select checkboxes).
            let iSrcKey = STORAGE_WIZ_TAB_SRC + ikind;
            let iStoredRaw = await api.v1.tempStorage.getOrDefault(iSrcKey, '') as string;
            let iStoredIds: string[] = [];
            try { let ipj = JSON.parse(iStoredRaw || '[]'); if (Array.isArray(ipj)) iStoredIds = ipj.filter(Boolean); } catch (eISrc) { iStoredIds = []; }
            iStoredIds = iStoredIds.filter(function(id) { return (chats.some(function(c) { return c.id === id; }) || ceEntries.some(function(e) { return e.id === id; })); });
            let iEffIds = iStoredIds.length ? iStoredIds : (active ? [active.id] : []);
            parts.push({ type: 'text', text: 'Context sources' + (iStoredIds.length ? '' : (active ? ' — using “' + active.title + '”' : ' — project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });
            if (chats.length > 0) {
                chats.forEach(function(pc) {
                    let onSrc = iStoredIds.indexOf(pc.id) >= 0;
                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {
                        let curRaw = await api.v1.tempStorage.getOrDefault(iSrcKey, '') as string;
                        let curIds: string[] = [];
                        try { let ipj2 = JSON.parse(curRaw || '[]'); if (Array.isArray(ipj2)) curIds = ipj2.filter(Boolean); } catch (eISrc2) { curIds = []; }
                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);
                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });
                        await api.v1.tempStorage.set(iSrcKey, JSON.stringify(curIds));
                        await redraw();
                    } } as UIPart);
                });
            }
            _wizCeSourceCheckboxParts(ceEntries, iStoredIds, iSrcKey, redraw).forEach(function(ccp) { parts.push(ccp); });

            // [v1.6.3 INTRO-STAGE] Staged workflow: generate a draft, review / edit / regenerate
            // it in-tab, then commit into the story — matching the other wizard tabs.
            let introDraft = await loadIntroDraft();
            let introHasDraft = !!(introDraft && ((introDraft.prose || '') as string).trim());

            parts.push({ type: 'button', text: introHasDraft ? '🔄 Regenerate opening draft' : '🎬 Generate opening draft', style: { width: '100%', margin: '10px 0 0 0', fontSize: '12px', fontWeight: 'bold', backgroundColor: 'rgba(136,204,255,0.18)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                let locPick = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_LOC, '') as string;
                if (!locPick) { api.v1.ui.toast('Pick an intro location first.', { type: 'error', autoClose: 2500 }); return; }
                api.v1.ui.toast('Writing the opening…', { id: 'wiz-intro', autoClose: false, type: 'info' });
                let okGen = await generateIntroDraft(locPick, iEffIds);
                api.v1.ui.toast(okGen ? 'Draft ready — review and edit below.' : 'Intro generation failed.', { id: 'wiz-intro', type: okGen ? 'success' : 'error', autoClose: 3000 });
                await redraw();
            } });

            if (introHasDraft) {
                parts.push({ type: 'text', text: '📝 Draft opening — edit freely, then commit:', style: { fontSize: '11px', fontWeight: 'bold', marginTop: '12px', marginBottom: '4px', color: '#88ccff' } });
                parts.push({ type: 'multilineTextInput', initialValue: String(introDraft.prose || ''), placeholder: 'The opening prose\u2026', style: { minHeight: wizTextareaHeight(String(introDraft.prose || ''), 160, 420), fontSize: '12px', lineHeight: '1.5' }, onChange: async function(v: string) {
                    let cur = await loadIntroDraft();
                    if (!cur || typeof cur !== 'object') cur = { locationId: '', prose: '' };
                    cur.prose = v;
                    await api.v1.storyStorage.set(STORAGE_WIZ_INTRO_DRAFT, JSON.stringify(cur)).catch(function() {});
                } } as UIPart);
                parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginTop: '8px' }, content: [
                    { type: 'button', text: '\u2705 Commit to story', style: { flex: '2 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold', backgroundColor: 'rgba(126,200,160,0.22)', color: '#7ec8a0', border: '1px solid rgba(126,200,160,0.5)' }, disabledWhileCallbackRunning: true, callback: async function() {
                        api.v1.ui.toast('Inserting the opening\u2026', { id: 'wiz-intro-commit', autoClose: false, type: 'info' });
                        let okC = await commitIntroDraft();
                        api.v1.ui.toast(okC ? 'Opening inserted into the story.' : 'Commit failed.', { id: 'wiz-intro-commit', type: okC ? 'success' : 'error', autoClose: 3000 });
                        await redraw();
                    } },
                    { type: 'button', text: '\ud83d\uddd1 Discard', style: { flex: '1 1 0', margin: 0, fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() {
                        await api.v1.storyStorage.remove(STORAGE_WIZ_INTRO_DRAFT).catch(function() {});
                        await api.v1.tempStorage.remove(STORAGE_WIZ_INTRO_DRAFT).catch(function() {});
                        api.v1.ui.toast('Draft discarded.', { type: 'info', autoClose: 1800 });
                        await redraw();
                    } }
                ] });
            }
        } else if (activeTab === 'help') {
            // ── HELP & RULES [v0.9.8.3] [v1.24.0 CLEANUP] Four Fs / resolution bands / Test
            // Roller moved to Action Studio's Help popup (openActionStudioHelp) — that's
            // where the mechanic is actually being authored. Icon Library stays here as a
            // build-time reference. ─────────────────────────────────────────────────────
            parts.push({ type: 'text', text: 'Looking for the Four Fs, resolution bands, or a test roller? See Action Studio → Help.', style: { fontSize: '12px', opacity: '0.75', lineHeight: '1.5', marginBottom: '10px' } });

            // — Icon Library —
            let iconIds: string[] = ['play','pause','save','download','upload','edit','delete','trash','add','plus','settings','info','warning','error','alert','success','check','home','user','search','refresh','reload','copy','eye','eye-off','hide','show','lock','unlock','mail','email','file','folder','image','code','send','close','x','chevron-right','chevron-left','chevron-up','chevron-down','right','left','up','down','list','grid','star','heart','favorite','filter','calendar','clock','time','zap','lightning','square','hexagon','help','trending-up','trending-down','file-minus','file-plus','file-text','folder-plus','folder-minus','activity','alertOctagon','alertTriangle','align-center','align-justify','align-left','align-right','anchor','archive','arrow-down','arrow-down-circle','arrow-down-left','arrow-down-right','arrow-left','arrow-left-circle','arrow-right','arrow-right-circle','arrow-up','arrow-up-circle','arrow-up-left','arrow-up-right','at-sign','award','bar-chart','bar-chart-2','battery','batteryCharging','bell','bell-off','bold','book','bookOpen','bookmark','box','breifcase','camera','cameraOff','check-circle','check-square','chevrons-down','chevrons-left','chevrons-right','chevrons-up','circle','clipboard','cloud','cloud-drizzle','cloud-lightning','cloud-off','cloud-rain','cloud-snow','coffee','columns','command','compass','corner-down-left','corner-down-right','corner-left-down','corner-left-up','corner-right-down','corner-right-up','corner-up-left','corner-up-right','cpu','crop','crosshair','database','disc','divide','divide-circle','divide-square','dollar-sign','download-cloud','droplet','edit-2','edit-3','external-link','fast-forward','feather','film','flag','frown','gift','globe','hard-drive','hash','headphones','help-circle','inbox','italic','key','layers','layout','life-buoy','link','link-2','loader','login','logout','map','map-pin','maximize','maximize-2','meh','menu','message-circle','message-square','mic','mic-off','minimize','minimize-2','minus','minus-circle','minus-square','monitor','moon','more-horizontal','more-vertical','mouse-pointer','move','music','navigation-2','navigation','octagon','package','paperclip','pause-circle','pen-tool','percent','phone','pie-chart','play-circle','plus-circle','plus-square','pocket','power','printer','radio','refresh-cw','refresh-ccw','repeat','rewind','rotate-ccw','rotate-cw','rss','scissors','server','share','share-2','shield','shield-off','shopping-bag','shopping-cart','shuffle','sidebar','skip-back','skip-forward','slash','sliders','smartphone','smile','speaker','stop-circle','sun','sunrise','sunset','tablet','tag','target','terminal','thermometer','thumbs-down','thumbs-up','toggle-left','toggle-right','tool','trash-2','triangle','truck','tv','type','x-square','x-octagon','zap-off','zoom-in','zoom-out'];
            let iconBtns: UIPart[] = iconIds.map(function(ic) {
                return { type: 'button', iconId: ic as any, text: ic, style: { margin: '2px', fontSize: '10px', padding: '3px 7px', textAlign: 'left', backgroundColor: 'transparent', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '4px', opacity: '0.8' }, callback: async function() {} } as UIPart;
            });
            parts.push({ type: 'collapsibleSection', title: 'Icon Library (' + iconIds.length + ' icons)', iconId: 'grid', initialCollapsed: true, storageKey: 'temp:wiz_help_icons', content: [
                { type: 'text', text: 'All Feather icons available via the NAI iconId enum. Use these string values for iconId on tabs, buttons, and collapsible sections.', style: { fontSize: '10px', opacity: '0.6', marginBottom: '8px' } },
                { type: 'row', style: { flexWrap: 'wrap', gap: '2px' }, content: iconBtns }
            ] as any });
        }
        return parts;
    }

    let initialContent = await buildWizardContent();
    pm = await openEngineModal({ id: 'ae-wizard', title: 'World-Build Wizard', size: 'large', content: initialContent });
}

// [v1.13.0 FACRES-REORG, HISTORICAL] Factions Manager workspace. Was: faction list plus
// per-faction editable Faction Resource amounts plus a player-faction picker. [CE-STRIP
// v2.0.x] Both the Resources amounts and the picker are gone (data model removed for
// the former, Holding Document removed for the latter — see the removal notes inside
// the function). What's actually left, current: the faction list itself (name /
// description / relationship states / lorebook), full CRUD, nothing else.
async function buildFactionsWorkspace(): Promise<UIPart[]> {
    const cfg = await loadConfig();
    const parts: UIPart[] = [];

    // [REMOVED v2.30.0] Was an intro line describing the Holding Document and the
    // player-faction picker — both already CE-STRIPped (see the removal note right
    // below, which predates this cleanup and was never reflected up here). Nothing
    // below this point renders either of those things; the accurate description is
    // the "Define factions..." line a few lines down, which stays.

    // [CE-STRIP v2.0.x] Holding Document authoring + player-faction picker removed — Holding cut.

    // [CE-STRIP v2.0.x] Faction Resources schema/values removed — data model already gone.

    parts.push({ type: 'text', text: `⚔️ Factions (${(cfg.factions || []).length})`, style: { fontWeight: 'bold', fontSize: '13px', marginBottom: '6px', color: '#e8a87c' } } as UIPart);
    parts.push({ type: 'text', text: 'Define factions and their relationship tracks. Each character\'s standing with a faction is set from their own Edit Profile screen.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } } as UIPart);

    for (let fci = 0; fci < (cfg.factions || []).length; fci++) {
        const fac = cfg.factions[fci];
        const captFci = fci; const captFacId = fac.id;

        const tmpFacKey = `wb_tmp_fac_${captFacId}`;
        const facLbContent: UIPart[] = [];
        if (fac.lorebookEntryId) {
            facLbContent.push(
                { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [{ type: 'text', text: '✓ Lorebook entry linked', style: { fontSize: '12px', color: '#7ec8a0', flex: '1 1 0' } }] },
                { type: 'text', text: `Keys: ${getFactionLorebookKeys(fac).join(', ')}`, style: { fontSize: '11px', opacity: '0.55', marginBottom: '8px' } },
                { type: 'row', style: { gap: '6px' }, content: [
                    { type: 'button', text: 'Sync Static Core', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.1)', border: '1px solid rgba(126,200,160,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await syncFactionLorebookEntry(captFacId); } },
                    { type: 'button', text: 'Unlink', style: { margin: 0, fontSize: '11px' }, callback: async function() { await unlinkFactionLorebookEntry(captFacId); await refreshSidebar(); } }
                ] }
            );
        } else {
            facLbContent.push(
                { type: 'text', text: "No lorebook entry. Create one to inject this faction's profile.", style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },
                { type: 'button', text: '+ Create & Link Lorebook Entry', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.1)', border: '1px solid rgba(136,204,255,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await createLinkedFactionLorebookEntry(captFacId); await refreshSidebar(); } }
            );
        }
        facLbContent.push({ type: 'text', text: 'Trigger Keys:', style: { fontSize: '11px', opacity: '0.6', marginTop: '12px', marginBottom: '4px' } });
        (fac.lorebookTags || []).forEach(function(tg, ti) {
            facLbContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
                { type: 'text', text: '• ' + tg, style: { flex: '1 1 0', fontSize: '12px' } },
                { type: 'button', iconId: 'x', style: { margin: 0, fontSize: '10px' }, callback: async function() { await mutConfig(function(c) { c.factions[captFci].lorebookTags!.splice(ti, 1); }); await refreshSidebar(); } }
            ] } as UIPart);
        });
        facLbContent.push({ type: 'row', style: { gap: '4px' }, content: [
            { type: 'textInput', placeholder: 'Add key...', storageKey: `temp:${tmpFacKey}`, style: { flex: '1 1 0' } },
            { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(tmpFacKey) as string || ''; if (!v.trim()) return; await mutConfig(function(c) { if (!c.factions[captFci].lorebookTags) c.factions[captFci].lorebookTags = []; if (!c.factions[captFci].lorebookTags!.includes(v.trim())) c.factions[captFci].lorebookTags!.push(v.trim()); }); await api.v1.tempStorage.remove(tmpFacKey); await refreshSidebar(); } }
        ] });

        // [CE-STRIP v2.0.x] Faction Resources display removed — data model already gone.

        parts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: '3px solid #e8a87c' }, content: [
            { type: 'textInput', label: 'Name', initialValue: fac.name || '', onChange: async function(v: string) { await mutConfig(function(c) { c.factions[captFci].name = v; }); } },
            { type: 'multilineTextInput', label: 'Description', initialValue: fac.description || '', style: { minHeight: '40px', marginTop: '4px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.factions[captFci].description = v; }); } },
            { type: 'text', text: 'Relationship States (cold \u2192 warm):', style: { fontSize: '11px', opacity: '0.6', marginTop: '4px', marginBottom: '2px' } },
            aeRenderIndexedStatesEditor(fac.relationshipStates || [], async function(next) { await mutConfig(function(c) { c.factions[captFci].relationshipStates = next; }); }, refreshSidebar, 'Standing'),
            { type: 'box', style: { borderTop: '1px solid rgba(255,255,255,0.1)', marginTop: '12px', paddingTop: '12px' }, content: facLbContent },
            { type: 'button', text: 'Delete Faction', style: { marginTop: '8px', fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.3)' }, callback: async function() { await mutConfig(function(c) { const di = (c.factions || []).findIndex(function(x: any) { return x.id === captFacId; }); if (di >= 0) c.factions.splice(di, 1); }); await refreshSidebar(); } }
        ] } as UIPart);
    }
    if ((cfg.factions || []).length === 0) parts.push({ type: 'text', text: 'No factions defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } } as UIPart);
    parts.push({ type: 'button', text: '+ Add Faction', style: { marginTop: '4px', width: '100%', fontSize: '11px' }, callback: async function() { await mutConfig(function(c) { if (!c.factions) c.factions = []; c.factions.push({ id: 'fac_' + Date.now(), name: 'New Faction', description: '', relationshipStates: ['Hostile', 'Wary', 'Neutral', 'Friendly', 'Allied'], lorebookTags: [] }); }); await refreshSidebar(); } } as UIPart);

    return parts;
}

// [CE-STRIP v2.11.0] Merged workspace — World Settings, Factions, and System
// Settings used to be three separate destinations (two standalone modals plus
// its own shell workspace); all three are peer sections in one scrollable
// workspace now. Each sub-builder's own collapsibleSections are concatenated
// flat rather than nested inside another collapsible, since they're already
// self-contained (avoids double-nesting). Factions' own builder doesn't wrap
// itself in a collapsible (it was a whole standalone workspace page before),
// so it gets one wrapper section here to sit as a peer of World/System's
// sections instead of dumping its full contents inline uncollapsed.
async function buildSettingsWorkspace(): Promise<UIPart[]> {
    const parts: UIPart[] = [];
    parts.push.apply(parts, await buildWorldbuildingContent());
    const cfgForCount = await loadConfig();
    parts.push({ type: 'collapsibleSection', title: `⚔️ Factions (${(cfgForCount.factions || []).length})`, initialCollapsed: true, storageKey: 'temp:settings_factions', content: await buildFactionsWorkspace() } as UIPart);
    parts.push.apply(parts, await buildConfigContent());
    return parts.filter(Boolean) as UIPart[];
}

async function openWorldbuildingModal(): Promise<void> {
    if (worldbuildingModalHandle && !worldbuildingModalHandle.isClosed()) worldbuildingModalHandle.close();
    worldbuildingModalHandle = await openEngineModal({ id: 'ae-worldbuilding', size: 'full', fillWidth: true, title: '🌍 Adventure Engine: Worldbuilding', content: await buildWorldbuildingContent() });
}

async function buildWorldbuildingContent(): Promise<UIPart[]> {
    const cfg = await loadConfig(); const parts: UIPart[] = [];

    // 2. Species
    // [v1.24.0 CLEANUP] The old "Introduction & Setup" walkthrough (bridge-toast /
    // widget onboarding copy) was removed here — stale relative to the current
    // landing-page + workspace shell, and workspace Help buttons now cover onboarding.
    parts.push({ type: 'collapsibleSection', title: `🧬 Species (${(cfg.species || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_species', content: await (async function() {
        const spParts: UIPart[] = [];
        spParts.push({ type: 'text', text: 'Define species available as a selector on character cards. Create lorebook entries to give the AI detailed knowledge of each.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });
        for (let si = 0; si < (cfg.species || []).length; si++) {
            const sp = cfg.species[si];
            // [v1.10.2 FACFIX] per-iteration bindings — var here leaked one shared
            // capture to every row's callbacks (all edits/deletes hit the last row).
            const captSi = si; const captSpId = sp.id;
            
            const tmpSpKey = `wb_tmp_sp_${captSpId}`;
            const spLbContent: UIPart[] = [];
            if (sp.lorebookEntryId) {
                spLbContent.push(
                    { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [{ type: 'text', text: '✓ Lorebook entry linked', style: { fontSize: '12px', color: '#7ec8a0', flex: '1 1 0' } }] },
                    { type: 'text', text: `Keys: ${getSpeciesLorebookKeys(sp).join(', ')}`, style: { fontSize: '11px', opacity: '0.55', marginBottom: '8px' } },
                    { type: 'row', style: { gap: '6px' }, content: [
                        { type: 'button', text: 'Sync Static Core', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.1)', border: '1px solid rgba(126,200,160,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await syncSpeciesLorebookEntry(captSpId); } },
                        { type: 'button', text: 'Unlink', style: { margin: 0, fontSize: '11px' }, callback: async function() { await unlinkSpeciesLorebookEntry(captSpId); await refreshWorldbuildingModal(); } }
                    ] }
                );
            } else {
                spLbContent.push(
                    { type: 'text', text: "No lorebook entry. Create one to inject this species' profile.", style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },
                    { type: 'button', text: '+ Create & Link Lorebook Entry', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.1)', border: '1px solid rgba(136,204,255,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await createLinkedSpeciesLorebookEntry(captSpId); await refreshWorldbuildingModal(); } }
                );
            }
            spLbContent.push({ type: 'text', text: 'Trigger Keys:', style: { fontSize: '11px', opacity: '0.6', marginTop: '12px', marginBottom: '4px' } });
            (sp.lorebookTags || []).forEach(function(tg, ti) {
                spLbContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
                    { type: 'text', text: '• ' + tg, style: { flex: '1 1 0', fontSize: '12px' } },
                    { type: 'button', iconId: 'x', style: { margin: 0, fontSize: '10px' }, callback: async function() { await mutConfig(function(c) { c.species[captSi].lorebookTags!.splice(ti, 1); }); await refreshWorldbuildingModal(); } }
                ] } as UIPart);
            });
            spLbContent.push({ type: 'row', style: { gap: '4px' }, content: [
                { type: 'textInput', placeholder: 'Add key...', storageKey: `temp:${tmpSpKey}`, style: { flex: '1 1 0' } },
                { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(tmpSpKey) as string || ''; if (!v.trim()) return; await mutConfig(function(c) { if (!c.species[captSi].lorebookTags) c.species[captSi].lorebookTags = []; if (!c.species[captSi].lorebookTags!.includes(v.trim())) c.species[captSi].lorebookTags!.push(v.trim()); }); await api.v1.tempStorage.remove(tmpSpKey); await refreshWorldbuildingModal(); } }
            ] });

            spParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: '3px solid #88ccff' }, content: [
                { type: 'textInput', label: 'Name', initialValue: sp.name || '', onChange: async function(v: string) { await mutConfig(function(c) { c.species[captSi].name = v; }); } },
                { type: 'multilineTextInput', label: 'Description', initialValue: sp.description || '', style: { minHeight: '40px', marginTop: '4px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.species[captSi].description = v; }); } },
                { type: 'box', style: { borderTop: '1px solid rgba(255,255,255,0.1)', marginTop: '12px', paddingTop: '12px' }, content: spLbContent },
                { type: 'button', text: 'Delete Species', style: { marginTop: '8px', fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.3)' }, callback: async function() { await mutConfig(function(c) { const di = (c.species || []).findIndex(function(x: any) { return x.id === captSpId; }); if (di >= 0) c.species.splice(di, 1); }); await refreshWorldbuildingModal(); } }
            ] } as UIPart);
        }
        if ((cfg.species || []).length === 0) spParts.push({ type: 'text', text: 'No species defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });
        spParts.push({ type: 'button', text: '+ Add Species', style: { marginTop: '4px', width: '100%', fontSize: '11px' }, callback: async function() { await mutConfig(function(c) { if (!c.species) c.species = []; c.species.push({ id: 'sp_' + Date.now(), name: 'New Species', description: '', lorebookTags: [] }); }); await refreshWorldbuildingModal(); } });
        return spParts;
    })() });

    // 4. Relationship Archetypes
    function buildPresetSection(title: string, items: string[], skBase: string, addKey: string, onAdd: (v: string, c: GlobalConfig) => void, onRemove: (i: number, c: GlobalConfig) => void): UIPart {
        const rows: UIPart[] = items.filter(Boolean).map(function(item, i) {
            const pi = i;
            return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
                { type: 'text', text: item, style: { flex: '1 1 0', fontSize: '12px' } },
                { type: 'button', iconId: 'x', style: { margin: 0 }, callback: async function() { await mutConfig(function(c){ onRemove(pi, c); }); await refreshWorldbuildingModal(); } }
            ] } as UIPart;
        });
        rows.push({ type: 'row', style: { gap: '4px', marginTop: '4px' }, content: [
            { type: 'textInput', placeholder: `Add ${title}…`, storageKey: `temp:${addKey}`, style: { flex: '1 1 0' } },
            { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(addKey) as string || ''; if (!v.trim()) return; await mutConfig(function(c){ onAdd(v.trim(), c); }); await api.v1.tempStorage.remove(addKey); await refreshWorldbuildingModal(); } }
        ] } as UIPart);
        return { type: 'collapsibleSection', title, initialCollapsed: true, storageKey: `temp:${skBase}`, content: rows };
    }
    parts.push({ type: 'collapsibleSection', title: `💞 Relationship Archetypes (${(cfg.relationshipArchetypes || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_rels', content: (function() {
        const archParts: UIPart[] = [];
        archParts.push({ type: 'text', text: 'Each archetype has an ordered stage progression (cold → warm). Actions can set the archetype and advance/retreat the stage. Leave stages blank for a label-only archetype.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });
        (cfg.relationshipArchetypes || []).forEach(function(def, i) {
            const ai = i;
            archParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: '3px solid #d88fc0' }, content: [
                { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                    { type: 'textInput', initialValue: def.name, placeholder: 'Archetype name', style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { await mutConfig(function(c) { c.relationshipArchetypes[ai].name = v; }); } },
                    { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px', color: '#ff6b6b' }, callback: async function() { await mutConfig(function(c) { c.relationshipArchetypes.splice(ai, 1); }); await refreshWorldbuildingModal(); } }
                ] },
                { type: 'text', text: 'Stages (cold \u2192 warm):', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } },
                aeRenderIndexedStatesEditor(def.stages || [], async function(next) { await mutConfig(function(c) { c.relationshipArchetypes[ai].stages = next; }); }, refreshWorldbuildingModal, 'Stage')
            ] } as UIPart);
        });
        if (!(cfg.relationshipArchetypes || []).length) archParts.push({ type: 'text', text: 'No archetypes defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });
        archParts.push({ type: 'button', text: '+ Add Archetype', style: { width: '100%', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.relationshipArchetypes.push({ id: 'arch_' + Date.now(), name: 'New Archetype', stages: ['Stage 1', 'Stage 2', 'Stage 3'] }); }); await refreshWorldbuildingModal(); } });
        return archParts;
    })() });

    // [v2.7.0 CONDITIONS] Same shape/pattern as Relationship Archetypes above,
    // deliberately — but a character can have MULTIPLE active at once (checked, not
    // picked), and this feeds the per-character dynamic lorebook entry, not the AN.
    parts.push({ type: 'collapsibleSection', title: `🩺 Conditions (${(cfg.conditions || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_conditions', content: (function() {
        const condParts: UIPart[] = [];
        condParts.push({ type: 'text', text: 'Each condition has an optional ordered severity progression (mild → severe) — leave stages blank for a pure on/off condition. Multiple conditions can be active on a character at once. Injects into a temporary per-character lorebook entry while active, not the Author\u2019s Note.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });
        (cfg.conditions || []).forEach(function(def, i) {
            const ci = i;
            condParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: '3px solid #e8a87c' }, content: [
                { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                    { type: 'textInput', initialValue: def.name, placeholder: 'Condition name', style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { await mutConfig(function(c) { c.conditions[ci].name = v; }); } },
                    { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px', color: '#ff6b6b' }, callback: async function() { await mutConfig(function(c) { c.conditions.splice(ci, 1); }); await refreshWorldbuildingModal(); } }
                ] },
                { type: 'text', text: 'Stages (mild \u2192 severe, blank = on/off only):', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } },
                aeRenderIndexedStatesEditor(def.stages || [], async function(next) { await mutConfig(function(c) { c.conditions[ci].stages = next; }); }, refreshWorldbuildingModal, 'Stage')
            ] } as UIPart);
        });
        if (!(cfg.conditions || []).length) condParts.push({ type: 'text', text: 'No conditions defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });
        condParts.push({ type: 'button', text: '+ Add Condition', style: { width: '100%', fontSize: '11px', margin: 0, marginBottom: '10px' }, callback: async function() { await mutConfig(function(c) { c.conditions.push({ id: 'cond_' + Date.now(), name: 'New Condition', stages: [] }); }); await refreshWorldbuildingModal(); } });

        // ── Narrative template + live preview (sample data) ──────────────────
        condParts.push({ type: 'text', text: 'Lorebook line template — how each active condition renders.', style: { fontSize: '11px', color: '#88ccff', marginTop: '4px' } });
        condParts.push({ type: 'text', text: 'Macros: |name|  |conditionName|  |stageText|', style: { fontSize: '10px', opacity: '0.5', marginBottom: '4px', fontFamily: 'monospace' } });
        condParts.push({ type: 'multilineTextInput', initialValue: cfg.lorebookTemplates.condition, placeholder: 'Enter template...', style: { fontFamily: 'monospace', fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.lorebookTemplates.condition = v; }); } });
        const _condSample = (cfg.conditions || [])[0] || { name: 'Intoxicated', stages: ['Tipsy, giggly, and warm to the touch.'] };
        const _condPreview = parseMacroTemplate(cfg.lorebookTemplates.condition, { name: 'Aria', conditionName: _condSample.name, stageText: (_condSample.stages || [])[0] || '' });
        condParts.push({ type: 'text', text: `Preview: ${_condPreview || '(Blank)'}`, style: { fontSize: '11px', opacity: 0.7, fontStyle: 'italic' } });

        return condParts;
    })() });

    // [v2.9.0 LOREFOLD] Lorebook Additions — which dynamic character fields fold into
    // that character's own lorebook entry each generation, and how each renders.
    parts.push({ type: 'collapsibleSection', title: '📖 Lorebook Additions', initialCollapsed: true, storageKey: 'temp:wb_cfg_lorefold', content: (function() {
        const lfParts: UIPart[] = [];
        lfParts.push({ type: 'text', text: 'These fold into each scene-present character\u2019s lorebook entry (not the Author\u2019s Note \u2014 thoughts and the NPC web live there). Uncheck any that feel excessive; the underlying character data is kept, just not injected. Each enabled line renders as prose via its template.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });
        const lf: any = cfg.lorebookFields || {};
        const lt: any = cfg.lorebookTemplates || {};
        const LF_FIELDS = [
            { key: 'equipment',     label: 'Equipment',               macros: '|name|  |equipList|',                                              sample: { name: 'Aria', equipList: 'a worn leather coat, an iron dagger' } },
            { key: 'relationship',  label: 'Relationship',            macros: '|name|  |relArchetype|  |primaryRelationship.targetName|',           sample: { name: 'Aria', relArchetype: 'Estranged Sister', primaryRelationship: { targetName: 'the protagonist' } } },
            { key: 'relTrajectory', label: 'Relationship trajectory', macros: '|name|  |primaryRelationship.targetName|  |primaryRelationship.trajectory|', sample: { name: 'Aria', primaryRelationship: { targetName: 'the protagonist', trajectory: 'thawing under an apology neither has spoken aloud' } } },
            { key: 'relStatus',     label: 'Relationship status',     macros: '|primaryRelationship.currentStatus|',                                sample: { name: 'Aria', primaryRelationship: { targetName: 'the protagonist', currentStatus: 'Aria and the protagonist trade clipped, formal sentences and never sit at the same table.' } } },
            { key: 'goal',          label: 'Goal / desire',           macros: '|name|  |midRange.currentDesire|',                                   sample: { name: 'Aria', midRange: { currentDesire: 'to clear her name before the tribunal convenes' } } },
            { key: 'socialMask',    label: 'Social mask',             macros: '|name|  |midRange.socialMask|',                                      sample: { name: 'Aria', midRange: { socialMask: 'someone unbothered, while privately mapping every exit' } } },
            { key: 'shiftedView',   label: 'Shifted view',            macros: '|name|  |midRange.shiftedView|',                                     sample: { name: 'Aria', midRange: { shiftedView: 'the people who raised her have been lying to her since the start' } } },
            { key: 'journal',       label: 'Journal',                 macros: '|name|  |journalBody|',                                              sample: { name: 'Aria', journalBody: 'Found the letter behind the loose brick. Said nothing to the others yet.' } }
        ];
        LF_FIELDS.forEach(function(fd) {
            const fk = fd.key;
            lfParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: '3px solid #7ec8a0' }, content: [
                { type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '4px' }, content: [
                    { type: 'checkboxInput', initialValue: lf[fk] !== false, onChange: async function(v: boolean) { await mutConfig(function(c) { (c.lorebookFields as any)[fk] = !!v; }); } },
                    { type: 'text', text: fd.label, style: { fontSize: '12px', fontWeight: 'bold', flex: '1 1 0' } }
                ] },
                { type: 'text', text: 'Macros: ' + fd.macros, style: { fontSize: '10px', opacity: '0.5', marginBottom: '4px', fontFamily: 'monospace' } },
                { type: 'multilineTextInput', initialValue: (lt[fk] || ''), placeholder: 'Enter template...', style: { fontFamily: 'monospace', fontSize: '11px', minHeight: '36px' }, onChange: async function(v: string) { await mutConfig(function(c) { (c.lorebookTemplates as any)[fk] = v; }); } },
                { type: 'text', text: 'Preview: ' + (parseMacroTemplate(lt[fk] || '', fd.sample) || '(Blank)'), style: { fontSize: '11px', opacity: 0.7, fontStyle: 'italic', marginTop: '2px' } }
            ] } as UIPart);
        });
        // Conditions toggle (its template + defs live in the Conditions section above).
        lfParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: '3px solid #e8a87c' }, content: [
            { type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '2px' }, content: [
                { type: 'checkboxInput', initialValue: lf.conditions !== false, onChange: async function(v: boolean) { await mutConfig(function(c) { (c.lorebookFields as any).conditions = !!v; }); } },
                { type: 'text', text: 'Conditions', style: { fontSize: '12px', fontWeight: 'bold', flex: '1 1 0' } }
            ] },
            { type: 'text', text: 'Template + definitions live in the \ud83e\ude7a Conditions section above.', style: { fontSize: '10px', opacity: '0.5' } }
        ] } as UIPart);
        return lfParts;
    })() });
    
        return parts.filter(Boolean) as UIPart[];
}

// ============================================================================
// [v2.20.0 GENDIAG] GENERATION DIAGNOSTICS — shared UI builder
// ============================================================================
// Shared content builder for the Generation Diagnostics viewer, backed by the
// [DIAG GEN] ring buffer (_diagGenLog / diagGenRecord / aeDiagGenerate) near the
// top of the file. Two entry points render this SAME content so they never drift:
//   1. Config modal → "🩺 Generation Diagnostics" collapsible section (always available).
//   2. A quick-access button next to "Generate All From Concept Dump" in the character
//      editor's Static tab (openGenDiagModal), for review right where a failure was hit.
// refreshFn lets each host redraw itself (config modal body vs. this standalone modal)
// after Refresh/Copy/Clear/Probe without the two entry points needing to know about
// each other.
async function buildGenDiagContent(refreshFn: () => Promise<void>): Promise<UIPart[]> {
    const parts: UIPart[] = [];
    const errCount = _diagGenLog.filter(function(e) { return e.outcome === 'error'; }).length;
    parts.push({ type: 'text', text: 'Every engine generation call is logged here as it happens \u2014 both the budget-free path (World-Build Wizard, "Generate All From Concept Dump") and the budgeted per-field / dynamic-engine path (ephemeral, mid-range, relationship, hooks, image prompts). A thrown error (including a transient AbortError from NAI\u2019s own pipeline) now gets one automatic retry before the call is reported failed. Session-only \u2014 resets on script reload. Also mirrored to the console (visible in eruda) as it happens, and to /gendiag (or /gendiagclear) in any wizard chat.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px', lineHeight: '1.5' } });
    parts.push({ type: 'text', text: _diagGenLog.length + ' call' + (_diagGenLog.length === 1 ? '' : 's') + ' logged this session \u00b7 ' + errCount + ' error' + (errCount === 1 ? '' : 's'), style: { fontSize: '11px', fontWeight: 'bold', marginBottom: '6px', color: (errCount > 0 ? '#ff8080' : '#7fd88f') } } as UIPart);

    parts.push({ type: 'row', style: { gap: '6px', marginBottom: '6px' }, content: [
        { type: 'button', text: 'Refresh', iconId: 'refresh-cw', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { await refreshFn(); } },
        { type: 'button', text: 'Copy Log', iconId: 'copy', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() {
            try {
                const granted = await api.v1.permissions.request('clipboardWrite', 'Copy the generation diagnostics log to your clipboard.');
                if (!granted) { api.v1.ui.toast('Clipboard permission denied.', { type: 'warning' }); return; }
                await api.v1.clipboard.writeText(dumpGenDiagLog());
                api.v1.ui.toast('Copied to clipboard.', { type: 'success', autoClose: 2000 });
            } catch (eGdCopy) { api.v1.ui.toast('Copy failed: ' + String((eGdCopy && (eGdCopy as any).message) || eGdCopy), { type: 'error' }); }
        } },
        { type: 'button', text: 'Clear', iconId: 'trash-2', style: { flex: '1 1 0', margin: 0, fontSize: '11px', color: '#ff6b6b' }, callback: async function() { clearGenDiagLog(); await refreshFn(); } }
    ] } as UIPart);

    parts.push({ type: 'button', text: 'Run A/B Probe (yoink vs direct)', iconId: 'activity', style: { width: '100%', margin: '0 0 8px', fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() {
        api.v1.ui.toast('Running probe\u2026', { id: 'ce-genprobe', autoClose: false, type: 'info' });
        await runBudgetProbe();
        api.v1.ui.toast('Probe complete \u2014 see log below.', { id: 'ce-genprobe', type: 'success', autoClose: 2000 });
        await refreshFn();
    } } as UIPart);

    parts.push({ type: 'box', style: { backgroundColor: 'rgba(255,255,255,0.03)', border: '1px dashed rgba(255,255,255,0.1)', padding: '8px', borderRadius: '6px', maxHeight: '320px', overflowY: 'auto' }, content: [
        { type: 'text', text: dumpGenDiagLog(), style: { fontSize: '10px', fontFamily: 'monospace', whiteSpace: 'pre-wrap', opacity: '0.85' } }
    ] } as UIPart);

    return parts;
}

// Quick-access standalone modal — same content as the Config modal section, opened
// from a button next to "Generate All From Concept Dump" (buildCharStaticTab) so a
// failure can be reviewed without leaving the character editor.
var genDiagModalHandle: any = null;
async function openGenDiagModal(): Promise<void> {
    if (genDiagModalHandle && !genDiagModalHandle.isClosed()) { genDiagModalHandle.close(); }
    async function refreshGenDiagModal(): Promise<void> {
        if (genDiagModalHandle && !genDiagModalHandle.isClosed()) {
            await genDiagModalHandle.update({ content: await buildGenDiagContent(refreshGenDiagModal) });
        }
    }
    genDiagModalHandle = await openEngineModal({ id: 'ce-gendiag', title: '\ud83e\ude7a Generation Diagnostics', size: 'large', content: await buildGenDiagContent(refreshGenDiagModal) });
}

// ============================================================================
// SECTION 24 — CONFIG MODAL (Engine Tweaks Only)
// ============================================================================

async function mutConfig(fn: (c: GlobalConfig) => void): Promise<void> {
    const c = await loadConfig(); fn(c); await saveConfig(c);
}
async function refreshConfigModal(): Promise<void> {
    if (configModalHandle && !configModalHandle.isClosed()) {
        await configModalHandle.update({ content: await buildConfigContent() });
        return;
    }
    // [CE-STRIP v2.11.0] System Settings now renders inside the merged Settings
    // workspace (buildSettingsWorkspace) instead of its own standalone modal —
    // refresh whichever workspace is currently open instead.
    await refreshWorkspace();
}
async function openConfigModal(): Promise<void> {
    if (configModalHandle && !configModalHandle.isClosed()) configModalHandle.close();
    configModalHandle = await openEngineModal({ id: 'ae-config', size: 'full', fillWidth: true, title: '⚙ Adventure Engine Settings', content: await buildConfigContent() });
}

async function buildConfigContent(): Promise<UIPart[]> {
    const cfg = await loadConfig(); const parts: UIPart[] = [];

    // 1. Engine Timing
    parts.push({ type: 'collapsibleSection', title: '⚡️Dynamic Updates Timing', initialCollapsed: true, storageKey: 'temp:ce_cfg_timing', content: [
        { type: 'text', text: 'How many context tokens must pass before each update type fires.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '10px' } },
        { type: 'sliderInput', label: 'Ephemeral (Thoughts) Interval', min: 1, max: 20, step: 1, initialValue: cfg.thoughtIntervalGens, suffix: ' gens', defaultValue: 2, onChange: async function(v: number) { await mutConfig(function(c){ c.thoughtIntervalGens = v; }); } },
        { type: 'sliderInput', label: 'Mid-Range State Interval', min: 1, max: 40, step: 1, initialValue: cfg.dynamicIntervalGens, suffix: ' gens', defaultValue: 4, onChange: async function(v: number) { await mutConfig(function(c){ c.dynamicIntervalGens = v; }); } },
        { type: 'sliderInput', label: 'Primary Relationship Interval', min: 2, max: 50, step: 1, initialValue: cfg.arcIntervalGens, suffix: ' gens', defaultValue: 10, onChange: async function(v: number) { await mutConfig(function(c){ c.arcIntervalGens = v; }); } },
        { type: 'sliderInput', label: 'Hook Scan Interval', min: 1, max: 30, step: 1, initialValue: cfg.hookIntervalGens, suffix: ' gens', defaultValue: 6, onChange: async function(v: number) { await mutConfig(function(c){ c.hookIntervalGens = v; }); } },
        { type: 'sliderInput', label: 'Max Ephemeral Injections per Generation', min: 1, max: 6, step: 1, initialValue: cfg.ephemeralCap, defaultValue: 3, onChange: async function(v: number) { await mutConfig(function(c){ c.ephemeralCap = v; }); } },
        { type: 'text', text: 'Dynamic character cap: how many present characters stay dynamic at once (0 = no cap). Ranked characters fill slots first by rank, then unranked present characters. Set each character\u2019s rank from their card or edit panel.', style: { fontSize: '11px', opacity: '0.6', marginTop: '10px', marginBottom: '4px' } },
        { type: 'sliderInput', label: 'Max Dynamic Characters', min: 0, max: 20, step: 1, initialValue: Number(cfg.maxDynamicCharacters) || 0, suffix: ' (0 = off)', defaultValue: 0, onChange: async function(v: number) { await mutConfig(function(c){ (c as any).maxDynamicCharacters = Math.max(0, Math.floor(v || 0)); }); } },
    ] });

    // 2. Generation Style
    parts.push({ type: 'collapsibleSection', title: '✍ Generation Style', initialCollapsed: true, storageKey: 'temp:ce_cfg_style', content: [
        { type: 'text', text: 'Injected at the top of every generation prompt. Controls overall tone and register. Tip: add "Ignore any game mechanic formatting in the story text — numbered choice lists, > action markers, ## headers, {} or () notes, LOREBOOK: references. Treat only prose narrative as story content."', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },
        { type: 'multilineTextInput', initialValue: cfg.generalStyle, style: { minHeight: '100px' }, onChange: async function(v: string) { await mutConfig(function(c){ c.generalStyle = v; }); } },
        { type: 'button', text: 'Reset to Default', style: { fontSize: '11px', marginTop: '6px' }, callback: async function() { await mutConfig(function(c){ c.generalStyle = DEFAULT_GENERAL_STYLE; }); await refreshConfigModal(); } }
    ] });

    // 3. Static Field Settings
    const fieldSections: UIPart[] = [
        { type: 'checkboxInput', label: 'Show field headers in context injection', initialValue: cfg.showFieldHeaders, onChange: async function(v: boolean) { await mutConfig(function(c){ c.showFieldHeaders = v; }); } } as UIPart
    ];
    STATIC_FIELD_DEFS.forEach(function(def) {
        fieldSections.push({ type: 'collapsibleSection', title: cfg.fieldLabels[def.key] || def.label, initialCollapsed: true, storageKey: `temp:ce_cfg_f_${def.key}`, content: [
            { type: 'textInput', label: 'Display Label', initialValue: cfg.fieldLabels[def.key] || def.label, onChange: async function(v: string) { await mutConfig(function(c){ c.fieldLabels[def.key] = v; }); } },
            { type: 'multilineTextInput', label: 'Generation Instructions', initialValue: cfg.fieldInstructions[def.key] || def.defaultInstructions, style: { minHeight: '80px' }, onChange: async function(v: string) { await mutConfig(function(c){ c.fieldInstructions[def.key] = v; }); } },
            { type: 'sliderInput', label: 'Generation Token Budget', min: 50, max: 500, step: 25, initialValue: cfg.fieldBudgets[def.key] || def.defaultBudget, suffix: ' tokens', defaultValue: def.defaultBudget, onChange: async function(v: number) { await mutConfig(function(c){ c.fieldBudgets[def.key] = v; }); } },
            { type: 'button', text: 'Reset Instructions', style: { fontSize: '11px', marginTop: '4px' }, callback: async function() { await mutConfig(function(c){ c.fieldInstructions[def.key] = def.defaultInstructions; c.fieldBudgets[def.key] = def.defaultBudget; }); await refreshConfigModal(); } }
        ] } as UIPart);
    });
    parts.push({ type: 'collapsibleSection', title: '📝 Static Field Settings', initialCollapsed: true, storageKey: 'temp:ce_cfg_fields', content: fieldSections });

    // 4. Scene Default Background
    parts.push({ type: 'collapsibleSection', title: '🖼 Scene Default Background', initialCollapsed: true, storageKey: 'temp:ce_cfg_bg', content: [
        { type: 'text', text: 'URL of the fallback image shown in the scene banner when a location has no portrait. Stored in the module config — anyone who loads this story sees the same background. Leave blank for the CSS gradient fallback.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px', lineHeight: '1.5' } },
        { type: 'textInput', label: 'Image URL', initialValue: (cfg as any).defaultBackgroundUrl || '', onChange: async function(v: string) { await mutConfig(function(c) { (c as any).defaultBackgroundUrl = v.trim(); }); } },
        { type: 'button', text: '✕ Clear', style: { fontSize: '11px', marginTop: '4px', color: 'var(--ae-color-danger)' }, callback: async function() { await mutConfig(function(c) { (c as any).defaultBackgroundUrl = ''; }); await refreshConfigModal(); api.v1.ui.toast('Scene background cleared.', { type: 'success', autoClose: 2000 }); } }
    ] } as any);

    // 5. Generation Diagnostics [v2.20.0 GENDIAG]
    parts.push({ type: 'collapsibleSection', title: '\ud83e\ude7a Generation Diagnostics', initialCollapsed: true, storageKey: 'temp:ce_cfg_gendiag', iconId: 'activity', content: await buildGenDiagContent(refreshConfigModal) });

    parts.push({ type: 'text', text: ' ', style: { marginBottom: '48px' } });
    return parts.filter(Boolean) as UIPart[];
}

async function confirmDeleteChar(id: string, name: string): Promise<void> {
    const m = await openEngineModal({ title: 'Confirm Delete', size: 'small', content: [
        { type: 'text', text: `Delete "${name}"? This cannot be undone.`, style: { marginBottom: '16px' } },
        { type: 'row', style: { gap: '8px' }, content: [
            { type: 'button', text: 'Delete', style: { flex: '1 1 0', margin: 0, color: '#ff6b6b' }, callback: async function() { await deleteCharacter(id); m.close(); await refreshSidebar(); try { await broadcastCharacterData(); await broadcastSceneState(); } catch (_) {} } },
            { type: 'button', text: 'Cancel', style: { flex: '1 1 0', margin: 0 }, callback: function() { m.close(); } }
        ] }
    ] });
}



// ============================================================================
// SMART IMPORTER
// ============================================================================
// importPayload(data) — accepts a parsed JSON object and imports whatever
// recognizable blocks it finds. Returns a summary of what was imported.
// All import entry-points (module button, config modal, new-story prompt)
// funnel through this single function so behaviour is always identical.
//
// Recognised top-level blocks (any combination, all optional):
//   config          — GlobalConfig object  → [v1.20.0 IMPORT-MERGE] merged field-by-
//                                            field over the CURRENT config, not the
//                                            engine defaults. Every id-keyed array
//                                            (actionTemplates, factions, species,
//                                            resources, characterResourceDefs,
//                                            relationshipArchetypes, factionResourceDefs,
//                                            stakeDefs, npcArchetypes, itemArchetypes,
//                                            customStaticFields, sheetCategories,
//                                            wizardSections) is upserted by `id` —
//                                            matched items are updated in place, new
//                                            ones appended, anything not mentioned in
//                                            the import is left alone. tierTravelDefaults
//                                            upserts by `templateId`. fieldLabels /
//                                            fieldInstructions / fieldBudgets do a
//                                            shallow key merge. Everything else
//                                            (scalars, contextTemplates, holdingDef,
//                                            time settings) only overwrites when the
//                                            key is actually present in the import, so
//                                            a hand-trimmed partial config (e.g. just
//                                            2 new action templates) merges safely
//                                            instead of resetting the rest to defaults.
//                                            totalGenerations is never imported — it's
//                                            live per-story runtime state.
//   characters      — CharacterRecord[]    → merged into character index
//   character       — CharacterRecord      → single character (not bundle)
//   entities        — EntityRecord[]       → merged into entity index
//   locations       — EntityRecord[]       → backwards-compat alias for entities
//   entity          — EntityRecord         → single entity node
//   npcWeb          — NpcWebEntry[]        → [v1.20.0 IMPORT-MERGE] upserted by `id`,
//                                            same as config arrays (was: full replace)
//   partyState      — PartyState           → [v1.20.0 IMPORT-MERGE] resourceValues is
//                                            a shallow key merge (was: full replace)
//
// Special typed wrappers (detected first, return early):
//   { type: 'character_bundle', character, entity? }
//
// Bare root-level records (no top-level array key):
//   { id, name, ...CharacterRecord }  — no `type` field  → single character
//   { id, name, type, ... }           — has `type` field → single entity
// ============================================================================

// ImportResult interface defined in Section 1 (types block).

// [v1.20.0 IMPORT-MERGE] Generic upsert-by-key merge for GlobalConfig's id-keyed
// arrays — the config-level analogue of what saveCharacter/saveEntity already do
// per-record. Matched items (by keyFn) are replaced in place with the incoming
// version; unmatched incoming items are appended; existing items absent from the
// incoming array are left untouched. Returns the merged array plus tallies so
// callers can report what actually changed.
function mergeArrayById(existing: any[] | undefined, incoming: any, keyFn: (item: any) => string | undefined): { merged: any[]; counts: ImportMergeCounts } {
    const base: any[] = Array.isArray(existing) ? existing.slice() : [];
    const counts: ImportMergeCounts = { added: 0, updated: 0 };
    if (!Array.isArray(incoming)) return { merged: base, counts: counts };
    for (const item of incoming.filter(Boolean)) {
        const key = keyFn(item);
        if (key === undefined || key === null || key === '') continue;
        const idx = base.findIndex(function(x) { return keyFn(x) === key; });
        if (idx >= 0) { base[idx] = item; counts.updated++; }
        else { base.push(item); counts.added++; }
    }
    return { merged: base, counts: counts };
}

// [v1.20.0 IMPORT-MERGE] Shallow key-merge for Record<string, any> config fields
// (fieldLabels, fieldInstructions, fieldBudgets, partyState.resourceValues) —
// incoming keys overwrite matching existing keys; every other key is preserved.
function mergeRecordShallow(existing: any, incoming: any): any {
    const base: any = (existing && typeof existing === 'object') ? { ...existing } : {};
    if (incoming && typeof incoming === 'object' && !Array.isArray(incoming)) {
        for (const k of Object.keys(incoming)) base[k] = incoming[k];
    }
    return base;
}

// [v1.20.0 IMPORT-MERGE] Builds the merged config that replaces `existing`, plus a
// per-category count summary. Deliberately starts from `existing` (the CURRENT
// story's config, already migrated) rather than a fresh default config — a partial
// import that only sets a few fields must never reset the rest to engine defaults.
function mergeConfigForImport(existing: GlobalConfig, incoming: any): { cfg: GlobalConfig; counts: { [category: string]: ImportMergeCounts } } {
    const merged: any = { ...existing };
    const counts: { [category: string]: ImportMergeCounts } = {};
    const byId = function(x: any) { return x && x.id; };

    const idArrayFields: string[] = [
        'sheetCategories', 'customStaticFields', 'relationshipArchetypes', 'resources',
        'characterResourceDefs', 'species', 'factions', 'factionResourceDefs',
        'stakeDefs', 'actionTemplates', 'wizardSections', 'conditions'
        // [v2.7.0 CONDITIONS] 'conditions' added — same id-keyed upsert as relationshipArchetypes.
        // NOTE: resources/characterResourceDefs/factionResourceDefs/stakeDefs/actionTemplates
        // are all confirmed-dead fields from earlier CE-STRIP passes, still listed here —
        // that's user's own flagged separate to-do ("make sure import/export reflect current
        // state"), deliberately not touched in this pass.
    ];
    for (const field of idArrayFields) {
        if (incoming[field] === undefined) continue;
        const r = mergeArrayById((existing as any)[field], incoming[field], byId);
        merged[field] = r.merged;
        counts[field] = r.counts;
    }

    // tierTravelDefaults has no `id` — keyed by templateId (a small fixed set of
    // system travel templates: sys_default_travel, sys_travel_tier1, sys_travel_tier2).
    if (incoming.tierTravelDefaults !== undefined) {
        const r = mergeArrayById((existing as any).tierTravelDefaults, incoming.tierTravelDefaults, function(x: any) { return x && x.templateId; });
        merged.tierTravelDefaults = r.merged;
        counts['tierTravelDefaults'] = r.counts;
    }

    // Record<string,*> fields — shallow key merge rather than whole-object replace.
    if (incoming.fieldLabels !== undefined)       merged.fieldLabels       = mergeRecordShallow(existing.fieldLabels, incoming.fieldLabels);
    if (incoming.fieldInstructions !== undefined) merged.fieldInstructions = mergeRecordShallow(existing.fieldInstructions, incoming.fieldInstructions);
    if (incoming.fieldBudgets !== undefined)      merged.fieldBudgets      = mergeRecordShallow(existing.fieldBudgets, incoming.fieldBudgets);

    // factionResourceSections is an ordered string[], not id-keyed — union, existing
    // order first, then append any section names the import introduces.
    if (Array.isArray(incoming.factionResourceSections)) {
        const cur: string[] = Array.isArray(existing.factionResourceSections) ? existing.factionResourceSections.slice() : [];
        for (const sec of incoming.factionResourceSections) { if (cur.indexOf(sec) < 0) cur.push(sec); }
        merged.factionResourceSections = cur;
    }

    // Everything else: scalar/object fields only overwrite when the import actually
    // sets them, so an import that never mentions (say) projectGenre can't blank it.
    const passthroughFields: string[] = [
        'contextTemplates', 'lorebookTemplates', 'lorebookFields', 'interfaceMode', 'thoughtIntervalGens', 'dynamicIntervalGens',
        'arcIntervalGens', 'hookIntervalGens', 'ephemeralCap', 'maxDynamicCharacters',
        'autoUpdateDefault', 'autoThoughtsDefault', 'showFieldHeaders', 'generalStyle',
        'defaultBackgroundUrl',
        'projectName', 'projectGenre', 'projectConcept'
    ];
    for (const field of passthroughFields) {
        if (incoming[field] !== undefined) merged[field] = incoming[field];
    }

    // totalGenerations is live per-story runtime state, never imported — always keep
    // whatever the destination story already has, regardless of what the import carries.
    merged.totalGenerations = existing.totalGenerations;

    return { cfg: merged as GlobalConfig, counts: counts };
}

// [v1.20.0 IMPORT-MERGE] Totals added/updated across every category in a
// configCategoryCounts map — used for the compact one-line import summary toast.
function sumMergeCounts(map: { [k: string]: ImportMergeCounts } | undefined): ImportMergeCounts {
    const out: ImportMergeCounts = { added: 0, updated: 0 };
    if (!map) return out;
    for (const k of Object.keys(map)) { out.added += map[k].added; out.updated += map[k].updated; }
    return out;
}

// ── Import Payload (full module importer) ────────────────────────────────────
async function importPayload(data: any): Promise<ImportResult> {
    const result: ImportResult = {
        charCount: 0, entityCount: 0,
        configImported: false, npcWebImported: false, partyStateImported: false
    };

    // 1. Config block — [v1.20.0 IMPORT-MERGE] merged field-by-field over the
    //    CURRENT config (id-keyed arrays upserted, everything else only touched
    //    when the import actually sets it) rather than replaced wholesale — see
    //    the Smart Importer comment block above for the full field-by-field rules.
    if (data.config && typeof data.config === 'object' && !Array.isArray(data.config)) {
        const priorCfg = await loadConfig();
        const mergeRes = mergeConfigForImport(priorCfg, data.config);
        const newCfg = migrateConfig(mergeRes.cfg);
        await saveConfig(newCfg);
        result.configImported = true;
        result.configCategoryCounts = mergeRes.counts;
    }

    const activeCfg = await loadConfig();

    // 2. Character bundle — typed single-export format (char + optional entity)
    //    Detected first and returns early so its keys don't fall through to the
    //    generic `character` / `entity` checks below.
    if (data.type === 'character_bundle' && data.character) {
        await saveCharacter(migrateCharacter(data.character, activeCfg));
        result.charCount = 1;
        if (data.entity && typeof data.entity === 'object') {
            await saveEntity(migrateEntity(data.entity));
            result.entityCount = 1;
        }
        return result;
    }

    // 3. Characters — array, singular block, or bare root record
    if (data.characters && Array.isArray(data.characters)) {
        for (const c of data.characters.filter(Boolean)) {
            await saveCharacter(migrateCharacter(c, activeCfg));
            result.charCount++;
        }
    } else if (data.character && typeof data.character === 'object' && !Array.isArray(data.character)) {
        await saveCharacter(migrateCharacter(data.character, activeCfg));
        result.charCount = 1;
    } else if (data.id && data.name && !data.type && !data.entities && !data.locations && !data.characters) {
        // Bare root-level CharacterRecord — no `type` field distinguishes it from entity
        await saveCharacter(migrateCharacter(data, activeCfg));
        result.charCount = 1;
    }

    // 4. Entities — array (with backwards-compat alias), singular block, or bare root record
    const rawNodes: any[] = Array.isArray(data.entities) ? data.entities
                          : Array.isArray(data.locations) ? data.locations   // pre-v0.9 exports
                          : [];
    if (rawNodes.length > 0) {
        for (const n of rawNodes.filter(Boolean)) {
            await saveEntity(migrateEntity(n));
            result.entityCount++;
        }
    } else if (data.entity && typeof data.entity === 'object' && !Array.isArray(data.entity)) {
        await saveEntity(migrateEntity(data.entity));
        result.entityCount = 1;
    } else if (data.id && data.name && data.type && !data.characters && !data.entities && !data.locations) {
        // Bare root-level EntityRecord — presence of `type` (entity kind) is the signal
        await saveEntity(migrateEntity(data));
        result.entityCount = 1;
    }

    // 5. NPC Web — [v1.20.0 IMPORT-MERGE] upserted by `id`, same as the config
    //    arrays (was: full replace, which silently dropped any web link the
    //    import didn't happen to include).
    if (data.npcWeb && Array.isArray(data.npcWeb)) {
        if (typeof loadNpcWeb === 'function' && typeof saveNpcWeb === 'function') {
            const priorWeb = await loadNpcWeb();
            const webRes = mergeArrayById(priorWeb, data.npcWeb, function(x: any) { return x && x.id; });
            await saveNpcWeb(webRes.merged);
            result.npcWebCounts = webRes.counts;
        }
        result.npcWebImported = true;
    }

    return result;
}

// ── Image / Architect Settings helpers ───────────────────────────────────────
// [NEW] Merged from auto-illustrator-sb engine. These functions were previously
//       in the AI engine's standalone modal. Now part of the AE config modal.

async function injectNote(type: string, isAdding: boolean): Promise<void> {
    // Inserts or removes the image System Note from Memory or Author's Note.
    try {
        const note = (globalSettings.systemNote || DEFAULT_NOTE).trim();
        if (!note) { api.v1.ui.toast('No System Note defined in Image Settings.'); return; }
        if (type === 'memory') {
            const text = (await api.v1.memory.get()) || '';
            if (isAdding && !text.includes(note)) {
                await api.v1.memory.set(text ? text + '\n\n' + note : note);
                api.v1.ui.toast('✅ Image note inserted into Memory.');
            } else if (!isAdding && text.includes(note)) {
                await api.v1.memory.set(text.replace('\n\n' + note, '').replace('\n' + note, '').replace(note, '').trim());
                api.v1.ui.toast('🗑 Image note removed from Memory.');
            } else {
                api.v1.ui.toast(isAdding ? 'Note already in Memory.' : 'Note not found in Memory.');
            }
        } else if (type === 'an') {
            const text = (await api.v1.an.get()) || '';
            if (isAdding && !text.includes(note)) {
                await api.v1.an.set(text ? text + '\n\n' + note : note);
                api.v1.ui.toast('✅ Image note inserted into Author\'s Note.');
            } else if (!isAdding && text.includes(note)) {
                await api.v1.an.set(text.replace('\n\n' + note, '').replace('\n' + note, '').replace(note, '').trim());
                api.v1.ui.toast('🗑 Image note removed from Author\'s Note.');
            } else {
                api.v1.ui.toast(isAdding ? 'Note already in Author\'s Note.' : 'Note not found.');
            }
        }
    } catch (e) {
        api.v1.ui.toast('Injection failed — ensure storyEdit permission is granted.');
    }
}

// ============================================================================
// SECTION 26 — HOOK REGISTRATIONS
// All api.v1.hooks.register() calls.
//
//    ADVENTURE ENGINE PIPELINE:
//    onBeforeContextBuild  → world-state AN injection (AE context builder S13)
//    onLorebookEntrySelected → lore ID tracking
//    onContextBuilt        → imperative block + background drama + probability
//    onGenerationEnd       → token count + runDynamicEngine (S15)
//    onHistoryNavigated    → retry/undo skip flag
//
// ============================================================================

const AE_AN_SENTINEL = '[ Scene State ]';
// [v0.9.7.3 AN-FIX] Sentinel bracketing the wizard-owned region of the persisted AN.
// Final layout of the AN slot at generation time:
//   [user manual content, if any]
//   \n\n[ World Style ]          <- AE_WIZ_AN_SENTINEL (persisted by commitWizardMemory)
//   [wizard style/tone AN sections]
//   \n\n[ Scene State ]          <- AE_AN_SENTINEL (ephemeral, appended per-generation)
//   [quest line + world state + drama]
// Style first so the model frames itself before reading the immediate scene.
// Scene last so it carries the highest recency weight inside the AN slot.
const AE_WIZ_AN_SENTINEL = '[ World Style ]';

// [v1.2.0 WIZMODE] Hard switch: block any user/story-initiated generation while the
// wizard mode is on. Our own yoink call sets _aeYoink.active BEFORE it calls
// api.v1.editor.generate() (see executeYoinkGenerationAttempt), so by the time this
// hook fires for that call, _aeYoink.active is already true and it passes through.
api.v1.hooks.register('onGenerationRequested', async function(params: any) {
    if (_diagProbeActive) return; // [DIAG] api.v1.generate() probe call — not a story generation
    if (_aeWizardMode && !_aeYoink.active) {
        api.v1.ui.toast('Wizard mode is on \u2014 close it to generate story text.', { type: 'warning', autoClose: 4000 });
        return { stopGeneration: true };
    }
});

api.v1.hooks.register('onBeforeContextBuild', async function(params: any) {

    // [DIAG] Probe guard — a runBudgetProbe() api.v1.generate() call is in flight.
    if (_diagProbeActive) { api.v1.log('[AE:budget] probe: onBeforeContextBuild fired (api.v1.generate DOES build story context)'); return; }

    // [vNEXT] Yoink hijack active — leave the context alone; our prompt is swapped
    // in at onContextBuilt. Returning nothing means no world-state AN injection.
    if (_aeYoink.active) return;

    // [v2.4.0 WIZLIVE] In-document wizard chat turn. The story prefix (system prompt,
    // memory, lorebook) is left completely untouched — prefix caching must survive the
    // chat — and the Author's Note is deactivated (a tail-of-context change only), per
    // the design: story style directives must not steer chat replies. No world-state
    // injection, no scene lorebook activation. Applied on the dryRun pass too so the
    // cost estimate matches the real turn.
    if (_aeLiveWiz.active) return { authorsNote: { active: false, content: '' } };

    // [v2.21.0 CHARCHAT] In-story character chat turn. The OPPOSITE trade to WIZLIVE
    // above: we take the whole prompt (system prompt, lorebook activation, Author's
    // Note, story text) rather than protecting the prefix cache. Story generation
    // cannot run while a chat is open, so every generation reaching this line IS a
    // chat turn — which is what makes applying the override unconditionally safe.
    // Applied on the dryRun pass too, deliberately: that makes NAI's own context
    // viewer the debugging window for the whole subsystem. See the CHARCHAT section.
    if (_aeCharChat.active) return await runCharChatContextOverride(params);

    // ── AE path: Authors Note world-state injection ──────────────────────────
    if (params.dryRun) return;
    diagBudgetSnapshot('STORY', (params && params.continuityId) || null);   // [DIAG] pre-read for a real story turn
    await api.v1.tempStorage.set(STORAGE_LORE_IDS, '[]').catch(function() {});

    // [v0.9.8.5] Scene lorebook activation (static identity + ephemeral equipment).
    // Returned regardless of whether an AN block is produced below.
    let aeResult: any = {};
    try {
        const sceneAct = await buildSceneLorebookActivation(params.lorebookEntries);
        if (sceneAct.lorebookEntries.length > 0) aeResult.lorebookEntries = sceneAct.lorebookEntries;
        if (sceneAct.temporaryLorebookEntries.length > 0) aeResult.temporaryLorebookEntries = sceneAct.temporaryLorebookEntries;
    } catch (eAct) { api.v1.error('[AE] scene activation:', eAct); }

    try {
        // [CE-STRIP v2.6.0 CTX-CUT] Quest line (buildTrackedNarrativeBlock) and Drama
        // block (buildDramaContextBlock) are gone — both functions deleted, both had
        // exactly one caller (here). buildWorldStateBlock alone is now the whole AN
        // body: per-character thoughts + critical hooks. anProtag is still resolved
        // and passed for signature back-compat only — see buildWorldStateBlock's own
        // header comment (pending protagonist pass).
        const anIdx = await loadIndex();
        const anProtagMeta = anIdx.find(function(m: any) { return m.isProtagonist; });
        const anProtag = anProtagMeta ? await loadCharacter(anProtagMeta.id) : null;
        const worldStateBlock = await buildWorldStateBlock(anProtag);

        const fullBlock = worldStateBlock.trim();
        if (fullBlock) {
            // [v0.9.38 AN-IDEMPOTENT] Strip any prior AE region before re-appending.
            // We always append our block LAST, sentinel-prefixed, so the sentinel (or
            // the '\n\n'+sentinel join that precedes it) marks the trailing AE region.
            // Removing it first means N hook passes / N engine copies converge on one copy.
            let existingANraw = (params.authorsNote && params.authorsNote.content) ? params.authorsNote.content : '';
            let anMarker = '\n\n' + AE_AN_SENTINEL;
            let anMarkerIdx = existingANraw.lastIndexOf(anMarker);
            let baseAN = (anMarkerIdx >= 0)
                ? existingANraw.substring(0, anMarkerIdx)
                : ((existingANraw.indexOf(AE_AN_SENTINEL) === 0) ? '' : existingANraw);
            baseAN = baseAN.replace(/\s+$/, '');
            let wrappedBlock = AE_AN_SENTINEL + '\n' + fullBlock;
            aeResult.authorsNote = {
                active: true,
                content: baseAN ? (baseAN + '\n\n' + wrappedBlock) : wrappedBlock
            };
        }
    } catch (e) { api.v1.error('[AE] Author\'s Note injection error:', e); }

    return Object.keys(aeResult).length > 0 ? aeResult : undefined;
});

api.v1.hooks.register('onLorebookEntrySelected', async function(params: any) {
    try {
        if (!params.entryId) return;
        const raw = await api.v1.tempStorage.getOrDefault(STORAGE_LORE_IDS, '[]') as string;
        const ids: string[] = JSON.parse(raw);
        if (!ids.includes(params.entryId)) {
            ids.push(params.entryId);
            await api.v1.tempStorage.set(STORAGE_LORE_IDS, JSON.stringify(ids));
        }
    } catch (e) { api.v1.error('[AE] LoreTracking error:', e); }
});


api.v1.hooks.register('onResponse', async function(params: any) {
    // [DIAG] Probe guard — do not swallow; api.v1.generate returns text via its own value.
    if (_diagProbeActive) { api.v1.log('[AE:budget] probe: onResponse fired'); return; }
    // [vNEXT] While a yoink generation is active, buffer the streamed chunks and
    // swallow them so nothing reaches the user's document. Inert otherwise.
    // [v1.22.1] Discriminate by continuityId when we have one: a response belonging to a
    // DIFFERENT generation is either a story turn or a late chunk from a generation the
    // watchdog abandoned, and must not be swallowed into the wizard's buffer.
    //
    // FAIL-SAFE: if we never captured a continuityId (older NAI build, or the field is
    // absent), fall back to the pre-v1.22.1 behavior of swallowing while active. Leaking
    // wizard prose into the user's story is far worse than over-swallowing.
    // [v1.2.0 WIZMODE] Swallow ALL output unconditionally while wizard mode is on, and
    // for any zombie continuityId left over from a watchdog-abandoned generation, even
    // after mode has since exited. This replaces the old "leave someone else's text
    // untouched" branch — that was the exact gap that let mismatched/abandoned yoink
    // output leak into the story. Only genuinely-ours chunks get buffered; everything
    // else is swallowed silently rather than passed through.
    const ygZombie = !!(params && params.continuityId && _wizZombieIds[params.continuityId]);
    if (_aeYoink.active || _aeWizardMode || ygZombie) {
        let ygMine = _aeYoink.active && (!_aeYoink.continuityId || !params || !params.continuityId || params.continuityId === _aeYoink.continuityId);
        if (ygMine && params && params.text && Array.isArray(params.text)) {
            _aeYoink.responseText += params.text.join('');
        }
        return { text: [''] };
    }

    // [v2.21.0 CHARCHAT] Clean the reply before it lands in the document. Native
    // generation exposes no per-turn stop sequences, so this regex net plus native
    // turn alternation is the whole anti-impersonation defence.
    //
    // STREAMING: this hook can fire many times per generation with partial chunks, and
    // a cleanup pass cannot run correctly across a chunk boundary (an impersonation
    // marker can straddle two chunks). Returning { seenData: false } while !final tells
    // NAI to re-deliver the same data plus anything new on the next call, so the final
    // call carries the entire reply and we clean it once, whole. On the final call
    // seenData has no effect, per the hook contract.
    // [UNVERIFIED — watch this in P1 testing] whether deferring seenData this way also
    // defers the streamed text appearing in the editor. If replies visibly land all at
    // once instead of streaming in, this is why, and the fix is to clean only on final
    // without the seenData deferral (accepting cross-chunk misses).
    if (_aeCharChat.active) {
        if (!params || !params.final) return { seenData: false };
        if (!params.text || !Array.isArray(params.text)) return;
        let ccRawReply = params.text.join('');
        if (!ccRawReply.trim()) return;
        let ccEmo = charChatParseEmotion(ccRawReply);
        if (ccEmo) { _aeCharChat.lastEmotion = ccEmo; }
        // [v2.27.0] No thought to parse out of the reply anymore — CHARCHAT-THINK is
        // gone. Whatever this contact is thinking now lives in char.ephemeral (updated
        // after each reply by onGenerationEnd's CHARCHAT branch when
        // charChatFreshThoughts is on — [v2.29.0] moved from a pre-reply call),
        // which is already persisted and already has readers, unlike the old log-only
        // stopgap this replaced.
        let ccCleaned = charChatCleanReply(ccRawReply, _aeCharChat.contactName, _aeCharChat.povName);
        return { text: [ccCleaned] };
    }
});

api.v1.hooks.register('onContextBuilt', async function(params: any) {

    // [DIAG] Probe guard — leave a probe generation's context untouched (no hijack, no injection).
    if (_diagProbeActive) { api.v1.log('[AE:budget] probe: onContextBuilt fired'); return; }

    // [vNEXT] Yoink hijack — replace the whole context with our prompt. Runs before
    // the dryRun gate and all normal injection so the wizard gen is fully isolated.
    // [v1.22.2 DRYRUN-FIX] onContextBuilt fires TWICE: once with dryRun:true (a costing/
    // preview pass) and once for the real generation, and the two carry DIFFERENT
    // continuityIds. v1.22.1 latched the dryRun's id, so the real generation's
    // onGenerationEnd never matched, was discarded as "foreign", and the yoink promise
    // stranded until the 90s watchdog fired. Every wizard call therefore took 90s and
    // returned nothing. Capture ONLY on the real pass; still hijack the context on both
    // so the dryRun cost estimate reflects our prompt rather than the user's story.
    if (_aeYoink.active) {
        if (!params.dryRun && !_aeYoink.continuityId && params && params.continuityId) {
            _aeYoink.continuityId = params.continuityId;
        }
        return { messages: _aeYoink.messages };
    }

    // [v2.4.0 WIZLIVE] Chat turns get no imperative/GM/knowledge injection — they are
    // conversation, not story. The pending-inject queue stays queued for the next
    // real story turn instead of being consumed here.
    if (_aeLiveWiz.active) return;

    // [v2.21.0 CHARCHAT] Same reasoning as WIZLIVE above: a text message is not a story
    // turn, so no imperative/GM/knowledge injection. The pending-inject queue stays
    // queued for the next real story turn rather than being consumed by a chat reply.
    if (_aeCharChat.active) return;

    // ── AE normal path: gate on dryRun ────────────────────────────────────────
    if (params.dryRun) return;
    const { messages } = params;
    if (!messages || messages.length === 0) return;

    // ── IMPERATIVE BLOCK ─────────────────────────────────────────────────────
    try {
        const impIdx = await loadIndex();
        const impLines: string[] = [];
        // [v0.9.25 E4] pendingEncounter injection removed — STORAGE_PENDING_ENCOUNTER is now a tombstone
        const pendingKnowledge = await api.v1.tempStorage.get(STORAGE_PENDING_KNOWLEDGE) as any;
        if (pendingKnowledge && pendingKnowledge.charName && pendingKnowledge.snapshot) {
            await api.v1.tempStorage.remove(STORAGE_PENDING_KNOWLEDGE);
            impLines.push('[' + pendingKnowledge.charName + '\'s established knowledge of ' + pendingKnowledge.entityName + ': ' + pendingKnowledge.snapshot + ']');
        }
        const pendingInject = await api.v1.tempStorage.get(STORAGE_PENDING_INJECT) as string | undefined;
        if (pendingInject && pendingInject.trim()) {
            await api.v1.tempStorage.remove(STORAGE_PENDING_INJECT);
            impLines.push('[GM: ' + pendingInject.trim() + ']');
        }
        // [CE-STRIP v2.6.0 CTX-CUT] Critical (85%+) hook loop REMOVED from here — it
        // now builds inside buildWorldStateBlock and rides the AN block instead of
        // this splice, merged with that character's thoughts line. See CE-INDEX
        // PASS 9 / Section 13 header for the full rationale.
        const impWeb = await loadNpcWeb();
        const impAllChars = await loadAllCharacters();
        const impPresentIds = new Set(impIdx.filter(function(m) { return m.scenePresent; }).map(function(m) { return m.id; }));
        const impHighLinks = impWeb.filter(function(link) { return link.priority >= 70 && impPresentIds.has(link.charA_id) && impPresentIds.has(link.charB_id) && link.dynamic.trim() !== ''; }).sort(function(a, b) { return b.priority - a.priority; });
        for (const link of impHighLinks) {
            const cA = impAllChars.find(function(c) { return c.id === link.charA_id; });
            const cB = impAllChars.find(function(c) { return c.id === link.charB_id; });
            if (cA && cB) impLines.push('[' + cA.name + ' and ' + cB.name + ': ' + link.dynamic.trim() + ']');
        }
        if (impLines.length > 0) {
            const impBlock = impLines.join('\n');
            const lastUserForImp = messages.map(function(m: any) { return m.role; }).lastIndexOf('user');
            const insertAtImp = lastUserForImp >= 0 ? lastUserForImp : messages.length;
            messages.splice(insertAtImp, 0, { role: 'user', content: impBlock });
        }
    } catch (e) { api.v1.error('[AE] Imperative injection error:', e); }

    // ── BACKGROUND DRAMA ─────────────────────────────────────────────────────
    // [WP-0] Background drama moved to the Author's Note block in

    // ── EQUIPMENT DESCRIPTIONS ────────────────────────────────────────────────
    // [WP-0] Removed. Full equipped-item descriptions now live on each character's
    // lorebook entry (buildLorebookContent "Wearing/Carrying" section), activating
    // with the character's keys instead of loading on every generation.

    // [RETIRED vNEXT] Legacy freeform #tag 1d6 probability engine removed — all skill
    // checks now run through the Quick Action composer (2d6 fail-forward + Stakes).
    return { messages };
});

// ── onGenerationEnd ───────────────────────────────────────────────────────────
api.v1.hooks.register('onGenerationEnd', async function(params: any) {
    try {
        // [DIAG] Probe guard — a probe api.v1.generate() must never advance story state.
        if (_diagProbeActive) { api.v1.log('[AE:budget] probe: onGenerationEnd fired (api.v1.generate DOES fire the generation lifecycle)'); return; }
        // [vNEXT] Yoink generation finished — hand the captured text back to the
        // awaiting caller and STOP. Must return before the gen counter, auto-triggers,
        // and dynamic engine so a wizard gen never advances story state.
        // [v1.22.1] Only if this end event belongs to OUR generation. A late end event
        // from a watchdog-abandoned generation must not resolve the newer call that has
        // since taken the slot. Same fail-safe as onResponse: with no continuityId
        // captured, behave exactly as before.
        if (_aeYoink.active) {
            let ygEndMine = !_aeYoink.continuityId || !params || !params.continuityId || params.continuityId === _aeYoink.continuityId;
            if (ygEndMine) {
                ae_genInFlight = false;
                if (_aeYoink.resolve) _aeYoink.resolve(_aeYoink.responseText);
                _aeYoink.active = false;
                _aeYoink.resolve = null;
                _aeYoink.reject = null;
                _aeYoink.continuityId = null;
                diagBudgetClose((params && params.continuityId) || null);   // [DIAG] close the YOINK reading
                if (_wizModeExitPending) { await aeCompleteWizardModeExit(); } // [v1.2.0 WIZMODE] resolve a deferred exit now that the yoink is done
                return;
            }
            // An orphaned generation ended. Do not touch _aeYoink; also do not run the
            // story-advancing logic below on its behalf.
            if (params && params.continuityId && _wizZombieIds[params.continuityId]) {
                delete _wizZombieIds[params.continuityId]; // [v1.2.0 WIZMODE] zombie finally resolved — stop tracking it
                api.v1.log('[AE:wizard] zombie generation ' + params.continuityId + ' ended \u2014 cleaned up.');
            } else {
                api.v1.log('[AE:wizard] ignoring generation-end from an abandoned/foreign generation.');
            }
            return;
        }

        // [v2.4.0 WIZLIVE] A finished chat turn is not a story turn: release the gen
        // guard, retint the freshly grown chat region, and skip the counter, auto-
        // triggers, and dynamic engine entirely.
        if (_aeLiveWiz.active) {
            ae_genInFlight = false;
            diagBudgetClose((params && params.continuityId) || null);
            // [FEATURE v2.29.0 WIZLIVE-BRACE-WRAP] Runs BEFORE the decoration refresh so
            // the tint is computed against the paragraphs that actually survive the pass —
            // same ordering CharChat's normalize-then-decorate already uses.
            try { await _wizliveNormalizeDocument(); } catch (eWn) { api.v1.log('[AE:wizlive] brace-wrap pass failed (chat still usable, formatting may be off):', eWn); }
            try { await refreshLiveWizDecorations(); } catch (eLd) { api.v1.log('[AE:wizlive] decoration refresh failed:', eLd); }
            return;
        }

        // [v2.21.0 CHARCHAT] A finished text message is not a story turn either: release
        // the gen guard, retint the freshly grown chat region, and skip the gen counter,
        // auto-triggers, and the dynamic engine entirely. Letting the dynamic engine run
        // here would let chat turns silently drive ephemeral/mid-range updates — exactly
        // the context poisoning this design promises not to do.
        if (_aeCharChat.active) {
            ae_genInFlight = false;
            diagBudgetClose((params && params.continuityId) || null);
            // [v2.24.0, per user: "maybe we handle it after generation?"] This is that
            // "after". The scaffold-append that used to live here is gone; instead the
            // whole chat region is re-canonicalised now that both this turn's POV message
            // and the reply are in the document — headers applied, stray blank paragraphs
            // dropped, unclosed braces closed. Runs BEFORE the decoration refresh so the
            // tint is computed against the paragraphs that actually survive the pass.
            try { await _charchatNormalizeDocument(); } catch (eNz) { api.v1.log('[AE:charchat] turn normalisation failed (chat still usable, formatting may be off):', eNz); }
            try { await refreshCharChatDecorations(); } catch (eCd) { api.v1.log('[AE:charchat] decoration refresh failed:', eCd); }
            // [BUGFIX v2.29.0 CHARCHAT-FRESH-THOUGHTS-TIMING, per user's gen log ("A
            // generation is already in progress")] MOVED here from
            // runCharChatContextOverride (onBeforeContextBuild) — see the removal note
            // at that old site for the full root-cause writeup. Short version: THIS
            // hook is where the plain (non-chat) dynamic engine already fires its own
            // generateEphemeral calls every normal turn without incident, so it's the
            // one place in the whole lifecycle nested api.v1.generate() calls are
            // actually safe. That means the refresh now happens AFTER this reply,
            // readying the "right now" line for the NEXT one rather than this one —
            // one turn later than v2.27.0 intended, but the only timing NAI's own
            // generation concurrency allows. _diagProbeActive still required: this
            // nested call re-fires the full hook lifecycle, INCLUDING this very
            // onGenerationEnd branch, and would otherwise recurse right back into
            // itself (the v2.28.0 finding was real, just not sufficient on its own).
            let ccCfgEnd = await loadConfig();
            if (ccCfgEnd && ccCfgEnd.charChatFreshThoughts) {
                let ccContactEnd = await loadCharacter(_aeCharChat.contactId);
                if (ccContactEnd) {
                    let ccGenCountEnd = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;
                    _diagProbeActive = true;
                    try { await generateEphemeral(ccContactEnd, ccCfgEnd, ccGenCountEnd); }
                    catch (eccEphEnd) { api.v1.error('[AE:charchat] post-reply ephemeral refresh failed:', eccEphEnd); }
                    _diagProbeActive = false;
                }
            }
            return;
        }

        ae_genInFlight = false; // [v0.9.36] generation finished — release the generate guard
        diagBudgetClose((params && params.continuityId) || null);   // [DIAG] close the STORY reading (no-op if none pending)
        // Skip on inline generations (tooltips, etc.) and retry/undo flagged turns
        if (params?.inlineGeneration) return;
        const skipFlag = await api.v1.tempStorage.get(STORAGE_ENGINE_SKIP) as string | undefined;
        if (skipFlag === 'true') {
            await api.v1.tempStorage.remove(STORAGE_ENGINE_SKIP);
            api.v1.log('[AE] Engine skipped this turn (retry/undo).');
            return;
        }

        // [v0.9.24 E1] Increment persistent generation count (replaces token estimation).
        try {
            let _genC = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;
            _genC = (Number(_genC) || 0) + 1;
            await api.v1.storyStorage.set(STORAGE_GEN_COUNT, _genC);
            api.v1.log('[AE] Generation count: ' + _genC);
        } catch (e) { api.v1.error('[AE] Gen count increment error:', e); }

        // [CE-STRIP v2.0.x] Time auto-advance removed — Clock/Calendar cut.

        api.v1.log('[AE] Generation complete — running auto-triggers...');
        await runAutoTriggers();
        api.v1.log('[AE] Generation complete — engaging dynamic engine...');
        await runDynamicEngine();
    } catch (e) {
        api.v1.error('[AE] onGenerationEnd error:', e);
        // [vNEXT] Failsafe — never leave the yoink lock stuck on error.
        if (_aeYoink.active) {
            if (_aeYoink.reject) _aeYoink.reject(e);
            _aeYoink.active = false;
            _aeYoink.resolve = null;
            _aeYoink.reject = null;
            _aeYoink.continuityId = null;
        }
    }
});

// Skip engine on retry and undo — token stamps shouldn't update when story reverts
api.v1.hooks.register('onHistoryNavigated', async function(params: any) {
    ae_genInFlight = false; // [v0.9.36] safety release if a generation was aborted/navigated
    if (params?.cause === 'retry' || params?.cause === 'undo') {
        await api.v1.tempStorage.set(STORAGE_ENGINE_SKIP, 'true');
    }
});


// ============================================================================
// SECTION 27 — STARTUP
//
// [CHANGE] onScriptsLoaded startup sequence:
//   1. Register sidebarPanel only (no ae-scene-hud scriptPanel — bridge owns HUD)
//   2. Request permissions
//   3. loadImageSettings() — seeds imagePromptFields[], globalSettings from storage
//   4. buildCharacterDataPayload() — seeds cachedCharVisuals before bridge connects
// ============================================================================



// ============================================================================
// INITIALIZATION
// ============================================================================




// [v0.9.22 E5] Intercepts direct player TA-box input and composes any pending
// player flavor into inputText before it is written to the story document.
// Only fires for actual player key-submissions; not triggered by generate().
api.v1.hooks.register('onTextAdventureInput', async function(params: any) {
    try {
        let taFlavor = await api.v1.tempStorage.get(STORAGE_PENDING_FLAVOR) as string | undefined;
        if (taFlavor && taFlavor.trim()) {
            await api.v1.tempStorage.remove(STORAGE_PENDING_FLAVOR);
            let taInput = String((params && params.inputText) || '');
            return { inputText: composeActionPrompt(taInput, taFlavor.trim()) };
        }
    } catch (_e) {}
});

// ============================================================================
// SECTION 27 — NATIVE TOOLBAR HUD (bridge-less interface)
// A toolbar tray whose five buttons each open a native modal rendering the same
// SceneStatePayload the bridge consumes. Gated by cfg.interfaceMode. Renderer-only:
// every verb is shared with the bridge. NAI has no dropdown UIPart, so the bridge's
// three side-by-side <select>s become full-width picker-buttons via openPickerModal.
// ============================================================================

// Persistent Goal & Approach composer state — mirrors the bridge _composer* vars
// so picks survive a modal reopen within a session.
var _aeNavGoal: string = '';
var _aeNavAttr: string | null = null;
var _aeNavStake: string | null = null;
var _aeNavStakeAuto: boolean = true;
var _aeNavTarget: string = 'none';
var _aeNavLuck: number = 0;
var _aeMapInspectId: string = '';   // [v0.9.9.5] native map "Looking at" inspected location id
var _aeNavInit: boolean = false;    // [v0.9.9.6] action composer defaults applied once (so 'No check' persists)

function aeRenderIndexedStatesEditor(states: string[], onChange: (next: string[]) => Promise<void>, refreshFn: () => Promise<void>, label: string): UIPart {
    // [RESTORED v2.1.4] Generic ordered string-list editor (states/stages/standings/
    // enum values/etc). Lost during an earlier Holding-block deletion even though it
    // had external callers outside Holding (Faction relationshipStates, Relationship
    // Archetype stages) — rebuilt from those call sites' usage shape; no copy of the
    // original implementation survived in any project file, so this is a fresh build,
    // not a restoration of the original source.
    const rows: UIPart[] = states.map(function(s, i) {
        return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '3px' }, content: [
            { type: 'textInput', initialValue: s, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, onChange: async function(v: string) {
                const next = states.slice(); next[i] = v; await onChange(next);
            } } as UIPart,
            { type: 'button', iconId: 'chevron-up', style: { margin: 0, padding: '2px 6px' }, disabled: i === 0, callback: async function() {
                if (i === 0) return;
                const next = states.slice(); const tmp = next[i - 1]; next[i - 1] = next[i]; next[i] = tmp;
                await onChange(next); await refreshFn();
            } } as UIPart,
            { type: 'button', iconId: 'chevron-down', style: { margin: 0, padding: '2px 6px' }, disabled: i === states.length - 1, callback: async function() {
                if (i === states.length - 1) return;
                const next = states.slice(); const tmp = next[i + 1]; next[i + 1] = next[i]; next[i] = tmp;
                await onChange(next); await refreshFn();
            } } as UIPart,
            { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px 6px', color: '#ff6b6b' }, callback: async function() {
                const next = states.slice(); next.splice(i, 1); await onChange(next); await refreshFn();
            } } as UIPart
        ] } as UIPart;
    });
    rows.push({ type: 'button', text: '+ Add ' + label, style: { fontSize: '10px', margin: 0, marginTop: '2px' }, callback: async function() {
        const next = states.slice(); next.push('New ' + label); await onChange(next); await refreshFn();
    } } as UIPart);
    return { type: 'column', style: { gap: '0', marginBottom: '6px' }, content: rows } as UIPart;
}

function _aeHudHeader(text: string): UIPart {
    return { type: 'text', text: text, style: { fontSize: '12px', fontWeight: 'bold', color: '#7ec8a0', marginTop: '10px', marginBottom: '4px' } } as UIPart;
}
function _aeHudInfo(text: string): UIPart {
    return { type: 'text', text: text, style: { fontSize: '11px', opacity: '0.65', marginBottom: '6px', lineHeight: '1.4' } } as UIPart;
}
function _aeHudSub(text: string): UIPart {
    return { type: 'text', text: text, style: { fontSize: '11px', fontWeight: 'bold', opacity: '0.7', marginTop: '6px', marginBottom: '2px', color: '#a9d4f5' } } as UIPart;
}
function _aeHudRow(content: UIPart[]): UIPart {
    return { type: 'row', style: { gap: '5px', marginBottom: '4px', alignItems: 'stretch' }, content: content } as UIPart;
}
function _aeHudClose(handleGetter: () => any): UIPart {
    return { type: 'button', text: 'Close', style: { marginTop: '12px' }, callback: async function() {
        let h = handleGetter(); try { if (h && !h.isClosed()) await h.close(); } catch (e) {}
    } } as UIPart;
}

// Smart Stakes default: the StakeDef whose defaultForAttrs includes the attr tag
// (# normalized on both sides). Mirrors the bridge composer exactly.
function _aeDefaultStakeFor(state: any, attrTag: string | null): string {
    let tag = String(attrTag || '').replace(/^#/, '').toLowerCase();
    if (!tag) return '';
    let match = (state.stakeDefs || []).filter(function(sd: any) {
        return (sd.defaultForAttrs || []).some(function(a: string) { return String(a).replace(/^#/, '').toLowerCase() === tag; });
    })[0];
    return match ? match.id : '';
}

// ── SHARED INSPECT / ITEM / NARRATIVE HELPERS ──────────────────────────────
// [v0.9.9.7] Used by the character inspection view, the top-level Inspect modal,
// and the Player modal's Inventory/Quests tabs -- one render path for "a list of
// items" or "a list of narratives" everywhere they appear in the native HUD.

function _aePressureLabel(p: number): string {
    if (p < 25) return 'Latent';
    if (p < 60) return 'Building';
    if (p < 85) return 'Urgent';
    return 'Critical';
}

// One-line dramatis persona for a single character: "Name (species, age, role) — brief".
function _aeCharDramatis(char: any): string {
    let idParts = [char.species, char.age, char.occupationRole].filter(function(x: any) { return x && String(x).trim(); });
    let header = idParts.length ? (char.name + ' (' + idParts.join(', ') + ')') : char.name;
    let brief = (char.briefDescription && String(char.briefDescription).trim()) ? '  \u2014  ' + String(char.briefDescription).trim() : '';
    return header + brief;
}

// [v0.9.9.7] Shared action-instance executor for any entity-attached action button
// (Action tab, item rows, narrative rows). Resolves the live instance, detects
// whether it needs a target picker, and runs it -- same resolve path RUN_ACTION_INSTANCE
// uses. closeFn (if given) is called right before the action actually runs, matching
// the close-then-act pattern used elsewhere in the native HUD.
// [CE-STRIP v2.1.6] aeRunEntityAction() removed — actionInstances cut, no callers left.

// Active-hooks list content (caller wraps in one 'Active Hooks (N)' collapsibleSection).
function _aeHookRows(hooks: any[], charId: string, refreshFn: () => Promise<void>): UIPart[] {
    if (!hooks || hooks.length === 0) return [_aeHudInfo('No active hooks.')];
    return hooks.map(function(h: any) {
        let targetLabel = h.targetName === '__player__' ? 'Player' : (h.targetName || 'Unknown');
        return { type: 'box', style: { padding: '8px 10px', marginBottom: '6px', backgroundColor: 'rgba(217,138,138,0.08)', border: '1px solid rgba(217,138,138,0.25)', borderRadius: '6px' }, content: [
            { type: 'text', text: '\ud83e\ude9d ' + targetLabel, style: { fontSize: '11px', fontWeight: 'bold', marginBottom: '2px' } } as UIPart,
            { type: 'text', text: h.description || '', style: { fontSize: '11px', opacity: '0.85', lineHeight: '1.4', marginBottom: '4px' } } as UIPart,
            { type: 'text', text: _aePressureLabel(h.pressureLevel) + '  (' + h.pressureLevel + ')', style: { fontSize: '10px', opacity: '0.6', marginBottom: '4px' } } as UIPart,
            { type: 'button', text: 'Resolve Hook', iconId: 'check', style: { width: '100%', fontSize: '11px', margin: 0 }, callback: async function() { await resolveCharHook(charId, h.id); await refreshFn(); } } as UIPart
        ] } as UIPart;
    });
}

// One collapsibleSection per item, always defaults closed. Equip toggle only ever
// targets the item's own owner/parent -- ownerCharId is resolved by the caller
// (the character whose inventory this is, or undefined for ownerless location items,
// which hides the toggle since there is no parent entity to toggle to).
function _aeItemSection(items: any[], ownerCharId: string | undefined, refreshFn: () => Promise<void>): UIPart[] {
    return (items || []).map(function(item: any) {
        let body: UIPart[] = [];
        body.push({ type: 'text', text: item.description || 'No description.', style: { fontSize: '11px', opacity: '0.8', lineHeight: '1.4', marginBottom: '6px' } } as UIPart);
        let equipTarget = item.isEquipped ? (item.equippedToCharId || ownerCharId) : ownerCharId;
        if (equipTarget) {
            body.push({ type: 'button', text: item.isEquipped ? 'Equipped' : 'Equip', iconId: item.isEquipped ? 'check-circle' : 'package', style: { width: '100%', fontSize: '11px', marginBottom: '4px', backgroundColor: item.isEquipped ? 'rgba(126,200,160,0.15)' : undefined, color: item.isEquipped ? '#7ec8a0' : undefined }, callback: async function() { await setItemEquip(equipTarget, item.id, !item.isEquipped); await refreshFn(); } } as UIPart);
        }
        // [CE-STRIP v2.1.6] Per-entity actionInstances run-buttons removed — actionInstances cut.
        body.push({ type: 'button', text: 'Edit Entity', iconId: 'tool', style: { width: '100%', fontSize: '11px', marginTop: '2px', opacity: '0.75' }, callback: async function() { try { await openEntityEditModal(item.id); } catch (e) {} } } as UIPart);
        return { type: 'collapsibleSection', title: aeIconPfx(item.icon) + item.name, initialCollapsed: true, storageKey: 'temp:ae_item_' + item.id, content: body } as UIPart;
    });
}

// One collapsibleSection per narrative, always defaults closed. storyState, tracked
// toggle (same STORAGE_TRACKED_NARRATIVE flag the bridge uses), target destination
// and a due-date countdown (from eventDayTarget), entity-attached actions, and an
// edit-modal button. curAbsDay is the clock's current absolute day (loaded once by
// the caller so a long list doesn't reload the clock per row).
function _aeNarrativeSection(narrs: any[], curAbsDay: number, refreshFn: () => Promise<void>): UIPart[] {
    return (narrs || []).map(function(n: any) {
        let body: UIPart[] = [];
        let stateLabel = n.storyState === 'active' ? '\ud83d\udd25 Active' : n.storyState === 'completed' ? '\u2705 Completed' : '\ud83d\udd12 Locked';
        if (n.isTracked) stateLabel = '\ud83c\udfaf Tracked  \u00b7  ' + stateLabel;
        body.push({ type: 'text', text: stateLabel, style: { fontSize: '11px', fontWeight: 'bold', marginBottom: '4px', color: n.isTracked ? '#7ec8a0' : '#a8a8b8' } } as UIPart);
        if (n.description) body.push({ type: 'text', text: n.description, style: { fontSize: '11px', opacity: '0.8', lineHeight: '1.4', marginBottom: '6px' } } as UIPart);
        if (n.questTargetName) body.push({ type: 'text', text: 'Target:  ' + n.questTargetName, style: { fontSize: '11px', opacity: '0.7', marginBottom: '2px' } } as UIPart);
        if (typeof n.eventDayTarget === 'number') {
            let due = Math.floor(n.eventDayTarget) - curAbsDay;
            let dueStr = due > 1 ? (due + ' days remaining') : due === 1 ? '1 day remaining' : due === 0 ? 'due today' : ('overdue by ' + (-due) + (due === -1 ? ' day' : ' days'));
            body.push({ type: 'text', text: 'Due:  ' + dueStr, style: { fontSize: '11px', marginBottom: '6px', color: due < 0 ? '#d98a8a' : '#e8c07d' } } as UIPart);
        }
        // [CE-STRIP v2.0.0] "Track Quest" button (toggleNarrativeTracking) and per-instance
        // action-run buttons removed — quest-tracker + Actions cut. This panel still
        // displays narrative/quest entities read-only pending the full Narrative removal pass.
        body.push({ type: 'button', text: 'Edit Entity', iconId: 'tool', style: { width: '100%', fontSize: '11px', marginTop: '2px', opacity: '0.75' }, callback: async function() { try { await openEntityEditModal(n.id); } catch (e) {} } } as UIPart);
        return { type: 'collapsibleSection', title: aeIconPfx(n.icon) + n.name, initialCollapsed: true, storageKey: 'temp:ae_narr_' + n.id, content: body } as UIPart;
    });
}

// Personal (per-character) resource rows with inline +/- steppers -- adjustCharResource
// runs directly in-worker, so there is no round-trip latency native has an edge here.
function _aeResourceRows(charId: string, resources: any[], refreshFn: () => Promise<void>): UIPart[] {
    if (!resources || resources.length === 0) return [_aeHudInfo('No personal resources.')];
    return resources.map(function(r: any) {
        let valLabel: string;
        if (r.type === 'pool') valLabel = String(r.value) + (typeof r.max === 'number' ? ' / ' + r.max : '');
        else valLabel = (r.states && r.states[r.value]) ? r.states[r.value] : String(r.value);
        return _aeHudRow([
            { type: 'text', text: r.name, style: { flex: '1 1 0', fontSize: '12px', alignSelf: 'center' } } as UIPart,
            { type: 'button', text: '\u2212', style: { width: '30px', margin: 0 }, callback: async function() { await adjustCharResource(charId, r.tag, -1); await broadcastSceneState(); await refreshFn(); } } as UIPart,
            { type: 'text', text: valLabel, style: { width: '70px', fontSize: '11px', textAlign: 'center', alignSelf: 'center' } } as UIPart,
            { type: 'button', text: '+', style: { width: '30px', margin: 0 }, callback: async function() { await adjustCharResource(charId, r.tag, 1); await broadcastSceneState(); await refreshFn(); } } as UIPart
        ]);
    });
}

// ── MAP ─────────────────────────────────────────────────────────────────────

// ── CALENDAR / CLOCK ───────────────────────────────────────────────────────
async function openMapModal(): Promise<void> {
    let mapHandle: any = null;

    // Resolve the outbound edge (child / sibling / connection) for a destination id.
    // Parent (return trip) has no edge and is free.
    function _mapEdge(g: any, id: string): any {
        let all: any[] = ([] as any[]).concat(g.children || [], g.siblings || [], g.connections || []);
        return all.filter(function(e: any) { return e.id === id; })[0] || null;
    }
    // Human cost string: time first ("2h"), then resource ("5 currency").
    function _mapCost(edge: any): string {
        if (!edge) return '';
        let bits: string[] = [];
        if (edge.timeCost && edge.timeCost > 0) bits.push(edge.timeCost + 'h');
        if (edge.resourceCost && edge.resourceTag) bits.push(edge.resourceCost + ' ' + String(edge.resourceTag).replace('#', ''));
        return bits.join('  +  ');
    }

    async function renderMap() {
        let state: any = await getSceneState();
        let parts: UIPart[] = [];
        if (!state) {
            parts.push(_aeHudInfo('No scene state available.'));
            parts.push(_aeHudClose(function() { return mapHandle; }));
            try { if (mapHandle && !mapHandle.isClosed()) { await mapHandle.update({ content: parts }); return; } } catch (e) {}
            mapHandle = await openEngineModal({ id: 'ae-nav-map', title: 'Map', size: 'medium', content: parts });
            return;
        }
        let g: any = state.locationGraph || {};

        // Current location header + body + atmosphere.
        parts.push({ type: 'text', text: (g.currentIcon ? g.currentIcon + ' ' : '') + (state.locationName || 'Unknown location'), style: { fontSize: '15px', fontWeight: 'bold', marginBottom: '2px' } } as UIPart);
        if (state.locationDescription) parts.push({ type: 'text', text: state.locationDescription, style: { fontSize: '11px', opacity: '0.75', lineHeight: '1.4', marginBottom: '3px' } } as UIPart);
        if (state.locationAtmosphere) parts.push({ type: 'text', text: state.locationAtmosphere, style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic', marginBottom: '3px' } } as UIPart);

        // "Looking at" panel: the inspected destination, its cost, and the Travel /
        // Teleport actions. Sits directly under the current location so the buttons
        // have the full modal width and room for the cost line.
        if (_aeMapInspectId && _aeMapInspectId !== state.locationId) {
            let insEnt: any = null;
            try { insEnt = await loadEntity(_aeMapInspectId); } catch (eIns) { insEnt = null; }
            if (insEnt) {
                let panel: UIPart[] = [];
                panel.push({ type: 'text', text: 'Looking at', style: { fontSize: '10px', opacity: '0.55', fontWeight: 'bold', marginBottom: '2px' } } as UIPart);
                panel.push({ type: 'text', text: aeIconPfx(insEnt.icon) + (insEnt.name || ''), style: { fontSize: '14px', fontWeight: 'bold', color: '#a9d4f5', marginBottom: '3px' } } as UIPart);
                panel.push({ type: 'text', text: insEnt.description || 'No description recorded.', style: { fontSize: '11px', opacity: '0.8', lineHeight: '1.4', marginBottom: '6px' } } as UIPart);
                // [CE-STRIP v2.0.0] Travel button (cost/gating) removed with Travel — Teleport
                // (direct reposition, no path/cost) is now the only move action.
                panel.push(_aeHudRow([
                    { type: 'button', text: 'Teleport', iconId: 'navigation', style: { flex: '1 1 0', fontSize: '12px', margin: 0, fontWeight: 'bold', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0', border: '1px solid #7ec8a0' }, callback: async function() {
                        let dest = _aeMapInspectId;
                        try { await commitTravel(dest, true); } catch (eTp) {}
                        _aeMapInspectId = '';
                        await renderMap();
                    } } as UIPart
                ]));
                parts.push({ type: 'box', style: { padding: '9px 11px', marginTop: '8px', marginBottom: '2px', backgroundColor: 'rgba(136,204,255,0.08)', border: '1px solid rgba(136,204,255,0.25)', borderRadius: '8px' }, content: panel } as UIPart);
            }
        }

        // Destination list: each location is a full-width name button that loads it
        // into the "Looking at" panel above. Grouped Above / Nearby / Inside.
        function navBtn(id: string, label: string, icon: any): UIPart {
            let sel = (_aeMapInspectId === id);
            return { type: 'button', text: aeIconPfx(icon) + label, iconId: 'eye', style: { width: '100%', textAlign: 'left', fontSize: '12px', marginBottom: '3px', backgroundColor: sel ? 'rgba(136,204,255,0.15)' : undefined, border: sel ? '1px solid rgba(136,204,255,0.4)' : undefined }, callback: async function() { _aeMapInspectId = id; await renderMap(); } } as UIPart;
        }

        parts.push(_aeHudHeader('Travel'));
        // [v1.19.0 LOCGEN] Anchored to state.locationId (the PLAYER's location), not
        // _aeMapInspectId (the "Looking at" selection) -- authoring is relative to
        // where you ARE, not what you're browsing. Mirrors the bridge Map tab's
        // "+ Location" button, which anchors the same way.
        parts.push({ type: 'button', text: '+ New Location', iconId: 'map-pin', style: { width: '100%', fontSize: '11px', marginBottom: '8px' }, callback: async function() { await openAddLocationModal(state.locationId, renderMap); } } as UIPart);
        let anyConn = false;

        if (g.parentId) {
            parts.push(_aeHudSub('Above'));
            parts.push(navBtn(g.parentId, g.parentName || 'Up one level', g.parentIcon));
            anyConn = true;
        }

        let nearby: any[] = [];
        (g.siblings || []).forEach(function(s: any) { nearby.push({ id: s.id, name: s.name, icon: s.icon }); });
        (g.connections || []).forEach(function(c: any) { nearby.push({ id: c.id, name: c.name + (c.label ? '  \u2014 ' + c.label : ''), icon: c.icon }); });
        if (nearby.length > 0) {
            parts.push(_aeHudSub('Nearby'));
            nearby.forEach(function(n: any) { parts.push(navBtn(n.id, n.name, n.icon)); });
            anyConn = true;
        }

        if ((g.children || []).length > 0) {
            parts.push(_aeHudSub('Inside'));
            (g.children || []).forEach(function(c: any) { parts.push(navBtn(c.id, c.name, c.icon)); });
            anyConn = true;
        }

        if (!anyConn) parts.push(_aeHudInfo('No connected locations.'));

        parts.push(_aeHudClose(function() { return mapHandle; }));
        try { if (mapHandle && !mapHandle.isClosed()) { await mapHandle.update({ content: parts }); return; } } catch (e) {}
        mapHandle = await openEngineModal({ id: 'ae-nav-map', title: 'Map', size: 'medium', content: parts });
    }
    await renderMap();
}

// ── INSPECT ───────────────────────────────────────────────────────────────────
async function openInspectModal(): Promise<void> {
    let insHandle: any = null;

    async function renderInspect() {
        let parts: UIPart[] = [];
        let state: any = await getSceneState();
        if (!state) {
            parts.push(_aeHudInfo('No scene state available.'));
            parts.push(_aeHudClose(function() { return insHandle; }));
            try { if (insHandle && !insHandle.isClosed()) { await insHandle.update({ content: parts }); return; } } catch (e) {}
            insHandle = await openEngineModal({ id: 'ae-nav-inspect', title: 'Inspect', size: 'medium', content: parts });
            return;
        }

        let chars = (state.presentCharacters || []).filter(function(c: any) { return !c.isProtagonist; });
        parts.push({ type: 'row', style: { alignItems: 'center', gap: '6px', marginTop: '4px', marginBottom: '2px' }, content: [
            { type: 'text', text: 'Characters', style: { flex: '1 1 0', fontWeight: 'bold', fontSize: '12px' } },
            { type: 'button', text: '\u27f3 Detect', iconId: 'refresh-cw', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 8px', opacity: '0.8' }, callback: async function() { await aeRefreshPresence(); await renderInspect(); } }
        ] } as UIPart);
        parts.push({ type: 'button', text: '+ Add Character to Scene', iconId: 'user-plus', style: { width: '100%', fontSize: '11px', marginBottom: '6px' }, callback: async function() {
            const acAll = await loadAllCharacters();
            const acPresent = new Set((state.presentCharacters || []).map(function(pc: any) { return pc.id; }));
            const acCands = acAll.filter(function(ac) { return ac.active && !ac.isProtagonist && !acPresent.has(ac.id); });
            // Pre-resolve each candidate's current location name for the picker sublabel.
            const acIdx = await loadEntityIndex();
            const acLocById: { [k: string]: string } = {};
            for (const ac of acCands) {
                let locName = 'no location';
                if (ac.entityId) {
                    let room = getEffectiveRoomId(ac.entityId, acIdx);
                    if (room) { let rn = acIdx.find(function(m) { return m.id === room; }); if (rn && rn.name) locName = rn.name; }
                }
                acLocById[ac.id] = locName;
            }
            await openPickerModal({
                title: 'Add Character to Scene',
                items: acCands,
                getId: function(it: any) { return it.id; },
                getLabel: function(it: any) { return it.name; },
                getSublabel: function(it: any) { return '\ud83d\udccd ' + (acLocById[it.id] || 'no location'); },
                searchable: true,
                emptyText: 'Everyone active is already here.',
                onSelect: async function(it: any) { await aeMoveCharToScene(it.id); await renderInspect(); }
            });
        } } as UIPart);
        parts.push({ type: 'button', text: '+ New Character Here', iconId: 'user-plus', style: { width: '100%', fontSize: '11px', marginBottom: '6px' }, callback: async function() { await openAddNpcModal(state.locationId, renderInspect); } } as UIPart);
        if (chars.length === 0) parts.push(_aeHudInfo('No one else is here.'));
        chars.forEach(function(c: any) {
            parts.push({ type: 'row', style: { gap: '4px', marginBottom: '3px', alignItems: 'center' }, content: [
                { type: 'button', text: c.name + (c.compressedLine ? '  \u2014  ' + c.compressedLine : ''), iconId: 'user', style: { flex: '1 1 0', textAlign: 'left', fontSize: '12px' }, callback: async function() { try { await openCharEditModal(c.id); } catch (e) {} } },
                { type: 'button', text: 'Exclude', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px', opacity: '0.8' }, callback: async function() { await aeSetCharScenePresent(c.id, false); await renderInspect(); } }
            ] } as UIPart);
        });

        // Items / narratives native to THIS location -- pulled from the same
        // buildEntityDetailPayload children the character inventory view uses, so
        // descriptions/actions/state are real instead of the old name-only buttons.
        let locEnt = state.locationId ? await loadEntity(state.locationId) : null;
        let locDetail = state.locationId ? await buildEntityDetailPayload(state.locationId, null, locEnt) : null;
        let locChildren = locDetail ? (locDetail.children || []) : [];
        let items = locChildren.filter(function(c: any) { return c.type === 'item'; });
        let narrs = locChildren.filter(function(c: any) { return c.type === 'narrative'; });

        parts.push(_aeHudHeader('Items (' + items.length + ')'));
        parts.push({ type: 'button', text: '+ Add Item Here', iconId: 'plus', style: { width: '100%', fontSize: '11px', marginBottom: '6px' }, callback: async function() { await openAddItemModal(state.locationId, renderInspect); } } as UIPart);
        if (items.length === 0) parts.push(_aeHudInfo('Nothing here.'));
        else parts.push.apply(parts, _aeItemSection(items, undefined, renderInspect));

        if (narrs.length > 0) {
            parts.push(_aeHudHeader('Narratives (' + narrs.length + ')'));
            parts.push.apply(parts, _aeNarrativeSection(narrs, 0, renderInspect)); // [CE-STRIP v2.0.x] Clock removed.
        }

        parts.push(_aeHudClose(function() { return insHandle; }));
        try { if (insHandle && !insHandle.isClosed()) { await insHandle.update({ content: parts }); return; } } catch (e) {}
        insHandle = await openEngineModal({ id: 'ae-nav-inspect', title: 'Inspect', size: 'medium', content: parts });
    }
    await renderInspect();
}

// ── ACTION (Goal & Approach) ──────────────────────────────────────────────────

// ── JOURNAL ─────────────────────────────────────────────────────────────────────
// [v1.7.0 JOURNAL] Native Player Journal UI. Opens from the Player modal. Renderer
// only — every verb lives in Section 10b so the bridge HUD can reuse them later.
// Draft text is held in module-level vars (updated via onChange, never mid-render)
// so re-rendering the modal after an action never clobbers what the user is typing.
var _aeJrnlEditingId: string | null = null;   // id of the bubble currently in edit mode
var _aeJrnlBusy: boolean = false;             // generation in flight (disables buttons)
var _aeJrnlShowArchived: boolean = false;     // archived list visibility toggle
var _aeJrnlCompose: string = '';              // draft for the "new entry" box
var _aeJrnlEditDraft: string = '';            // draft for the bubble being edited
async function openJournalModal(): Promise<void> {
    let jHandle: any = null;

    // Kick a rewrite/compress: seed edit mode, run story-aware generation, then load
    // the result into the edit draft for review. Never commits without an explicit Save.
    async function runJrnlGen(kind: string, b: JournalBubble): Promise<void> {
        if (_aeJrnlBusy) return;
        const srcText = (_aeJrnlEditingId === b.id) ? (_aeJrnlEditDraft || b.text) : b.text;
        _aeJrnlBusy = true; _aeJrnlEditingId = b.id;
        await renderJournal();
        let out: string | null = null;
        try { out = (kind === 'rewrite') ? await journalGenerateRewrite(srcText) : await journalGenerateCompress(srcText); }
        catch (e) { api.v1.error('[AE:hud] journal gen:', e); }
        _aeJrnlBusy = false;
        if (out) { _aeJrnlEditDraft = out; api.v1.ui.toast(kind === 'rewrite' ? 'Rewritten \u2014 review and Save.' : 'Compressed \u2014 review and Save.', { type: 'success' }); }
        else { api.v1.ui.toast('Generation failed or returned nothing.', { type: 'error' }); }
        await renderJournal();
    }

    function renderBubble(b: JournalBubble, isArchived: boolean, cfg: GlobalConfig): UIPart {
        const editing = _aeJrnlEditingId === b.id;
        const body: UIPart[] = [];

        // Header line: "Archived" tag only now — in-story stamps removed.
        if (isArchived) {
            body.push({ type: 'row', style: { marginBottom: '4px' }, content: [
                { type: 'text', text: 'Archived', style: { fontSize: '10px', opacity: '0.6', flex: '1 1 0', alignSelf: 'center' } } as UIPart
            ] } as UIPart);
        }

        if (editing && _aeJrnlBusy) {
            body.push(_aeHudInfo('Working\u2026'));
        } else if (editing) {
            body.push({ type: 'multilineTextInput', initialValue: _aeJrnlEditDraft, placeholder: 'Edit this entry\u2026', onChange: function(v: string) { _aeJrnlEditDraft = v; }, style: { minHeight: '120px', marginBottom: '6px' } } as UIPart);
            body.push(_aeHudRow([
                { type: 'button', text: 'Save', iconId: 'save', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0' }, callback: async function() { await journalUpdateBubble(b.id, _aeJrnlEditDraft); _aeJrnlEditingId = null; api.v1.ui.toast('Saved.', { type: 'success' }); await renderJournal(); } } as UIPart,
                { type: 'button', text: 'Cancel', iconId: 'x', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { _aeJrnlEditingId = null; await renderJournal(); } } as UIPart
            ]));
            body.push(_aeHudRow([
                { type: 'button', text: 'Rewrite', iconId: 'feather', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runJrnlGen('rewrite', b).catch(function(e) { api.v1.error('[AE:hud] jrnl rewrite:', e); }); } } as UIPart,
                { type: 'button', text: 'Compress', iconId: 'file-minus', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runJrnlGen('compress', b).catch(function(e) { api.v1.error('[AE:hud] jrnl compress:', e); }); } } as UIPart
            ]));
        } else {
            // Reading surface: grows with content, then scrolls — never squished/clipped.
            body.push({ type: 'box', style: { maxHeight: '240px', overflowY: 'auto', padding: '8px 10px', backgroundColor: 'rgba(255,255,255,0.03)', border: '1px solid rgba(255,255,255,0.08)', borderRadius: '6px', marginBottom: '6px' }, content: [
                { type: 'text', text: (b.text && b.text.trim()) ? b.text : '(empty)', noTemplate: true, style: { fontSize: '12px', lineHeight: '1.5', whiteSpace: 'pre-wrap', wordBreak: 'break-word' } } as UIPart
            ] } as UIPart);
            body.push(_aeHudRow([
                { type: 'button', text: 'Edit', iconId: 'edit-3', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { _aeJrnlEditDraft = b.text || ''; _aeJrnlEditingId = b.id; await renderJournal(); } } as UIPart,
                isArchived
                    ? { type: 'button', text: 'Unarchive', iconId: 'refresh', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { await journalSetArchived(b.id, false); api.v1.ui.toast('Restored to Always-On.', { type: 'success' }); await renderJournal(); } } as UIPart
                    : { type: 'button', text: 'Archive', iconId: 'archive', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { await journalSetArchived(b.id, true); api.v1.ui.toast('Archived \u2014 removed from context.', { type: 'success' }); await renderJournal(); } } as UIPart
            ]));
            body.push(_aeHudRow([
                { type: 'button', text: 'Rewrite', iconId: 'feather', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runJrnlGen('rewrite', b).catch(function(e) { api.v1.error('[AE:hud] jrnl rewrite:', e); }); } } as UIPart,
                { type: 'button', text: 'Compress', iconId: 'file-minus', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runJrnlGen('compress', b).catch(function(e) { api.v1.error('[AE:hud] jrnl compress:', e); }); } } as UIPart,
                { type: 'button', text: 'Delete', iconId: 'trash', disabled: _aeJrnlBusy, style: { flex: '0 0 auto', margin: 0, fontSize: '11px', color: '#d98a8a' }, callback: async function() { await journalDeleteBubble(b.id); if (_aeJrnlEditingId === b.id) _aeJrnlEditingId = null; api.v1.ui.toast('Deleted.', { type: 'success' }); await renderJournal(); } } as UIPart
            ]));
        }

        return { type: 'box', style: { padding: '8px', marginBottom: '8px', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '8px', opacity: isArchived ? '0.55' : '1', backgroundColor: isArchived ? 'rgba(255,255,255,0.01)' : 'rgba(126,200,160,0.04)' }, content: body } as UIPart;
    }

    async function renderJournal(): Promise<void> {
        const state = await loadJournal();
        const cfg = await loadConfig();
        const active   = state.bubbles.filter(function(b) { return !b.archived; });
        const archived = state.bubbles.filter(function(b) { return b.archived; });
        const parts: UIPart[] = [];

        parts.push(_aeHudInfo('Your running record. Active entries stay Always-On in the lorebook as \u201CThe story so far\u201D, so they survive context. Archived entries are kept but never injected.'));

        // Compose new entry
        parts.push(_aeHudSub('New entry'));
        parts.push({ type: 'multilineTextInput', initialValue: _aeJrnlCompose, placeholder: 'Write what just happened\u2026', onChange: function(v: string) { _aeJrnlCompose = v; }, style: { minHeight: '80px', marginBottom: '6px' } } as UIPart);
        parts.push({ type: 'button', text: 'Add', iconId: 'plus', disabled: _aeJrnlBusy, style: { margin: 0, fontSize: '11px' }, callback: async function() {
            const txt = (_aeJrnlCompose || '').trim();
            if (!txt) { api.v1.ui.toast('Nothing to add.', { type: 'warning' }); return; }
            _aeJrnlCompose = '';
            await journalAddBubble(txt);
            api.v1.ui.toast('Added to journal.', { type: 'success' });
            await renderJournal();
        } } as UIPart);

        // Toolbar: merge-down + archived visibility
        const tools: UIPart[] = [];
        if (active.length > 1) {
            tools.push({ type: 'button', text: 'Merge all', iconId: 'chevrons-down', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() {
                const n = active.length;
                await journalMergeDown();
                _aeJrnlEditingId = null;
                api.v1.ui.toast('Merged ' + n + ' entries into one.', { type: 'success' });
                await renderJournal();
            } } as UIPart);
        }
        if (archived.length > 0) {
            tools.push({ type: 'button', text: (_aeJrnlShowArchived ? 'Hide archived (' + archived.length + ')' : 'Show archived (' + archived.length + ')'), iconId: 'archive', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { _aeJrnlShowArchived = !_aeJrnlShowArchived; await renderJournal(); } } as UIPart);
        }
        if (tools.length > 0) parts.push(_aeHudRow(tools));

        // Active entries
        parts.push(_aeHudSub('Entries (' + active.length + ')'));
        if (active.length === 0) parts.push(_aeHudInfo('No entries yet. Add one above.'));
        else active.forEach(function(b) { parts.push(renderBubble(b, false, cfg)); });

        // Archived entries (optional)
        if (_aeJrnlShowArchived && archived.length > 0) {
            parts.push(_aeHudSub('Archived (' + archived.length + ')'));
            archived.forEach(function(b) { parts.push(renderBubble(b, true, cfg)); });
        }

        parts.push(_aeHudClose(function() { return jHandle; }));
        try { if (jHandle && !jHandle.isClosed()) { await jHandle.update({ content: parts }); return; } } catch (e) {}
        jHandle = await openEngineModal({ id: 'ae-nav-journal', title: 'Journal', size: 'medium', content: parts });
    }

    await renderJournal();
}

// [v2.12.0 CHARJOURNAL] Per-character journal — same interaction model as
// openJournalModal above (compose/edit/archive/merge/rewrite/compress), scoped to
// one character. Own module-level draft vars so opening a character journal never
// clobbers a still-open main journal's draft state.
var _aeCJrnlEditingId: string | null = null;
var _aeCJrnlBusy: boolean = false;
var _aeCJrnlShowArchived: boolean = false;
var _aeCJrnlCompose: string = '';
var _aeCJrnlEditDraft: string = '';

async function openCharJournalModal(charId: string): Promise<void> {
    let cjHandle: any = null;
    const char = await loadCharacter(charId);
    const charName = char ? char.name : 'Character';

    async function runCJrnlGen(kind: string, b: CharJournalBubble): Promise<void> {
        if (_aeCJrnlBusy) return;
        const srcText = (_aeCJrnlEditingId === b.id) ? (_aeCJrnlEditDraft || b.text) : b.text;
        _aeCJrnlBusy = true; _aeCJrnlEditingId = b.id;
        await renderCharJournal();
        let out: string | null = null;
        try { out = (kind === 'rewrite') ? await journalGenerateRewrite(srcText) : await journalGenerateCompress(srcText); }
        catch (e) { api.v1.error('[AE:hud] char journal gen:', e); }
        _aeCJrnlBusy = false;
        if (out) { _aeCJrnlEditDraft = out; api.v1.ui.toast(kind === 'rewrite' ? 'Rewritten \u2014 review and Save.' : 'Compressed \u2014 review and Save.', { type: 'success' }); }
        else { api.v1.ui.toast('Generation failed or returned nothing.', { type: 'error' }); }
        await renderCharJournal();
    }

    function renderCJBubble(b: CharJournalBubble, isArchived: boolean): UIPart {
        const editing = _aeCJrnlEditingId === b.id;
        const body: UIPart[] = [];

        if (isArchived) {
            body.push({ type: 'row', style: { marginBottom: '4px' }, content: [
                { type: 'text', text: 'Archived', style: { fontSize: '10px', opacity: '0.6', flex: '1 1 0', alignSelf: 'center' } } as UIPart
            ] } as UIPart);
        }

        if (editing && _aeCJrnlBusy) {
            body.push(_aeHudInfo('Working\u2026'));
        } else if (editing) {
            body.push({ type: 'multilineTextInput', initialValue: _aeCJrnlEditDraft, placeholder: 'Edit this entry\u2026', onChange: function(v: string) { _aeCJrnlEditDraft = v; }, style: { minHeight: '120px', marginBottom: '6px' } } as UIPart);
            body.push(_aeHudRow([
                { type: 'button', text: 'Save', iconId: 'save', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0' }, callback: async function() { await charJournalUpdateBubble(charId, b.id, _aeCJrnlEditDraft); _aeCJrnlEditingId = null; api.v1.ui.toast('Saved.', { type: 'success' }); await renderCharJournal(); } } as UIPart,
                { type: 'button', text: 'Cancel', iconId: 'x', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { _aeCJrnlEditingId = null; await renderCharJournal(); } } as UIPart
            ]));
            body.push(_aeHudRow([
                { type: 'button', text: 'Rewrite', iconId: 'feather', disabled: _aeCJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runCJrnlGen('rewrite', b).catch(function(e) { api.v1.error('[AE:hud] cjrnl rewrite:', e); }); } } as UIPart,
                { type: 'button', text: 'Compress', iconId: 'file-minus', disabled: _aeCJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runCJrnlGen('compress', b).catch(function(e) { api.v1.error('[AE:hud] cjrnl compress:', e); }); } } as UIPart
            ]));
        } else {
            body.push({ type: 'box', style: { maxHeight: '240px', overflowY: 'auto', padding: '8px 10px', backgroundColor: 'rgba(255,255,255,0.03)', border: '1px solid rgba(255,255,255,0.08)', borderRadius: '6px', marginBottom: '6px' }, content: [
                { type: 'text', text: (b.text && b.text.trim()) ? b.text : '(empty)', noTemplate: true, style: { fontSize: '12px', lineHeight: '1.5', whiteSpace: 'pre-wrap', wordBreak: 'break-word' } } as UIPart
            ] } as UIPart);
            body.push(_aeHudRow([
                { type: 'button', text: 'Edit', iconId: 'edit-3', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { _aeCJrnlEditDraft = b.text || ''; _aeCJrnlEditingId = b.id; await renderCharJournal(); } } as UIPart,
                isArchived
                    ? { type: 'button', text: 'Unarchive', iconId: 'refresh', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { await charJournalSetArchived(charId, b.id, false); api.v1.ui.toast('Restored — folds back into the lorebook entry.', { type: 'success' }); await renderCharJournal(); } } as UIPart
                    : { type: 'button', text: 'Archive', iconId: 'archive', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { await charJournalSetArchived(charId, b.id, true); api.v1.ui.toast('Archived \u2014 removed from the lorebook entry.', { type: 'success' }); await renderCharJournal(); } } as UIPart
            ]));
            body.push(_aeHudRow([
                { type: 'button', text: 'Rewrite', iconId: 'feather', disabled: _aeCJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runCJrnlGen('rewrite', b).catch(function(e) { api.v1.error('[AE:hud] cjrnl rewrite:', e); }); } } as UIPart,
                { type: 'button', text: 'Compress', iconId: 'file-minus', disabled: _aeCJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runCJrnlGen('compress', b).catch(function(e) { api.v1.error('[AE:hud] cjrnl compress:', e); }); } } as UIPart,
                { type: 'button', text: 'Delete', iconId: 'trash', disabled: _aeCJrnlBusy, style: { flex: '0 0 auto', margin: 0, fontSize: '11px', color: '#d98a8a' }, callback: async function() { await charJournalDeleteBubble(charId, b.id); if (_aeCJrnlEditingId === b.id) _aeCJrnlEditingId = null; api.v1.ui.toast('Deleted.', { type: 'success' }); await renderCharJournal(); } } as UIPart
            ]));
        }

        return { type: 'box', style: { padding: '8px', marginBottom: '8px', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '8px', opacity: isArchived ? '0.55' : '1', backgroundColor: isArchived ? 'rgba(255,255,255,0.01)' : 'rgba(126,200,160,0.04)' }, content: body } as UIPart;
    }

    async function renderCharJournal(): Promise<void> {
        const state = await loadCharJournal(charId);
        const active   = state.bubbles.filter(function(b) { return !b.archived; });
        const archived = state.bubbles.filter(function(b) { return b.archived; });
        const parts: UIPart[] = [];

        parts.push(_aeHudInfo('Active entries fold into ' + charName + '\u2019s own lorebook entry as running notes (toggle in World Settings \u2192 Lorebook Additions). Archived entries are kept but excluded. Nothing is auto-summarized — merge or archive as you see fit.'));

        parts.push(_aeHudSub('New entry'));
        parts.push({ type: 'multilineTextInput', initialValue: _aeCJrnlCompose, placeholder: 'Write a note for ' + charName + '\u2026', onChange: function(v: string) { _aeCJrnlCompose = v; }, style: { minHeight: '80px', marginBottom: '6px' } } as UIPart);
        parts.push({ type: 'button', text: 'Add', iconId: 'plus', disabled: _aeCJrnlBusy, style: { margin: 0, fontSize: '11px' }, callback: async function() {
            const txt = (_aeCJrnlCompose || '').trim();
            if (!txt) { api.v1.ui.toast('Nothing to add.', { type: 'warning' }); return; }
            _aeCJrnlCompose = '';
            await charJournalAddBubble(charId, txt);
            api.v1.ui.toast('Added.', { type: 'success' });
            await renderCharJournal();
        } } as UIPart);

        const tools: UIPart[] = [];
        if (active.length > 1) {
            tools.push({ type: 'button', text: 'Merge all', iconId: 'chevrons-down', disabled: _aeCJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() {
                const n = active.length;
                await charJournalMergeDown(charId);
                _aeCJrnlEditingId = null;
                api.v1.ui.toast('Merged ' + n + ' entries into one.', { type: 'success' });
                await renderCharJournal();
            } } as UIPart);
        }
        if (archived.length > 0) {
            tools.push({ type: 'button', text: (_aeCJrnlShowArchived ? 'Hide archived (' + archived.length + ')' : 'Show archived (' + archived.length + ')'), iconId: 'archive', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { _aeCJrnlShowArchived = !_aeCJrnlShowArchived; await renderCharJournal(); } } as UIPart);
        }
        if (tools.length > 0) parts.push(_aeHudRow(tools));

        parts.push(_aeHudSub('Entries (' + active.length + ')'));
        if (active.length === 0) parts.push(_aeHudInfo('No entries yet. Add one above.'));
        else active.forEach(function(b) { parts.push(renderCJBubble(b, false)); });

        if (_aeCJrnlShowArchived && archived.length > 0) {
            parts.push(_aeHudSub('Archived (' + archived.length + ')'));
            archived.forEach(function(b) { parts.push(renderCJBubble(b, true)); });
        }

        parts.push(_aeHudClose(function() { return cjHandle; }));
        try { if (cjHandle && !cjHandle.isClosed()) { await cjHandle.update({ content: parts }); return; } } catch (e) {}
        cjHandle = await openEngineModal({ id: 'ae-char-journal', title: charName + ' \u2014 Journal', size: 'medium', content: parts });
    }

    await renderCharJournal();
}

// ============================================================================
// LIVE CHAT TAB  —  buildLiveChatTab()  [v2.5.0 CE-CHATS]
//
// The in-document wizard chat's control surface, rendered as the "Live Chat" tab
// INSIDE the existing World-Build Wizard modal (openWizardModal). Reached from the
// native "Wizard" toolbar button or the sidebar. Two states:
//   inactive -> pick a persona (+ optional Always-On context) and start, OR resume
//               a saved chat pulled from the CE Chats lorebook category;
//   active   -> Summarize->Preview (editable, save to lorebook), Save & Close,
//               Discard, plus live Always-On context toggles.
// It renders into the host modal's content and refreshes through the modal's own
// redraw() (passed in as 'refresh'); persona-pick / resume close the modal first
// (via 'closeModal') so start's toast + decorations aren't stacked under it.
// ============================================================================
var _wizModalPreview: string = '';   // last summary preview text ('' = none shown)
var _wizModalCtxPick: any = {};      // { entryId: true } — context preselected for a not-yet-started chat
var _wizDiscardArmed: boolean = false;   // [v2.5.0] two-tap guard for Discard (no window.confirm in the Worker)
var _wizDiscardTimer: any = null;

async function _wizPickPersonaAndStart(closeModal: () => Promise<void>): Promise<void> {
    let cfg = await loadConfig();
    let topics = ((cfg as any).wizardTopics && (cfg as any).wizardTopics.length) ? (cfg as any).wizardTopics : DEFAULT_WIZARD_TOPICS;
    let ctx = Object.keys(_wizModalCtxPick);
    try { await closeModal(); } catch (_e) {}
    await openPickerModal({
        title: 'Choose a wizard persona',
        items: topics,
        getId: function(t: any) { return t.id; },
        getLabel: function(t: any) { return t.label; },
        getSublabel: function(t: any) { return (t.commitKind === 'concept') ? 'general' : ''; },
        searchable: true,
        pinnedOptions: [ { id: '__generic__', label: 'General worldbuilding', icon: '\u2728', onSelect: async function() { await startLiveWizardChat('', ctx); _wizModalCtxPick = {}; } } ],
        onSelect: async function(t: any) { await startLiveWizardChat(t.id, ctx); _wizModalCtxPick = {}; }
    });
}

async function buildLiveChatTab(refresh: () => Promise<void>, closeModal: () => Promise<void>): Promise<UIPart[]> {
    let parts: UIPart[] = [];
    let entries = await listWizChatEntries();

    if (_aeLiveWiz.active) {
        parts.push({ type: 'text', text: 'A wizard chat is live in your story, below the violet marker. Write in a new paragraph and press Send \u2014 no need to type curly braces, they\u2019re added for you. Blue paragraphs are your directions; violet are the wizard\u2019s. Close it here when you\u2019re done.', style: { fontSize: '12px', opacity: '0.85', marginBottom: '10px' } });
        // [v2.6.0] Renameable chat title, mirroring the classic wizard chat's 'Chat Name'
        // field. Defaults to the topic picked at start; never auto-stamped with a date.
        parts.push({ type: 'textInput', label: 'Chat name', initialValue: _aeLiveWiz.title || '', style: { marginBottom: '8px' }, onChange: async function(v: string) { _aeLiveWiz.title = v; await saveLiveWizState(); } });

        if (entries.length > 0) {
            let ctxRows: UIPart[] = [];
            for (let i = 0; i < entries.length; i++) {
                let e = entries[i];
                ctxRows.push({
                    type: 'checkboxInput',
                    label: (e.displayName || 'Untitled chat'),
                    initialValue: !!e.forceActivation,
                    onChange: (function(id) { return async function(v: boolean) {
                        try {
                            await setContextEntriesActivation([id], v);
                            if (v) { if (_aeLiveWiz.contextEntryIds.indexOf(id) < 0) _aeLiveWiz.contextEntryIds.push(id); }
                            else { _aeLiveWiz.contextEntryIds = _aeLiveWiz.contextEntryIds.filter(function(x) { return x !== id; }); }
                            await saveLiveWizState();
                        } catch (err) { api.v1.error('[AE:wizlive] live ctx toggle:', err); }
                    }; })(e.id)
                });
            }
            parts.push({ type: 'collapsibleSection', title: 'Context lorebooks (Always-On this session)', initialCollapsed: true, content: ctxRows });
        }

        if (_wizModalPreview) {
            parts.push({ type: 'multilineTextInput', label: 'Summary preview \u2014 edit, then save to the lorebook', initialValue: _wizModalPreview, onChange: function(v: string) { _wizModalPreview = v; }, style: { minHeight: '130px', marginTop: '8px' } });
            parts.push({ type: 'button', text: 'Save summary to CE Chats', style: { width: '100%', marginTop: '4px', backgroundColor: 'rgba(126,200,160,0.18)', border: '1px solid rgba(126,200,160,0.4)' }, disabledWhileCallbackRunning: true, callback: async function() {
                try {
                    let title = ((_aeLiveWiz.title || '').trim() || 'Wizard Chat') + ' \u2014 Summary';
                    await upsertChatEntry(null, title, [{ role: 'assistant', content: _wizModalPreview }], _aeLiveWiz.topicId);
                    api.v1.ui.toast('Summary saved to the CE Chats lorebook.', { type: 'success', autoClose: 3000 });
                    _wizModalPreview = '';
                    await refresh();
                } catch (e) { api.v1.error('[AE:wizlive] save summary:', e); api.v1.ui.toast('Could not save the summary.', { type: 'error', autoClose: 4000 }); }
            } });
        }

        parts.push({ type: 'text', text: '\u2500\u2500\u2500', style: { opacity: '0.2', textAlign: 'center', marginTop: '8px', marginBottom: '6px' } });
        parts.push({ type: 'button', text: 'Summarize \u2192 Preview', style: { width: '100%', marginBottom: '4px' }, disabledWhileCallbackRunning: true, callback: async function() {
            try {
                api.v1.ui.toast('Summarizing the chat\u2026', { type: 'info', autoClose: 2500 });
                let s = await previewSummarizeLiveChat();
                if (s) { _wizModalPreview = s; await refresh(); }
                else api.v1.ui.toast('Nothing to summarize yet \u2014 send a turn first.', { type: 'warning', autoClose: 3500 });
            } catch (e) { api.v1.error('[AE:wizlive] summarize preview:', e); api.v1.ui.toast('Summarize failed \u2014 try again.', { type: 'error', autoClose: 4000 }); }
        } });
        parts.push({ type: 'button', text: 'Save & Close', style: { width: '100%', marginBottom: '4px', backgroundColor: 'rgba(126,200,160,0.2)', border: '1px solid rgba(126,200,160,0.45)', fontWeight: '600' }, disabledWhileCallbackRunning: true, callback: async function() {
            await endLiveWizardChat('save'); _wizModalPreview = ''; await refresh();
        } });
        parts.push({ type: 'button', text: _wizDiscardArmed ? 'Tap again to discard \u2014 the chat is deleted, not saved' : 'Discard chat', style: { width: '100%', backgroundColor: _wizDiscardArmed ? 'rgba(220,110,110,0.35)' : 'rgba(220,110,110,0.15)', border: '1px solid rgba(220,110,110,0.5)', fontWeight: _wizDiscardArmed ? '600' : 'normal' }, disabledWhileCallbackRunning: true, callback: async function() {
            if (!_wizDiscardArmed) {
                _wizDiscardArmed = true;
                // [BUGFIX v2.19.1] Bare setTimeout/clearTimeout don't exist in the Worker
                // sandbox -- this was the only setTimeout call anywhere in the file. The
                // clearTimeout below was already try/caught so it no-opped harmlessly, but
                // the setTimeout call that followed it was NOT guarded, so it threw a
                // ReferenceError that silently rejected this callback's promise before
                // _wizDiscardArmed's flip ever reached a refresh() -- the button visibly did
                // nothing. api.v1.timers.setTimeout/clearTimeout are the sandbox-safe
                // equivalents (both async, per script-types.txt).
                if (_wizDiscardTimer) { try { await api.v1.timers.clearTimeout(_wizDiscardTimer); } catch (_eT) {} }
                _wizDiscardTimer = await api.v1.timers.setTimeout(function() { _wizDiscardArmed = false; refresh().catch(function() {}); }, 4000);
                await refresh();
                return;
            }
            if (_wizDiscardTimer) { try { await api.v1.timers.clearTimeout(_wizDiscardTimer); } catch (_eT2) {} _wizDiscardTimer = null; }
            _wizDiscardArmed = false;
            await endLiveWizardChat('discard'); _wizModalPreview = ''; await refresh();
        } });
    } else {
        parts.push({ type: 'text', text: 'Start a wizard chat that lives right in your story document. Pick a persona and it drops in below a marker \u2014 write in a new paragraph and press Send, no need to type curly braces yourself. Saved chats live in the \u201cCE Chats\u201d lorebook category: resume them here, or switch them on as Always-On context for a chat or a batch generator.', style: { fontSize: '12px', opacity: '0.85', marginBottom: '10px' } });

        if (entries.length > 0) {
            let ctxRows: UIPart[] = [];
            for (let i = 0; i < entries.length; i++) {
                let e = entries[i];
                ctxRows.push({
                    type: 'checkboxInput',
                    label: (e.displayName || 'Untitled chat'),
                    initialValue: !!_wizModalCtxPick[e.id],
                    onChange: (function(id) { return function(v: boolean) { if (v) _wizModalCtxPick[id] = true; else delete _wizModalCtxPick[id]; }; })(e.id)
                });
            }
            parts.push({ type: 'collapsibleSection', title: 'Include saved chats as context (optional)', initialCollapsed: true, content: ctxRows });
        }

        parts.push({ type: 'button', text: 'Choose persona \u2192 Start chat', style: { width: '100%', marginTop: '4px', marginBottom: '4px', backgroundColor: 'rgba(147,112,219,0.2)', border: '1px solid rgba(147,112,219,0.45)', fontWeight: '600' }, callback: async function() { await _wizPickPersonaAndStart(closeModal); } });

        if (entries.length > 0) {
            parts.push({ type: 'text', text: 'Resume a saved chat', style: { fontWeight: '600', fontSize: '12px', marginTop: '10px', marginBottom: '4px' } });
            for (let i = 0; i < entries.length; i++) {
                let e = entries[i];
                parts.push({ type: 'button', text: '\u21ba ' + (e.displayName || 'Untitled chat'), style: { width: '100%', textAlign: 'left', marginBottom: '2px', fontSize: '12px', backgroundColor: 'rgba(255,255,255,0.04)', border: '1px solid rgba(255,255,255,0.08)' }, callback: (function(id) { return async function() {
                    try { await closeModal(); } catch (_e) {}
                    await resumeLiveWizardChatFromEntry(id);
                }; })(e.id) });
            }
        } else {
            parts.push({ type: 'text', text: 'No saved chats yet \u2014 start one above and Save & Close to bank it here.', style: { fontSize: '11px', opacity: '0.55', marginTop: '8px' } });
        }
    }

    return parts;
}

// ── Registration + mode switch ─────────────────────────────────────────────────
// Builds the script UI extension set (sidebar panel + optional toolbar tray) from
// the current cfg.interfaceMode and registers it. Re-callable to apply a mode change.
async function registerEngineUI(): Promise<void> {
    let cfg = await loadConfig();
    let mode = (cfg as any).interfaceMode || 'native';
    let ext: any[] = [
        { type: 'sidebarPanel', id: 'ce-panel', name: 'Adventure', iconId: 'compass', content: [{ type: 'text', text: 'Loading\u2026' }] }
    ];
    // [v2.5.0 CE-CHATS] World-Build Wizard button opens the wizard modal (landing on the
    // Live Chat tab). Pushed before the native/both gate so bridge-only users still get it.
    ext.push({ type: 'toolbarButton', id: 'ae-tb-wizard', text: 'Wizard', iconId: 'star', callback: function() { openWizardModal().catch(function(e) { api.v1.error('[AE:hud] wizard:', e); }); } });
    // [v2.21.0 CHARCHAT] Entry point for the in-story character chat. Outside the
    // native/both gate for the same reason as Wizard above: bridge-only users need a way
    // in too, and the bridge HUD panel for this is P6.
    ext.push({ type: 'toolbarButton', id: 'ae-tb-charchat', text: 'Chat', iconId: 'message-circle', callback: function() { openCharChatPicker().catch(function(e) { api.v1.error('[AE:hud] charchat:', e); }); } });
    if (mode === 'native' || mode === 'both') {
        ext.push({ type: 'toolbarButton', id: 'ae-tb-map',     text: 'Map',     iconId: 'map',     callback: function() { openMapModal().catch(function(e) { api.v1.error('[AE:hud] map:', e); }); } });
        ext.push({ type: 'toolbarButton', id: 'ae-tb-inspect', text: 'Inspect', iconId: 'search',  callback: function() { openInspectModal().catch(function(e) { api.v1.error('[AE:hud] inspect:', e); }); } });
        ext.push({ type: 'toolbarButton', id: 'ae-tb-roster',  text: 'Roster',  iconId: 'users',   callback: function() { launchWorkspace('roster').catch(function(e) { api.v1.error('[AE:hud] roster:', e); }); } });
        ext.push({ type: 'toolbarButton', id: 'ae-tb-journal', text: 'Journal', iconId: 'book',    callback: function() { openJournalModal().catch(function(e) { api.v1.error('[AE:hud] journal:', e); }); } });
    }
    await api.v1.ui.register(ext);
}

// [v0.9.9.5] Set a specific HUD mode (native | bridge | both) and re-register UI.
async function setInterfaceMode(mode: string): Promise<void> {
    try {
        if (mode !== 'native' && mode !== 'bridge' && mode !== 'both') mode = 'bridge';
        let cfg = await loadConfig();
        if (((cfg as any).interfaceMode || 'native') === mode) return;
        (cfg as any).interfaceMode = mode;
        await saveConfig(cfg);
        await registerEngineUI();
        await refreshSidebar();
        api.v1.ui.toast('HUD mode: ' + mode, { type: 'info', autoClose: 1500 });
    } catch (e) { api.v1.error('[AE:hud] setInterfaceMode:', e); }
}

// Cycles bridge -> native -> both -> bridge and re-registers the UI immediately.
async function cycleInterfaceMode(): Promise<void> {
    try {
        let cfg = await loadConfig();
        let cur = (cfg as any).interfaceMode || 'native';
        let next = (cur === 'bridge') ? 'native' : ((cur === 'native') ? 'both' : 'bridge');
        (cfg as any).interfaceMode = next;
        await saveConfig(cfg);
        await registerEngineUI();
        await refreshSidebar();
        api.v1.ui.toast('HUD mode: ' + next, { type: 'info', autoClose: 1800 });
    } catch (e) { api.v1.error('[AE:hud] cycleInterfaceMode:', e); }
}

api.v1.hooks.register('onScriptsLoaded', async function() {
    try {
        // 1. Register NAI UI: sidebar panel + (when cfg.interfaceMode is native/both)
        //    the native toolbar HUD tray. Bridge mode registers the panel only.
        await registerEngineUI();

        // 2. Permissions
        await api.v1.permissions.request(['fileInput', 'fileDownload', 'lorebookEdit', 'storyEdit', 'documentEdit', 'editorDecorations']);
        await api.v1.timers.sleep(300);

        // 3. [CHANGE] Load image settings before bridge connects so auto-snap is ready.
        await loadImageSettings();

        // 3b. [v0.9.7.9] Lorebook world-pack auto-import. Runs only when storyStorage
        //     has no config (fresh story created from a packed scenario). Non-destructive:
        //     existing stories are always skipped. Runs before bridge handshake so the
        //     first SCENE_STATE_UPDATE already reflects the imported world.
        try { await loadConfigFromLorebook(); } catch (eLcInit) { api.v1.log('[AE:pack] init import error:', eLcInit); }

        // 4. [CHANGE] Pre-seed cachedCharVisuals from storage so getCharacterData() works
        //    immediately on the first generation, even before bridge handshake completes.
        await buildCharacterDataPayload();

        // 5. [CHANGE] initMessaging() — sends HANDSHAKE_REQUEST to bridge. When bridge
        //    ACKs, handleBridgeMessage → broadcastCharacterData + broadcastSceneState.
        await initMessaging();

        // 5b. [v2.4.0 WIZLIVE] Rehydrate an in-document wizard chat left open in this
        //     story (marker re-verified against the live document; stale state cleared).
        try { await restoreLiveWizOnStartup(); } catch (eLw) { api.v1.log('[AE:wizlive] startup restore error:', eLw); }

        // 5c. [v2.21.0 CHARCHAT] Same rehydration contract for an in-story character chat
        //     (marker re-verified against the live document; stale state cleared and the
        //     pinned max_tokens restored — a stranded 120-token cap would otherwise
        //     silently truncate every story generation).
        try { await restoreCharChatOnStartup(); } catch (eCc) { api.v1.log('[AE:charchat] startup restore error:', eCc); }

        // 6. Story init path
        const rawIndex = await api.v1.storyStorage.get(STORAGE_INDEX);
        const isFreshStory = !rawIndex || (Array.isArray(rawIndex) && (rawIndex as any[]).length === 0);

        // [BUGFIX v2.3.3] refreshSidebar() used to live inside the isFreshStory
        // branch below, so it only ever ran on a brand-new story. registerEngineUI()
        // (step 1 above) registers the ce-panel sidebarPanel with a hardcoded
        // '{ type: "text", text: "Loading…" }' placeholder as its initial content —
        // refreshSidebar() -> buildSidebar() is what's supposed to replace that with
        // the real panel. For every returning/existing story, nothing ever called
        // it, so the native sidebar was stuck on the literal placeholder forever.
        // Moved out here so it always runs regardless of freshness; only the
        // fresh-story-specific migration kick stays gated below.
        await refreshSidebar();

        if (isFreshStory) {
            queueSceneStateBroadcast();

            // 6b. [UNIFY] One-time migration of faction-standing args on entity-attached
            // action instances (action TEMPLATES are already migrated on every loadConfig
            // call above). Only relevant for existing stories — a fresh one has no entities
            // yet. Gated internally by a storyStorage flag so it only ever runs once.
            try { await migrateFactionArgsOnEntities(await loadConfig()); } catch (eFacMig) { api.v1.log('[AE:migrate] entity faction-arg migration skipped:', eFacMig); }
        }

        api.v1.log('[AE] Adventure Engine initialized.');
    } catch (e) {
        api.v1.error('[AE] Init error:', e);
    }
});
