var OLD_NPC_TEMPLATE_V28 = "[|name|][ — |relArchetype|, |relStage|][ with |primaryRelationship.targetName|][ (|conditionStates|)][. Goal: |midRange.currentDesire|][. Thinking: |ephemeral.compressedLine|]";

