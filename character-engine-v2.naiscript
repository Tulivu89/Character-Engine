    { label: 'Landscape', w: 1216, h: 832  },
    { label: 'Square',    w: 1024, h: 1024 }
];

// ── Emotion Constants (used by image generation pipeline and direct chat) ─────

var ALL_EMOTIONS_LIST = 'neutral, happy, excited, laughing, love, sad, hurt, worried, scared,'
    + ' nervous, angry, irritated, disgusted, surprised, embarrassed, shy, smug, playful,'
    + ' confused, thinking, determined, tired, bored, aroused';

// Normalises freeform emotion words from model output to the canonical 24-state list.
// Used by resolveEmotion() in Section 4.
var EMOTION_MAP: Record<string, string> = {
    happy:'happy', joyful:'happy', pleased:'happy', glad:'happy', delighted:'happy', cheerful:'happy', content:'happy', elated:'happy',
    excited:'excited', thrilled:'excited', eager:'excited', enthusiastic:'excited', pumped:'excited', giddy:'excited',
    laughing:'laughing', amused:'laughing', giggling:'laughing', chuckling:'laughing', jovial:'laughing',
    love:'love', loving:'love', affectionate:'love', adoring:'love', fond:'love', tender:'love', warm:'love',
    sad:'sad', unhappy:'sad', sorrowful:'sad', miserable:'sad', heartbroken:'sad', melancholic:'sad', melancholy:'sad', dejected:'sad', gloomy:'sad', despondent:'sad',
    hurt:'hurt', wounded:'hurt', pained:'hurt', stung:'hurt', aching:'hurt',
    worried:'worried', anxious:'worried', concerned:'worried', uneasy:'worried', apprehensive:'worried', fretful:'worried',
    scared:'scared', afraid:'scared', frightened:'scared', terrified:'scared', fearful:'scared', petrified:'scared',
    nervous:'nervous', tense:'nervous', jittery:'nervous', edgy:'nervous',
    angry:'angry', mad:'angry', furious:'angry', enraged:'angry', livid:'angry', irate:'angry', outraged:'angry', wrathful:'angry',
    irritated:'irritated', annoyed:'irritated', frustrated:'irritated', aggravated:'irritated', vexed:'irritated', exasperated:'irritated',
    disgusted:'disgusted', revolted:'disgusted', repulsed:'disgusted', appalled:'disgusted',
    surprised:'surprised', shocked:'surprised', astonished:'surprised', startled:'surprised', stunned:'surprised', dumbfounded:'surprised',
    embarrassed:'embarrassed', ashamed:'embarrassed', flustered:'embarrassed', mortified:'embarrassed', abashed:'embarrassed',
    shy:'shy', bashful:'shy', timid:'shy', reserved:'shy', coy:'shy',
    smug:'smug', self_satisfied:'smug', superior:'smug', haughty:'smug',
    playful:'playful', mischievous:'playful', teasing:'playful', cheeky:'playful', flirty:'playful', impish:'playful',
    confused:'confused', puzzled:'confused', perplexed:'confused', bewildered:'confused', baffled:'confused',
    thinking:'thinking', contemplative:'thinking', pensive:'thinking', reflective:'thinking', pondering:'thinking', thoughtful:'thinking',
    determined:'determined', resolute:'determined', focused:'determined', driven:'determined', intent:'determined', steadfast:'determined',
    tired:'tired', exhausted:'tired', weary:'tired', drained:'tired', sleepy:'tired', fatigued:'tired',
    bored:'bored', uninterested:'bored', listless:'bored', apathetic:'bored',
    aroused:'aroused', captivated:'aroused', drawn:'aroused', attracted:'aroused',
    neutral:'neutral', calm:'neutral', composed:'neutral', stoic:'neutral'
};

// ── Default Values ────────────────────────────────────────────────────────────

// [v2.19.0 WIZARD-2.0] Starter world-canon sections, rewritten POV/genre-agnostic
// (the old set assumed a second-person text-adventure with a player-protagonist).
// Memory-target sections assemble into the static Memory block IN LIST ORDER; the two
// AN-target sections (ATTG, Style) sit last and assemble into the Author's Note
// (visually lower in context). This is the default output order — users reorder freely
// in the Memory tab. Sections past Central Conflict start disabled.
var DEFAULT_WIZARD_SECTIONS: WizardMemorySection[] = [
    { id: 'wsec_premise', label: 'Premise', enabled: true, content: '', target: 'memory',
      instructions: 'Write ONE sentence \u2014 the story\'s logline: who the central figure is, the situation they are in, and what is at stake. Specific to this story, not a theme and not a question. Do not assume a point of view or address the reader. Register to aim for: "A disgraced navigator hired to chart waters her old commander declared unmappable." "A woman who stayed in the house after the divorce because leaving would mean admitting it mattered."' },
    { id: 'wsec_setting', label: 'Setting', enabled: true, content: '', target: 'memory',
      instructions: 'State the world, place, and era the story sits in, and the scope it occupies within that world. The facts of the stage \u2014 not plot, not characters, not theme. One or two sentences.' },
    { id: 'wsec_themes', label: 'Themes', enabled: true, content: '', target: 'memory',
      instructions: 'Name the emotional register and the throughlines the story keeps returning to. Abstractions, not events. Do not restate the setting or describe specific characters.' },
    { id: 'wsec_conflict', label: 'Central Conflict', enabled: true, content: '', target: 'memory',
      instructions: 'Describe the opposing forces and what is contested between them \u2014 the shape of the pressure, not its resolution and not the individual beats.' },
    { id: 'wsec_worldrules', label: 'World Rules', enabled: false, content: '', target: 'memory',
      instructions: 'Describe how this world works where it departs from the ordinary: the powers, technologies, or social orders in play, what they make possible, and what they cost. Rules, not instances.' },
    { id: 'wsec_intimacy', label: 'Intimacy and Consequences', enabled: false, content: '', target: 'memory',
      instructions: 'Describe how attraction, desire, and intimacy operate in this world and what tends to follow from them \u2014 the tone and the stakes of closeness, not a specific pairing.' },
    { id: 'wsec_danger', label: 'Danger and Consequences', enabled: false, content: '', target: 'memory',
      instructions: 'Describe how harm, violence, and danger operate in this world and what their aftermath looks like \u2014 how lethal, how lasting, how the narrative treats it. Not a specific confrontation.' },
    { id: 'wsec_stakes', label: 'Stakes', enabled: false, content: '', target: 'memory',
      instructions: 'Describe what can be won or lost at the largest scale this story reaches \u2014 the weight on the scales, not the mechanics or the plot beats.' },
    { id: 'wsec_attg', label: 'ATTG', enabled: true, content: '', target: 'an',
      instructions: 'Output ONLY a single ATTG line, enclosed in spaced brackets, in exactly this form: [ Author: <name>; Title: <title>; Tags: <comma-separated tags>; Genre: <genre> ]. Pick a well-known author whose sensibility fits this story. Output only the bracketed line \u2014 no heading, no commentary, no markdown.' },
    { id: 'wsec_style', label: 'Style', enabled: true, content: '', target: 'an',
      instructions: 'Describe the narrative voice, beginning with a two-author tonal anchor: name two authors whose combined sensibilities capture this story\'s voice, matched to emotional register and prose style rather than surface genre, the pairing set in productive tension. Then describe the resulting voice concretely: sentence rhythm, level of description, use of interiority, how the prose handles emotion. Under 100 words. No markdown.' }
];

// [v2.19.0 WIZARD-2.0] Starter topic registry. 'Initial Concept' is the general rolling
// chat that feeds context to the rest; 'World Memory' develops the canon and fans out to
// the Memory sections on commit; 'Style & Voice' develops the Author's Note voice. Entity-
// producing topics (Species, Factions, Locations, Characters, ...) follow. Instructions
// are POV/genre-agnostic and deliberately non-railroading: guide, don't dictate.
var DEFAULT_WIZARD_TOPICS: WizardTopic[] = [
    { id: 'wtopic_concept', label: 'Initial Concept', commitKind: 'concept',
      seedMessage: 'This chat shapes your story\'s foundation \u2014 the title, genre, and central premise everything else will stand on. Bring whatever you have, even a stray image or a single line, and we\'ll sharpen it together. What\'s the core idea you\'re starting from?',
      instructions: 'You are a narrative designer acting as a sounding board, helping the user develop a story\'s core concept \u2014 its title, genre, and central premise \u2014 into a cohesive foundation the rest of the world can stand on.\n\nWrite in plain prose \u2014 no markdown, headers, or lists. Keep a warm, collaborative tone; you are a creative partner, not a gatekeeper. Build on the user\'s idea with a concrete suggestion or two that push the premise forward, and follow their lead rather than steering toward any particular genre or tone. Usually ask one focused question at a time.\n\nTypically respond in 2-5 sentences; a short paragraph is fine when drawing several threads together.' },
    { id: 'wtopic_memory', label: 'World Memory', commitKind: 'memoryFanout',
      seedMessage: 'This chat builds the permanent facts of your world \u2014 the premise, the setting and its scope, the themes it keeps returning to, and the conflict driving everything. Once something lands here it becomes canon that holds steady for the whole story. Where should we start \u2014 the premise, or the shape of the conflict?',
      instructions: 'You are a world-builder helping the user define the static canon of their story \u2014 the permanent memory block. Its sections may include the premise (a one-sentence logline of the central figure, their situation, and what is at stake), the setting and its scope, the core themes, the central conflict, and optional world rules, intimacy, danger, and stakes. The story may be any genre and any point of view; do not assume a player-protagonist or a second-person frame.\n\nWrite in plain prose \u2014 no markdown, headers, or lists. Keep a warm, collaborative tone. Favour durable facts, throughlines, and world rules over plot events or character arcs. If an idea is vague, offer a couple of concrete directions to react to. Usually ask one focused question at a time.\n\nTypically respond in 2-5 sentences; a short paragraph is fine when drawing several threads together.' },
    { id: 'wtopic_style', label: 'Style & Voice', commitKind: 'memoryFanout',
      seedMessage: 'This chat sets the narrative voice for your Author\'s Note \u2014 tense, perspective, tone, pacing, prose density, and the authors whose sensibilities you\'re reaching for. Describe the reading experience you\'re after, even loosely, and we\'ll pin it down. What\'s the voice you\'re hearing?',
      instructions: 'You are a prose stylist helping the user define the narrative voice for the Author\'s Note \u2014 tense, perspective, tone, pacing, and density.\n\nWrite in plain prose \u2014 no markdown, headers, or lists. Keep a warm, collaborative tone. Talk about writing mechanics rather than story content. A strong anchor is naming one or two authors whose combined sensibilities capture the voice \u2014 matched to emotional register and prose style, not surface genre \u2014 then describing the concrete result: sentence rhythm, description density, interiority, how the prose handles emotion. If the user\'s description is broad (e.g. "dark"), offer a few specific techniques or authorial blends to react to. Usually ask one focused question at a time.\n\nTypically respond in 2-5 sentences; a short paragraph is fine when drawing several threads together.' },
    { id: 'wtopic_species', label: 'Species', commitKind: 'speciesBatch',
      seedMessage: 'This chat designs the species, peoples, or creature-types living in your world \u2014 what makes each one fundamentally distinct, not just differently dressed. Tell me about one you already picture, however roughly. What\'s the first one?',
      instructions: 'You are helping the user design distinct species, peoples, or creature-types, each of which becomes a structured lorebook entry.\n\nWrite in plain prose \u2014 no markdown, headers, or lists. Keep a warm, collaborative tone. Look for what makes a species fundamentally distinct: anatomy, inherent cultural drives, and its role in the world. If an idea leans on a familiar trope, offer a stranger or more grounded angle to react to rather than just flagging it. Usually ask one focused question at a time.\n\nTypically respond in 2-5 sentences; a short paragraph is fine when drawing several threads together.' },
    { id: 'wtopic_factions', label: 'Factions', commitKind: 'factionsBatch',
      seedMessage: 'This chat builds the factions, organizations, and power structures shaping your world \u2014 what each one claims to want, and what\'s actually driving it underneath. Tell me about a group with real stake in how things turn out. Who\'s the first one?',
      instructions: 'You are helping the user design factions, organizations, and power structures, each of which becomes a structured lorebook entry.\n\nWrite in plain prose \u2014 no markdown, headers, or lists. Keep a warm, collaborative tone. Dig into the gap between a faction\'s stated goals and its private realities, methods, and tensions. If a group reads as flatly good or evil, help find its legitimate claims and real flaws with a specific angle to react to. Usually ask one focused question at a time.\n\nTypically respond in 2-5 sentences; a short paragraph is fine when drawing several threads together.' },
    { id: 'wtopic_locations', label: 'Locations', commitKind: 'locationsBatch',
      seedMessage: 'This chat maps the places in your world, from sweeping regions down to single rooms, pairing what a person senses on arrival with the deeper history behind it. Tell me about one place, at whatever scale feels right. Where should we begin?',
      instructions: 'You are helping the user map their setting: specific locations, their scale (region, settlement, or a single room), the immediate scene-present view, and the deeper background lore for the lorebook.\n\nWrite in plain prose \u2014 no markdown, headers, or lists. Keep a warm, collaborative tone. For each place, draw out two layers: (A) the immediate description \u2014 one or two sentences of what is physically sensed on arrival, at whatever scale the place is \u2014 and (B) the hidden history, culture, or systems reserved for the lorebook entry. Keep the two from duplicating each other. Usually ask one focused question at a time, drilling into scale, atmosphere, or connections.\n\nTypically respond in 2-5 sentences; a short paragraph is fine when drawing several threads together.' },
    { id: 'wtopic_characters', label: 'Characters', commitKind: 'charactersBatch',
      seedMessage: 'This chat builds a character\'s static identity \u2014 who they are at a glance, their physical presence, and what shaped them. We\'ll work through one detail at a time rather than all at once. Who\'s the character, and what\'s the first thing you see when you picture them?',
      instructions: 'You are workshopping a character with the user \u2014 their static baseline: name, age, gender, species, role, a tight one-sentence summary, a physical scene-present description, core contradictions, voice and mannerisms, and formative background.\n\nWrite in plain prose \u2014 no markdown, headers, or lists. Keep a warm, collaborative tone. Work one detail at a time rather than asking for every field at once. If something feels flat, offer a concrete, sensory, or grounded alternative to react to. Keep to static identity \u2014 momentary feelings, immediate goals, and shifting relationships belong in other chats. Usually ask one focused question at a time.\n\nTypically respond in 2-5 sentences; a short paragraph is fine when drawing several threads together.' },
    { id: 'wtopic_drama', label: 'Drama & Tension', commitKind: 'dramaSeed',
      seedMessage: 'This chat seeds the tensions your story runs on \u2014 the debts, secrets, and wants tying your established characters together. We\'re sharpening dynamics between who and what already exists, not inventing new people. What\'s a relationship or thread you want to charge with stakes?',
      instructions: 'You are a dramaturg helping the user seed the dramatic engine: the tensions characters carry, the charged dynamics between them, and the threads that drive the story.\n\nWrite in plain prose \u2014 no markdown, headers, or lists. Keep a warm, collaborative tone. Work with the established cast rather than introducing new named people, and tie each tension to a specific person, debt, secret, or want with concrete stakes. If a conflict feels symmetric or toothless, suggest a specific asymmetry, hidden motive, or forcing stake to react to. Usually ask one focused question at a time.\n\nTypically respond in 2-5 sentences; a short paragraph is fine when drawing several threads together.' },
    { id: 'wtopic_intro', label: 'Intro / Opening', commitKind: 'introScene',
      seedMessage: 'This chat designs your opening scene \u2014 the moment the story begins and control takes hold. Tell me the situation it opens on: where things are, and what\'s already in motion.',
      instructions: 'You are a writing partner helping the user workshop the OPENING scene \u2014 the moment the story begins and interaction takes hold. Take the intro they bring on its own terms, whatever pacing or structure they picture.\n\nWrite in plain prose \u2014 no markdown, headers, or lists. Keep a warm, collaborative tone. Help sharpen the sensory grounding of the first moment and find where the first action or choice takes hold \u2014 whether the scene opens mid-action or eases in, both are legitimate. Usually ask one focused question at a time, developing atmosphere, the immediate situation, or where agency begins.\n\nTypically respond in 2-5 sentences; a short paragraph is fine when drawing several threads together.' },
    // [v2.19.0 WIZARD-2.0 DEAD-PENDING] The 'Bestiary' and 'Items' topics below are residue
    // from the removed Bestiary / Item-Template systems (CE-STRIP v2.1.6 / v2.2.0); their
    // commitKinds (archetypeBatch / itemBatch) no longer have generators. Left in place
    // (harmless) and flagged for a dedicated Bestiary-residue removal pass \u2014 NOT part of
    // the wizard-2.0 cleanup, and deliberately not de-railroaded since they are slated to go.
    { id: 'wtopic_bestiary', label: 'Bestiary', commitKind: 'archetypeBatch',
      seedMessage: 'This chat stocks your bestiary of drop-in minor NPCs \u2014 the quick, disposable folk and creatures you spawn into a scene: someone to fight, someone to bribe, someone to haggle with. Each one gets a NAME and a one-line BRIEF for why they\'re here, and either can vary at spawn with {a|b|c} alternation, like "{Brittle|Rattling|Ancient} Skeleton." What\'s the first one?',
      instructions: 'You are a creature-and-cast designer helping the user stock a bestiary of MINOR, drop-in NPCs \u2014 the lightweight, disposable figures spawned into a scene (mobs to fight, folk to bargain with, ambient background people), NOT deep named characters. You author exactly two things for each archetype: the name and the brief.\n\nFORMAT:\n1. Write in pure prose. No markdown, bolding, italics, headers, or lists.\n2. Keep a warm, collaborative tone.\n3. For each archetype, help pin down two things: a short NAME or label (offer spawn-time variety with {a|b|c} alternation where it fits) and a one-line BRIEF of what they are doing here.\n4. Keep them shallow by design: a name and a one-line reason to be present, nothing more. If the user starts developing one with real depth, gently suggest promoting it to a full character instead.\n5. Ask exactly ONE focused question per turn to sharpen a specific archetype.\n\nTypically respond in 2-5 sentences; when summarizing or drawing together several already-established points for the user, a short paragraph is fine.' },
    { id: 'wtopic_items', label: 'Items', commitKind: 'itemBatch',
      seedMessage: 'This chat stocks your set of item templates \u2014 the things a player finds, carries, wields, or wears. Each one gets a NAME and a one-line DESCRIPTION, and either can vary at spawn with {a|b|c} alternation, like a "{rusty|gleaming} {iron|steel} dagger." What\'s the first one?',
      instructions: 'You are an item designer helping the user stock a set of ITEM TEMPLATES: the objects a player finds, carries, wields, or wears \u2014 weapons, garments, tools, trinkets, consumables. You author exactly two things for each item: the name and the description.\n\nFORMAT:\n1. Write in pure prose. No markdown, bolding, italics, headers, or lists.\n2. Keep a warm, collaborative tone.\n3. For each item, pin down two things: a short NAME (offer spawn-time variety with {a|b|c} alternation where colour, material, or condition could differ, e.g. a {rusty|gleaming|chipped} {iron|steel} dagger) and a one-sentence DESCRIPTION of what it is and its notable qualities.\n4. Keep them concrete and evocative but shallow: one name, one sentence, nothing more.\n5. Ask exactly ONE focused question per turn to sharpen a specific item.\n\nTypically respond in 2-5 sentences; when summarizing or drawing together several already-established points for the user, a short paragraph is fine.' }
];

// ── World-Build Wizard: chat storage + CRUD (storyStorage) ───────────────────
async function loadWizardChats(): Promise<WizardChat[]> {
    let raw = await api.v1.storyStorage.getOrDefault(STORAGE_WIZ_CHATS, '[]') as string;
    try {
        let arr = JSON.parse(raw);
        if (Array.isArray(arr)) { for (let mc of arr) { if (!mc.characterIds) mc.characterIds = []; } return arr; }
        return [];
    } catch (e) {
        api.v1.error('[AE:wizard] loadWizardChats parse error:', e);
        return [];
    }
}

async function saveWizardChats(chats: WizardChat[]): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_WIZ_CHATS, JSON.stringify(chats || []));
}

async function loadWizardChat(id: string): Promise<WizardChat | null> {
    let chats = await loadWizardChats();
    return chats.find(function(c) { return c.id === id; }) || null;
}

async function saveWizardChat(chat: WizardChat): Promise<void> {
    if (!chat || !chat.id) return;
    let chats = await loadWizardChats();
    let idx = chats.findIndex(function(c) { return c.id === chat.id; });
    chat.updatedAt = Date.now();
    if (idx >= 0) chats[idx] = chat;
    else chats.push(chat);
    await saveWizardChats(chats);
}

async function createWizardChat(topicId: string, title: string): Promise<WizardChat> {
    // [vNEXT] Seed the topic's opening message (if any) so a new chat greets the user
    // and explains what this topic produces.
    let seedMsgs: WizardChatMessage[] = [];
    try {
        let seedCfg = await loadConfig();
        let seedTopic = getWizardTopic(seedCfg, topicId);
        if (seedTopic && (seedTopic as any).seedMessage && String((seedTopic as any).seedMessage).trim()) {
            seedMsgs.push({ role: 'assistant', content: String((seedTopic as any).seedMessage).trim() });
        }
    } catch (eSeed) { /* non-fatal: start empty */ }
    let chat: WizardChat = {
        id: 'wchat_' + generateId(),
        topicId: topicId,
        title: title || 'New Chat',
        messages: seedMsgs,
        contextChatIds: [],
        includeStory: false,
        lorebookEntryIds: [],
        characterIds: [],
        createdAt: Date.now(),
        updatedAt: Date.now()
    };
    await saveWizardChat(chat);
    return chat;
}

async function deleteWizardChat(id: string): Promise<void> {
    let chats = await loadWizardChats();
    chats = chats.filter(function(c) { return c.id !== id; });
    await saveWizardChats(chats);
}

// ── World-Build Wizard: staging store (storyStorage) ─────────────────────────
// [v1.22.0 STAGING] Generalizes the generate -> review -> commit pattern that
// previously existed only for the intro draft (generateIntroDraft/commitIntroDraft).
// Batch generators now stage parsed output as WizardDraft records; nothing touches
// cfg.* or the lorebook until commitStagedDrafts() runs. This means a bad generation
// (CJK drift, dot-point mush, half-parsed entries) can be discarded without leaving
// orphan records and orphan lorebook entries behind.
//
// kind is one of: 'species' | 'faction' | 'archetype' | 'item' | 'location'
// fields is a flat string map so one store and one editor serve every kind; the
// per-kind shape lives in WIZ_DRAFT_FIELDS below and commit routes on kind.
interface WizardDraft {
    id: string;
    kind: string;
    fields: { [k: string]: string };
    sourceChatIds: string[];
    parentId: string | null;   // locations only; null for every other kind
    createdAt: number;
}

// [v1.22.2] WizardTombstone REMOVED — see the note above discardWizardDraft.

// [v1.22.0 STAGING] Per-kind field schema. Drives the staging editor's inputs and the
// commit routing. `multiline` selects textInput vs multilineTextInput in the native UI.
var WIZ_DRAFT_FIELDS: { [kind: string]: { key: string; label: string; multiline: boolean }[] } = {
    species:   [{ key: 'name', label: 'Name', multiline: false }, { key: 'description', label: 'Lore', multiline: true }],
    faction:   [{ key: 'name', label: 'Name', multiline: false }, { key: 'description', label: 'Lore', multiline: true }],
    archetype: [{ key: 'name', label: 'Name', multiline: false }, { key: 'brief', label: 'Brief', multiline: true }],
    item:      [{ key: 'name', label: 'Name', multiline: false }, { key: 'description', label: 'Description', multiline: true }],
    location:  [{ key: 'name', label: 'Name', multiline: false }, { key: 'description', label: 'On arrival', multiline: true }, { key: 'lore', label: 'Lorebook', multiline: true }],
    // [v1.22.2 CHAR-STAGE] Characters previously went chat -> names -> dump -> fields ->
    // saveCharacter in one unbroken run, so a failed dump/fields call silently produced a
    // character with nothing but a name. Staging the name + concept dump gives the user a
    // visible, editable checkpoint; the structured fields are derived at commit time from
    // whatever dump is on screen then.
    character: [{ key: 'name', label: 'Name', multiline: false }, { key: 'dump', label: 'Concept', multiline: true }]
};

// Human-readable plural per kind, for toasts and headers.
function wizKindLabel(kind: string): string {
    if (kind === 'species')   return 'species';
    if (kind === 'faction')   return 'factions';
    if (kind === 'archetype') return 'archetypes';
    if (kind === 'item')      return 'items';
    if (kind === 'location')  return 'locations';
    if (kind === 'character') return 'characters';
    return kind;
}

// [v1.22.3 TEXTAREA-SIZE] Native multilineTextInput has no auto-grow and no `rows` prop
// (only `style`), and the Worker sandbox has no DOM to measure with. Read-mode bubbles
// use type:'text', which grows to fit; swapping in a fixed-minHeight textarea therefore
// COLLAPSES a long message into a small scrolling box. Estimate the needed height from
// the content up front so the editor opens at roughly the size the text already occupied.
//
// ~46 chars per visual line at fontSize 11-12px in the sidebar's width; 16px per line.
// Clamped so a one-liner does not get a giant box and an essay does not fill the screen.
function wizTextareaHeight(text: string, minPx: number, maxPx: number): string {
    let t = String(text || '');
    let lines = 0;
    let paras = t.split('\n');
    for (let p of paras) {
        lines += Math.max(1, Math.ceil(p.length / 46));
    }
    let px = 20 + (lines * 16);
    if (px < minPx) px = minPx;
    if (px > maxPx) px = maxPx;
    return px + 'px';
}

async function loadWizardDrafts(): Promise<WizardDraft[]> {
    let raw = await api.v1.storyStorage.getOrDefault(STORAGE_WIZ_DRAFTS, '[]') as string;
    try {
        let arr = JSON.parse(raw);
        if (Array.isArray(arr)) return arr;
        return [];
    } catch (eWdLoad) {
        api.v1.error('[AE:wizard] loadWizardDrafts parse error:', eWdLoad);
        return [];
    }
}

async function saveWizardDrafts(drafts: WizardDraft[]): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_WIZ_DRAFTS, JSON.stringify(drafts || []));
}

async function loadWizardDraftsOfKind(kind: string): Promise<WizardDraft[]> {
    let all = await loadWizardDrafts();
    return all.filter(function(d) { return d.kind === kind; });
}

// Appends parsed generator output as drafts. Returns the ids created, so a caller that
// generated-and-wants-to-commit-immediately (the legacy run*Batch wrappers) can commit
// exactly its own drafts without sweeping up anything the user already had staged.
async function addWizardDrafts(kind: string, items: { [k: string]: string }[], sourceChatIds: string[], parentId: string | null): Promise<string[]> {
    let all = await loadWizardDrafts();
    let newIds: string[] = [];
    for (let it of (items || [])) {
        let did = 'wdraft_' + generateId();
        newIds.push(did);
        all.push({
            id: did,
            kind: kind,
            fields: it,
            sourceChatIds: (sourceChatIds || []).slice(),
            parentId: parentId || null,
            createdAt: Date.now()
        });
    }
    await saveWizardDrafts(all);
    return newIds;
}

async function updateWizardDraftField(draftId: string, fieldKey: string, value: string): Promise<void> {
    let all = await loadWizardDrafts();
    let target = all.find(function(d) { return d.id === draftId; });
    if (!target) return;
    target.fields[fieldKey] = value;
    await saveWizardDrafts(all);
}

// [v1.22.2] Tombstones REMOVED. v1.22.0 recorded discarded draft names and fed them into
// each generator's "these ALREADY EXIST — do NOT recreate" list. That was wrong: a
// rejected draft is not an existing entity. If the user staged "Hogwarts", discarded it
// because the lore was bad, and regenerated, the prompt then explicitly forbade the one
// name the brainstorming chat was about — so the model invented unrelated originals
// instead. Discarding now simply deletes the draft. Only staged (still-pending) names
// feed the do-not-recreate list, which is all that was ever needed: it stops a second
// Generate press from duplicating the batch already sitting on screen.

// Discard one staged draft.
async function discardWizardDraft(draftId: string): Promise<void> {
    let all = await loadWizardDrafts();
    await saveWizardDrafts(all.filter(function(d) { return d.id !== draftId; }));
}

// Discard every staged draft of a kind.
async function discardAllWizardDrafts(kind: string): Promise<number> {
    let all = await loadWizardDrafts();
    let doomed = all.filter(function(d) { return d.kind === kind; });
    await saveWizardDrafts(all.filter(function(d) { return d.kind !== kind; }));
    return doomed.length;
}

// Remove drafts by id (used after a successful commit).
async function removeWizardDrafts(draftIds: string[]): Promise<void> {
    if (!draftIds || !draftIds.length) return;
    let all = await loadWizardDrafts();
    await saveWizardDrafts(all.filter(function(d) { return draftIds.indexOf(d.id) < 0; }));
}

// [vNEXT] Export World-Build Wizard chat transcripts to a JSON file the user can
// save. Reuses the same api.v1.file.save pattern as the world export (fileDownload
// permission is requested at init). scope 'all' dumps every chat; scope 'one' dumps
// just the chat with the given id. Each chat carries its topic label (resolved from
// the registry) for readability. Returns the number of chats written (0 = nothing to
// export / failure), and surfaces its own toasts.
async function exportWizardChats(scope: 'all' | 'one', chatId?: string): Promise<number> {
    try {
        const cfg = await loadConfig();
        let chats = await loadWizardChats();
        if (scope === 'one') {
            chats = chats.filter(function(c) { return c.id === chatId; });
        }
        if (!chats.length) {
            api.v1.ui.toast('No wizard chats to export.', { type: 'info', autoClose: 2500 });
            return 0;
        }

        // Attach a human-readable topic label to each exported chat without mutating
        // the stored records.
        const exportChats = chats.map(function(c) {
            const topic = getWizardTopic(cfg, c.topicId);
            return {
                id: c.id,
                title: c.title,
                topicId: c.topicId,
                topicLabel: topic ? topic.label : '',
                includeStory: !!c.includeStory,
                contextChatIds: c.contextChatIds || [],
                lorebookEntryIds: c.lorebookEntryIds || [],
                characterIds: (c as any).characterIds || [],
                createdAt: c.createdAt,
                updatedAt: c.updatedAt,
                messages: (c.messages || []).map(function(m) { return { role: m.role, content: m.content }; })
            };
        });

        const payload = {
            _aeWizardChats: true,
            aeVersion: '0.9.9.2',
            exportedAt: new Date().toISOString(),
            projectName: (cfg as any).projectName || '',
            chatCount: exportChats.length,
            chats: exportChats
        };

        const safeBase = (((cfg as any).projectName || 'ae_world').replace(/[^a-z0-9]/gi, '_').toLowerCase()) || 'ae_world';
        const fname = safeBase + (scope === 'one' ? '_wizardchat' : '_wizardchats') + '.json';
        await api.v1.file.save(fname, JSON.stringify(payload, null, 2));
        api.v1.ui.toast('Exported ' + exportChats.length + ' chat' + (exportChats.length === 1 ? '' : 's') + '.', { type: 'success', autoClose: 3000 });
        return exportChats.length;
    } catch (e) {
        api.v1.error('[AE:wizard] exportWizardChats failed:', e);
        api.v1.ui.toast('Chat export failed — see engine log.', { type: 'error', autoClose: 3000 });
        return 0;
    }
}

// [vNEXT] Resolve a topic by id from the config registry (falls back to the seeded
// defaults if config has none yet).
function getWizardTopic(cfg: GlobalConfig, topicId: string): WizardTopic | null {
    let list = ((cfg as any).wizardTopics && (cfg as any).wizardTopics.length)
        ? (cfg as any).wizardTopics
        : DEFAULT_WIZARD_TOPICS;
    return list.find(function(t: WizardTopic) { return t.id === topicId; }) || null;
}

